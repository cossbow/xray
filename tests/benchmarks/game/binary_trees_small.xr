// Binary Trees Benchmark - Xray Json 版本（小规模测试）
// 用于性能对比测试

// type Tree = {left:Tree?,right:Tree?}

fn makeTree(depth: int) : Json {
    if (depth > 0) {
        return { "left": makeTree(depth - 1), "right": makeTree(depth - 1) }
    } else {
        return { "left": null, "right": null }
    }
}

fn checksum(node: Json) : int {
    if (node == null) {
        return 0
    }
    if (node.left == null) {
        return 1
    }
    return checksum(node.left) + checksum(node.right) + 1
}

fn run(maxDepth: int) : void {
    let minDepth = 4
    // Stretch tree
    let stretchDepth = maxDepth + 1
    let stretchTree = makeTree(stretchDepth)
    print("stretch tree of depth ${stretchDepth}\t check: ${checksum(stretchTree)}")
    // Long-lived tree
    let longLivedTree = makeTree(maxDepth)
    // Iterations
    let depth = minDepth
    while (depth <= maxDepth) {
        let iterations = 1
        let j = 0
        while (j < maxDepth - depth + minDepth) {
            iterations = iterations * 2
            j = j + 1
        }
        let check = 0
        let i = 1
        while (i <= iterations) {
            let tree = makeTree(depth)
            check = check + checksum(tree)
            i = i + 1
        }
        print("${iterations}\t trees of depth ${depth}\t check: ${check}")
        depth = depth + 2
    }
    print("long lived tree of depth ${maxDepth}\t check: ${checksum(longLivedTree)}")
}

// 小规模测试，深度 10
let maxDepth = 10
run(maxDepth)
