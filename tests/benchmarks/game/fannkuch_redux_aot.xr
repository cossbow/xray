/*
** fannkuch_redux_aot.xr - Fannkuch-Redux Benchmark (AOT typed version)
*/

fn flip(perm: Array<int>, n: int) {
    let lo = 0
    let hi = n - 1
    while (lo < hi) {
        let tmp = perm[lo]
        perm[lo] = perm[hi]
        perm[hi] = tmp
        lo = lo + 1
        hi = hi - 1
    }
}

fn rotate(perm: Array<int>, n: int) {
    let first = perm[0]
    for (let i = 0; i < n - 1; i++) {
        perm[i] = perm[i + 1]
    }
    perm[n - 1] = first
}

fn countFlips(perm: Array<int>, n: int): int {
    let work: Array<int> = []
    for (let i = 0; i < n; i++) {
        work.push(perm[i])
    }
    let flips = 0
    while (work[0] != 1) {
        let k = work[0]
        flip(work, k)
        flips = flips + 1
    }
    return flips
}

fn nextPermutation(perm: Array<int>, count: Array<int>, n: int): bool {
    rotate(perm, n)
    let i = 2
    while (count[i - 1] >= i - 1) {
        count[i - 1] = 0
        i = i + 1
        if (i > n) {
            return false
        }
        rotate(perm, i)
    }
    count[i - 1] = count[i - 1] + 1
    return true
}

fn fannkuch(n: int) {
    let perm: Array<int> = []
    let count: Array<int> = []
    for (let i = 0; i < n; i++) {
        perm.push(i + 1)
        count.push(0)
    }
    let maxFlips = 0
    let checksum = 0
    let permIndex = 0
    let hasMore = true
    while (hasMore) {
        let flips = countFlips(perm, n)
        if (flips > maxFlips) {
            maxFlips = flips
        }
        if (permIndex % 2 == 0) {
            checksum = checksum + flips
        } else {
            checksum = checksum - flips
        }
        permIndex = permIndex + 1
        hasMore = nextPermutation(perm, count, n)
    }
    print(checksum)
    print("Pfannkuchen(" + n + ") = " + maxFlips)
}

let n = process.args.length > 0 ? int(process.args[0]) ?? 10 : 10
fannkuch(n)
