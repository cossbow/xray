// Binary Trees Benchmark - Xray Map 版本（下标访问语法）
// 用于与 Json 版本性能对比测试
fn makeTree(depth: int) {
    if (depth > 0) {
        return { "left" => makeTree(depth - 1), "right" => makeTree(depth - 1) }
    } else {
        return { "left" => null, "right" => null }
    }
}

fn checksum(node): int {
    if (node == null) {
        return 0
    }
    if (node["left"] == null) {
        return 1
    }
    return checksum(node["left"]) + checksum(node["right"]) + 1
}

fn run(maxDepth: int) {
    let minDepth = 4
    // Stretch tree
    let stretchDepth = maxDepth + 1
    let stretchTree = makeTree(stretchDepth)
    print("stretch tree of depth " + stretchDepth + "	 check: " + checksum(stretchTree))
    // Long-lived tree
    let longLivedTree = makeTree(maxDepth)
    // Iterations
    let depth = minDepth
    while (depth <= maxDepth) {
        let iterations = 1
        let j = 0
        while (j < maxDepth - depth + minDepth) {
            iterations = iterations * 2
            j = j + 1
        }
        let check = 0
        let i = 1
        while (i <= iterations) {
            let tree = makeTree(depth)
            check = check + checksum(tree)
            i = i + 1
        }
        print(iterations + "	 trees of depth " + depth + "	 check: " + check)
        depth = depth + 2
    }
    print("long lived tree of depth " + maxDepth + "	 check: " + checksum(longLivedTree))
}

// 从命令行读取深度参数，默认 16
let maxDepth = process.args.length > 0 ? int(process.args[0]) ?? 16 : 16
run(maxDepth)
