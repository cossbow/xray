// Test: OSR with nested loops and multiple phi variables
// EXPECTED: 1000000
// Test: OSR with nested loops - both inner and outer loop may trigger JIT

fn nested_sum() -> int {
    let total = 0
    let i = 0
    while (i < 1000) {
        let j = 0
        while (j < 1000) {
            total = total + 1
            j = j + 1
        }
        i = i + 1
    }
    return total
}

print(nested_sum())
