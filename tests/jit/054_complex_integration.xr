// EXPECTED: 0
// Test: Complex integration - mix of arrays, Json, loops, function calls, closures

fn make_points(n: int) {
    let arr = []
    let i = 0
    while (i < n) {
        arr.push({ "x": i, "y": i * 2 })
        i = i + 1
    }
    return arr
}

fn total_distance(points) : int {
    let sum = 0
    let i = 0
    while (i < points.length) {
        sum = sum + points[i].x + points[i].y
        i = i + 1
    }
    return sum
}

fn verify(n: int) : int {
    let pts = make_points(n)
    let dist = total_distance(pts)
    // sum(i, i=0..n-1) + sum(2*i, i=0..n-1) = 3 * n*(n-1)/2
    let expected = 3 * n * (n - 1) / 2
    if (dist != expected) { return 1 }
    return 0
}

let wrong = 0
let i = 0
while (i < 500) {
    wrong = wrong + verify(10)
    i = i + 1
}
print(wrong)
