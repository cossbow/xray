// EXPECTED: ell
// EXPECTED: abcabcabc
// EXPECTED: A
// EXPECTED: 5
// Test: String operations in JIT (SUBSTRING/STR_REPEAT/CHR)

fn test_substring(s: string, start: int, end: int) : string {
    return s.substring(start, end)
}

fn test_repeat(s: string, n: int) : string {
    return s.repeat(n)
}

fn test_chr(code: int) : string {
    return chr(code)
}

fn test_length(s: string) : int {
    return s.length
}

let i = 0
while (i < 200) {
    test_substring("hello", 1, 4)
    test_repeat("abc", 3)
    test_chr(65)
    test_length("hello")
    i = i + 1
}

print(test_substring("hello", 1, 4))
print(test_repeat("abc", 3))
print(test_chr(65))
print(test_length("hello"))
