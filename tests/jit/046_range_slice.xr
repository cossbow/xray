// Test: Range and slice operations in JIT
// EXPECTED: 3
// EXPECTED: 2
// Test: Range and slice operations in JIT

fn slice_len(arr, start: int, end: int) : int {
    let s = arr[start:end]
    return s.length
}

let a = [10, 20, 30, 40, 50]

let i = 0
while (i < 200) {
    slice_len(a, 1, 4)
    i = i + 1
}

print(slice_len(a, 1, 4))
print(slice_len(a, 0, 2))
