// EXPECTED: 100
// EXPECTED: 200
// Test: Shared/global variable access in JIT (GETSHARED, SETSHARED)

shared let counter = 0

fn increment_shared(n: int) {
    let i = 0
    while (i < n) {
        counter = counter + 1
        i = i + 1
    }
}

increment_shared(100)
print(counter)
increment_shared(100)
print(counter)
