// EXPECTED: 12345678910
// Test: String concatenation in loop (STRBUF_NEW, STRBUF_APPEND, STRBUF_FINISH)

fn build_str(n: int) {
    let s = ""
    let i = 1
    while (i <= n) {
        s = s + i
        i = i + 1
    }
    return s
}

let i = 0
while (i < 200) {
    build_str(10)
    i = i + 1
}

print(build_str(10))
