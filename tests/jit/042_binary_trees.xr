// EXPECTED: 0
// Test: Binary trees benchmark pattern - recursive Json tree (regression for minimal2)

fn makeTree(depth: int) : Json {
    if (depth > 0) {
        let left = makeTree(depth - 1)
        let right = makeTree(depth - 1)
        return { "left": left, "right": right }
    } else {
        return { "left": null, "right": null }
    }
}

fn checksum(node: Json) : int {
    if (node == null) { return 0 }
    if (node.left == null) { return 1 }
    return checksum(node.left) + checksum(node.right) + 1
}

let wrong = 0
let i = 0
while (i < 500) {
    let t = makeTree(3)
    let c = checksum(t)
    if (c != 15) {
        wrong = wrong + 1
    }
    i = i + 1
}
print(wrong)
