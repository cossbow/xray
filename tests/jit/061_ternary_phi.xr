// EXPECTED: 15
// Test: Ternary expression with phi node in loop (regression for jump threading pred bug)

fn accumulate(n: int) : int {
    let m = {}
    let i = 1
    while (i <= n) {
        m["sum"] = (m["sum"] == null) ? i : m["sum"] + i
        i = i + 1
    }
    return m["sum"]
}

let j = 0
while (j < 200) {
    accumulate(5)
    j = j + 1
}

print(accumulate(5))
