// EXPECTED: 7
// EXPECTED: 31
// EXPECTED: 127
// Test: Recursive tree building and checksum (tests deep recursion + JSON creation in JIT)

fn makeTree(depth: int) : Json {
    if (depth <= 0) {
        return { "left": null, "right": null }
    }
    return { "left": makeTree(depth - 1), "right": makeTree(depth - 1) }
}

fn checksum(node: Json) : int {
    if (node == null) { return 0 }
    if (node.left == null) { return 1 }
    return 1 + checksum(node.left) + checksum(node.right)
}

fn run(d: int) : int {
    return checksum(makeTree(d))
}

let i = 0
while (i < 200) {
    run(2)
    i = i + 1
}

print(run(2))
print(run(4))
print(run(6))
