// EXPECTED: 0
// Test: Write barrier stress - many reference stores in JIT to exercise GC barriers

fn build_chain(n: int) {
    let arr = []
    let i = 0
    while (i < n) {
        let obj = { "value": i, "next": null }
        if (arr.length > 0) {
            obj.next = arr[arr.length - 1]
        }
        arr.push(obj)
        i = i + 1
    }
    return arr
}

fn verify_chain(arr) : int {
    let errors = 0
    let i = 0
    while (i < arr.length) {
        if (arr[i].value != i) {
            errors = errors + 1
        }
        if (i > 0 && arr[i].next == null) {
            errors = errors + 1
        }
        i = i + 1
    }
    return errors
}

// Multiple rounds to trigger GC during JIT execution
let total_errors = 0
let round = 0
while (round < 50) {
    let chain = build_chain(100)
    total_errors = total_errors + verify_chain(chain)
    round = round + 1
}
print(total_errors)
