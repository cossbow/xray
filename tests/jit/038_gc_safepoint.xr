// EXPECTED: 10000
// Test: GC safepoints in JIT loops - ensure GC can run during hot loops

fn count_with_alloc(n: int) : int {
    let count = 0
    let i = 0
    while (i < n) {
        let arr = [i, i+1, i+2]
        count = count + arr.length
        i = i + 1
    }
    return count / 3
}

print(count_with_alloc(10000))
