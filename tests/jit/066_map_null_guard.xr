// EXPECTED: 42
// Test: Map get with null guard and default value (tests null comparison in JIT)

fn get_or_default(m: Json, key: string, default_val: int) -> int {
    let v = m[key]
    if (v == null) {
        return default_val
    }
    return v
}

fn test() -> int {
    let m = {}
    m["x"] = 42
    let a = get_or_default(m, "x", 0)
    let b = get_or_default(m, "y", 99)
    return a + b - b
}

let j = 0
while (j < 200) {
    test()
    j = j + 1
}

print(test())
