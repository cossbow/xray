// EXPECTED: 5050
// EXPECTED: 55
// Test: While loop in JIT (sum 1..N)

fn sum_to(n: int) : int {
    let s = 0
    let i = 1
    while (i <= n) {
        s = s + i
        i = i + 1
    }
    return s
}

let i = 0
while (i < 200) {
    sum_to(100)
    i = i + 1
}

print(sum_to(100))
print(sum_to(10))
