// EXPECTED: 19
// EXPECTED: 3
// Test: Nested Json objects and recursive traversal in JIT

fn make_tree(depth: int) -> Json {
    if (depth <= 0) {
        return { "left": null, "right": null, "val": 1 }
    }
    return {
        "left": make_tree(depth - 1),
        "right": make_tree(depth - 1),
        "val": depth
    }
}

fn tree_sum(node: Json) -> int {
    if (node == null) { return 0 }
    let v = node.val
    if (node.left == null) { return v }
    return v + tree_sum(node.left) + tree_sum(node.right)
}

let i = 0
while (i < 200) {
    let t = make_tree(3)
    tree_sum(t)
    i = i + 1
}

let t = make_tree(3)
print(tree_sum(t))
print(t.val)
