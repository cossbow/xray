// EXPECTED: 5
// EXPECTED: 15
// Test: Array push and dynamic growth in JIT

fn build_array(n: int) -> int {
    let arr: Array<int> = []
    let i = 0
    while (i < n) {
        arr.push(i + 1)
        i = i + 1
    }
    return arr.length
}

fn build_and_sum(n: int) -> int {
    let arr: Array<int> = []
    let i = 0
    while (i < n) {
        arr.push(i + 1)
        i = i + 1
    }
    let s = 0
    let j = 0
    while (j < arr.length) {
        s = s + arr[j]
        j = j + 1
    }
    return s
}

let i = 0
while (i < 200) {
    build_array(5)
    build_and_sum(5)
    i = i + 1
}

print(build_array(5))
print(build_and_sum(5))
