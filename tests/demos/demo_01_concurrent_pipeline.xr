// Concurrent Data Pipeline
// Demonstrates: Channel, goroutines, structured concurrency, higher-order functions
//
// A multi-stage data processing pipeline where each stage runs as
// a coroutine, connected by channels — classic CSP pattern.

import time

// ===== Stage 1: Data Generator =====
// Produces raw sensor readings into the pipeline
fn generator(out, count) {
    for (let i = 0; i < count; i++) {
        let reading = {
            id: i,
            value: (i * 17 + 31) % 100,
            timestamp: time.now()
        }
        out.send(reading)
    }
    out.close()
}

// ===== Stage 2: Filter =====
// Only passes readings above threshold
fn filter(input, output, threshold) {
    while (true) {
        let data = input.recv()
        if (data == null) { break }
        if (data.value > threshold) {
            output.send(data)
        }
    }
    output.close()
}

// ===== Stage 3: Transform =====
// Enriches data with computed fields
fn transform(input, output) {
    while (true) {
        let data = input.recv()
        if (data == null) { break }
        data.normalized = data.value / 100.0
        data.category = match data.value {
            v if (v > 80) => "critical",
            v if (v > 60) => "warning",
            _ => "normal"
        }
        output.send(data)
    }
    output.close()
}

// ===== Stage 4: Aggregator =====
// Collects results and computes statistics
fn aggregator(input) {
    let results = []
    let sum = 0.0
    let count = 0
    let categories = { critical: 0, warning: 0, normal: 0 }

    while (true) {
        let data = input.recv()
        if (data == null) { break }
        results.push(data)
        sum += data.normalized
        count++
        categories[data.category] = categories[data.category] + 1
    }

    return {
        total: count,
        avg: count > 0 ? sum / count : 0.0,
        categories: categories
    }
}

// ===== Run the pipeline =====
fn main() {
    const N = 1000
    print("=== Concurrent Data Pipeline ===")
    print("Processing", N, "sensor readings...")

    // Create channels connecting pipeline stages
    const ch1 = Channel(64)
    const ch2 = Channel(64)
    const ch3 = Channel(64)

    let start = time.monotonic()

    // Launch pipeline stages as concurrent coroutines
    scope {
        go generator(ch1, N)
        go filter(ch1, ch2, 30)
        go transform(ch2, ch3)
    }

    // Aggregator runs synchronously — collects all results
    let stats = aggregator(ch3)

    let elapsed = time.monotonic() - start

    print("--- Results ---")
    print("Total processed:", stats.total)
    print("Average (normalized):", stats.avg)
    print("Categories:", json.stringify(stats.categories))
    print("Pipeline time:", elapsed, "ms")
}

main()
