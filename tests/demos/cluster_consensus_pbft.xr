// Distributed PBFT Consensus Protocol
// ============================================================
// Practical Byzantine Fault Tolerance implemented with xray cluster.
// Each validator node runs this script; 3f+1 nodes tolerate f Byzantine faults.
//
// Cluster API used:
//   cluster.channel("pre-prepare", 64)  — Leader broadcasts proposals
//   cluster.channel("prepare", 256)     — Validators broadcast prepare votes
//   cluster.channel("commit", 256)      — Validators broadcast commit votes
//   cluster.serve("view_change")        — RPC for view change protocol
//   cluster.call("view_change", req)    — Trigger view change on leader failure
//   cluster.monitor("*")               — Detect leader/validator failures
//   cluster.publish("consensus.decided", blk)  — Announce finalized blocks
//   cluster.subscribe("consensus.>")    — Observe consensus progress
//
// Run 4 nodes (tolerates 1 Byzantine fault):
//   ./build/xray cluster_consensus_pbft.xr -- --name validator-0 --port 9101 --leader
//   ./build/xray cluster_consensus_pbft.xr -- --name validator-1 --port 9102 --join 127.0.0.1:9101
//   ./build/xray cluster_consensus_pbft.xr -- --name validator-2 --port 9103 --join 127.0.0.1:9101
//   ./build/xray cluster_consensus_pbft.xr -- --name validator-3 --port 9104 --join 127.0.0.1:9101

import cluster
import crypto
import time
import json

// ===== Configuration =====

fn parseArgs() {
    let config = {
        name: "validator-0",
        port: 9101,
        secret: "pbft-secret",
        join_host: null,
        join_port: 0,
        is_leader: false
    }

    let args = sys.args()
    for (let i = 0; i < args.length; i++) {
        match args[i] {
            "--name" => { config.name = args[i + 1]; i++ },
            "--port" => { config.port = int(args[i + 1]); i++ },
            "--leader" => { config.is_leader = true },
            "--join" => {
                let parts = args[i + 1].split(":")
                config.join_host = parts[0]
                config.join_port = int(parts[1])
                i++
            },
            _ => {}
        }
    }
    return config
}

// ===== PBFT State =====

shared const pbft = {
    view: 0,                // Current view number
    sequence: 0,            // Next sequence number
    leader: "validator-0",  // Current leader name
    validators: [],         // All validator names (including self)
    log: [],                // Committed block log
    prepareVotes: {},       // seq -> {voter -> digest}
    commitVotes: {},        // seq -> {voter -> digest}
    f: 1                    // Max Byzantine faults tolerated
}

fn quorumSize() {
    // PBFT requires 2f+1 matching votes
    return 2 * pbft.f + 1
}

fn isLeader(name) {
    return name == pbft.leader
}

// ===== Message Signing (simplified) =====

fn signMessage(msg, signer) {
    msg.signer = signer
    msg.signature = crypto.sha256(json.stringify(msg) + signer)
    return msg
}

fn verifySignature(msg) {
    if (msg.signer == null || msg.signature == null) { return false }
    let sig = msg.signature
    msg.signature = null
    let expected = crypto.sha256(json.stringify(msg) + msg.signer)
    msg.signature = sig
    return sig == expected
}

// ===== Phase 1: Pre-Prepare (Leader only) =====
// Leader proposes a block by sending to the "pre-prepare" Named Channel

fn prePreparePhase(config) {
    if (!isLeader(config.name)) { return }

    let prePrepareCh = cluster.channel("pre-prepare", 64)
    let txPool = cluster.channel("tx-pool", 128)

    print("[Leader] Pre-prepare phase started")

    while (true) {
        // Collect transactions (simulated)
        time.sleep(2000)

        let txBatch = []
        let drainCount = 0
        while (drainCount < 10) {
            select {
                tx from txPool => {
                    txBatch.push(tx)
                    drainCount++
                }
                _ => { drainCount = 10 }  // default: stop draining
            }
        }

        if (txBatch.length == 0) {
            // Generate dummy transactions for demo
            txBatch.push({
                from: "Alice", to: "Bob",
                amount: pbft.sequence * 10 + 1,
                hash: crypto.sha256("tx-" + string(pbft.sequence))
            })
        }

        // Create proposal
        let proposal = {
            view: pbft.view,
            sequence: pbft.sequence,
            digest: crypto.sha256(json.stringify(txBatch)),
            transactions: txBatch,
            timestamp: time.now()
        }
        let signed = signMessage(proposal, config.name)

        print("[Pre-Prepare] seq:", proposal.sequence,
              "| txs:", txBatch.length,
              "| digest:", proposal.digest.slice(0, 12) + "...")

        // Broadcast to all validators via Named Channel
        prePrepareCh.send(signed)
        pbft.sequence++
    }
}

// ===== Phase 2: Prepare (All validators) =====
// On receiving pre-prepare, each validator verifies and broadcasts prepare vote

fn preparePhase(config) {
    let prePrepareCh = cluster.channel("pre-prepare", 64)
    let prepareCh = cluster.channel("prepare", 256)

    print("[Validator] Prepare phase listening")

    while (true) {
        let proposal = prePrepareCh.recv()
        if (proposal == null) { break }

        // Verify the proposal
        if (proposal.view != pbft.view) {
            print("[Prepare] Rejected: wrong view", proposal.view, "expected", pbft.view)
            continue
        }

        // Verify leader signature
        if (!verifySignature(proposal)) {
            print("[Prepare] Rejected: invalid signature")
            continue
        }

        // Verify transactions (simplified: check digest)
        let computed = crypto.sha256(json.stringify(proposal.transactions))
        if (computed != proposal.digest) {
            print("[Prepare] Rejected: digest mismatch")
            continue
        }

        // Send prepare vote
        let prepareMsg = signMessage({
            type: "prepare",
            view: pbft.view,
            sequence: proposal.sequence,
            digest: proposal.digest,
            voter: config.name
        }, config.name)

        prepareCh.send(prepareMsg)
        print("[Prepare] Voted for seq:", proposal.sequence)
    }
}

// ===== Phase 3: Commit (All validators) =====
// Collect prepare votes; when quorum reached, broadcast commit vote

fn commitPhase(config) {
    let prepareCh = cluster.channel("prepare", 256)
    let commitCh = cluster.channel("commit", 256)

    print("[Validator] Commit phase listening")

    while (true) {
        let vote = prepareCh.recv()
        if (vote == null) { break }

        let seq = vote.sequence
        let seqKey = string(seq)

        // Track prepare votes per sequence
        if (pbft.prepareVotes[seqKey] == null) {
            pbft.prepareVotes[seqKey] = {}
        }
        pbft.prepareVotes[seqKey][vote.voter] = vote.digest

        // Count matching votes
        let voteCount = 0
        let digest = vote.digest
        let voters = pbft.prepareVotes[seqKey]
        for (v in pbft.validators) {
            if (voters[v] != null && voters[v] == digest) {
                voteCount++
            }
        }

        // Quorum check: 2f+1 prepare votes
        if (voteCount >= quorumSize()) {
            print("[Prepare Quorum] seq:", seq, "| votes:", voteCount, "/", quorumSize())

            // Send commit vote
            let commitMsg = signMessage({
                type: "commit",
                view: pbft.view,
                sequence: seq,
                digest: digest,
                voter: config.name
            }, config.name)

            commitCh.send(commitMsg)
        }
    }
}

// ===== Finalization: Collect commit votes and apply block =====

fn finalizationPhase(config) {
    let commitCh = cluster.channel("commit", 256)

    print("[Validator] Finalization phase listening")

    while (true) {
        let vote = commitCh.recv()
        if (vote == null) { break }

        let seq = vote.sequence
        let seqKey = string(seq)

        // Track commit votes
        if (pbft.commitVotes[seqKey] == null) {
            pbft.commitVotes[seqKey] = {}
        }
        pbft.commitVotes[seqKey][vote.voter] = vote.digest

        // Count matching votes
        let voteCount = 0
        let voters = pbft.commitVotes[seqKey]
        for (v in pbft.validators) {
            if (voters[v] != null && voters[v] == vote.digest) {
                voteCount++
            }
        }

        // Quorum check: 2f+1 commit votes → FINALIZED
        if (voteCount >= quorumSize()) {
            print("[COMMITTED] Block seq:", seq,
                  "| digest:", vote.digest.slice(0, 12) + "...",
                  "| votes:", voteCount)

            // Record in log
            pbft.log.push({
                sequence: seq,
                digest: vote.digest,
                view: pbft.view,
                committedAt: time.now()
            })

            // Announce via pub/sub
            cluster.publish("consensus.decided", {
                sequence: seq,
                digest: vote.digest,
                view: pbft.view,
                validator: config.name
            })

            // Cleanup vote maps
            pbft.prepareVotes[seqKey] = null
            pbft.commitVotes[seqKey] = null
        }
    }
}

// ===== View Change: Leader Failure Recovery =====
// If the leader is detected as failed, validators trigger a view change

fn viewChangeService(config) {
    let reqCh = cluster.serve("view_change")

    while (true) {
        let req = reqCh.recv()
        if (req == null) { break }

        let newView = req.args.new_view
        let requestor = req.args.requestor

        print("[View Change] Request from", requestor,
              "| new view:", newView)

        // Accept view change if new view > current
        if (newView > pbft.view) {
            pbft.view = newView
            // Round-robin leader selection
            let leaderIdx = newView % pbft.validators.length
            pbft.leader = pbft.validators[leaderIdx]
            print("[View Change] New leader:", pbft.leader, "| view:", pbft.view)

            cluster.reply(req, {
                ok: true,
                new_leader: pbft.leader,
                new_view: pbft.view
            })
        } else {
            cluster.reply(req, { ok: false, reason: "stale view" })
        }
    }
}

// ===== Leader Failure Detector =====
// Uses cluster.monitor to detect leader disconnection

fn leaderFailureDetector(config) {
    let monCh = cluster.monitor("*")

    while (true) {
        let disconnected = monCh.recv()
        if (disconnected == null) { break }

        print("[Monitor] Node disconnected:", disconnected)

        // If the leader disconnected, trigger view change
        if (disconnected == pbft.leader && !isLeader(config.name)) {
            print("[Monitor] LEADER FAILURE detected! Initiating view change...")

            let newView = pbft.view + 1
            let result = cluster.call("view_change", {
                new_view: newView,
                requestor: config.name
            })

            if (result != null && result.ok) {
                print("[View Change] Success! New leader:", result.new_leader)
            }
        }
    }
}

// ===== Consensus Observer (via pub/sub) =====

fn consensusObserver() {
    let subCh = cluster.subscribe("consensus.>")

    while (true) {
        let event = subCh.recv()
        if (event == null) { break }

        print("[Observer] Consensus event: seq", event.sequence,
              "| view:", event.view,
              "| by:", event.validator)
    }
}

// ===== Status Reporter =====

fn statusReporter(config) {
    while (true) {
        time.sleep(15000)

        print("\n--- PBFT Status:", config.name, "---")
        print("  View:", pbft.view)
        print("  Leader:", pbft.leader, isLeader(config.name) ? "(self)" : "")
        print("  Committed blocks:", pbft.log.length)
        print("  Validators:", pbft.validators)
        print("  Peers:", cluster.nodes())
        print("---\n")
    }
}

// ===== Main =====

fn main() {
    let config = parseArgs()

    print("=== PBFT Consensus Node ===")
    print("Name:", config.name)
    print("Port:", config.port)
    print("Role:", config.is_leader ? "Leader" : "Validator")

    // Start cluster
    cluster.start(config.name, config.port, config.secret)

    if (config.join_host != null) {
        cluster.join(config.join_host, config.join_port)
        print("[Cluster] Joined", config.join_host + ":" + string(config.join_port))
    }

    // Wait for peers to connect
    time.sleep(2000)
    pbft.validators = [config.name]
    let peers = cluster.nodes()
    for (p in peers) {
        pbft.validators.push(p)
    }
    pbft.f = (pbft.validators.length - 1) / 3
    print("[PBFT] Validators:", pbft.validators, "| f:", pbft.f)

    // Launch all PBFT phases concurrently
    scope {
        go prePreparePhase(config)     // Leader: propose blocks
        go preparePhase(config)        // All: verify & vote prepare
        go commitPhase(config)         // All: collect prepare → vote commit
        go finalizationPhase(config)   // All: collect commit → finalize
        go viewChangeService(config)   // RPC: handle view change requests
        go leaderFailureDetector(config) // Monitor: detect leader crash
        go consensusObserver()         // Pub/Sub: observe decisions
        go statusReporter(config)      // Periodic status
    }
}

main()
