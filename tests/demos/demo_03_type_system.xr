// Type System Showcase
// Demonstrates: Generics, interfaces, enums, match expressions,
//               type annotations, nullable types, gradual typing

// ===== Generic Data Structures =====

class Stack<T> {
    items: Array<T>

    constructor() {
        this.items = []
    }

    push(item: T) {
        this.items.push(item)
    }

    pop(): T? {
        if (this.items.length == 0) { return null }
        return this.items.pop()
    }

    peek(): T? {
        if (this.items.length == 0) { return null }
        return this.items[this.items.length - 1]
    }

    isEmpty(): bool {
        return this.items.length == 0
    }

    size(): int {
        return this.items.length
    }
}

class Pair<K, V> {
    key: K
    value: V

    constructor(k: K, v: V) {
        this.key = k
        this.value = v
    }

    toString(): string {
        return string(this.key) + " => " + string(this.value)
    }
}

// ===== Interfaces — Behavioral Contracts =====

interface Serializable {
    serialize(): string
}

interface Comparable {
    compareTo(other): int
}

// ===== Enums — Rich Value Types =====

enum Priority {
    Low = 1,
    Medium = 5,
    High = 10,
    Critical = 20
}

enum TaskState {
    Pending,
    Running,
    Completed,
    Failed
}

// ===== Class Implementing Interfaces =====

class Task implements Serializable, Comparable {
    id: int
    name: string
    priority: int
    state: int

    constructor(id: int, name: string, priority, state) {
        this.id = id
        this.name = name
        this.priority = priority
        this.state = state
    }

    serialize(): string {
        return json.stringify({
            id: this.id,
            name: this.name,
            priority: this.priority
        })
    }

    compareTo(other): int {
        return this.priority - other.priority
    }

    getStateLabel(): string {
        return match this.state {
            TaskState.Pending => "⏳ Pending",
            TaskState.Running => "🔄 Running",
            TaskState.Completed => "✅ Completed",
            TaskState.Failed => "❌ Failed",
            _ => "Unknown"
        }
    }
}

// ===== Inheritance =====

class Entity {
    id: int
    createdAt: int

    constructor(id: int) {
        this.id = id
        this.createdAt = 0
    }

    toString(): string {
        return "Entity#" + string(this.id)
    }
}

class User extends Entity {
    name: string
    email: string

    constructor(id: int, name: string, email: string) {
        base(id)
        this.name = name
        this.email = email
    }

    toString(): string {
        return this.name + " <" + this.email + ">"
    }
}

// ===== Pattern Matching with Guards =====

fn classifyScore(score: int): string {
    return match score {
        s if (s >= 90) => "A — Excellent",
        s if (s >= 80) => "B — Good",
        s if (s >= 70) => "C — Average",
        s if (s >= 60) => "D — Pass",
        _ => "F — Fail"
    }
}

fn describePriority(p): string {
    return match p {
        Priority.Low => "Low priority — can wait",
        Priority.Medium => "Medium priority — schedule soon",
        Priority.High => "High priority — handle today",
        Priority.Critical => "Critical — handle immediately!",
        _ => "Unknown priority"
    }
}

// ===== Higher-order generics usage =====

fn sortByPriority(tasks) {
    // Simple bubble sort by priority (descending)
    for (let i = 0; i < tasks.length; i++) {
        for (let j = i + 1; j < tasks.length; j++) {
            if (tasks[i].compareTo(tasks[j]) < 0) {
                let tmp = tasks[i]
                tasks[i] = tasks[j]
                tasks[j] = tmp
            }
        }
    }
    return tasks
}

// ===== Demo =====

fn main() {
    print("=== Type System Showcase ===")

    // Generic Stack
    let stack = new Stack<int>()
    stack.push(10)
    stack.push(20)
    stack.push(30)
    print("Stack peek:", stack.peek())
    print("Stack pop:", stack.pop())
    print("Stack size:", stack.size())

    // Generic Pair
    let pair = new Pair<string, int>("age", 25)
    print("Pair:", pair.toString())

    // Enum iteration
    print("\n--- Priorities ---")
    for (p in Priority) {
        print(" ", p.name, "=", p.value, "→", describePriority(p))
    }

    // Tasks with pattern matching
    print("\n--- Tasks ---")
    let tasks = [
        new Task(1, "Fix login bug", Priority.Critical.value, TaskState.Running),
        new Task(2, "Update docs", Priority.Low.value, TaskState.Pending),
        new Task(3, "Deploy v2.0", Priority.High.value, TaskState.Pending),
        new Task(4, "Code review", Priority.Medium.value, TaskState.Completed)
    ]

    let sorted = sortByPriority(tasks)
    for (t in sorted) {
        print("  [" + t.getStateLabel() + "]", t.name, "(priority:", t.priority + ")")
    }

    // Inheritance
    print("\n--- Inheritance ---")
    let user = new User(1, "Alice", "alice@example.com")
    print("User:", user.toString())
    print("Is Entity:", user.id)

    // Scores with match guards
    print("\n--- Score Classification ---")
    let scores = [95, 82, 73, 61, 45]
    for (s in scores) {
        print("  Score", s, "→", classifyScore(s))
    }

    // Nullable type safety
    print("\n--- Nullable Safety ---")
    let emptyStack = new Stack<string>()
    let result = emptyStack.pop()
    if (result == null) {
        print("  Empty stack pop → null (safe!)")
    }

    print("\nDone.")
}

main()
