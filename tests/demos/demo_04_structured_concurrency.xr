// Structured Concurrency & Fault Tolerance
// Demonstrates: scope, await.all, await.any, Coro.monitor,
//               error handling, task supervision patterns

import time
import coro

// ===== Pattern 1: Parallel fetch with scope =====
// All tasks MUST complete before scope exits — no leaked goroutines

fn fetchUser(id) {
    time.sleep(10)
    return { id: id, name: "User-" + string(id) }
}

fn fetchOrders(userId) {
    time.sleep(15)
    return [
        { orderId: userId * 100, amount: 99.9 },
        { orderId: userId * 100 + 1, amount: 49.5 }
    ]
}

fn fetchRecommendations(userId) {
    time.sleep(5)
    return ["item-A", "item-B", "item-C"]
}

fn demo_parallel_fetch() {
    print("=== Pattern 1: Parallel Fetch (scope) ===")
    let start = time.monotonic()

    shared const results = { user: null, orders: null, recs: null }

    // All three fetches run concurrently; scope waits for ALL
    scope {
        go {
            let u = fetchUser(42)
            results.user = u
        }
        go {
            let o = fetchOrders(42)
            results.orders = o
        }
        go {
            let r = fetchRecommendations(42)
            results.recs = r
        }
    }

    let elapsed = time.monotonic() - start
    print("User:", results.user.name)
    print("Orders:", results.orders.length)
    print("Recommendations:", results.recs.length)
    print("Total time:", elapsed, "ms (parallel, not sequential)")
}

// ===== Pattern 2: await.all — Batch processing =====

fn processItem(id) {
    time.sleep(5)
    if (id == 3) {
        throw "Item 3 processing failed"
    }
    return "result-" + string(id)
}

fn demo_await_all() {
    print("\n=== Pattern 2: await.all (Batch) ===")

    let tasks = []
    for (let i = 1; i <= 5; i++) {
        tasks.push(go processItem(i))
    }

    let results = await.all(tasks)

    for (let i = 0; i < tasks.length; i++) {
        let t = tasks[i]
        if (t.error != null) {
            print("  Task", i + 1, "FAILED:", t.error)
        } else {
            print("  Task", i + 1, "OK:", results[i])
        }
    }
}

// ===== Pattern 3: await.any — First response wins =====

fn queryReplica(name, latency) {
    time.sleep(latency)
    return { source: name, data: "response from " + name }
}

fn demo_await_any() {
    print("\n=== Pattern 3: await.any (First Wins) ===")

    let tasks = [
        go queryReplica("replica-US", 50),
        go queryReplica("replica-EU", 30),
        go queryReplica("replica-Asia", 10)
    ]

    let fastest = await.any(tasks)
    print("Fastest response:", fastest.source)
}

// ===== Pattern 4: Supervisor with monitor =====

fn workerProcess(name) {
    time.sleep(20)
    if (name == "worker-2") {
        throw "out of memory"
    }
    return "done"
}

fn demo_supervisor() {
    print("\n=== Pattern 4: Supervisor (monitor) ===")

    let workerNames = ["worker-1", "worker-2", "worker-3"]
    let monitors = []

    // Start workers with names and monitor each
    for (name in workerNames) {
        go(name: name) workerProcess(name)
        monitors.push({
            name: name,
            ch: coro.monitor(name)
        })
    }

    // Watch for failures
    for (m in monitors) {
        let reason = m.ch.recv()
        if (reason != "normal") {
            print("  [ALERT]", m.name, "crashed:", reason)
        } else {
            print("  [OK]", m.name, "exited normally")
        }
    }
}

// ===== Pattern 5: Timeout with select =====

fn slowComputation() {
    time.sleep(200)
    return 42
}

fn demo_timeout() {
    print("\n=== Pattern 5: Timeout (select + after) ===")

    const resultCh = Channel(1)

    go {
        let r = slowComputation()
        resultCh.trySend(r)
    }

    select {
        result from resultCh => {
            print("  Got result:", result)
        }
        after 50 => {
            print("  Timeout! Computation took too long.")
        }
    }
}

// ===== Pattern 6: Graceful shutdown =====

fn longRunningService(stopCh) {
    let count = 0
    while (true) {
        select {
            _ from stopCh => {
                print("  Service: received stop signal after", count, "ticks")
                return count
            }
            after 10 => {
                count++
            }
        }
    }
}

fn demo_graceful_shutdown() {
    print("\n=== Pattern 6: Graceful Shutdown ===")

    const stop = Channel(1)
    let svc = go longRunningService(stop)

    // Let it run for a while
    time.sleep(55)

    // Signal stop
    stop.send(true)
    let ticks = await svc
    print("  Service completed with", ticks, "ticks")
}

// ===== Run all patterns =====

fn main() {
    demo_parallel_fetch()
    demo_await_all()
    demo_await_any()
    demo_supervisor()
    demo_timeout()
    demo_graceful_shutdown()
    print("\nAll patterns demonstrated.")
}

main()
