// Decentralized Exchange (DEX)
// ============================================================
// A distributed order-book DEX built on xray cluster primitives.
// Demonstrates how Named Channels naturally model order flow,
// services model RPC endpoints, and pub/sub models price feeds.
//
// Cluster API used:
//   cluster.channel("orderbook.BTC-USDT", 512)  — distributed order book
//   cluster.serve("place_order")       — RPC: submit limit/market orders
//   cluster.serve("cancel_order")      — RPC: cancel pending orders
//   cluster.serve("query_balance")     — RPC: check account balance
//   cluster.call("place_order", order) — cross-node order submission
//   cluster.publish("trade.BTC-USDT", trade)  — broadcast executed trades
//   cluster.publish("price.BTC-USDT", tick)   — broadcast price updates
//   cluster.subscribe("trade.>")       — receive all trade notifications
//   cluster.subscribe("price.>")       — receive price feed
//   cluster.monitor("*")               — detect matcher node failure
//
// Architecture:
//   - Matcher Node: runs the matching engine, owns the order book channel
//   - Gateway Node: accepts user orders, forwards to matcher
//   - Observer Node: subscribes to trades/prices for analytics
//
// Run:
//   ./build/xray cluster_defi_dex.xr -- --name matcher --port 9201 --role matcher
//   ./build/xray cluster_defi_dex.xr -- --name gateway-1 --port 9202 --join 127.0.0.1:9201 --role gateway
//   ./build/xray cluster_defi_dex.xr -- --name observer --port 9203 --join 127.0.0.1:9201 --role observer

import cluster
import crypto
import time
import json

// ===== Configuration =====

fn parseArgs() {
    let config = {
        name: "matcher",
        port: 9201,
        secret: "dex-secret",
        role: "matcher",
        join_host: null,
        join_port: 0
    }
    let args = sys.args()
    for (let i = 0; i < args.length; i++) {
        match args[i] {
            "--name" => { config.name = args[i + 1]; i++ },
            "--port" => { config.port = int(args[i + 1]); i++ },
            "--role" => { config.role = args[i + 1]; i++ },
            "--join" => {
                let parts = args[i + 1].split(":")
                config.join_host = parts[0]
                config.join_port = int(parts[1])
                i++
            },
            _ => {}
        }
    }
    return config
}

// ===== Order Types =====

enum OrderSide {
    Buy,
    Sell
}

enum OrderType {
    Limit,
    Market
}

enum OrderStatus {
    Open,
    Filled,
    PartialFill,
    Cancelled
}

fn sideName(s) {
    return match s {
        OrderSide.Buy => "BUY",
        OrderSide.Sell => "SELL",
        _ => "?"
    }
}

// ===== Account Management =====

shared const accounts = {}

fn initAccount(addr: string) {
    if (accounts[addr] == null) {
        accounts[addr] = {
            BTC: 10.0,
            USDT: 100000.0,
            lockedBTC: 0.0,
            lockedUSDT: 0.0
        }
    }
}

fn getBalance(addr: string) {
    initAccount(addr)
    return accounts[addr]
}

fn lockFunds(addr: string, asset: string, amount: float): bool {
    let acct = getBalance(addr)
    if (acct[asset] < amount) { return false }
    acct[asset] -= amount
    acct["locked" + asset] += amount
    return true
}

fn unlockFunds(addr: string, asset: string, amount: float) {
    let acct = getBalance(addr)
    acct["locked" + asset] -= amount
    acct[asset] += amount
}

fn settleTrade(buyer, seller, btcAmount, usdtAmount) {
    let buyAcct = getBalance(buyer)
    let sellAcct = getBalance(seller)

    // Buyer: locked USDT → BTC
    buyAcct.lockedUSDT -= usdtAmount
    buyAcct.BTC += btcAmount

    // Seller: locked BTC → USDT
    sellAcct.lockedBTC -= btcAmount
    sellAcct.USDT += usdtAmount
}

// ===== Order Book =====

shared const orderBook = {
    bids: [],   // Buy orders, sorted by price descending
    asks: [],   // Sell orders, sorted by price ascending
    nextId: 1,
    tradeHistory: [],
    lastPrice: 50000.0
}

fn createOrder(trader, side, orderType, price, quantity) {
    let id = orderBook.nextId
    orderBook.nextId++
    return {
        id: id,
        trader: trader,
        side: side,
        type: orderType,
        price: price,
        quantity: quantity,
        filled: 0.0,
        status: OrderStatus.Open,
        timestamp: time.now(),
        hash: crypto.sha256(trader + string(id) + string(time.now()))
    }
}

// ===== Matching Engine =====
// Runs on the Matcher node; receives orders via Named Channel

fn matchOrder(order) {
    let trades = []

    if (order.side == OrderSide.Buy) {
        // Match against asks (lowest price first)
        let i = 0
        while (i < orderBook.asks.length && order.filled < order.quantity) {
            let ask = orderBook.asks[i]
            if (ask.status != OrderStatus.Open) { i++; continue }

            // Price check: buy price >= ask price
            if (order.type == OrderType.Market || order.price >= ask.price) {
                let fillQty = math.min(
                    order.quantity - order.filled,
                    ask.quantity - ask.filled
                )
                let fillPrice = ask.price

                // Execute trade
                order.filled += fillQty
                ask.filled += fillQty

                if (ask.filled >= ask.quantity) {
                    ask.status = OrderStatus.Filled
                }

                settleTrade(order.trader, ask.trader, fillQty, fillQty * fillPrice)
                orderBook.lastPrice = fillPrice

                trades.push({
                    buyOrderId: order.id,
                    sellOrderId: ask.id,
                    buyer: order.trader,
                    seller: ask.trader,
                    price: fillPrice,
                    quantity: fillQty,
                    timestamp: time.now()
                })
            }
            i++
        }

        // If not fully filled, add remaining to bids
        if (order.filled < order.quantity && order.type == OrderType.Limit) {
            order.status = order.filled > 0 ? OrderStatus.PartialFill : OrderStatus.Open
            orderBook.bids.push(order)
            // Sort bids: highest price first
            sortBids()
        } else {
            order.status = OrderStatus.Filled
        }

    } else {
        // Match against bids (highest price first)
        let i = 0
        while (i < orderBook.bids.length && order.filled < order.quantity) {
            let bid = orderBook.bids[i]
            if (bid.status != OrderStatus.Open) { i++; continue }

            if (order.type == OrderType.Market || order.price <= bid.price) {
                let fillQty = math.min(
                    order.quantity - order.filled,
                    bid.quantity - bid.filled
                )
                let fillPrice = bid.price

                order.filled += fillQty
                bid.filled += fillQty

                if (bid.filled >= bid.quantity) {
                    bid.status = OrderStatus.Filled
                }

                settleTrade(bid.trader, order.trader, fillQty, fillQty * fillPrice)
                orderBook.lastPrice = fillPrice

                trades.push({
                    buyOrderId: bid.id,
                    sellOrderId: order.id,
                    buyer: bid.trader,
                    seller: order.trader,
                    price: fillPrice,
                    quantity: fillQty,
                    timestamp: time.now()
                })
            }
            i++
        }

        if (order.filled < order.quantity && order.type == OrderType.Limit) {
            order.status = order.filled > 0 ? OrderStatus.PartialFill : OrderStatus.Open
            orderBook.asks.push(order)
            sortAsks()
        } else {
            order.status = OrderStatus.Filled
        }
    }

    return trades
}

fn sortBids() {
    // Simple sort: highest price first
    for (let i = 0; i < orderBook.bids.length; i++) {
        for (let j = i + 1; j < orderBook.bids.length; j++) {
            if (orderBook.bids[j].price > orderBook.bids[i].price) {
                let tmp = orderBook.bids[i]
                orderBook.bids[i] = orderBook.bids[j]
                orderBook.bids[j] = tmp
            }
        }
    }
}

fn sortAsks() {
    for (let i = 0; i < orderBook.asks.length; i++) {
        for (let j = i + 1; j < orderBook.asks.length; j++) {
            if (orderBook.asks[j].price < orderBook.asks[i].price) {
                let tmp = orderBook.asks[i]
                orderBook.asks[i] = orderBook.asks[j]
                orderBook.asks[j] = tmp
            }
        }
    }
}

// ===== Matcher Node Services =====

fn matcherOrderService() {
    let reqCh = cluster.serve("place_order")
    print("[Matcher] place_order service registered")

    while (true) {
        let req = reqCh.recv()
        if (req == null) { break }

        let params = req.args
        let order = createOrder(
            params.trader,
            params.side,
            params.type ?? OrderType.Limit,
            params.price,
            params.quantity
        )

        // Lock funds
        let locked = false
        if (order.side == OrderSide.Buy) {
            locked = lockFunds(order.trader, "USDT", order.price * order.quantity)
        } else {
            locked = lockFunds(order.trader, "BTC", order.quantity)
        }

        if (!locked) {
            cluster.reply(req, { ok: false, error: "insufficient funds" })
            continue
        }

        // Run matching engine
        let trades = matchOrder(order)

        // Broadcast trades via pub/sub
        for (trade in trades) {
            cluster.publish("trade.BTC-USDT", trade)
            orderBook.tradeHistory.push(trade)
        }

        // Broadcast price update
        if (trades.length > 0) {
            cluster.publish("price.BTC-USDT", {
                pair: "BTC-USDT",
                price: orderBook.lastPrice,
                timestamp: time.now()
            })
        }

        print("[Match]", sideName(order.side),
              order.quantity, "BTC @", order.price,
              "| trades:", trades.length,
              "| filled:", order.filled)

        cluster.reply(req, {
            ok: true,
            orderId: order.id,
            status: order.status,
            filled: order.filled,
            trades: trades.length
        })
    }
}

fn matcherCancelService() {
    let reqCh = cluster.serve("cancel_order")
    print("[Matcher] cancel_order service registered")

    while (true) {
        let req = reqCh.recv()
        if (req == null) { break }

        let orderId = req.args.orderId
        let found = false

        // Search in bids
        for (bid in orderBook.bids) {
            if (bid.id == orderId && bid.status == OrderStatus.Open) {
                bid.status = OrderStatus.Cancelled
                unlockFunds(bid.trader, "USDT",
                    (bid.quantity - bid.filled) * bid.price)
                found = true
                break
            }
        }

        // Search in asks
        if (!found) {
            for (ask in orderBook.asks) {
                if (ask.id == orderId && ask.status == OrderStatus.Open) {
                    ask.status = OrderStatus.Cancelled
                    unlockFunds(ask.trader, "BTC", ask.quantity - ask.filled)
                    found = true
                    break
                }
            }
        }

        cluster.reply(req, { ok: found })
    }
}

fn matcherBalanceService() {
    let reqCh = cluster.serve("query_balance")
    print("[Matcher] query_balance service registered")

    while (true) {
        let req = reqCh.recv()
        if (req == null) { break }

        let addr = req.args.address ?? ""
        let bal = getBalance(addr)
        cluster.reply(req, {
            address: addr,
            BTC: bal.BTC,
            USDT: bal.USDT,
            lockedBTC: bal.lockedBTC,
            lockedUSDT: bal.lockedUSDT
        })
    }
}

// ===== Gateway Node: Forward orders =====

fn gatewayOrderLoop(config) {
    let traders = ["Alice", "Bob", "Charlie", "Diana"]
    let orderCount = 0

    time.sleep(2000)
    print("[Gateway] Starting order flow simulation")

    while (orderCount < 100) {
        time.sleep(200 + (orderCount % 3) * 100)

        let trader = traders[orderCount % traders.length]
        let side = orderCount % 2 == 0 ? OrderSide.Buy : OrderSide.Sell
        let basePrice = 50000.0
        let priceOffset = ((orderCount * 17) % 200 - 100) * 1.0
        let price = basePrice + priceOffset
        let qty = 0.01 + (orderCount % 5) * 0.005

        // Submit to matcher via cluster.call (RPC)
        let result = cluster.call("place_order", {
            trader: trader,
            side: side,
            type: OrderType.Limit,
            price: price,
            quantity: qty
        })

        if (result != null && result.ok) {
            print("[Gateway]", sideName(side), qty, "BTC @", price,
                  "→ order #" + string(result.orderId),
                  "| filled:", result.filled)
            orderCount++
        }
    }

    print("[Gateway] Completed", orderCount, "orders")
}

// ===== Observer Node: Analytics =====

fn observerTradeStream() {
    let tradeSub = cluster.subscribe("trade.>")
    let totalVolume = 0.0
    let tradeCount = 0

    print("[Observer] Subscribed to trade.>")

    while (true) {
        let trade = tradeSub.recv()
        if (trade == null) { break }

        totalVolume += trade.price * trade.quantity
        tradeCount++

        print("[Trade]", trade.buyer, "←→", trade.seller,
              "|", trade.quantity, "BTC @", trade.price,
              "| total volume:", totalVolume)
    }
}

fn observerPriceFeed() {
    let priceSub = cluster.subscribe("price.>")
    let priceHistory = []

    print("[Observer] Subscribed to price.>")

    while (true) {
        let tick = priceSub.recv()
        if (tick == null) { break }

        priceHistory.push(tick.price)

        // Simple moving average
        let windowSize = 10
        let window = priceHistory.slice(
            math.max(0, priceHistory.length - windowSize),
            priceHistory.length
        )
        let sum = window.reduce((a, b) => a + b, 0.0)
        let sma = sum / window.length

        print("[Price]", tick.pair, ":", tick.price,
              "| SMA(" + string(windowSize) + "):", sma)
    }
}

// ===== Matcher Failover Monitor =====

fn matcherFailoverMonitor(config) {
    let monCh = cluster.monitor("*")

    while (true) {
        let disconnected = monCh.recv()
        if (disconnected == null) { break }

        print("[ALERT] Node", disconnected, "disconnected!")

        if (disconnected == "matcher") {
            print("[ALERT] Matcher node failed! DEX is temporarily offline.")
            print("[ALERT] In production: trigger matcher election or standby promotion")
        }
    }
}

// ===== Status Reporter =====

fn statusReporter(config) {
    while (true) {
        time.sleep(10000)

        if (config.role == "matcher") {
            let openBids = orderBook.bids.filter((o) => o.status == OrderStatus.Open)
            let openAsks = orderBook.asks.filter((o) => o.status == OrderStatus.Open)

            print("\n--- DEX Status:", config.name, "---")
            print("  Last price:", orderBook.lastPrice, "USDT")
            print("  Open bids:", openBids.length)
            print("  Open asks:", openAsks.length)
            print("  Total trades:", orderBook.tradeHistory.length)
            if (openBids.length > 0) {
                print("  Best bid:", openBids[0].price)
            }
            if (openAsks.length > 0) {
                print("  Best ask:", openAsks[0].price)
            }
            print("  Peers:", cluster.nodes())
            print("---\n")
        }
    }
}

// ===== Main =====

fn main() {
    let config = parseArgs()

    print("=== Decentralized Exchange ===")
    print("Name:", config.name, "| Role:", config.role)

    cluster.start(config.name, config.port, config.secret)

    if (config.join_host != null) {
        cluster.join(config.join_host, config.join_port)
        print("[Cluster] Joined", config.join_host + ":" + string(config.join_port))
    }

    match config.role {
        "matcher" => {
            scope {
                go matcherOrderService()
                go matcherCancelService()
                go matcherBalanceService()
                go matcherFailoverMonitor(config)
                go statusReporter(config)
            }
        },
        "gateway" => {
            scope {
                go gatewayOrderLoop(config)
                go matcherFailoverMonitor(config)
                go statusReporter(config)
            }
        },
        "observer" => {
            scope {
                go observerTradeStream()
                go observerPriceFeed()
                go matcherFailoverMonitor(config)
            }
        },
        _ => {
            print("Unknown role:", config.role)
        }
    }
}

main()
