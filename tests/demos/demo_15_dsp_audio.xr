import math

// Demo 11: DSP Audio Processing
// Scenario: biquad IIR filter on fixed-size audio buffer
// Verify: [32]float fixed array in struct, in/ref params, struct mutation, float math
//
// NOTE: Original design used [512]float, but VM bytecode uses 8-bit register
// indices (0-255). Since struct fields occupy consecutive registers, struct
// total field count must stay under ~200. Using [32]float instead.

struct AudioBuffer {
    samples: [32]float
}

// Biquad IIR filter state
struct BiquadState {
    x1: float
    x2: float
    y1: float
    y2: float
}

// Biquad IIR filter coefficients
struct BiquadCoeffs {
    b0: float
    b1: float
    b2: float
    a1: float
    a2: float
}

// Apply biquad filter in-place
fn biquad_process(buf: ref AudioBuffer, state: ref BiquadState, c: in BiquadCoeffs): void {
    for (i in 0..32) {
        let x0 = buf.samples[i]
        let y0 = c.b0*x0 + c.b1*state.x1 + c.b2*state.x2 - c.a1*state.y1 - c.a2*state.y2
        state.x2 = state.x1
        state.x1 = x0
        state.y2 = state.y1
        state.y1 = y0
        buf.samples[i] = y0
    }
}

// Design low-pass filter coefficients
fn lowpass_coeffs(sample_rate: float, cutoff: float, q: float): BiquadCoeffs {
    let w0 = 2.0 * 3.14159265 * cutoff / sample_rate
    let alpha = math.sin(w0) / (2.0 * q)
    let cos_w0 = math.cos(w0)
    let a0 = 1.0 + alpha
    return BiquadCoeffs{
        b0: (1.0 - cos_w0) / 2.0 / a0,
        b1: (1.0 - cos_w0) / a0,
        b2: (1.0 - cos_w0) / 2.0 / a0,
        a1: 0.0 - 2.0 * cos_w0 / a0,
        a2: (1.0 - alpha) / a0
    }
}

// Mix two buffers: dst += src * gain
fn mix(dst: ref AudioBuffer, src: in AudioBuffer, gain: float): void {
    for (i in 0..32) {
        dst.samples[i] = dst.samples[i] + src.samples[i] * gain
    }
}

// Compute RMS volume
fn rms(buf: in AudioBuffer): float {
    let sum = 0.0
    for (i in 0..32) {
        sum = sum + buf.samples[i] * buf.samples[i]
    }
    return math.sqrt(sum / 32.0)
}

// --- Test ---

// Test 1: RMS of silence should be 0
let silence = AudioBuffer{}
print(rms(silence))  // 0

// Test 2: Fill buffer with constant 1.0, RMS should be 1.0
let ones = AudioBuffer{}
for (i in 0..32) {
    ones.samples[i] = 1.0
}
print(rms(ones))  // 1

// Test 3: Generate simple sine wave (period = 8 samples)
let buf = AudioBuffer{}
for (i in 0..32) {
    buf.samples[i] = math.sin(2.0 * 3.14159265 * float(i) / 8.0)
}
let sine_rms = rms(buf)
print(sine_rms > 0.7)   // true (sine RMS ~ 0.707)
print(sine_rms < 0.72)  // true

// Test 4: Apply low-pass filter
let lp = lowpass_coeffs(44100.0, 1000.0, 0.707)
let state = BiquadState{x1: 0.0, x2: 0.0, y1: 0.0, y2: 0.0}
print(lp.b0 > 0.0)  // true (valid coefficient)

biquad_process(buf, state, lp)
let filtered_rms = rms(buf)
// Filtered signal should have lower RMS (low-pass attenuates high freq sine)
print(filtered_rms < sine_rms)  // true

// Test 5: Mix buffers
let mix_buf = AudioBuffer{}
mix(mix_buf, ones, 0.5)
print(rms(mix_buf))  // 0.5

// Test 6: Fixed array .length
print(buf.samples.length)  // 32

// Test 7: Struct field counts
print(Reflect.fieldCount(buf))    // 1 (samples)
print(Reflect.fieldCount(state))  // 4 (x1, x2, y1, y2)
print(Reflect.fieldCount(lp))     // 5 (b0, b1, b2, a1, a2)
