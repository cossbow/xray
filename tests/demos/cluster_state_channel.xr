// Layer-2 State Channel (Payment Channel)
// ============================================================
// Off-chain bilateral payment channels with on-chain settlement,
// built on xray cluster primitives. Demonstrates how Named Channels
// naturally model off-chain state updates between two parties.
//
// Cluster API used:
//   cluster.channel("state.Alice-Bob", 64)   — off-chain state updates
//   cluster.channel("dispute.Alice-Bob", 8)  — dispute resolution channel
//   cluster.serve("open_channel")    — RPC: open a payment channel
//   cluster.serve("settle_channel")  — RPC: cooperative close
//   cluster.serve("dispute")         — RPC: submit dispute with proof
//   cluster.call("open_channel", p)  — request channel opening
//   cluster.publish("settlement.>", s)  — broadcast settlement events
//   cluster.subscribe("settlement.>")   — observe settlements
//   cluster.monitor(node_name)       — detect counterparty failure
//
// Concept:
//   1. Two parties open a payment channel by locking funds on-chain
//   2. They exchange signed state updates off-chain via Named Channel
//   3. Either party can settle cooperatively or dispute with latest state
//   4. If counterparty goes offline (detected by monitor), force-close
//
// Run:
//   ./build/xray cluster_state_channel.xr -- --name hub --port 9301 --role hub
//   ./build/xray cluster_state_channel.xr -- --name alice --port 9302 --join 127.0.0.1:9301 --role user
//   ./build/xray cluster_state_channel.xr -- --name bob --port 9303 --join 127.0.0.1:9301 --role user

import cluster
import crypto
import time
import json

// ===== Configuration =====

fn parseArgs() {
    let config = {
        name: "hub",
        port: 9301,
        secret: "l2-secret",
        role: "hub",
        join_host: null,
        join_port: 0
    }
    let args = sys.args()
    for (let i = 0; i < args.length; i++) {
        match args[i] {
            "--name" => { config.name = args[i + 1]; i++ },
            "--port" => { config.port = int(args[i + 1]); i++ },
            "--role" => { config.role = args[i + 1]; i++ },
            "--join" => {
                let parts = args[i + 1].split(":")
                config.join_host = parts[0]
                config.join_port = int(parts[1])
                i++
            },
            _ => {}
        }
    }
    return config
}

// ===== On-Chain Ledger (simplified simulation) =====

shared const onChain = {
    balances: {
        "Alice": 10000.0,
        "Bob": 10000.0,
        "Charlie": 10000.0
    },
    lockedChannels: {},  // channelId -> { partyA, partyB, depositA, depositB, ... }
    nonce: 0
}

fn onChainDeposit(party, amount): bool {
    if (onChain.balances[party] == null || onChain.balances[party] < amount) {
        return false
    }
    onChain.balances[party] -= amount
    return true
}

fn onChainWithdraw(party, amount) {
    if (onChain.balances[party] == null) {
        onChain.balances[party] = 0.0
    }
    onChain.balances[party] += amount
}

// ===== State Channel Data Structures =====

fn channelId(partyA, partyB) {
    // Deterministic channel ID
    if (partyA < partyB) {
        return partyA + "-" + partyB
    }
    return partyB + "-" + partyA
}

fn createChannelState(chId, partyA, partyB, balA, balB, nonce) {
    let state = {
        channelId: chId,
        partyA: partyA,
        partyB: partyB,
        balanceA: balA,
        balanceB: balB,
        nonce: nonce,
        timestamp: time.now()
    }
    state.hash = crypto.sha256(json.stringify(state))
    return state
}

fn signState(state, signer) {
    return {
        state: state,
        signer: signer,
        signature: crypto.sha256(state.hash + signer)
    }
}

fn verifyStateSignature(signedState, expectedSigner) {
    let expected = crypto.sha256(signedState.state.hash + expectedSigner)
    return signedState.signature == expected
}

// ===== Payment Channel Registry =====

shared const channels = {}  // channelId -> channel info

fn registerChannel(chId, partyA, partyB, depositA, depositB) {
    channels[chId] = {
        id: chId,
        partyA: partyA,
        partyB: partyB,
        depositA: depositA,
        depositB: depositB,
        currentState: createChannelState(chId, partyA, partyB, depositA, depositB, 0),
        stateNonce: 0,
        status: "open",
        openedAt: time.now(),
        updates: 0
    }
    return channels[chId]
}

// ===== Hub Services =====

// Open a payment channel between two parties
fn openChannelService() {
    let reqCh = cluster.serve("open_channel")
    print("[Hub] open_channel service registered")

    while (true) {
        let req = reqCh.recv()
        if (req == null) { break }

        let p = req.args
        let chId = channelId(p.partyA, p.partyB)

        // Check if channel already exists
        if (channels[chId] != null && channels[chId].status == "open") {
            cluster.reply(req, { ok: false, error: "channel already open" })
            continue
        }

        // Lock funds on-chain
        if (!onChainDeposit(p.partyA, p.depositA)) {
            cluster.reply(req, { ok: false, error: p.partyA + " insufficient funds" })
            continue
        }
        if (!onChainDeposit(p.partyB, p.depositB)) {
            onChainWithdraw(p.partyA, p.depositA)  // Refund
            cluster.reply(req, { ok: false, error: p.partyB + " insufficient funds" })
            continue
        }

        // Create on-chain record
        let ch = registerChannel(chId, p.partyA, p.partyB, p.depositA, p.depositB)
        onChain.lockedChannels[chId] = {
            partyA: p.partyA,
            partyB: p.partyB,
            depositA: p.depositA,
            depositB: p.depositB,
            totalLocked: p.depositA + p.depositB
        }

        // Create Named Channel for off-chain state exchange
        cluster.channel("state." + chId, 64)

        print("[Channel Opened]", chId,
              "|", p.partyA, ":", p.depositA,
              "|", p.partyB, ":", p.depositB)

        cluster.reply(req, {
            ok: true,
            channelId: chId,
            initialState: ch.currentState
        })
    }
}

// Cooperative settlement
fn settleChannelService() {
    let reqCh = cluster.serve("settle_channel")
    print("[Hub] settle_channel service registered")

    while (true) {
        let req = reqCh.recv()
        if (req == null) { break }

        let p = req.args
        let chId = p.channelId
        let ch = channels[chId]

        if (ch == null || ch.status != "open") {
            cluster.reply(req, { ok: false, error: "channel not found or closed" })
            continue
        }

        // Verify both signatures on the final state
        let finalState = p.finalState
        let sigA = p.signatureA
        let sigB = p.signatureB

        if (!verifyStateSignature(sigA, ch.partyA) ||
            !verifyStateSignature(sigB, ch.partyB)) {
            cluster.reply(req, { ok: false, error: "invalid signatures" })
            continue
        }

        // Verify state nonce is latest
        if (finalState.nonce < ch.stateNonce) {
            cluster.reply(req, { ok: false, error: "stale state" })
            continue
        }

        // Settlement: withdraw to on-chain balances
        onChainWithdraw(ch.partyA, finalState.balanceA)
        onChainWithdraw(ch.partyB, finalState.balanceB)

        ch.status = "settled"

        print("[Settlement]", chId,
              "|", ch.partyA, "→", finalState.balanceA,
              "|", ch.partyB, "→", finalState.balanceB,
              "| after", ch.updates, "off-chain updates")

        // Broadcast settlement event
        cluster.publish("settlement.cooperative", {
            channelId: chId,
            partyA: ch.partyA,
            partyB: ch.partyB,
            balanceA: finalState.balanceA,
            balanceB: finalState.balanceB,
            totalUpdates: ch.updates,
            type: "cooperative"
        })

        cluster.reply(req, {
            ok: true,
            settled: true,
            balanceA: finalState.balanceA,
            balanceB: finalState.balanceB
        })
    }
}

// Dispute resolution: accept latest signed state as proof
fn disputeService() {
    let reqCh = cluster.serve("dispute")
    print("[Hub] dispute service registered")

    while (true) {
        let req = reqCh.recv()
        if (req == null) { break }

        let p = req.args
        let chId = p.channelId
        let ch = channels[chId]

        if (ch == null || ch.status != "open") {
            cluster.reply(req, { ok: false, error: "channel not found" })
            continue
        }

        let claimedState = p.state
        let signature = p.signature
        let claimant = p.claimant

        // Verify the signature
        let counterparty = claimant == ch.partyA ? ch.partyB : ch.partyA
        if (!verifyStateSignature(signature, counterparty)) {
            cluster.reply(req, { ok: false, error: "invalid counterparty signature" })
            continue
        }

        // Accept if nonce is higher than current
        if (claimedState.nonce > ch.stateNonce) {
            ch.currentState = claimedState
            ch.stateNonce = claimedState.nonce
        }

        // Force settle with latest known state
        let state = ch.currentState
        onChainWithdraw(ch.partyA, state.balanceA)
        onChainWithdraw(ch.partyB, state.balanceB)
        ch.status = "force-closed"

        print("[Dispute Settled]", chId,
              "| claimant:", claimant,
              "| nonce:", state.nonce,
              "|", ch.partyA, "→", state.balanceA,
              "|", ch.partyB, "→", state.balanceB)

        cluster.publish("settlement.dispute", {
            channelId: chId,
            claimant: claimant,
            nonce: state.nonce,
            type: "dispute"
        })

        cluster.reply(req, {
            ok: true,
            type: "force-close",
            balanceA: state.balanceA,
            balanceB: state.balanceB
        })
    }
}

// ===== User Node: Off-chain Payment Flow =====

fn userPaymentFlow(config) {
    time.sleep(2000)  // Wait for cluster

    let myName = config.name
    let counterparty = myName == "alice" ? "Bob" : "Alice"
    let myNameCap = myName == "alice" ? "Alice" : "Bob"

    // 1. Open channel (only Alice opens)
    if (myName == "alice") {
        print("[User] Opening payment channel with Bob...")
        let result = cluster.call("open_channel", {
            partyA: "Alice",
            partyB: "Bob",
            depositA: 1000.0,
            depositB: 1000.0
        })

        if (result == null || !result.ok) {
            print("[User] Failed to open channel:", result?.error ?? "unknown")
            return
        }

        print("[User] Channel opened:", result.channelId)
        time.sleep(1000)
    } else {
        time.sleep(3000)  // Bob waits for Alice to open
    }

    let chId = channelId("Alice", "Bob")
    let stateCh = cluster.channel("state." + chId, 64)

    // 2. Exchange off-chain payments
    if (myName == "alice") {
        // Alice sends payments to Bob
        let currentBalA = 1000.0
        let currentBalB = 1000.0

        for (let i = 1; i <= 20; i++) {
            let amount = 10.0 + (i % 5) * 5.0

            currentBalA -= amount
            currentBalB += amount

            let newState = createChannelState(chId, "Alice", "Bob",
                currentBalA, currentBalB, i)
            let signed = signState(newState, "Alice")

            // Send state update via Named Channel (off-chain!)
            stateCh.send({
                update: signed,
                payment: amount,
                nonce: i
            })

            print("[Off-chain TX #" + string(i) + "] Alice → Bob:",
                  amount, "| balances:", currentBalA, "/", currentBalB)

            time.sleep(100)
        }

        // 3. Cooperative settlement
        time.sleep(500)
        let finalState = createChannelState(chId, "Alice", "Bob",
            currentBalA, currentBalB, 20)

        print("[User] Requesting cooperative settlement...")
        let settlement = cluster.call("settle_channel", {
            channelId: chId,
            finalState: finalState,
            signatureA: signState(finalState, "Alice"),
            signatureB: signState(finalState, "Bob")
        })

        if (settlement != null && settlement.ok) {
            print("[Settled] Alice:", settlement.balanceA,
                  "| Bob:", settlement.balanceB)
        }
    } else {
        // Bob receives state updates
        let latestNonce = 0
        let latestState = null

        for (let i = 0; i < 20; i++) {
            select {
                msg from stateCh => {
                    if (msg.nonce > latestNonce) {
                        latestNonce = msg.nonce
                        latestState = msg.update
                        print("[Off-chain RX #" + string(msg.nonce) + "]",
                              "Received", msg.payment, "from Alice")
                    }
                }
                after 5000 => {
                    print("[User] Timeout waiting for state update")
                    break
                }
            }
        }

        print("[User] Latest off-chain nonce:", latestNonce)
    }
}

// ===== Counterparty Failure Detector =====

fn counterpartyMonitor(config) {
    let myName = config.name
    if (myName == "hub") { return }

    let counterparty = myName == "alice" ? "bob" : "alice"
    let monCh = cluster.monitor(counterparty)

    let disconnected = monCh.recv()
    if (disconnected != null) {
        print("[ALERT] Counterparty", disconnected, "went offline!")
        print("[ALERT] Initiating dispute with latest signed state...")

        let chId = channelId("Alice", "Bob")
        let ch = channels[chId]
        if (ch != null && ch.status == "open") {
            // Submit dispute with latest state
            let result = cluster.call("dispute", {
                channelId: chId,
                claimant: myName == "alice" ? "Alice" : "Bob",
                state: ch.currentState,
                signature: signState(ch.currentState,
                    myName == "alice" ? "Bob" : "Alice")
            })
            if (result != null && result.ok) {
                print("[Dispute] Force-closed! A:", result.balanceA,
                      "| B:", result.balanceB)
            }
        }
    }
}

// ===== Settlement Observer =====

fn settlementObserver() {
    let sub = cluster.subscribe("settlement.>")
    print("[Observer] Watching settlement events")

    while (true) {
        let evt = sub.recv()
        if (evt == null) { break }

        print("[Settlement Event]", evt.type,
              "| channel:", evt.channelId,
              "| updates:", evt.totalUpdates ?? "N/A")
    }
}

// ===== Status Reporter =====

fn statusReporter(config) {
    while (true) {
        time.sleep(10000)

        print("\n--- State Channel Status:", config.name, "---")
        print("  On-chain balances:", json.stringify(onChain.balances))
        print("  Open channels:", json.stringify(onChain.lockedChannels))
        print("  Peers:", cluster.nodes())
        print("---\n")
    }
}

// ===== Main =====

fn main() {
    let config = parseArgs()

    print("=== Layer-2 State Channel ===")
    print("Name:", config.name, "| Role:", config.role)

    cluster.start(config.name, config.port, config.secret)

    if (config.join_host != null) {
        cluster.join(config.join_host, config.join_port)
    }

    match config.role {
        "hub" => {
            scope {
                go openChannelService()
                go settleChannelService()
                go disputeService()
                go settlementObserver()
                go statusReporter(config)
            }
        },
        "user" => {
            scope {
                go userPaymentFlow(config)
                go counterpartyMonitor(config)
                go settlementObserver()
            }
        },
        _ => {
            print("Unknown role:", config.role)
        }
    }
}

main()
