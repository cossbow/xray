// OOP Design Patterns
// Demonstrates: Classes, inheritance, interfaces, operator overloading,
//               getter/setter, method chaining, factory pattern, iterator

// ===== Pattern 1: Builder Pattern =====

class QueryBuilder {
    _table: string
    _conditions: Array<string>
    _orderBy: string
    _limit: int

    constructor(table: string) {
        this._table = table
        this._conditions = []
        this._orderBy = ""
        this._limit = 0
    }

    where(condition: string): QueryBuilder {
        this._conditions.push(condition)
        return this
    }

    orderBy(field: string): QueryBuilder {
        this._orderBy = field
        return this
    }

    limit(n: int): QueryBuilder {
        this._limit = n
        return this
    }

    build(): string {
        let sql = "SELECT * FROM " + this._table
        if (this._conditions.length > 0) {
            sql += " WHERE " + this._conditions.reduce(
                (a, b) => a + " AND " + b, ""
            )
        }
        if (this._orderBy != "") {
            sql += " ORDER BY " + this._orderBy
        }
        if (this._limit > 0) {
            sql += " LIMIT " + string(this._limit)
        }
        return sql
    }
}

fn demo_builder() {
    print("=== Builder Pattern ===")
    let query = new QueryBuilder("users")
        .where("age > 18")
        .where("active = true")
        .orderBy("name")
        .limit(10)
        .build()
    print("SQL:", query)
}

// ===== Pattern 2: Strategy Pattern with Interfaces =====

interface SortStrategy {
    sort(arr): void
}

class BubbleSort implements SortStrategy {
    sort(arr) {
        let n = arr.length
        for (let i = 0; i < n; i++) {
            for (let j = 0; j < n - i - 1; j++) {
                if (arr[j] > arr[j + 1]) {
                    let tmp = arr[j]
                    arr[j] = arr[j + 1]
                    arr[j + 1] = tmp
                }
            }
        }
    }
}

class InsertionSort implements SortStrategy {
    sort(arr) {
        for (let i = 1; i < arr.length; i++) {
            let key = arr[i]
            let j = i - 1
            while (j >= 0 && arr[j] > key) {
                arr[j + 1] = arr[j]
                j--
            }
            arr[j + 1] = key
        }
    }
}

class Sorter {
    strategy: SortStrategy

    constructor(strategy: SortStrategy) {
        this.strategy = strategy
    }

    execute(data) {
        let arr = data[:]  // slice copy
        this.strategy.sort(arr)
        return arr
    }
}

fn demo_strategy() {
    print("\n=== Strategy Pattern ===")
    let data = [64, 34, 25, 12, 22, 11, 90]

    let bubbleSorter = new Sorter(new BubbleSort())
    let insertSorter = new Sorter(new InsertionSort())

    print("Original:", data)
    print("Bubble sort:", bubbleSorter.execute(data))
    print("Insertion sort:", insertSorter.execute(data))
}

// ===== Pattern 3: Operator Overloading =====

class Vector2D {
    x: float
    y: float

    constructor(x: float, y: float) {
        this.x = x
        this.y = y
    }

    operator+(other) {
        return new Vector2D(this.x + other.x, this.y + other.y)
    }

    operator-(other) {
        return new Vector2D(this.x - other.x, this.y - other.y)
    }

    operator*(scalar) {
        return new Vector2D(this.x * scalar, this.y * scalar)
    }

    operator==(other) {
        return this.x == other.x && this.y == other.y
    }

    magnitude(): float {
        return (this.x * this.x + this.y * this.y) ** 0.5
    }

    dot(other): float {
        return this.x * other.x + this.y * other.y
    }

    toString(): string {
        return "(${this.x}, ${this.y})"
    }
}

fn demo_operators() {
    print("\n=== Operator Overloading ===")
    let a = new Vector2D(3.0, 4.0)
    let b = new Vector2D(1.0, 2.0)

    print("a =", a.toString())
    print("b =", b.toString())
    print("a + b =", (a + b).toString())
    print("a - b =", (a - b).toString())
    print("a * 2 =", (a * 2).toString())
    print("|a| =", a.magnitude())
    print("a · b =", a.dot(b))
    print("a == a:", a == a)
    print("a == b:", a == b)
}

// ===== Pattern 4: Inheritance & Polymorphism =====

class Shape {
    name: string

    constructor(name: string) {
        this.name = name
    }

    area(): float { return 0.0 }

    describe(): string {
        return this.name + ": area = " + string(this.area())
    }
}

class Circle extends Shape {
    radius: float

    constructor(r: float) {
        base("Circle")
        this.radius = r
    }

    area(): float {
        return 3.14159 * this.radius * this.radius
    }
}

class Rect extends Shape {
    width: float
    height: float

    constructor(w: float, h: float) {
        base("Rectangle")
        this.width = w
        this.height = h
    }

    area(): float {
        return this.width * this.height
    }
}

class Triangle extends Shape {
    base_len: float
    height: float

    constructor(b: float, h: float) {
        base("Triangle")
        this.base_len = b
        this.height = h
    }

    area(): float {
        return 0.5 * this.base_len * this.height
    }
}

fn demo_polymorphism() {
    print("\n=== Inheritance & Polymorphism ===")

    let shapes = [
        new Circle(5.0),
        new Rect(4.0, 6.0),
        new Triangle(3.0, 8.0)
    ]

    let totalArea = 0.0
    for (s in shapes) {
        print("  " + s.describe())
        totalArea += s.area()
    }
    print("Total area:", totalArea)
}

// ===== Pattern 5: Observer Pattern =====

class EventEmitter {
    _listeners: Map<string, Array<any>>

    constructor() {
        this._listeners = {}
    }

    on(event: string, handler) {
        if (this._listeners[event] == null) {
            this._listeners[event] = []
        }
        this._listeners[event].push(handler)
    }

    emit(event: string, data) {
        let handlers = this._listeners[event]
        if (handlers != null) {
            for (h in handlers) {
                h(data)
            }
        }
    }
}

fn demo_observer() {
    print("\n=== Observer Pattern ===")

    let emitter = new EventEmitter()
    let log = []

    emitter.on("login", (user) => {
        log.push("User logged in: " + user)
    })

    emitter.on("login", (user) => {
        log.push("Analytics: login event for " + user)
    })

    emitter.on("purchase", (item) => {
        log.push("Purchase: " + item)
    })

    emitter.emit("login", "Alice")
    emitter.emit("purchase", "Laptop")
    emitter.emit("login", "Bob")

    for (entry in log) {
        print("  " + entry)
    }
}

// ===== Pattern 6: Enum-based State Machine =====

enum State {
    Idle,
    Loading,
    Success,
    Error
}

class StateMachine {
    current: int
    data: any
    error: string

    constructor() {
        this.current = State.Idle
        this.data = null
        this.error = ""
    }

    transition(action: string) {
        this.current = match action {
            "fetch" => State.Loading,
            "success" => State.Success,
            "fail" => State.Error,
            "reset" => State.Idle,
            _ => this.current
        }
    }

    display(): string {
        return match this.current {
            State.Idle => "[Idle] Ready",
            State.Loading => "[Loading] Please wait...",
            State.Success => "[Success] Data loaded",
            State.Error => "[Error] " + this.error,
            _ => "[Unknown]"
        }
    }
}

fn demo_state_machine() {
    print("\n=== Enum State Machine ===")
    let sm = new StateMachine()

    let actions = ["fetch", "success", "reset", "fetch", "fail"]
    for (action in actions) {
        sm.transition(action)
        if (action == "fail") { sm.error = "Network timeout" }
        print("  Action:", action, "→", sm.display())
    }
}

// ===== Run all =====

fn main() {
    demo_builder()
    demo_strategy()
    demo_operators()
    demo_polymorphism()
    demo_observer()
    demo_state_machine()
    print("\nAll OOP patterns demonstrated.")
}

main()
