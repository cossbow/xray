import math

// Demo 4: N-body Gravity Simulation
// Scenario: gravitational force between bodies, velocity/position integration
// Verify: nested struct, in/ref, struct return, float math, nested loops

struct Vec3 {
    x: float
    y: float
    z: float
}

struct Body {
    pos: Vec3
    vel: Vec3
    mass: float
}

fn vec3_sub(a: in Vec3, b: in Vec3): Vec3 {
    return Vec3{x: a.x - b.x, y: a.y - b.y, z: a.z - b.z}
}

fn vec3_length_sq(v: in Vec3): float {
    return v.x * v.x + v.y * v.y + v.z * v.z
}

fn vec3_scale(v: in Vec3, s: float): Vec3 {
    return Vec3{x: v.x * s, y: v.y * s, z: v.z * s}
}

// Compute gravitational forces and update velocities
fn compute_forces(b1: ref Body, b2: ref Body, dt: float): void {
    let G = 1.0  // simplified G for testing
    let diff = vec3_sub(b2.pos, b1.pos)
    let dist_sq = vec3_length_sq(diff) + 0.001  // softening
    let dist = math.sqrt(dist_sq)
    let force = G * b1.mass * b2.mass / dist_sq

    let acc1_s = force / (b1.mass * dist) * dt
    let acc2_s = force / (b2.mass * dist) * dt

    b1.vel.x = b1.vel.x + diff.x * acc1_s
    b1.vel.y = b1.vel.y + diff.y * acc1_s
    b1.vel.z = b1.vel.z + diff.z * acc1_s
    b2.vel.x = b2.vel.x - diff.x * acc2_s
    b2.vel.y = b2.vel.y - diff.y * acc2_s
    b2.vel.z = b2.vel.z - diff.z * acc2_s
}

// Integrate position from velocity
fn integrate(b: ref Body, dt: float): void {
    b.pos.x = b.pos.x + b.vel.x * dt
    b.pos.y = b.pos.y + b.vel.y * dt
    b.pos.z = b.pos.z + b.vel.z * dt
}

// Kinetic energy: 0.5 * m * v^2
fn kinetic_energy(b: in Body): float {
    let v2 = vec3_length_sq(b.vel)
    return 0.5 * b.mass * v2
}

// --- Test ---

// Two bodies: one at origin, one at x=10
let b1 = Body{
    pos: Vec3{x: 0.0, y: 0.0, z: 0.0},
    vel: Vec3{x: 0.0, y: 0.0, z: 0.0},
    mass: 100.0
}
let b2 = Body{
    pos: Vec3{x: 10.0, y: 0.0, z: 0.0},
    vel: Vec3{x: 0.0, y: 0.0, z: 0.0},
    mass: 1.0
}

// Initial state
print(b1.pos.x)  // 0
print(b2.pos.x)  // 10

// Simulate: bodies should attract each other
let dt = 0.1
compute_forces(b1, b2, dt)

// b1 should barely move (heavy), b2 should move toward b1
print(b1.vel.x > 0.0)   // true (attracted toward b2)
print(b2.vel.x < 0.0)   // true (attracted toward b1)

// b2 velocity should be ~100x b1 velocity (mass ratio)
let ratio = b2.vel.x / b1.vel.x
print(ratio)  // approximately -100

integrate(b1, dt)
integrate(b2, dt)

// b2 moved more than b1
print(b2.pos.x < 10.0)  // true (moved toward b1)
print(b1.pos.x > 0.0)   // true (moved toward b2, barely)

// Energy should be positive (both have kinetic energy now)
let ke = kinetic_energy(b1) + kinetic_energy(b2)
print(ke > 0.0)  // true

// Verify struct sizes
print(Reflect.fieldCount(b1))  // 3 (pos, vel, mass)
