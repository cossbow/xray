// AOT basic test: try/catch exception handling (same-function)
fn safe_double(x: int): int {
    try {
        if (x < 0) {
            throw "negative"
        }
        return x * 2
    } catch (e) {
        return -1
    }
}

print(safe_double(5))    // 10
print(safe_double(-3))   // -1
print(safe_double(0))    // 0
