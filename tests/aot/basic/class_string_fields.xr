// AOT test: class instances with string and mixed-type fields.
// Verifies that tagged (16-byte XrValue) field store/load round-trips
// correctly for non-numeric types (strings, objects).

class Animal {
    name: string
    constructor(name: string) {
        this.name = name
    }
    speak(): string {
        return "Animal: " + this.name
    }
}

class Dog extends Animal {
    breed: string
    constructor(name: string, breed: string) {
        super(name)
        this.breed = breed
    }
    speak(): string {
        return "Dog: " + this.name + " (" + this.breed + ")"
    }
    parent_speak(): string {
        return super.speak()
    }
}

// Test basic string field access
let a = Animal("Buddy")
print(a.name)
print(a.speak())

// Test inherited + own string fields
let d = Dog("Rex", "Labrador")
print(d.name)
print(d.breed)
print(d.speak())
print(d.parent_speak())

// Test class with mixed int + string fields
class Person {
    name: string
    age: int
    constructor(name: string, age: int) {
        this.name = name
        this.age = age
    }
    greet(): string {
        return this.name + " is " + this.age
    }
}

let p = Person("Alice", 30)
print(p.name)
print(p.age)
print(p.greet())
