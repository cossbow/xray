// AOT test: collection methods (B.5)

// --- String methods ---
let s = "  Hello World  "
print(s.trim())           // Hello World
print("hello".toUpperCase())  // HELLO
print("HELLO".toLowerCase())  // hello

// split
let parts = "a,b,c".split(",")
print(parts.length)       // 3
print(parts[0])           // a
print(parts[1])           // b
print(parts[2])           // c

// replace
print("hello world".replace("world", "xray"))  // hello xray

// repeat
print("ab".repeat(3))    // ababab

// indexOf
print("hello".indexOf("ll"))  // 2
print("hello".indexOf("zz"))  // -1

// includes, startsWith, endsWith
print("hello".includes("ell"))     // true
print("hello".startsWith("he"))    // true
print("hello".endsWith("lo"))      // true

// slice
print("hello".slice(1, 3))  // el
print("hello".slice(2))     // llo

// --- Array methods ---
let arr = [10, 20, 30, 40, 50]

// indexOf
print(arr.indexOf(30))    // 2
print(arr.indexOf(99))    // -1

// includes
print(arr.includes(20))   // true
print(arr.includes(99))   // false

// slice
let sub = arr.slice(1, 3)
print(sub.length)         // 2
print(sub[0])             // 20
print(sub[1])             // 30

// join
print([1, 2, 3].join(", "))  // 1, 2, 3

// reverse
let rev = [1, 2, 3]
rev.reverse()
print(rev[0])             // 3
print(rev[1])             // 2
print(rev[2])             // 1

// --- Map methods ---
let m = #{"a": 1, "b": 2, "c": 3}
let keys = m.keys()
print(keys.length)        // 3

let vals = m.values()
print(vals.length)        // 3

// has / get / delete
print(m.has("b"))         // true
print(m.get("a"))         // 1
m.delete("b")
print(m.has("b"))         // false
