// AOT test: collection operations (map, filter, typed arrays)
let nums = [10, 20, 30, 40, 50, 60]

// Length
print(nums.length)

// Typed array access
print(nums[0])
print(nums[2])
print(nums[4])

// Push
nums.push(70)
print(nums.length)

// Map: double each element
let doubled = nums.map(fn(x: int) -> int { return x * 2 })
print(doubled.length)
print(doubled[0])
print(doubled[3])

// Filter: keep elements > 30
let big = nums.filter(fn(x: int) -> bool { return x > 30 })
print(big.length)
print(big[0])
print(big[2])
