// AOT test: match expression support.
// Match is compiled to standard control flow (if/else chains),
// so AOT handles it via existing branch codegen.

fn describe(x: int) -> string {
    return match (x) {
        1 -> "one"
        2 -> "two"
        3 -> "three"
        _ -> "other"
    }
}

fn grade(score: int) -> string {
    return match (score) {
        90..100 -> "A"
        80..89  -> "B"
        70..79  -> "C"
        _       -> "F"
    }
}

// Basic value matching
print(describe(1))
print(describe(2))
print(describe(3))
print(describe(99))

// Range matching
print(grade(95))
print(grade(85))
print(grade(75))
print(grade(50))
