/*
 * ws_echo_test.xr - WebSocket echo test
 */

import ws

print("=== WebSocket Echo Test ===")

const TEST_URL = "wss://ws.postman-echo.com/raw"

print("Connecting to: " + TEST_URL)
let conn = ws.connect(TEST_URL, null)

if (conn.error) {
    print("Connection error: " + conn.error)
} else {
    print("Connected!")
    print("State: " + ws.state(conn))
    
    // Send message
    print("Sending message...")
    let sent = ws.send(conn, "Hello WebSocket!", null)
    if (sent) {
        print("Message sent!")
    } else {
        print("Send failed")
    }
    
    // Receive echo
    print("Waiting for echo...")
    let msg = ws.recv(conn, null)
    if (msg == null) {
        print("recv returned null")
    } else if (msg.error) {
        print("Recv error: " + msg.error)
    } else if (msg.data) {
        print("Received: " + msg.data)
    } else {
        print("No data in message")
    }
    
    // Close
    print("Closing...")
    ws.close(conn, null, null)
    print("Closed!")
}

print("Test complete!")
