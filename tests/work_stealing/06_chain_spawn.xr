/*
** 06_chain_spawn.xr - 链式创建测试
** 作者：xingleixu@gmail.com
**
** 测试目的：验证协程内创建协程的工作窃取
** 测试方法：协程 A 创建协程 B，B 创建 C...形成链式创建
*/
import time
print("========== 测试6：链式创建测试 ==========")
/* 测试参数 */
const CHAIN_DEPTH = 10
const BRANCHES_PER_LEVEL = 3

/* 递归创建协程 */
fn spawn_chain(level, id) {
    if (level >= CHAIN_DEPTH) {
        /* 叶子节点：做一些计算 */
        let sum = 0
        for (let i = 0; i < 100; i++) {
            sum = sum + i
        }
        return { "level": level, "id": id, "children": 0, "sum": sum }
    }
    /* 非叶子节点：创建子协程 */
    let children = []
    for (let i = 0; i < BRANCHES_PER_LEVEL; i++) {
        let child_id = id * BRANCHES_PER_LEVEL + i
        let task = go spawn_chain(level + 1, child_id)
        children.push(task)
    }
    /* 等待所有子协程 */
    let child_sum = 0
    for (let i = 0; i < children.length; i++) {
        await children[i]
        child_sum = child_sum + children[i].result.sum
    }
    return { "level": level, "id": id, "children": children.length, "sum": child_sum }
}

/* 启动根协程 */
print("启动链式创建（深度=" + string(CHAIN_DEPTH) + ", 分支=" + string(BRANCHES_PER_LEVEL) + "）...")
let start_time = time.monotonic()
let root_task = go spawn_chain(0, 0)
await root_task
let total_time = time.monotonic() - start_time
let result = root_task.result
print("
结果:")
print("  根节点 level: " + string(result.level))
print("  总计算 sum: " + string(result.sum))
print("  耗时: " + string(total_time) + " ms")

/* 计算预期的协程总数 */
fn power(base, exp) {
    let result = 1
    for (let i = 0; i < exp; i++) {
        result = result * base
    }
    return result
}

let expected_coros = 0
for (let i = 0; i <= CHAIN_DEPTH; i++) {
    expected_coros = expected_coros + power(BRANCHES_PER_LEVEL, i)
}
print("  预期协程总数: " + string(expected_coros))
/* 验证 */
if (result.sum > 0) {
    print("
✓ 链式创建测试通过：所有层级协程都执行了")
} else {
    print("
✗ 测试失败")
    throw "链式创建测试失败"
}
print("========== 测试6 完成 ==========")
