// 测试10：死锁场景与检测
// 作者：xingleixu@gmail.com
// 
// 验证：各种死锁场景的处理
// - 循环等待：A等B，B等A
// - Channel 死锁：无缓冲 Channel 无人接收
// - 资源饥饿：多协程竞争有限资源
// - 死锁预防：超时机制
print("========== 测试10：死锁场景与检测 ==========")

// 测试1：使用超时接收避免永久阻塞
fn test_channel_timeout_prevention() {
    let ch = Channel()
    // 无缓冲 Channel
    // 测试超时接收（无发送者）
    let received = ch.recvTimeout(100)
    // 100ms 超时
    // 接收应该返回 null（超时，因为没有发送者）
    print("接收结果（应为 null）:", received)
    assert_eq(received, null)
    print("✓ Channel 超时预防死锁测试通过")
}

// 测试2：使用 tryRecv/trySend 避免阻塞
fn test_non_blocking_operations() {
    let ch = Channel(1)
    // 非阻塞发送
    let sent1 = ch.trySend(1)
    let sent2 = ch.trySend(2)
    // 应该失败，缓冲区满
    print("第一次发送:", sent1)
    print("第二次发送:", sent2)
    assert_eq(sent1, true)
    assert_eq(sent2, false)
    // 非阻塞接收
    let val1 = ch.tryRecv()
    let val2 = ch.tryRecv()
    // 应该返回 null
    print("第一次接收:", val1)
    print("第二次接收:", val2)
    assert_eq(val1, 1)
    assert_eq(val2, null)
    print("✓ 非阻塞操作测试通过")
}

// 测试3：多生产者竞争有限缓冲区
fn test_producer_competition() {
    let ch = Channel(5)
    // 只有 5 个槽位
    let results = Channel(10)
    fn producer(id) {
        let sent_count = 0
        for (let i = 0; i < 10; i++) {
            // 使用超时发送，避免死锁
            let sent = ch.sendTimeout({ "id" => id, "seq" => i }, 50)
            if (sent) {
                sent_count = sent_count + 1
            }
        }
        results.send({ "producer" => id, "sent" => sent_count })
        return sent_count
    }
    // 启动多个生产者，但不启动消费者
    let p1 = go producer(1)
    let p2 = go producer(2)
    let p3 = go producer(3)
    let r1 = await p1
    let r2 = await p2
    let r3 = await p3
    // 统计发送成功的消息
    let total_sent = r1 + r2 + r3
    print("总发送成功数:", total_sent)
    // 应该最多发送 5 条（缓冲区大小）
    assert(total_sent >= 5)
    assert(total_sent <= 15)
    // 不可能超过总发送数
    print("✓ 多生产者竞争测试通过")
}

// 测试4：消费者-生产者平衡
fn test_balanced_producer_consumer() {
    let ch = Channel(3)
    let done = Channel(1)
    fn producer() {
        for (let i = 0; i < 20; i++) {
            ch.send(i)
        }
        return "producer done"
    }
    fn consumer() {
        let count = 0
        for (let i = 0; i < 20; i++) {
            let val = ch.recv()
            count = count + 1
        }
        done.send(count)
        return count
    }
    let p = go producer()
    let c = go consumer()
    await [p, c]
    let consumed = done.recv()
    print("消费数量:", consumed)
    assert_eq(consumed, 20)
    print("✓ 生产者-消费者平衡测试通过")
}

// 测试5：模拟资源锁（使用 Channel 作为信号量）
fn test_semaphore_pattern() {
    // 用 Channel 实现信号量（最多 2 个并发）
    let sem = Channel(2)
    sem.send(1)
    sem.send(1)
    // 初始化 2 个令牌
    let results = Channel(10)
    let active_count = Channel(1)
    active_count.send(0)
    // 当前活跃数
    fn worker(id) {
        // 获取令牌
        let token = sem.recv()
        // 模拟工作
        let sum = 0
        for (let i = 0; i < 1000; i++) {
            sum = sum + i
        }
        results.send({ "id" => id, "result" => sum })
        // 释放令牌
        sem.send(token)
        return sum
    }
    // 启动 5 个 worker，但只有 2 个能同时运行
    let w1 = go worker(1)
    let w2 = go worker(2)
    let w3 = go worker(3)
    let w4 = go worker(4)
    let w5 = go worker(5)
    await [w1, w2, w3, w4, w5]
    // 所有 worker 应该都完成
    let completed = 0
    for (let i = 0; i < 5; i++) {
        let r = results.tryRecv()
        if (r != null) {
            completed = completed + 1
        }
    }
    print("完成的 worker 数:", completed)
    assert_eq(completed, 5)
    print("✓ 信号量模式测试通过")
}

// 测试6：检测潜在死锁模式（通过超时）
fn test_deadlock_pattern_detection() {
    let ch1 = Channel()
    let ch2 = Channel()
    // 可能导致死锁的模式：两个协程互相等待
    fn task_a() {
        // 先发 ch1，再收 ch2（但使用超时）
        let sent = ch1.sendTimeout(1, 100)
        if (!sent) {
            return "a_timeout_send"
        }
        let val = ch2.recvTimeout(100)
        if (val == null) {
            return "a_timeout_recv"
        }
        return "a_ok"
    }
    fn task_b() {
        // 先发 ch2，再收 ch1（但使用超时）
        let sent = ch2.sendTimeout(2, 100)
        if (!sent) {
            return "b_timeout_send"
        }
        let val = ch1.recvTimeout(100)
        if (val == null) {
            return "b_timeout_recv"
        }
        return "b_ok"
    }
    let a = go task_a()
    let b = go task_b()
    let ra = await a
    let rb = await b
    print("Task A 结果:", ra)
    print("Task B 结果:", rb)
    // 由于超时机制，不会真正死锁
    // 结果可能是各种超时组合
    assert(ra != null)
    assert(rb != null)
    print("✓ 死锁模式检测测试通过")
}

// 测试7：正确的双向通信模式
fn test_bidirectional_communication() {
    let request = Channel(1)
    let response = Channel(1)
    fn server() {
        let req = request.recv()
        let resp = req * 2
        response.send(resp)
        return "server done"
    }
    fn client() {
        request.send(21)
        let resp = response.recv()
        return resp
    }
    let s = go server()
    let c = go client()
    await s
    let result = await c
    print("客户端收到响应:", result)
    assert_eq(result, 42)
    print("✓ 双向通信测试通过")
}

// 运行所有测试
test_channel_timeout_prevention()
test_non_blocking_operations()
test_producer_competition()
test_balanced_producer_consumer()
test_semaphore_pattern()
test_deadlock_pattern_detection()
test_bidirectional_communication()
print("
🎉 测试10全部通过：死锁场景处理正确！")
