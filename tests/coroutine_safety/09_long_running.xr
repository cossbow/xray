// 测试9：长时间运行与抢占调度
// 作者：xingleixu@gmail.com
// 
// 验证：调度器对长时间运行协程的处理能力
// - 抢占式调度：长时间运行的协程不会饿死其他协程
// - 取消机制：可以取消正在运行的协程
// - 超时保护：await 超时机制
print("========== 测试9：长时间运行与抢占调度 ==========")

// 测试1：CPU 密集型协程不会饿死其他协程
fn test_cpu_intensive_fairness() {
    let results = new Channel(10)
    // CPU 密集型任务（计算）
    fn cpu_heavy(id) {
        let sum = 0
        for (let i = 0; i < 10000; i++) {
            sum = sum + i
        }
        results.send({ "id" => id, "sum" => sum })
        return sum
    }
    // 轻量级任务
    fn light_task(id) {
        results.send({ "id" => id, "type" => "light" })
        return id
    }
    // 同时启动 CPU 密集型和轻量级任务
    let heavy1 = go cpu_heavy(1)
    let light1 = go light_task(101)
    let heavy2 = go cpu_heavy(2)
    let light2 = go light_task(102)
    // 等待所有任务完成
    await all [heavy1, heavy2, light1, light2]
    // 验证所有任务都完成了
    let completed = []
    for (let i = 0; i < 4; i++) {
        let r = results.tryRecv()
        if (r != null) {
            completed.push(r)
        }
    }
    print("完成的任务数:", completed.length)
    assert_eq(completed.length, 4)
    print("✓ CPU 密集型公平调度测试通过")
}

// 测试2：协程取消机制
fn test_cancel_running_coro() {
    let started = new Channel(1)
    // 长时间运行的任务，检查取消状态
    fn long_task() {
        started.send(true)
        let count = 0
        while (count < 100000) {
            count = count + 1
            // 每隔一段时间检查是否被取消
            if (count % 1000 == 0) {
                if (cancelled()) {
                    return "cancelled"
                }
            }
        }
        return "completed"
    }
    let task = go long_task()
    // 等待任务启动（使用超时避免阻塞）
    let signal = started.recvTimeout(1000)
    // 取消任务
    task.cancel()
    // 等待任务结束（可能完成也可能取消）
    await task
    print("任务已取消:", task.cancelled)
    // 取消后 task.cancelled 应该为 true
    assert(task.cancelled)
    print("✓ 协程取消测试通过")
}

// 测试3：多个长时间运行协程的公平调度
fn test_multiple_long_running() {
    let completions = new Channel(10)
    fn work(id, iterations) {
        let sum = 0
        for (let i = 0; i < iterations; i++) {
            sum = sum + i
        }
        completions.send(id)
        return sum
    }
    // 启动多个不同工作量的协程
    let t1 = go work(1, 1000)
    let t2 = go work(2, 5000)
    let t3 = go work(3, 2000)
    let t4 = go work(4, 3000)
    let t5 = go work(5, 1000)
    await all [t1, t2, t3, t4, t5]
    // 收集完成顺序
    let order = []
    for (let i = 0; i < 5; i++) {
        let id = completions.tryRecv()
        if (id != null) {
            order.push(id)
        }
    }
    print("完成顺序:", order)
    assert_eq(order.length, 5)
    print("✓ 多协程公平调度测试通过")
}

// 测试4：协程让出控制权
fn test_yield_behavior() {
    let log = new Channel(20)
    // 协作式让出的任务
    fn cooperative_task(id) {
        for (let i = 0; i < 5; i++) {
            log.send({ "id" => id, "step" => i })
        }
        return id
    }
    let t1 = go cooperative_task(1)
    let t2 = go cooperative_task(2)
    await all [t1, t2]
    // 验证两个任务的步骤交替执行
    let entries = []
    for (let i = 0; i < 10; i++) {
        let entry = log.tryRecv()
        if (entry != null) {
            entries.push(entry)
        }
    }
    print("日志条目数:", entries.length)
    assert_eq(entries.length, 10)
    print("✓ 协程让出测试通过")
}

// 测试5：嵌套循环的协程
fn test_nested_loops() {
    fn nested_work() {
        let total = 0
        for (let i = 0; i < 100; i++) {
            for (let j = 0; j < 100; j++) {
                total = total + i * j
            }
        }
        return total
    }
    let t1 = go nested_work()
    let t2 = go nested_work()
    let t3 = go nested_work()
    let r1 = await t1
    let r2 = await t2
    let r3 = await t3
    // 所有结果应该相同
    assert_eq(r1, r2)
    assert_eq(r2, r3)
    print("嵌套循环结果:", r1)
    print("✓ 嵌套循环协程测试通过")
}

// 运行所有测试
test_cpu_intensive_fairness()
test_cancel_running_coro()
test_multiple_long_running()
test_yield_behavior()
test_nested_loops()
print("
🎉 测试9全部通过：长时间运行与抢占调度正确！")
