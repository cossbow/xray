// 0100_int_basic.xr
// 作者：xingleixu@gmail.com
// 测试：整数字面量基础
// ===== 正常路径 =====
@test
fn test_positive_integers(): void {
    assert_eq(1, 1)
    assert_eq(42, 42)
    assert_eq(100, 100)
    assert_eq(999999, 999999)
}

@test
fn test_zero(): void {
    assert_eq(0, 0)
    let x = 0
    assert_eq(x, 0)
}

@test
fn test_negative_integers(): void {
    assert_eq(-1, -1)
    assert_eq(-42, -42)
    assert_eq(-999999, -999999)
}

// ===== 多进制 =====
@test
fn test_hexadecimal(): void {
    assert_eq(255, 255)
    assert_eq(16, 16)
    assert_eq(43981, 43981)
    assert_eq(0, 0)
}

@test
fn test_binary(): void {
    assert_eq(10, 10)
    assert_eq(15, 15)
    assert_eq(0, 0)
    assert_eq(255, 255)
}

@test
fn test_octal(): void {
    assert_eq(511, 511)
    assert_eq(8, 8)
    assert_eq(0, 0)
}

// ===== 下划线分隔符 =====
@test
fn test_underscore_separator(): void {
    assert_eq(1000000, 1000000)
    assert_eq(123, 123)
    assert_eq(65535, 65535)
    assert_eq(240, 240)
}

// ===== 边界条件 =====
@test
fn test_single_digit(): void {
    for (i in 0..10) {
        assert_eq(i >= 0, true)
        assert_eq(i < 10, true)
    }
}

@test
fn test_large_numbers(): void {
    let billion = 1000000000
    assert_eq(billion, 1000000000)
    // Test max 48-bit signed integer (NaN Boxing limit)
    let max_int = 140737488355327
    assert_eq(max_int > 0, true)
    // For larger numbers, use BigInt
    let large = 9223372036854775807n
    // INT64_MAX as BigInt
    assert_eq(large > 0n, true)
}
