// Test: generic class/struct `is` checks and Reflect.typeOf
// Covers: instanceof with generic_origin, struct generics, rep-sharing correctness

class Box<T> {
    value: T
    constructor(v: T) {
        this.value = v
    }
}

struct Pair<A, B> {
    first: A
    second: B
}

class Wrapper<T> {
    value: T
    constructor(v: T) {
        this.value = v
    }
}

@test
fn test_generic_instanceof() {
    // T1: instanceof with generic — generic_origin check
    let b = new Box<int>(42)
    assert(b is Box)

    let bs = new Box<string>("hello")
    assert(bs is Box)

    // Non-Box should fail
    let w = new Wrapper<int>(1)
    assert(!(w is Box))
    assert(w is Wrapper)
}

@test
fn test_generic_typeof() {
    // T2: Reflect.typeOf for generic class
    let b = new Box<int>(42)
    assert_eq(Reflect.typeOf(b), "Box<int>")

    let bs = new Box<string>("hello")
    assert_eq(Reflect.typeOf(bs), "Box<string>")

    // T7: Multiple type parameters
    let p = Pair<int, string>{first: 1, second: "x"}
    assert_eq(Reflect.typeOf(p), "Pair<int, string>")

    // T8: Non-generic instance
    let plain = new Box(99)
    assert_eq(Reflect.typeOf(plain), "Box")
}

@test
fn test_struct_generic_is_typeof() {
    // T9: Struct generic `is` + Reflect.typeOf
    let p1 = Pair<int, string>{first: 1, second: "x"}
    assert(p1 is Pair)
    assert_eq(Reflect.typeOf(p1), "Pair<int, string>")

    let p2 = Pair<float, bool>{first: 3.14, second: true}
    assert(p2 is Pair)
    assert_eq(Reflect.typeOf(p2), "Pair<float, bool>")

    // Non-struct should not match
    let b = new Box<int>(1)
    assert(!(b is Pair))
}

@test
fn test_rep_sharing_correctness() {
    // T10: Rep-sharing must not merge distinct reference-type instantiations
    // Wrapper<string> and Wrapper<Array> have the same slot layout (both PTR)
    // but must remain distinct classes with correct type info
    let ws = new Wrapper<string>("hello")
    let wi = new Wrapper<int>(42)

    assert_eq(Reflect.typeOf(ws), "Wrapper<string>")
    assert_eq(Reflect.typeOf(wi), "Wrapper<int>")

    // Both should be Wrapper via generic_origin
    assert(ws is Wrapper)
    assert(wi is Wrapper)

    // Different instantiations must not be confused
    let b = new Box<int>(1)
    assert(!(b is Wrapper))
    assert(!(ws is Box))
}
