// Test generic function type inference
// Basic identity function
fn identity<T>(x: T): T {
    return x
}

// Test basic type inference
let n = identity(42)
print(n)
// Should be 42
print(n + 1)
// Should be 43 (proves n is int)
let s = identity("hello")
print(s)
// Should be "hello"
print(s.length)

// Should be 5 (proves s is string)
// Generic function with array
fn first<T>(arr: Array<T>): T? {
    if (arr.length > 0) {
        return arr[0]
    }
    return null
}

let nums = [1, 2, 3]
let f = first(nums)
print(f)
// Should be 1
let strs = ["a", "b", "c"]
let fs = first(strs)
print(fs)

// Should be "a"
// Generic function with multiple params
fn pair<T, U>(a: T, b: U): (T, U) {
    return a, b
}

let pa, pb = pair(1, "two")
print(pa, pb)
// Should be 1 two
print("Generic inference test completed")
