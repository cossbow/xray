// 1204_class_type.xr
// Test class type inference
import math

// ===== Basic Class Type =====
class Point {
    x: int
    y: int

    constructor(x: int, y: int) {
        this.x = x
        this.y = y
    }

    distance() -> float {
        let sum = this.x * this.x + this.y * this.y
        return math.sqrt(float(sum))
    }

    toString() -> string {
        return "Point(" + string(this.x) + ", " + string(this.y) + ")"
    }
}

@test
fn test_class_instance_type() {
    let p = Point(3, 4)
    assert_eq(typeof(p), "Point")
}

@test
fn test_class_field_access() {
    let p = Point(3, 4)
    assert_eq(p.x, 3)
    assert_eq(p.y, 4)
}

@test
fn test_class_method_call() {
    let p = Point(3, 4)
    let d = p.distance()
    assert_eq(typeof(d), "float")
    assert(d > 4.9 && d < 5.1)
}

@test
fn test_class_method_return_type() {
    let p = Point(0, 0)
    let s = p.toString()
    assert_eq(typeof(s), "string")
    assert_eq(s, "Point(0, 0)")
}

// ===== Class Inheritance =====
class Animal {
    name: string

    constructor(name: string) {
        this.name = name
    }

    speak() -> string {
        return this.name + " makes a sound"
    }
}

class Dog extends Animal {
    breed: string

    constructor(name: string, breed: string) {
        super(name)
        this.breed = breed
    }

    speak() -> string {
        return this.name + " barks"
    }

    fetch() -> string {
        return this.name + " fetches the ball"
    }
}

@test
fn test_inheritance_type() {
    let d = Dog("Rex", "Labrador")
    assert_eq(typeof(d), "Dog")
}

@test
fn test_inheritance_field() {
    let d = Dog("Rex", "Labrador")
    assert_eq(d.name, "Rex")
    // Inherited field
    assert_eq(d.breed, "Labrador")
}

@test
fn test_inheritance_method() {
    let d = Dog("Rex", "Labrador")
    assert_eq(d.speak(), "Rex barks")
    // Overridden
    assert_eq(d.fetch(), "Rex fetches the ball")
}

@test
fn test_polymorphism() {
    let animals = [Animal("Generic"), Dog("Rex", "Lab")]
    assert_eq(animals[0].speak(), "Generic makes a sound")
    assert_eq(animals[1].speak(), "Rex barks")
}

// ===== Static Members =====
class Counter {
    static count: int = 0

    static increment() {
        Counter.count = Counter.count + 1
    }

    static getCount() -> int {
        return Counter.count
    }
}

@test
fn test_static_field() {
    Counter.count = 0
    // Reset
    assert_eq(Counter.count, 0)
    Counter.count = 5
    assert_eq(Counter.count, 5)
}

@test
fn test_static_method() {
    Counter.count = 0
    // Reset
    Counter.increment()
    Counter.increment()
    assert_eq(Counter.getCount(), 2)
}

// ===== Class with Generic-like Patterns =====
class Box {
    value: int

    constructor(value: int) {
        this.value = value
    }

    get() -> int {
        return this.value
    }

    set(value: int) {        this.value = value
    }
}

@test
fn test_box_int() {
    let b = Box(42)
    assert_eq(b.get(), 42)
}

@test
fn test_box_string() {
    let b = Box("hello")
    assert_eq(b.get(), "hello")
}

@test
fn test_box_mutation() {
    let b = Box(1)
    b.set(2)
    assert_eq(b.get(), 2)
}

// ===== is Operator =====
@test
fn test_is_operator_class() {
    let d = Dog("Rex", "Lab")
    assert(d is Dog)
    assert(d is Animal)
}

@test
fn test_is_operator_primitives() {
    let x = 42
    assert(x is int)
    let s = "hello"
    assert(s is string)
    let b = true
    assert(b is bool)
}

// ===== Multiple Classes =====
class Rectangle {
    width: int
    height: int

    constructor(w: int, h: int) {
        this.width = w
        this.height = h
    }

    area() -> int {
        return this.width * this.height
    }
}

class Circle {
    radius: float

    constructor(r: float) {
        this.radius = r
    }

    area() -> float {
        return 3.14159 * this.radius * this.radius
    }
}

@test
fn test_different_classes() {
    let rect = Rectangle(4, 5)
    let circ = Circle(3)
    assert_eq(typeof(rect), "Rectangle")
    assert_eq(typeof(circ), "Circle")
    assert_eq(rect.area(), 20)
    assert(circ.area() > 28 && circ.area() < 29)
}
