// 1231_type_alias.xr
// Test: Type alias functionality

// ===== Basic type alias =====

type Age = int
type Name = string

@test
fn test_basic_alias(): void {
    let a: Age = 25
    let n: Name = "Alice"
    assert_eq(a, 25)
    assert_eq(n, "Alice")
}

// ===== Struct type alias =====

type Point = { x: float, y: float }

@test
fn test_struct_alias(): void {
    let p: Point = { x: 1.0, y: 2.0 }
    assert_eq(p.x, 1.0)
    assert_eq(p.y, 2.0)
}

// ===== Function type alias =====

type Mapper = fn(int): int
type Predicate = fn(int): bool

@test
fn test_fn_type_alias(): void {
    fn apply(x: int, f: Mapper): int {
        return f(x)
    }
    
    let result = apply(5, (n) => n * 2)
    assert_eq(result, 10)
}

// ===== Container type alias =====

type StringList = Array<string>

@test
fn test_container_alias(): void {
    let names: StringList = ["Alice", "Bob", "Charlie"]
    assert_eq(names.length, 3)
    assert_eq(names[0], "Alice")
}

// ===== Optional type alias =====

type MaybeInt = int?

@test
fn test_optional_alias(): void {
    let x: MaybeInt = 42
    let y: MaybeInt = null
    assert_eq(x, 42)
    assert_eq(y, null)
}

// ===== Nested type alias =====

type Callback = fn(int): int

@test
fn test_nested_alias(): void {
    fn applyTwice(x: int, f: Callback): int {
        return f(f(x))
    }
    
    assert_eq(applyTwice(3, (n) => n * 2), 12)
}

// ===== Type alias in return type =====

@test
fn test_alias_in_return(): void {
    fn getAge(): Age {
        return 30
    }
    assert_eq(getAge(), 30)
}

// ===== Type alias with void function =====

type Action = fn(int): void

@test
fn test_void_fn_alias(): void {
    let sum = 0
    
    fn forEach(arr: Array<int>, f: Action): void {
        for (item in arr) {
            f(item)
        }
    }
    
    forEach([1, 2, 3], (x) => {
        sum = sum + x
    })
    assert_eq(sum, 6)
}