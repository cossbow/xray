// 1232_generic_multi_constraint.xr
// Multi-constraint generics: <T: A & B & C> intersection-style constraints.
// All constraints in the intersection must be satisfied for a type to be a
// valid type argument.
//
// REGRESSION: Bug #2 - dangling builtin-interface XrType* across
//             isolates (commit 1f39808, second hunk).
// FAIL_AT:    pre-1f39808 on MSVC Debug, second .xr file onwards
//             -> builtin_interfaces[].type is a process-wide static
//                cache holding XrType* allocated from the *current*
//                isolate's type pool. The g_interfaces_initialized
//                guard prevented re-initialisation in later isolates,
//                so after the first isolate's pool was freed every
//                subsequent isolate's constraint check read freed
//                memory. MSVC Debug 0xDD fill made the corruption
//                visible (`unknown` / `int?` printouts); macOS / Linux
//                often left the freed arena memory readable long
//                enough to silently succeed.
// PASS_AT:    1f39808+ on all platforms
//             -> xa_register_builtin_interfaces unconditionally
//                rebuilds the cache in the caller's isolate, so the
//                pointers always live in the current type pool.
// Triggering shape: any .xr file using a builtin interface as a
// generic constraint (Comparable / Hashable below). Because xray test
// gives each .xr file its own isolate, this single file already
// stresses the second-isolate path — the regression is only fully
// covered when at least one earlier file has populated the cache
// in the process (true for the entire regression suite under
// `scripts/run_regression_tests.sh`).

// ===== Single constraint (regression) =====
@test
fn test_single_constraint_int() {
    fn first<T: Comparable>(a: T, b: T) -> T {
        return a
    }
    assert_eq(first(1, 2), 1)
}

@test
fn test_single_constraint_string() {
    fn first<T: Comparable>(a: T, b: T) -> T {
        return a
    }
    assert_eq(first("alpha", "beta"), "alpha")
}

// ===== Two constraints =====
@test
fn test_two_constraints_int() {
    fn passThrough<T: Comparable & Hashable>(x: T) -> T {
        return x
    }
    assert_eq(passThrough(42), 42)
}

@test
fn test_two_constraints_string() {
    fn passThrough<T: Comparable & Hashable>(x: T) -> T {
        return x
    }
    assert_eq(passThrough("hello"), "hello")
}

@test
fn test_two_constraints_float() {
    fn passThrough<T: Comparable & Hashable>(x: T) -> T {
        return x
    }
    let f = passThrough(3.14)
    assert(f > 3.0 && f < 4.0)
}

// ===== Three constraints =====
@test
fn test_three_constraints() {
    fn passThrough<T: Comparable & Hashable & Stringable>(x: T) -> T {
        return x
    }
    assert_eq(passThrough(7), 7)
    assert_eq(passThrough("ok"), "ok")
}

// ===== Mixed constraints across multiple type parameters =====
@test
fn test_mixed_param_constraints() {
    fn pickValue<K: Hashable, V>(k: K, v: V) -> V {
        return v
    }
    assert_eq(pickValue(1, "one"), "one")
    assert_eq(pickValue("key", 42), 42)
}

// ===== No constraint still works =====
@test
fn test_unconstrained_after_constrained() {
    fn id<T>(x: T) -> T {
        return x
    }
    fn ord<T: Comparable>(x: T) -> T {
        return x
    }
    assert_eq(id(ord(5)), 5)
}

// ===== Explicit type arguments =====
@test
fn test_explicit_type_args_multi_constraint() {
    fn passThrough<T: Comparable & Hashable>(x: T) -> T {
        return x
    }
    assert_eq(passThrough<int>(11), 11)
    assert_eq(passThrough<string>("xy"), "xy")
}

print("All multi-constraint generic tests passed!")
