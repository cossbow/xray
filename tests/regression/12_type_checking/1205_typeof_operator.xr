// 1205_typeof_operator.xr
// Test typeof operator and runtime type checking

// ===== Primitive Types =====

@test
fn test_typeof_int(): void {
    let x = 42
    assert_eq(typeof(x), Type.int)
}

@test
fn test_typeof_float(): void {
    let x = 3.14
    assert_eq(typeof(x), Type.float)
}

@test
fn test_typeof_string(): void {
    let x = "hello"
    assert_eq(typeof(x), Type.string)
}

@test
fn test_typeof_bool(): void {
    assert_eq(typeof(true), Type.bool)
    assert_eq(typeof(false), Type.bool)
}

@test
fn test_typeof_null(): void {
    let x = null
    assert_eq(typeof(x), Type.null)
}

// ===== Container Types =====

@test
fn test_typeof_array(): void {
    let arr = [1, 2, 3]
    assert_eq(typeof(arr), Type.Array)
}

@test
fn test_typeof_map(): void {
    let m = {"a" => 1}
    assert_eq(typeof(m), Type.Map)
}

@test
fn test_typeof_set(): void {
    let s = #[1, 2, 3]
    assert_eq(typeof(s), Type.Set)
}

// ===== Function Types =====

@test
fn test_typeof_function(): void {
    fn add(a: int, b: int): int { return a + b }
    assert_eq(typeof(add), Type.function)
}

@test
fn test_typeof_arrow(): void {
    let f = (x: int) => x * 2
    assert_eq(typeof(f), Type.function)
}

@test
fn test_typeof_closure(): void {
    let x = 10
    let f = () => x
    assert_eq(typeof(f), Type.function)
}

// ===== Class Types =====

class Person {
    name: string
    constructor(name: string) {
        this.name = name
    }
}

class Student extends Person {
    grade: int
    constructor(name: string, grade: int) {
        super(name)
        this.grade = grade
    }
}

@test
fn test_typeof_class_instance(): void {
    let p = Person("Alice")
    assert_eq(typename(p), "Person")
}

@test
fn test_typeof_subclass_instance(): void {
    let s = Student("Bob", 10)
    assert_eq(typename(s), "Student")
}

// ===== Type Checking in Conditionals =====

@test
fn test_typeof_conditional(): void {
    fn describe<T>(x: T): string {
        if (typeof(x) == Type.int) {
            return "an integer"
        } else if (typeof(x) == Type.string) {
            return "a string"
        } else {
            return "something else"
        }
    }
    
    assert_eq(describe(42), "an integer")
    assert_eq(describe("hello"), "a string")
    assert_eq(describe([1,2,3]), "something else")
}

@test
fn test_typeof_switch(): void {
    fn typeLabel<T>(x: T): string {
        return match typeof(x) {
            Type.int => "integer",
            Type.float => "decimal",
            Type.string => "text",
            Type.bool => "boolean",
            Type.Array => "list",
            _ => "unknown"
        }
    }
    
    assert_eq(typeLabel(42), "integer")
    assert_eq(typeLabel(3.14), "decimal")
    assert_eq(typeLabel("hi"), "text")
    assert_eq(typeLabel(true), "boolean")
    assert_eq(typeLabel([1,2]), "list")
}

// ===== Dynamic Type Operations =====

@test
fn test_typeof_after_assignment(): void {
    let x = 42
    assert_eq(typeof(x), Type.int)
    
    // Variable can't change type in xray, but we can test with any
    let y: int = 42
    assert_eq(typeof(y), Type.int)
}

@test
fn test_typeof_expression_result(): void {
    assert_eq(typeof(1 + 2), Type.int)
    assert_eq(typeof(1.0 + 2.0), Type.float)
    assert_eq(typeof("a" + "b"), Type.string)
    assert_eq(typeof(1 < 2), Type.bool)
}

// ===== Special Cases =====

@test
fn test_typeof_empty_array(): void {
    let arr: Array<int> = []
    assert_eq(typeof(arr), Type.Array)
}

@test
fn test_typeof_empty_map(): void {
    let m = #{}
    assert_eq(typeof(m), Type.Map)
}

@test
fn test_typeof_empty_set(): void {
    let s = #[]
    assert_eq(typeof(s), Type.Set)
}

@test
fn test_typeof_bytes(): void {
    let b = Bytes(10)
    assert_eq(typeof(b), Type.Array)
}

@test
fn test_typeof_regex(): void {
    let r = /\d+/
    assert_eq(typeof(r), Type.Regex)
}

// ===== Json Type =====

@test
fn test_typeof_json_object(): void {
    let obj = { name: "Alice", age: 30 }
    assert_eq(typeof(obj), Type.Json)
}

@test
fn test_typeof_nested_json(): void {
    let obj = {
        user: {
            name: "Bob",
            scores: [90, 85, 95]
        }
    }
    assert_eq(typeof(obj), Type.Json)
    assert_eq(typeof(obj.user.scores), Type.Array)
}

