// 1230_function_type_annotation.xr
// Test: Function type annotation syntax fn(T): R

// ===== Basic function type parameter =====

@test
fn test_fn_type_basic() {
    fn apply(x: int, f: fn(int): int): int {
        return f(x)
    }
    
    let result = apply(5, (n) => n * 2)
    assert_eq(result, 10)
}

// ===== Function type with void return =====

@test
fn test_fn_type_void() {
    let count = 0
    
    fn forEach(arr: Array<int>, f: fn(int)) {
        for (item in arr) {
            f(item)
        }
    }
    
    forEach([1, 2, 3], (x) => {
        count = count + x
    })
    assert_eq(count, 6)
}

// ===== Function type with no parameters =====

@test
fn test_fn_type_no_params() {
    fn callIt(f: fn(): int): int {
        return f()
    }
    
    let result = callIt(() => 42)
    assert_eq(result, 42)
}

// ===== Function type with multiple parameters =====

@test
fn test_fn_type_multi_params() {
    fn combine(a: int, b: int, f: fn(int, int): int): int {
        return f(a, b)
    }
    
    assert_eq(combine(3, 4, (a, b) => a + b), 7)
    assert_eq(combine(3, 4, (a, b) => a * b), 12)
}

// ===== Function type with string return =====

@test
fn test_fn_type_string_return() {
    fn transform(x: int, f: fn(int): string): string {
        return f(x)
    }
    
    let result = transform(42, (n) => "value: " + string(n))
    assert_eq(result, "value: 42")
}

// ===== Higher-order: function returning function =====

@test
fn test_fn_type_higher_order() {
    fn makeAdder(n: int): fn(int): int {
        return (x) => x + n
    }
    
    let add5 = makeAdder(5)
    assert_eq(add5(10), 15)
    assert_eq(add5(0), 5)
}

// ===== Nested function types: fn(fn(int): int): int =====

@test
fn test_fn_type_nested() {
    fn applyTwice(x: int, f: fn(int): int): int {
        return f(f(x))
    }
    
    assert_eq(applyTwice(3, (n) => n * 2), 12)
    assert_eq(applyTwice(1, (n) => n + 10), 21)
}

// ===== Function type in variable declaration =====

@test
fn test_fn_type_variable() {
    let f: fn(int): int = (x) => x * 3
    assert_eq(f(5), 15)
}

// ===== Optional function type =====

@test
fn test_fn_type_optional() {
    fn maybeApply(x: int, f: fn(int): int): int {
        return f(x)
    }
    
    assert_eq(maybeApply(5, (n) => n + 1), 6)
}

// ===== Tuple type still works: (int, bool) =====

@test
fn test_tuple_type_unchanged() {
    fn divide(a: int, b: int): (int, bool) {
        if (b == 0) {
            return (0, false)
        }
        return (a / b, true)
    }
    
    let (result, ok) = divide(10, 3)
    assert_eq(result, 3)
    assert_eq(ok, true)
    
    let (result2, ok2) = divide(10, 0)
    assert_eq(result2, 0)
    assert_eq(ok2, false)
}
