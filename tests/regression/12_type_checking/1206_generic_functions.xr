// 1206_generic_functions.xr
// Comprehensive generic function tests
// ===== Basic Generic Functions =====
@test
fn test_identity_int() {
    fn identity<T>(x: T): T {
        return x
    }
    let n = identity(42)
    assert_eq(n, 42)
    assert_eq(n + 1, 43)
}

@test
fn test_identity_string() {
    fn identity<T>(x: T): T {
        return x
    }
    let s = identity("hello")
    assert_eq(s, "hello")
    assert_eq(s.length, 5)
}

@test
fn test_identity_float() {
    fn identity<T>(x: T): T {
        return x
    }
    let f = identity(3.14)
    assert(f > 3 && f < 4)
}

@test
fn test_identity_bool() {
    fn identity<T>(x: T): T {
        return x
    }
    assert_eq(identity(true), true)
    assert_eq(identity(false), false)
}

@test
fn test_identity_array() {
    fn identity<T>(x: T): T {
        return x
    }
    let arr = identity([1, 2, 3])
    assert_eq(arr.length, 3)
    assert_eq(arr[0], 1)
}

// ===== Multiple Type Parameters =====
@test
fn test_pair_creation() {
    fn makePair<T, U>(a: T, b: U): (T, U) {
        return a, b
    }
    let x, y = makePair(1, "one")
    assert_eq(x, 1)
    assert_eq(y, "one")
}

@test
fn test_swap_types() {
    fn swap<T, U>(a: T, b: U): (U, T) {
        return b, a
    }
    let x, y = swap("hello", 42)
    assert_eq(x, 42)
    assert_eq(y, "hello")
}

@test
fn test_triple_params() {
    fn triple<A, B, C>(a: A, b: B, c: C): (A, B, C) {
        return a, b, c
    }
    let x, y, z = triple(1, "two", true)
    assert_eq(x, 1)
    assert_eq(y, "two")
    assert_eq(z, true)
}

// ===== Generic Functions with Array Parameters =====
@test
fn test_array_first() {
    fn first<T>(arr: Array<T>): T? {
        if (arr.length > 0) {
            return arr[0]
        }
        return null
    }
    assert_eq(first([1, 2, 3]), 1)
    assert_eq(first(["a", "b"]), "a")
    assert_eq(first([]), null)
}

@test
fn test_array_last() {
    fn last<T>(arr: Array<T>): T? {
        if (arr.length > 0) {
            return arr[arr.length - 1]
        }
        return null
    }
    assert_eq(last([1, 2, 3]), 3)
    assert_eq(last(["x", "y", "z"]), "z")
    assert_eq(last([]), null)
}

@test
fn test_array_swap_elements() {
    fn swapElements<T>(arr: Array<T>, i: int, j: int) {
        let temp = arr[i]
        arr[i] = arr[j]
        arr[j] = temp
    }
    let nums = [1, 2, 3]
    swapElements(nums, 0, 2)
    assert_eq(nums[0], 3)
    assert_eq(nums[2], 1)
    let strs = ["a", "b", "c"]
    swapElements(strs, 0, 1)
    assert_eq(strs[0], "b")
    assert_eq(strs[1], "a")
}

@test
fn test_array_contains() {
    fn contains<T>(arr: Array<T>, target: T): bool {
        for (item in arr) {
            if (item == target) {
                return true
            }
        }
        return false
    }
    assert(contains([1, 2, 3], 2))
    assert(!contains([1, 2, 3], 5))
    assert(contains(["a", "b", "c"], "b"))
    assert(!contains(["a", "b", "c"], "z"))
}

@test
fn test_array_find_index() {
    fn findIndex<T>(arr: Array<T>, target: T): int {
        for (let i = 0; i < arr.length; i++) {
            if (arr[i] == target) {
                return i
            }
        }
        return -1
    }
    assert_eq(findIndex([10, 20, 30], 20), 1)
    assert_eq(findIndex([10, 20, 30], 50), -1)
    assert_eq(findIndex(["x", "y", "z"], "z"), 2)
}

// ===== Generic Functions with Return Types =====
@test
fn test_wrap_in_array() {
    fn wrap<T>(x: T): Array<T> {
        return [x]
    }
    let intArr = wrap(42)
    assert_eq(intArr.length, 1)
    assert_eq(intArr[0], 42)
    let strArr = wrap("hello")
    assert_eq(strArr.length, 1)
    assert_eq(strArr[0], "hello")
}

@test
fn test_repeat_value() {
    fn repeat<T>(x: T, n: int): Array<T> {
        let result: Array<T> = []
        for (let i = 0; i < n; i++) {
            result.push(x)
        }
        return result
    }
    let nums = repeat(1, 3)
    assert_eq(nums.length, 3)
    assert_eq(nums[0], 1)
    assert_eq(nums[2], 1)
    let strs = repeat("x", 2)
    assert_eq(strs.length, 2)
    assert_eq(strs[0], "x")
}

// ===== Generic Higher-Order Functions =====
@test
fn test_generic_apply() {
    fn apply<T, R>(x: T, f: fn(T): R): R {
        return f(x)
    }
    let doubled = apply(5, fn(n) {
        return n * 2
    })
    assert_eq(doubled, 10)
    let length = apply("hello", fn(s) {
        return s.length
    })
    assert_eq(length, 5)
}

@test
fn test_generic_transform() {
    fn transform<T>(arr: Array<T>, f: fn(T): T): Array<T> {
        let result: Array<T> = []
        for (item in arr) {
            result.push(f(item))
        }
        return result
    }
    let doubled = transform([1, 2, 3], fn(x) {
        return x * 2
    })
    assert_eq(doubled[0], 2)
    assert_eq(doubled[1], 4)
    assert_eq(doubled[2], 6)
}

// ===== Generic with Optional Return =====
@test
fn test_safe_get() {
    fn safeGet<T>(arr: Array<T>, index: int): T? {
        if (index >= 0 && index < arr.length) {
            return arr[index]
        }
        return null
    }
    assert_eq(safeGet([1, 2, 3], 1), 2)
    assert_eq(safeGet([1, 2, 3], 10), null)
    assert_eq(safeGet([1, 2, 3], -1), null)
}

@test
fn test_find_element() {
    fn find<T>(arr: Array<T>, predicate: fn(T): bool): T? {
        for (item in arr) {
            if (predicate(item)) {
                return item
            }
        }
        return null
    }
    let result: int? = find([1, 2, 3, 4, 5], fn(x) {
        return x > 3
    })
    assert_eq(result, 4)
    let notFound: int? = find([1, 2, 3], fn(x) {
        return x > 10
    })
    assert_eq(notFound, null)
}

// ===== Nested Generic Calls =====
@test
fn test_nested_generic_calls() {
    fn identity<T>(x: T): T {
        return x
    }
    fn wrap<T>(x: T): Array<T> {
        return [x]
    }
    // Nested calls: wrap(identity(value))
    let arr = wrap(identity(42))
    assert_eq(arr.length, 1)
    assert_eq(arr[0], 42)
}

@test
fn test_chained_generic_operations() {
    fn first<T>(arr: Array<T>): T? {
        if (arr.length > 0) {
            return arr[0]
        }
        return null
    }
    fn wrap<T>(x: T): Array<T> {
        return [x]
    }
    // Chain: first(wrap(value))
    let result = first(wrap("test"))
    assert_eq(result, "test")
}

// ===== Generic Functions with Complex Types =====
@test
fn test_generic_with_map() {
    fn getOrDefault<K, V>(m: Map<K, V>, key: K, defaultVal: V): V {
        if (m.has(key)) {
            return m.get(key)
        }
        return defaultVal
    }
    let m = { "a" => 1, "b" => 2 }
    assert_eq(getOrDefault(m, "a", 0), 1)
    assert_eq(getOrDefault(m, "z", -1), -1)
}

@test
fn test_generic_merge_arrays() {
    fn merge<T>(a: Array<T>, b: Array<T>): Array<T> {
        let result: Array<T> = []
        for (item in a) {
            result.push(item)
        }
        for (item in b) {
            result.push(item)
        }
        return result
    }
    let merged = merge([1, 2], [3, 4])
    assert_eq(merged.length, 4)
    assert_eq(merged[0], 1)
    assert_eq(merged[3], 4)
}

// ===== Type Inference Edge Cases =====
@test
fn test_infer_from_return_usage() {
    fn identity<T>(x: T): T {
        return x
    }
    // Type inferred from arithmetic operation
    let n = identity(10) + 5
    assert_eq(n, 15)
    // Type inferred from string operation
    let s = identity("hello") + " world"
    assert_eq(s, "hello world")
}

@test
fn test_infer_from_array_literal() {
    fn first<T>(arr: Array<T>): T? {
        if (arr.length > 0) {
            return arr[0]
        }
        return null
    }
    // Direct array literal as argument
    assert_eq(first([100, 200, 300]), 100)
    assert_eq(first(["one", "two"]), "one")
}

// ===== Generic Functions with Default Values =====
@test
fn test_generic_with_default() {
    fn valueOrDefault<T>(val: T?, defaultVal: T): T {
        if (val != null) {
            return val
        }
        return defaultVal
    }
    assert_eq(valueOrDefault(null, 42), 42)
    assert_eq(valueOrDefault(10, 42), 10)
    assert_eq(valueOrDefault(null, "default"), "default")
    assert_eq(valueOrDefault("actual", "default"), "actual")
}

print("All generic function tests passed!")
