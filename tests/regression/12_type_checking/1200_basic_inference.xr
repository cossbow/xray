// 1200_basic_inference.xr
// Test basic type inference
// ===== Literal Type Inference =====
@test
fn test_int_literal() {
    let x = 42
    assert_eq(typeof(x), "int")
}

@test
fn test_float_literal() {
    let x = 3.14
    assert_eq(typeof(x), "float")
}

@test
fn test_string_literal() {
    let x = "hello"
    assert_eq(typeof(x), "string")
}

@test
fn test_bool_literal() {
    let x = true
    let y = false
    assert_eq(typeof(x), "bool")
    assert_eq(typeof(y), "bool")
}

@test
fn test_null_literal() {
    let x = null
    assert_eq(typeof(x), "null")
}

// ===== Array Inference =====
@test
fn test_array_int() {
    let arr = [1, 2, 3]
    assert_eq(typeof(arr), "Array")
    assert_eq(arr.length, 3)
}

@test
fn test_array_string() {
    let arr = ["a", "b", "c"]
    assert_eq(typeof(arr), "Array")
}

@test
fn test_array_empty() {
    let arr: Array<int> = []
    assert_eq(typeof(arr), "Array")
}

@test
fn test_array_nested() {
    let arr = [[1, 2], [3, 4]]
    assert_eq(typeof(arr), "Array")
    assert_eq(arr[0][0], 1)
}

// ===== Map Inference =====
@test
fn test_map_basic() {
    let m = #{"a": 1, "b": 2}
    assert_eq(typeof(m), "Map")
    assert_eq(m.get("a"), 1)
}

@test
fn test_map_empty() {
    let m = #{}
    assert_eq(typeof(m), "Map")
}

// ===== Set Inference =====
@test
fn test_set_basic() {
    let s = #[1, 2, 3]
    assert_eq(typeof(s), "Set")
    assert_eq(s.length, 3)
}

// ===== Binary Expression Inference =====
@test
fn test_arithmetic_int() {
    let a = 10
    let b = 3
    let sum = a + b
    let diff = a - b
    let prod = a * b
    let quot = a / b
    assert_eq(typeof(sum), "int")
    assert_eq(sum, 13)
}

@test
fn test_arithmetic_float() {
    let a = 10.0
    let b = 3.0
    let result = a / b
    assert_eq(typeof(result), "float")
}

@test
fn test_arithmetic_mixed() {
    let a = 10
    let b = 3.0
    let result = a + b
    // int + float = float
    assert_eq(typeof(result), "float")
}

@test
fn test_string_concat() {
    let a = "hello"
    let b = " world"
    let result = a + b
    assert_eq(typeof(result), "string")
    assert_eq(result, "hello world")
}

@test
fn test_comparison() {
    let a = 10
    let b = 20
    let result = a < b
    assert_eq(typeof(result), "bool")
    assert_eq(result, true)
}

@test
fn test_logical() {
    let a = true
    let b = false
    let and_result = a && b
    let or_result = a || b
    assert_eq(typeof(and_result), "bool")
    assert_eq(typeof(or_result), "bool")
}

// ===== Ternary Expression Inference =====
@test
fn test_ternary_same_type() {
    let x = true ? 1 : 2
    assert_eq(typeof(x), "int")
    assert_eq(x, 1)
}

@test
fn test_ternary_different_types() {
    let cond = true
    // When types differ, result is the common type or any
    let x = cond ? 1 : "hello"
    // Either int, string, or any depending on implementation
    assert(x == 1)
}

// ===== Variable Reassignment =====
@test
fn test_reassignment() {
    let x = 10
    assert_eq(typeof(x), "int")
    x = 20
    assert_eq(typeof(x), "int")
    assert_eq(x, 20)
}
