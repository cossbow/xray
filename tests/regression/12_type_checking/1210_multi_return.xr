/*
 * Multi-value return type safety tests
 * Tests tuple type annotation syntax and multi-value return compilation
 */

// Test 1: Basic multi-value return with type annotation
fn divide(a: int, b: int): (int, bool) {
    if (b == 0) {
        return 0, false
    }
    return a / b, true
}

@test
fn test_multi_return_basic() {
    let result, ok = divide(10, 2)
    assert_eq(result, 5)
    assert_eq(ok, true)
    
    let result2, ok2 = divide(10, 0)
    assert_eq(result2, 0)
    assert_eq(ok2, false)
}

// Test 2: Triple return values
fn minmax(a: int, b: int, c: int): (int, int, int) {
    let min_val = a
    let max_val = a
    let sum = a + b + c
    
    if (b < min_val) { min_val = b }
    if (c < min_val) { min_val = c }
    if (b > max_val) { max_val = b }
    if (c > max_val) { max_val = c }
    
    return min_val, max_val, sum
}

@test
fn test_triple_return() {
    let min_v, max_v, sum = minmax(3, 1, 5)
    assert_eq(min_v, 1)
    assert_eq(max_v, 5)
    assert_eq(sum, 9)
}

// Test 3: Take fewer values than returned
fn quadruple(): (int, int, int, int) {
    return 1, 2, 3, 4
}

@test
fn test_partial_capture() {
    // Only capture first two values
    let a, b = quadruple()
    assert_eq(a, 1)
    assert_eq(b, 2)
}

// Test 4: Multi-value return in conditional
fn safeDivide(a: int, b: int): (float, bool) {
    if (b == 0) {
        return 0.0, false
    }
    return float(a) / float(b), true
}

@test
fn test_conditional_multi_return() {
    let r1, ok1 = safeDivide(10, 4)
    assert_eq(ok1, true)
    assert(r1 > 2.4 && r1 < 2.6)
    
    let r2, ok2 = safeDivide(5, 0)
    assert_eq(ok2, false)
    assert_eq(r2, 0.0)
}

print("all multi-return tests passed")
