// 1233_generic_class_bound.xr
// Class upper-bound generics: <T: BaseClass> accepts BaseClass and any
// of its subclasses, allowing the body to rely on the base API while
// callers preserve their concrete subtype.
//
// REGRESSION: Bug #1 - uninitialised names[] in
//             xa_set_function_type_params_from_ast (commit 1f39808).
// FAIL_AT:    pre-1f39808 on MSVC Debug
//             -> 0xCDCDCDCDCDCDCDCD pointer fed to strcmp via
//                resolve_class_to_type_param, ACCESS_VIOLATION.
//             -> on macOS / Linux usually silently passed because the
//                xr_malloc'd garbage happened to be a readable string.
// PASS_AT:    1f39808+ on all platforms with or without --jit-force
//             -> generic signatures mixing constrained and
//                unconstrained type params resolve cleanly.
// Triggering shape:  fn pair<T: Animal, U>(...) below. The first pass
// over `names[]` in xa_set_function_type_params_from_ast must complete
// before any resolve_class_to_type_param call so the constraint
// lookup never reads uninitialised slots.

class Animal {
    name: string
    constructor(n: string) { this.name = n }
    species() -> string { return "animal" }
}

class Dog extends Animal {
    breed: string
    constructor(n: string, b: string) {
        super(n)
        this.breed = b
    }
    species() -> string { return "dog" }
}

class Cat extends Animal {
    constructor(n: string) { super(n) }
    species() -> string { return "cat" }
}

class Puppy extends Dog {
    constructor(n: string) {
        super(n, "Mixed")
    }
    species() -> string { return "puppy" }
}

// ===== Direct subclass satisfies upper bound =====
@test
fn test_direct_subclass() {
    fn nameOf<T: Animal>(a: T) -> string { return a.name }

    let dog = Dog("Rex", "Labrador")
    assert_eq(nameOf<Dog>(dog), "Rex")
}

@test
fn test_sibling_subclass() {
    fn nameOf<T: Animal>(a: T) -> string { return a.name }

    let cat = Cat("Whiskers")
    assert_eq(nameOf<Cat>(cat), "Whiskers")
}

// ===== Transitive (grand-child) subclass also satisfies =====
@test
fn test_grandchild_subclass() {
    fn nameOf<T: Animal>(a: T) -> string { return a.name }

    let puppy = Puppy("Buddy")
    assert_eq(nameOf<Puppy>(puppy), "Buddy")
}

// ===== Base class itself satisfies (reflexive) =====
@test
fn test_base_class_self() {
    fn nameOf<T: Animal>(a: T) -> string { return a.name }

    let animal = Animal("Generic")
    assert_eq(nameOf<Animal>(animal), "Generic")
}

// ===== Type parameter inferred without explicit type arg =====
@test
fn test_inferred_type_arg() {
    fn nameOf<T: Animal>(a: T) -> string { return a.name }

    let dog = Dog("Spot", "Beagle")
    assert_eq(nameOf(dog), "Spot")
}

// ===== Class upper bound combined with second unconstrained param =====
@test
fn test_class_bound_with_second_param() {
    fn pair<T: Animal, U>(a: T, tag: U) -> U { return tag }

    let cat = Cat("Mittens")
    assert_eq(pair<Cat, int>(cat, 7), 7)
    assert_eq(pair<Cat, string>(cat, "ok"), "ok")
}

print("All class-bound generic tests passed!")
