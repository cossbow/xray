// 测试：if 条件语句

// ===== 基础 if =====

@test
fn test_if_true() {
    let result = 0
    if (true) {
        result = 1
    }
    assert_eq(result, 1)
}

@test
fn test_if_false() {
    let result = 0
    if (false) {
        result = 1
    }
    assert_eq(result, 0)
}

@test
fn test_if_expression() {
    let x = 10
    let result = 0
    if (x > 5) {
        result = 1
    }
    assert_eq(result, 1)
}

// ===== if-else =====

@test
fn test_if_else_true() {
    let result = ""
    if (true) {
        result = "yes"
    } else {
        result = "no"
    }
    assert_eq(result, "yes")
}

@test
fn test_if_else_false() {
    let result = ""
    if (false) {
        result = "yes"
    } else {
        result = "no"
    }
    assert_eq(result, "no")
}

@test
fn test_if_else_expression() {
    let x = 3
    let result = ""
    if (x > 5) {
        result = "big"
    } else {
        result = "small"
    }
    assert_eq(result, "small")
}

// ===== if-else if-else =====

@test
fn test_elseif_first() {
    let x = 1
    let result = ""
    if (x == 1) {
        result = "one"
    } else if (x == 2) {
        result = "two"
    } else {
        result = "other"
    }
    assert_eq(result, "one")
}

@test
fn test_elseif_second() {
    let x = 2
    let result = ""
    if (x == 1) {
        result = "one"
    } else if (x == 2) {
        result = "two"
    } else {
        result = "other"
    }
    assert_eq(result, "two")
}

@test
fn test_elseif_else() {
    let x = 3
    let result = ""
    if (x == 1) {
        result = "one"
    } else if (x == 2) {
        result = "two"
    } else {
        result = "other"
    }
    assert_eq(result, "other")
}

@test
fn test_multiple_elseif() {
    let score = 75
    let grade = ""
    if (score >= 90) {
        grade = "A"
    } else if (score >= 80) {
        grade = "B"
    } else if (score >= 70) {
        grade = "C"
    } else if (score >= 60) {
        grade = "D"
    } else {
        grade = "F"
    }
    assert_eq(grade, "C")
}

// ===== 嵌套 if =====

@test
fn test_nested_if() {
    let x = 5
    let y = 10
    let result = ""
    
    if (x > 0) {
        if (y > 5) {
            result = "x>0, y>5"
        } else {
            result = "x>0, y<=5"
        }
    } else {
        result = "x<=0"
    }
    assert_eq(result, "x>0, y>5")
}

@test
fn test_deep_nested() {
    let a = 1
    let b = 2
    let c = 3
    let result = 0
    
    if (a > 0) {
        if (b > 0) {
            if (c > 0) {
                result = a + b + c
            }
        }
    }
    assert_eq(result, 6)
}

// ===== 真值判断 =====

@test
fn test_truthy_number() {
    let result = ""
    if (1) { result = "truthy" } else { result = "falsy" }
    assert_eq(result, "truthy")
    
    if (0) { result = "truthy" } else { result = "falsy" }
    assert_eq(result, "falsy")
}

@test
fn test_truthy_string() {
    let result = ""
    if ("hello") { result = "truthy" } else { result = "falsy" }
    assert_eq(result, "truthy")
    
    if ("") { result = "truthy" } else { result = "falsy" }
    assert_eq(result, "falsy")
}

@test
fn test_truthy_null() {
    let result = ""
    if (null) { result = "truthy" } else { result = "falsy" }
    assert_eq(result, "falsy")
}

// ===== 复合条件 =====

@test
fn test_and_condition() {
    let x = 5
    let y = 10
    let result = false
    if (x > 0 && y > 0) {
        result = true
    }
    assert_eq(result, true)
}

@test
fn test_or_condition() {
    let x = -5
    let y = 10
    let result = false
    if (x > 0 || y > 0) {
        result = true
    }
    assert_eq(result, true)
}

@test
fn test_not_condition() {
    let flag = false
    let result = 0
    if (!flag) {
        result = 1
    }
    assert_eq(result, 1)
}

// ===== 边界条件 =====

@test
fn test_empty_if_body() {
    let x = 10
    if (x < 5) {
        // 空体
    }
    assert_eq(x, 10)  // 什么都没发生
}

@test
fn test_if_only_once() {
    let count = 0
    let x = 10
    
    if (x > 5) {
        count++
    }
    if (x > 3) {
        count++
    }
    assert_eq(count, 2)
}

