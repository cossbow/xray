// 测试：match 表达式
// ===== 字面量匹配 =====
@test
fn test_match_literal_int() {
    let x = 2
    let result = match (x) {
        1 -> "one"
        2 -> "two"
        3 -> "three"
        _ -> "other"
    }
    assert_eq(result, "two")
}

@test
fn test_match_literal_string() {
    let cmd = "start"
    let result = match (cmd) {
        "start" -> 1
        "stop" -> 2
        "pause" -> 3
        _ -> 0
    }
    assert_eq(result, 1)
}

@test
fn test_match_default() {
    let x = 100
    let result = match (x) {
        1 -> "one"
        2 -> "two"
        _ -> "default"
    }
    assert_eq(result, "default")
}

// ===== 范围匹配 =====
@test
fn test_match_range() {
    let score = 85
    let grade = match (score) {
        90..100 -> "A"
        80..90 -> "B"
        70..80 -> "C"
        60..70 -> "D"
        _ -> "F"
    }
    assert_eq(grade, "B")
}

@test
fn test_match_range_boundary() {
    let x = 10
    let result = match (x) {
        0..10 -> "less than 10"
        10..20 -> "10 to 19"
        _ -> "20 or more"
    }
    assert_eq(result, "10 to 19")
}

// ===== 多值匹配 =====
@test
fn test_match_multi_value() {
    let day = "Sat"
    let result = match (day) {
        "Mon", "Tue", "Wed", "Thu", "Fri" -> "weekday"
        "Sat", "Sun" -> "weekend"
        _ -> "unknown"
    }
    assert_eq(result, "weekend")
}

@test
fn test_match_multi_number() {
    let x = 5
    let result = match (x) {
        1, 3, 5, 7, 9 -> "odd"
        2, 4, 6, 8, 10 -> "even"
        _ -> "other"
    }
    assert_eq(result, "odd")
}

// ===== 守卫条件 =====
@test
fn test_match_guard() {
    let x = 15
    let result = match (x) {
        n if (n < 0) -> "negative"
        n if (n == 0) -> "zero"
        n if (n < 10) -> "small"
        n if (n < 100) -> "medium"
        _ -> "large"
    }
    assert_eq(result, "medium")
}

@test
fn test_match_guard_complex() {
    let x = 42
    let result = match (x) {
        n if (n % 2 == 0 && n > 40) -> "even and big"
        n if (n % 2 == 0) -> "even"
        n if (n > 40) -> "odd and big"
        _ -> "odd and small"
    }
    assert_eq(result, "even and big")
}

// ===== 枚举匹配 =====
@test
fn test_match_enum() {
    enum Color {
        Red,
        Green,
        Blue
    }
    let c = Color.Green
    let result = match (c) {
        Color.Red -> "red"
        Color.Green -> "green"
        Color.Blue -> "blue"
    }
    assert_eq(result, "green")
}

// ===== 嵌套 match =====
@test
fn test_match_nested() {
    let x = 5
    let y = 10
    let result = match (x) {
        n if (n > 0) -> match (y) {
            m if (m > 5) -> "x>0, y>5"
            _ -> "x>0, y<=5"
        }
        _ -> "x<=0"
    }
    assert_eq(result, "x>0, y>5")
}

// ===== match 表达式求值 =====
@test
fn test_match_expression_result() {
    let x = 3
    let doubled = match (x) {
        1 -> 2
        2 -> 4
        3 -> 6
        _ -> 0
    } * 2
    // 注意：这里测试 match 结果可以参与表达式
    assert_eq(doubled, 12)
}

@test
fn test_match_in_function() {
    fn classify(n: int) -> string {
        return match (n) {
            0 -> "zero"
            n if (n > 0) -> "positive"
            _ -> "negative"
        }
    }
    assert_eq(classify(0), "zero")
    assert_eq(classify(5), "positive")
    assert_eq(classify(-3), "negative")
}

// ===== 边界条件 =====
@test
fn test_match_first_wins() {
    let x = 5
    let result = match (x) {
        n if (n > 0) -> "first"
        5 -> "five"
        _ -> "default"
    }
    assert_eq(result, "first")
}

@test
fn test_match_all_guards_fail() {
    let x = 0
    let result = match (x) {
        n if (n > 10) -> "big"
        n if (n < -10) -> "small"
        _ -> "middle"
    }
    assert_eq(result, "middle")
}
