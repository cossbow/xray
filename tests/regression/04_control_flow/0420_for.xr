// 测试：for 循环

// ===== 基础 for =====

@test
fn test_for_count_up() {
    let sum = 0
    for (let i = 0; i < 5; i++) {
        sum += i
    }
    assert_eq(sum, 10)  // 0+1+2+3+4
}

@test
fn test_for_count_down() {
    let sum = 0
    for (let i = 5; i > 0; i--) {
        sum += i
    }
    assert_eq(sum, 15)  // 5+4+3+2+1
}

@test
fn test_for_start_from_one() {
    let sum = 0
    for (let i = 1; i <= 5; i++) {
        sum += i
    }
    assert_eq(sum, 15)  // 1+2+3+4+5
}

// ===== 步进 =====

@test
fn test_for_step_two() {
    let sum = 0
    for (let i = 0; i < 10; i += 2) {
        sum += i
    }
    assert_eq(sum, 20)  // 0+2+4+6+8
}

@test
fn test_for_step_three() {
    let result: Array<int> = []
    for (let i = 0; i < 10; i += 3) {
        result.push(i)
    }
    assert_eq(result.length, 4)  // [0,3,6,9]
}

// ===== 边界条件 =====

@test
fn test_for_never_run() {
    let count = 0
    for (let i = 10; i < 0; i++) {
        count++
    }
    assert_eq(count, 0)
}

@test
fn test_for_once() {
    let count = 0
    for (let i = 0; i < 1; i++) {
        count++
    }
    assert_eq(count, 1)
}

// ===== break =====

@test
fn test_for_break() {
    let last = 0
    for (let i = 0; i < 10; i++) {
        if (i == 5) {
            break
        }
        last = i
    }
    assert_eq(last, 4)
}

@test
fn test_for_break_early() {
    let sum = 0
    for (let i = 0; i < 100; i++) {
        sum += i
        if (sum > 10) {
            break
        }
    }
    assert_eq(sum, 15)  // 0+1+2+3+4+5
}

// ===== continue =====

@test
fn test_for_continue() {
    let sum = 0
    for (let i = 0; i < 10; i++) {
        if (i % 2 == 0) {
            continue
        }
        sum += i
    }
    assert_eq(sum, 25)  // 1+3+5+7+9
}

@test
fn test_for_continue_first() {
    let result: Array<int> = []
    for (let i = 0; i < 5; i++) {
        if (i == 0) {
            continue
        }
        result.push(i)
    }
    assert_eq(result.length, 4)
}

// ===== 嵌套 for =====

@test
fn test_for_nested() {
    let total = 0
    for (let i = 0; i < 3; i++) {
        for (let j = 0; j < 3; j++) {
            total++
        }
    }
    assert_eq(total, 9)
}

@test
fn test_for_multiplication_table() {
    let sum = 0
    for (let i = 1; i <= 3; i++) {
        for (let j = 1; j <= 3; j++) {
            sum += i * j
        }
    }
    // (1+2+3) + (2+4+6) + (3+6+9) = 6+12+18 = 36
    assert_eq(sum, 36)
}

@test
fn test_for_nested_break() {
    let count = 0
    for (let i = 0; i < 5; i++) {
        for (let j = 0; j < 5; j++) {
            count++
            if (j == 2) {
                break  // 只跳出内层
            }
        }
    }
    assert_eq(count, 15)  // 5 * 3
}

// ===== 外层变量访问 =====

@test
fn test_for_outer_variable() {
    let x = 100
    for (let i = 0; i < 3; i++) {
        x += i
    }
    assert_eq(x, 103)  // 100+0+1+2
}

@test
fn test_for_collect() {
    let result: Array<int> = []
    for (let i = 0; i < 5; i++) {
        result.push(i * i)
    }
    assert_eq(result.length, 5)
    assert_eq(result[0], 0)
    assert_eq(result[4], 16)
}

// ===== 特殊用法 =====

@test
fn test_for_expression_init() {
    let start = 5
    let sum = 0
    for (let i = start; i < start + 3; i++) {
        sum += i
    }
    assert_eq(sum, 18)  // 5+6+7
}

