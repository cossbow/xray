// 测试：for-in 循环

// ===== 数组遍历 =====

@test
fn test_for_in_array() {
    let arr = [1, 2, 3, 4, 5]
    let sum = 0
    for (x in arr) {
        sum += x
    }
    assert_eq(sum, 15)
}

@test
fn test_for_in_empty_array() {
    let arr: Array<int> = []
    let count = 0
    for (x in arr) {
        count++
    }
    assert_eq(count, 0)
}

@test
fn test_for_in_single() {
    let arr = [42]
    let result = 0
    for (x in arr) {
        result = x
    }
    assert_eq(result, 42)
}

@test
fn test_for_in_strings() {
    let arr = ["a", "b", "c"]
    let result = ""
    for (s in arr) {
        result += s
    }
    assert_eq(result, "abc")
}

// ===== 范围遍历 =====

@test
fn test_for_in_range() {
    let sum = 0
    for (i in 0..5) {
        sum += i
    }
    assert_eq(sum, 10)  // 0+1+2+3+4
}

@test
fn test_for_in_range_start() {
    let sum = 0
    for (i in 3..6) {
        sum += i
    }
    assert_eq(sum, 12)  // 3+4+5
}

@test
fn test_for_in_range_empty() {
    let count = 0
    for (i in 5..5) {
        count++
    }
    assert_eq(count, 0)
}

@test
fn test_for_in_range_one() {
    let count = 0
    for (i in 5..6) {
        count++
    }
    assert_eq(count, 1)
}

// ===== Map 遍历 =====

@test
fn test_for_in_map() {
    let m = {"a" => 1, "b" => 2, "c" => 3}
    let sum = 0
    for (k, v in m) {
        sum += v
    }
    assert_eq(sum, 6)
}

@test
fn test_for_in_map_keys() {
    let m = {"x" => 10, "y" => 20}
    let keys: Array<string> = []
    for (k, v in m) {
        keys.push(k)
    }
    assert_eq(keys.length, 2)
}

@test
fn test_for_in_empty_map() {
    let m = #{}
    let count = 0
    for (kv in m) {
        count++
    }
    assert_eq(count, 0)
}

// ===== break/continue =====

@test
fn test_for_in_break() {
    let arr = [1, 2, 3, 4, 5]
    let sum = 0
    for (x in arr) {
        if (x == 4) {
            break
        }
        sum += x
    }
    assert_eq(sum, 6)  // 1+2+3
}

@test
fn test_for_in_continue() {
    let arr = [1, 2, 3, 4, 5]
    let sum = 0
    for (x in arr) {
        if (x % 2 == 0) {
            continue
        }
        sum += x
    }
    assert_eq(sum, 9)  // 1+3+5
}

// ===== 嵌套 =====

@test
fn test_for_in_nested_array() {
    let matrix = [[1, 2], [3, 4], [5, 6]]
    let sum = 0
    for (row in matrix) {
        for (x in row) {
            sum += x
        }
    }
    assert_eq(sum, 21)
}

@test
fn test_for_in_nested_range() {
    let total = 0
    for (i in 0..3) {
        for (j in 0..3) {
            total++
        }
    }
    assert_eq(total, 9)
}

// ===== 实际应用 =====

@test
fn test_for_in_collect() {
    let arr = [1, 2, 3, 4]
    let squares: Array<int> = []
    for (x in arr) {
        squares.push(x * x)
    }
    assert_eq(squares.length, 4)
    assert_eq(squares[0], 1)
    assert_eq(squares[3], 16)
}

@test
fn test_for_in_filter() {
    let arr = [1, 2, 3, 4, 5, 6]
    let evens: Array<int> = []
    for (x in arr) {
        if (x % 2 == 0) {
            evens.push(x)
        }
    }
    assert_eq(evens.length, 3)
}

@test
fn test_for_in_transform() {
    let names = ["alice", "bob", "charlie"]
    let upper: Array<string> = []
    for (name in names) {
        upper.push(name.toUpperCase())
    }
    assert_eq(upper[0], "ALICE")
    assert_eq(upper[1], "BOB")
}

