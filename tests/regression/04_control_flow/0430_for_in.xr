// 测试：for-in 循环

// ===== 数组遍历 =====

@test
fn test_for_in_array() {
    let arr = [1, 2, 3, 4, 5]
    let sum = 0
    for (x in arr) {
        sum += x
    }
    assert_eq(sum, 15)
}

@test
fn test_for_in_empty_array() {
    let arr: Array<int> = []
    let count = 0
    for (x in arr) {
        count++
    }
    assert_eq(count, 0)
}

@test
fn test_for_in_single() {
    let arr = [42]
    let result = 0
    for (x in arr) {
        result = x
    }
    assert_eq(result, 42)
}

@test
fn test_for_in_strings() {
    let arr = ["a", "b", "c"]
    let result = ""
    for (s in arr) {
        result += s
    }
    assert_eq(result, "abc")
}

// ===== 范围遍历 =====

@test
fn test_for_in_range() {
    let sum = 0
    for (i in 0..5) {
        sum += i
    }
    assert_eq(sum, 10)  // 0+1+2+3+4
}

@test
fn test_for_in_range_start() {
    let sum = 0
    for (i in 3..6) {
        sum += i
    }
    assert_eq(sum, 12)  // 3+4+5
}

@test
fn test_for_in_range_empty() {
    let count = 0
    for (i in 5..5) {
        count++
    }
    assert_eq(count, 0)
}

@test
fn test_for_in_range_one() {
    let count = 0
    for (i in 5..6) {
        count++
    }
    assert_eq(count, 1)
}

// ===== Map 遍历 =====

@test
fn test_for_in_map() {
    let m = #{"a": 1, "b": 2, "c": 3}
    let sum = 0
    for (k, v in m) {
        sum += v
    }
    assert_eq(sum, 6)
}

@test
fn test_for_in_map_keys() {
    let m = #{"x": 10, "y": 20}
    let keys: Array<string> = []
    for (k, v in m) {
        keys.push(k)
    }
    assert_eq(keys.length, 2)
}

@test
fn test_for_in_empty_map() {
    let m = #{}
    let count = 0
    for (kv in m) {
        count++
    }
    assert_eq(count, 0)
}

// ===== Map / Json single-var iteration yields keys =====

@test
fn test_for_in_map_single_var_yields_key() {
    let m: Map<string, int> = #{"a": 1, "b": 2, "c": 3}
    let acc = ""
    for (k in m) {
        acc += k
    }
    // Map iteration order is insertion order in xray.
    assert_eq(acc, "abc")
}

@test
fn test_for_in_json_single_var_yields_key() {
    let j: Json = {x: 1, y: 2, z: 3}
    let keys: Array<string> = []
    for (k in j) {
        keys.push(k)
    }
    assert_eq(keys.length, 3)
    assert_eq(keys[0], "x")
    assert_eq(keys[1], "y")
    assert_eq(keys[2], "z")
}

// ===== Direct iterator() protocol =====

@test
fn test_iterator_array_manual() {
    let arr = [10, 20, 30]
    let it = arr.iterator()
    let sum = 0
    while (it.hasNext()) {
        sum += it.next()
    }
    assert_eq(sum, 60)
}

@test
fn test_iterator_string_manual() {
    let it = "abc".iterator()
    let acc = ""
    while (it.hasNext()) {
        acc += it.next()
    }
    assert_eq(acc, "abc")
}

@test
fn test_iterator_map_manual_yields_keys() {
    let m: Map<string, int> = #{"a": 1, "b": 2}
    let it = m.iterator()
    let acc = ""
    while (it.hasNext()) {
        acc += it.next()
    }
    assert_eq(acc, "ab")
}

@test
fn test_entries_iterator_yields_tuples() {
    let arr = [10, 20]
    let it = arr.entriesIterator()
    let acc = ""
    while (it.hasNext()) {
        let pair = it.next()
        acc += "${pair.0}=${pair.1};"
    }
    assert_eq(acc, "0=10;1=20;")
}

// ===== Array index-element shorthand =====

@test
fn test_for_in_array_index_elem() {
    let arr = ["x", "y", "z"]
    let indexed = ""
    for (i, e in arr) {
        indexed += "${i}:${e};"
    }
    assert_eq(indexed, "0:x;1:y;2:z;")
}

@test
fn test_for_in_array_index_sum() {
    let arr = [10, 20, 30, 40]
    let idx_sum = 0
    let elem_sum = 0
    for (i, e in arr) {
        idx_sum += i
        elem_sum += e
    }
    assert_eq(idx_sum, 6)
    assert_eq(elem_sum, 100)
}

@test
fn test_for_in_array_index_empty() {
    let arr: Array<int> = []
    let count = 0
    for (i, e in arr) {
        count++
    }
    assert_eq(count, 0)
}

@test
fn test_for_in_array_entries_method() {
    let arr = [100, 200, 300]
    let acc = ""
    for ((i, e) in arr.entries()) {
        acc += "${i}=${e},"
    }
    assert_eq(acc, "0=100,1=200,2=300,")
}

// ===== string index-char shorthand =====

@test
fn test_for_in_string_index_char() {
    let s = "abc"
    let acc = ""
    for (i, c in s) {
        acc += "${i}:${c};"
    }
    assert_eq(acc, "0:a;1:b;2:c;")
}

@test
fn test_for_in_string_index_unicode() {
    let s = "你好"
    let count = 0
    let last_idx = -1
    for (i, c in s) {
        count++
        last_idx = i
    }
    assert_eq(count, 2)
    assert_eq(last_idx, 1)
}

@test
fn test_for_in_string_entries_method() {
    let s = "hi"
    let acc = ""
    for ((i, c) in s.entries()) {
        acc += "${i}-${c}|"
    }
    assert_eq(acc, "0-h|1-i|")
}

// ===== break/continue =====

@test
fn test_for_in_break() {
    let arr = [1, 2, 3, 4, 5]
    let sum = 0
    for (x in arr) {
        if (x == 4) {
            break
        }
        sum += x
    }
    assert_eq(sum, 6)  // 1+2+3
}

@test
fn test_for_in_continue() {
    let arr = [1, 2, 3, 4, 5]
    let sum = 0
    for (x in arr) {
        if (x % 2 == 0) {
            continue
        }
        sum += x
    }
    assert_eq(sum, 9)  // 1+3+5
}

// ===== 嵌套 =====

@test
fn test_for_in_nested_array() {
    let matrix = [[1, 2], [3, 4], [5, 6]]
    let sum = 0
    for (row in matrix) {
        for (x in row) {
            sum += x
        }
    }
    assert_eq(sum, 21)
}

@test
fn test_for_in_nested_range() {
    let total = 0
    for (i in 0..3) {
        for (j in 0..3) {
            total++
        }
    }
    assert_eq(total, 9)
}

// ===== 实际应用 =====

@test
fn test_for_in_collect() {
    let arr = [1, 2, 3, 4]
    let squares: Array<int> = []
    for (x in arr) {
        squares.push(x * x)
    }
    assert_eq(squares.length, 4)
    assert_eq(squares[0], 1)
    assert_eq(squares[3], 16)
}

@test
fn test_for_in_filter() {
    let arr = [1, 2, 3, 4, 5, 6]
    let evens: Array<int> = []
    for (x in arr) {
        if (x % 2 == 0) {
            evens.push(x)
        }
    }
    assert_eq(evens.length, 3)
}

@test
fn test_for_in_transform() {
    let names = ["alice", "bob", "charlie"]
    let upper: Array<string> = []
    for (name in names) {
        upper.push(name.toUpperCase())
    }
    assert_eq(upper[0], "ALICE")
    assert_eq(upper[1], "BOB")
}

