// 测试：提前返回

// ===== 函数提前返回 =====

@test
fn test_early_return() {
    fn findPositive(arr: Array<int>): int {
        for (x in arr) {
            if (x > 0) {
                return x
            }
        }
        return -1
    }
    
    assert_eq(findPositive([-1, -2, 3, 4]), 3)
    assert_eq(findPositive([-1, -2, -3]), -1)
}

@test
fn test_guard_clause() {
    fn divide(a: int, b: int): int? {
        if (b == 0) {
            return null
        }
        return a / b
    }
    
    assert_eq(divide(10, 2), 5)
    assert_eq(divide(10, 0), null)
}

// ===== 多条件提前返回 =====

@test
fn test_multiple_guards() {
    fn classify(n: int): string {
        if (n < 0) { return "negative" }
        if (n == 0) { return "zero" }
        if (n < 10) { return "small" }
        if (n < 100) { return "medium" }
        return "large"
    }
    
    assert_eq(classify(-5), "negative")
    assert_eq(classify(0), "zero")
    assert_eq(classify(5), "small")
    assert_eq(classify(50), "medium")
    assert_eq(classify(500), "large")
}

// ===== 嵌套循环提前返回 =====

@test
fn test_nested_return() {
    fn findPair(arr: Array<int>, target: int): Array<int>? {
        for (i in 0..arr.length) {
            for (j in (i+1)..arr.length) {
                if (arr[i] + arr[j] == target) {
                    return [i, j]
                }
            }
        }
        return null
    }
    
    let result = findPair([1, 2, 3, 4], 5)
    assert_eq(result != null, true)
    assert_eq(result[0], 0)
    assert_eq(result[1], 3)
}

// ===== 递归提前返回 =====

@test
fn test_recursive_return() {
    fn binarySearch(arr: Array<int>, target: int, low: int, high: int): int {
        if (low > high) {
            return -1
        }
        let mid = (low + high) / 2
        if (arr[mid] == target) {
            return mid
        }
        if (arr[mid] < target) {
            return binarySearch(arr, target, mid + 1, high)
        }
        return binarySearch(arr, target, low, mid - 1)
    }
    
    let arr = [1, 3, 5, 7, 9]
    assert_eq(binarySearch(arr, 5, 0, arr.length - 1), 2)
    assert_eq(binarySearch(arr, 4, 0, arr.length - 1), -1)
}

// ===== 空返回 =====

@test
fn test_void_return() {
    let executed = false
    
    fn process(flag: bool) {
        if (!flag) {
            return
        }
        executed = true
    }
    
    process(false)
    assert_eq(executed, false)
    
    process(true)
    assert_eq(executed, true)
}

