// 测试：while 循环

// ===== 基础 while =====

@test
fn test_while_count_up(): void {
    let i = 0
    let sum = 0
    while (i < 5) {
        sum += i
        i++
    }
    assert_eq(sum, 10)  // 0+1+2+3+4
    assert_eq(i, 5)
}

@test
fn test_while_count_down(): void {
    let i = 5
    let sum = 0
    while (i > 0) {
        sum += i
        i--
    }
    assert_eq(sum, 15)  // 5+4+3+2+1
    assert_eq(i, 0)
}

// ===== 边界条件 =====

@test
fn test_while_never_run(): void {
    let count = 0
    while (false) {
        count++
    }
    assert_eq(count, 0)
}

@test
fn test_while_once(): void {
    let i = 0
    let count = 0
    while (i < 1) {
        count++
        i++
    }
    assert_eq(count, 1)
}

@test
fn test_while_condition_becomes_false(): void {
    let i = 10
    while (i < 0) {
        i++  // 永远不会执行
    }
    assert_eq(i, 10)
}

// ===== break =====

@test
fn test_while_break(): void {
    let i = 0
    while (i < 100) {
        if (i == 5) {
            break
        }
        i++
    }
    assert_eq(i, 5)
}

@test
fn test_while_break_early(): void {
    let sum = 0
    let i = 0
    while (true) {
        sum += i
        i++
        if (i > 5) {
            break
        }
    }
    assert_eq(sum, 15)
}

// ===== continue =====

@test
fn test_while_continue(): void {
    let sum = 0
    let i = 0
    while (i < 10) {
        i++
        if (i % 2 == 0) {
            continue
        }
        sum += i
    }
    assert_eq(sum, 25)  // 1+3+5+7+9
}

@test
fn test_while_continue_and_break(): void {
    let result: Array<int> = []
    let i = 0
    while (i < 10) {
        i++
        if (i % 2 == 0) {
            continue
        }
        if (i > 7) {
            break
        }
        result.push(i)
    }
    assert_eq(result.length, 4)  // [1,3,5,7]
}

// ===== 嵌套 while =====

@test
fn test_while_nested(): void {
    let total = 0
    let i = 0
    while (i < 3) {
        let j = 0
        while (j < 3) {
            total++
            j++
        }
        i++
    }
    assert_eq(total, 9)
}

@test
fn test_while_nested_break(): void {
    let i = 0
    let count = 0
    while (i < 3) {
        let j = 0
        while (j < 5) {
            count++
            if (j == 2) {
                break  // 只跳出内层
            }
            j++
        }
        i++
    }
    assert_eq(count, 9)  // 3 * 3
}

// ===== 复杂条件 =====

@test
fn test_while_and_condition(): void {
    let i = 0
    let j = 10
    let count = 0
    while (i < 5 && j > 5) {
        i++
        j--
        count++
    }
    assert_eq(count, 5)
}

@test
fn test_while_or_condition(): void {
    let i = 0
    let count = 0
    while (i < 3 || count < 5) {
        i++
        count++
    }
    assert_eq(count, 5)
}

// ===== 实际应用 =====

@test
fn test_while_find(): void {
    let arr = [1, 3, 5, 7, 9, 11]
    let target = 7
    let found = false
    let i = 0
    while (i < arr.length) {
        if (arr[i] == target) {
            found = true
            break
        }
        i++
    }
    assert_eq(found, true)
    assert_eq(i, 3)
}

@test
fn test_while_accumulate(): void {
    let arr = [1, 2, 3, 4, 5]
    let sum = 0
    let i = 0
    while (i < arr.length) {
        sum += arr[i]
        i++
    }
    assert_eq(sum, 15)
}

