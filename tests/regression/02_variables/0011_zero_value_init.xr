// Typed variables without initializer get zero values

@test
fn test_int_zero_value() {
    let a: int
    assert_eq(a, 0)
}

@test
fn test_float_zero_value() {
    let b: float
    assert_eq(b, 0.0)
}

@test
fn test_bool_zero_value() {
    let c: bool
    assert_eq(c, false)
}

@test
fn test_string_zero_value() {
    let d: string
    assert_eq(d, "")
}

@test
fn test_nullable_defaults_to_null() {
    let e: int?
    assert_eq(e, null)
}
