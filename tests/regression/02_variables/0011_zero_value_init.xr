// Typed variables without initializer get zero values

let a: int
print(a)       // expect: 0

let b: float
print(b)       // expect: 0

let c: bool
print(c)       // expect: false

let d: string
print(d == "")  // expect: true

// Nullable types default to null
let e: int?
print(e)       // expect: null
