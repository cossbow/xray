// 0220_destructure.xr
// Flat destructuring tests (no nesting, no rest, no renaming)

// ===== Array destructuring =====

@test
fn test_array_basic() {
    let [a, b, c] = [1, 2, 3]
    assert_eq(a, 1)
    assert_eq(b, 2)
    assert_eq(c, 3)
}

@test
fn test_array_partial() {
    let [first, second] = [1, 2, 3, 4, 5]
    assert_eq(first, 1)
    assert_eq(second, 2)
}

@test
fn test_array_single() {
    let [x] = [42]
    assert_eq(x, 42)
}

// ===== Skip elements =====

@test
fn test_skip_elements() {
    let [first, , third] = [10, 20, 30]
    assert_eq(first, 10)
    assert_eq(third, 30)
}

@test
fn test_skip_multiple() {
    let [a, , , d] = [1, 2, 3, 4]
    assert_eq(a, 1)
    assert_eq(d, 4)
}

// ===== Flat array: nested values are kept as-is =====

@test
fn test_flat_nested_value() {
    let [a, b, c] = [10, [11, 12], 13]
    assert_eq(a, 10)
    assert_eq(b[0], 11)
    assert_eq(b[1], 12)
    assert_eq(c, 13)
}

// ===== Object destructuring (same-name only) =====

@test
fn test_object_basic() {
    let { name, age } = { name: "Alice", age: 30 }
    assert_eq(name, "Alice")
    assert_eq(age, 30)
}

@test
fn test_object_flat_nested_value() {
    let { d, e, f } = { d: 100, e: 200, f: { f1: 300, f2: 400 } }
    assert_eq(d, 100)
    assert_eq(e, 200)
    assert_eq(f.f1, 300)
    assert_eq(f.f2, 400)
}

