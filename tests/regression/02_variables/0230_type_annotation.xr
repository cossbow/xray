// 测试：类型注解
// ===== 基本类型注解 =====
@test
fn test_int_annotation(): void {
    let x: int = 42
    assert_eq(x, 42)
    assert_eq(typeof(x), Type.int)
}

@test
fn test_float_annotation(): void {
    let x: float = 3.14
    assert_eq(x > 3, true)
    assert_eq(typeof(x), Type.float)
}

@test
fn test_string_annotation(): void {
    let s: string = "hello"
    assert_eq(s, "hello")
    assert_eq(typeof(s), Type.string)
}

@test
fn test_bool_annotation(): void {
    let flag: bool = true
    assert_eq(flag, true)
    assert_eq(typeof(flag), Type.bool)
}

// ===== 集合类型注解 =====
@test
fn test_array_annotation(): void {
    let arr: Array<int> = [1, 2, 3]
    assert_eq(arr.length, 3)
    assert_eq(typeof(arr), Type.Array)
}

@test
fn test_map_annotation(): void {
    let m: Map<string, int> = { "a" => 1 }
    assert_eq(m.get("a"), 1)
    assert_eq(typeof(m), Type.Map)
}

@test
fn test_set_annotation(): void {
    let s: Set<int> = #[1, 2, 3]
    assert_eq(s.length, 3)
    assert_eq(typeof(s), Type.Set)
}

// ===== 函数参数类型注解 =====
@test
fn test_function_param_annotation(): void {
    fn add(a: int, b: int): int {
        return a + b
    }
    assert_eq(add(2, 3), 5)
}

@test
fn test_function_return_annotation(): void {
    fn double(x: int): int {
        return x * 2
    }
    assert_eq(double(5), 10)
}

// ===== 类字段类型注解 =====
@test
fn test_class_field_annotation(): void {
    class Point {
        x: int
        y: int

        constructor(x: int, y: int) {
            this.x = x
            this.y = y
        }
    }
    let p = new Point(3, 4)
    assert_eq(p.x, 3)
    assert_eq(p.y, 4)
}

// ===== 复杂类型 =====
@test
fn test_nullable_type(): void {
    let x: int = 10
    let y: int? = null
    if (y == null) {
        y = x
    }
    assert_eq(y, 10)
}
