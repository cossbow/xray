/*
** 测试协程优先级 API 和调度效果
** 作者：xingleixu@gmail.com
**
** Test 1: setPriority(task, 0/1/2) API 可用性
** Test 2: 先创建 LOW 任务、后创建 HIGH 任务，验证 HIGH 仍先完成
**         每个任务含多次 yield，让调度器按优先级反复择优
*/

fn compute(n: int): int {
    return n * n
}

fn work_and_report(label: string, ch: Channel<string>): string {
    let sum = 0
    for (let i = 0; i < 200; i++) {
        sum = sum + i
        if (i % 20 == 0) { yield }
    }
    ch.send(label)
    return label
}

@test
fn test_coro_priority() {
    // Test 1: setPriority API with all priority levels
    print("test1: setPriority API")
    let t1 = go compute(3)
    Coro.setPriority(t1, 0)
    print("  low:", await t1)
    let t2 = go compute(4)
    Coro.setPriority(t2, 1)
    print("  normal:", await t2)
    let t3 = go compute(5)
    Coro.setPriority(t3, 2)
    print("  high:", await t3)

    // Test 2: Priority scheduling effect
    // LOW tasks created first (FIFO-advantaged), HIGH tasks created after
    // If priority works, HIGH still completes earlier
    print("test2: priority scheduling")
    const ch = new Channel<string>(20)

    for (let i = 0; i < 10; i++) {
        let lo = go work_and_report("L", ch)
        Coro.setPriority(lo, 0)
    }
    for (let i = 0; i < 10; i++) {
        let hi = go work_and_report("H", ch)
        Coro.setPriority(hi, 2)
    }

    // Collect completion order (20 recvs = all tasks done)
    let high_early = 0
    for (let i = 0; i < 20; i++) {
        let label = ch.recv()
        if (i < 10 && label == "H") {
            high_early = high_early + 1
        }
    }
    ch.close()

    // With priority scheduling, majority of HIGH tasks complete in first half
    print("  priority effective:", high_early >= 6)
    print("done")
}

// 期望输出：
// test1: setPriority API
//   low: 9
//   normal: 16
//   high: 25
// test2: priority scheduling
//   priority effective: true
// done
