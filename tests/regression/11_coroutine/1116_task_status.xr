// 测试 task.done 和 task.cancelled 属性
// 作者：xingleixu@gmail.com

fn blocked(ch: Channel<int>) -> int {
    return ch.recv()
}

fn compute(x: int) -> int {
    return x * 2
}

@test
fn test_main() {
    // Test 1: blocked task — done is deterministically false
    const ch = new Channel<int>(0)
    let task = go blocked(ch)
    print("before send:")
    print("  done:", task.done)
    print("  cancelled:", task.cancelled)

    ch.send(21)
    let result = await task
    print("after await:")
    print("  done:", task.done)
    print("  result:", result)
    ch.close()

    // Test 2: cancel blocked task — cancelled is deterministically true
    const ch2 = new Channel<int>(0)
    let task2 = go blocked(ch2)
    task2.cancel()
    let result2 = await task2
    print("after cancel:")
    print("  done:", task2.done)
    print("  cancelled:", task2.cancelled)
    print("  result:", result2)
    ch2.close()

    // Test 3: completed task status
    let task3 = go compute(21)
    let result3 = await task3
    print("completed:")
    print("  done:", task3.done)
    print("  cancelled:", task3.cancelled)
    print("  result:", result3)
}

// 期望输出：
// before send:
//   done: false
//   cancelled: false
// after await:
//   done: true
//   result: 21
// after cancel:
//   done: true
//   cancelled: true
//   result: null
// completed:
//   done: true
//   cancelled: false
//   result: 42
