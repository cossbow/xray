/*
** preempt_test.xr - 协程并发调度测试
** 作者：xingleixu@gmail.com
**
** 测试目的：验证多个协程能够并发执行并通过 Channel 通信
*/

import time
fn worker(id: int, ch: Channel<int>, iterations: int) {
    for (let i = 0; i < iterations; i++) {
        time.sleep(5)
    }
    ch.send(id)
}

@test
fn test_preempt_test() {
    shared const WORKER_COUNT = 4
    shared const ITERATIONS = 3
    shared const resultCh = new Channel(WORKER_COUNT)


    print("启动 " + string(WORKER_COUNT) + " 个协程...")
    for (let i = 0; i < WORKER_COUNT; i++) {
        go worker(i, resultCh, ITERATIONS)
    }
    /* Collect IDs first; concurrent scheduling makes recv order
     * non-deterministic, so we sort before printing to keep stdout
     * stable across runs and across interp/JIT modes. */
    let ids: Array<int> = []
    let received = 0
    for (let i = 0; i < WORKER_COUNT; i++) {
        let id = resultCh.recv()
        received++
        ids.push(id)
    }
    ids.sort()
    for (let i = 0; i < ids.length; i++) {
        print("协程 " + string(ids[i]) + " 完成")
    }
    /* 验证 */
    if (received == WORKER_COUNT) {
        print("调度测试通过：" + string(received) + "/" + string(WORKER_COUNT) + " 协程完成")
    } else {
        throw "调度测试失败：只有 " + string(received) + " 个协程完成"
    }
}

