/*
** 作者：xingleixu@gmail.com
** 测试 scope 结构化并发基础功能
**
** scope { ... } 会自动等待内部所有 go 启动的协程完成
**
** 注意：协程函数通过参数传递数据，避免闭包捕获非线程安全变量
*/

shared const results: Array<string> = []

fn task1(arr: Array<string>): int {
    arr.push("task1 start")
    arr.push("task1 end")
    return 1
}

fn task2(arr: Array<string>): int {
    arr.push("task2 start")
    arr.push("task2 end")
    return 2
}

fn task3(arr: Array<string>): int {
    arr.push("task3 start")
    arr.push("task3 end")
    return 3
}

// 测试 scope 自动等待
print("=== scope 基础测试 ===")

scope {
    go task1(results)
    go task2(results)
    go task3(results)
}

// scope 退出后，所有任务应该已完成
print("scope 结束")
print("任务数量:", results.length)

// 检查所有任务都执行了
if (results.length >= 6) {
    print("所有任务完成")
} else {
    print("错误：任务未完成")
}

print("=== 嵌套 scope 测试 ===")

shared const outer_results: Array<string> = []

fn inner1_task(arr: Array<string>): void {
    arr.push("inner1")
}

fn nested_task(arr: Array<string>): void {
    arr.push("nested_coro")
}

scope {
    outer_results.push("outer1")
    go inner1_task(outer_results)
    
    scope {
        outer_results.push("nested1")
        go nested_task(outer_results)
    }
    
    outer_results.push("after_nested")
}

print("嵌套 scope 结果数量:", outer_results.length)
