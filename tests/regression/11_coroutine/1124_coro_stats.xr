/*
** 测试协程统计 API
** 作者：xingleixu@gmail.com
** 
** 测试内容：
** 1. Coro.stats() - 获取协程统计
** 2. Coro.list() - 列出所有协程
** 3. task.info() - 获取单个协程信息
*/

// 测试 1：Coro.stats() 基本功能
print("test1: Coro.stats()")
let stats = Coro.stats()
print("  active:", stats["active"])
print("  total:", stats["total"])

// 测试 2：创建协程后统计变化
print("test2: stats after creating coroutines")
shared const ch1 = Channel(1)
shared const ch2 = Channel(1)

let t1 = go(name: "worker-1") {
    ch1.recv()  // 阻塞
    return 1
}

let t2 = go(name: "worker-2") {
    ch2.recv()  // 阻塞
    return 2
}

// 给协程时间进入阻塞状态
let stats2 = Coro.stats()
print("  active:", stats2["active"])
print("  blocked:", stats2["blocked"])

// 测试 3：Coro.list() 
print("test3: Coro.list()")
let list = Coro.list()
print("  count:", list.length)
for (item in list) {
    print("    id:", item["id"], "name:", item["name"], "state:", item["state"])
}

// 解除阻塞
ch1.send(100)
ch2.send(200)
await t1
await t2

// 测试 4：协程完成后统计
print("test4: stats after completion")
let stats3 = Coro.stats()
print("  total created:", stats3["total"])

print("all tests passed")
