// 测试 task.cancel() 功能
// 作者：xingleixu@gmail.com

fn compute(x: int): int {
    return x * 2
}

fn main(): void {
    // 创建协程
    let task = go compute(21)
    
    // 取消协程（使用对象方法）
    task.cancel()
    
    // 验证协程已被取消
    // 由于协程是延迟执行的，取消后 await 应该返回 null
    let result = await task
    
    if (result == null) {
        print("cancel ok")
    } else {
        print("cancel failed, got:", result)
    }
}

main()
