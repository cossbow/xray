/*
** 测试协程命名和调试信息
** 作者：xingleixu@gmail.com
** 
** 测试内容：
** 1. go(name: "xxx") 语法
** 2. 命名协程正常执行
** 3. 匿名协程正常执行
*/

fn worker(id: int): int {
    return id * 10
}

@test
fn test_coro_naming() {

    // 测试命名协程
    let task1 = go(name: "worker-1") worker(1)
    let result1 = await task1
    print(result1)  // expect: 10

    // 测试命名协程（匿名块形式）
    let task2 = go(name: "counter") {
        let sum = 0
        for (i in 1..5) {
            sum = sum + i
        }
        return sum
    }
    let result2 = await task2
    print(result2)  // expect: 10

    // 测试无名称协程
    let task3 = go worker(2)
    let result3 = await task3
    print(result3)  // expect: 20

    // 测试混合使用
    let task4 = go(name: "alpha") worker(3)
    let task5 = go(name: "beta") worker(4)
    let task6 = go worker(5)

    print(await task4)  // expect: 30
    print(await task5)  // expect: 40
    print(await task6)  // expect: 50

    print("done")  // expect: done
}

