// Test task.link() / task.unlink() bidirectional association

import time

fn failing() -> int {
    throw new Exception("link error")
    return 0
}
fn slow_work() -> int {
    // Park on a cooperative cancel point. The peer task throws almost
    // immediately, and the resulting xr_task_cancel_tree must be able to
    // unblock us so that `await` observes a cancelled (null) result.
    // A tight CPU loop without a cancel point would let us race past the
    // peer's failure and finish normally — the assertion below would then
    // observe the body's return value instead of the cancellation signal.
    time.sleep(50)
    return 1
}
fn ok() -> int {
    return 42
}
fn test_link_cancel() {
    let t1 = go slow_work()
    let t2 = go failing()
    t1.link(t2)
    let r1 = await t1
    let r2 = await t2
    assert(r1 == null, "linked peer should be cancelled when other fails")
}
fn test_unlink() {
    let t1 = go ok()
    let t2 = go ok()
    t1.link(t2)
    t1.unlink(t2)
    let r1 = await t1
    let r2 = await t2
    assert(r1 == 42, "unlinked tasks should complete normally")
    assert(r2 == 42)
}
fn test_link_both_ok() {
    let t1 = go ok()
    let t2 = go ok()
    t1.link(t2)
    let r1 = await t1
    let r2 = await t2
    assert(r1 == 42)
    assert(r2 == 42)
}

@test
fn test_task_link() {



    // Test 1: task.link() — when one fails, linked peer gets cancelled

    // Test 2: task.unlink() — basic API works without crash

    // Test 3: both succeed — link has no effect

    test_link_cancel()
    test_unlink()
    test_link_both_ok()
}

