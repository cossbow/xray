/*
** shared 变量与 move 语义测试
** 作者：xingleixu@gmail.com
**
** 测试内容：
**   - shared const: 全局堆，引用计数共享，并发读取
**   - shared let: 全局堆，可通过 move 显式转移所有权
**   - move var: 显式所有权转移（用于 go / ch.send）
**   - 普通变量: 传递给协程时深拷贝
*/

// Test 1: shared const — concurrent read (zero-copy via refcount)
@test
fn test_shared_const(): void {
    print("=== Test shared const ===")

    shared const config = {
        name: "test",
        value: 42
    }
    print(config)

    // Multiple coroutines read the same shared const (zero-copy)
    let t1 = go fn(c: Json): int {
        return c.value
    }(config)

    let t2 = go fn(c: Json): int {
        return c.value * 2
    }(config)

    let r1 = await t1
    let r2 = await t2
    print("coro1:", r1)
    print("coro2:", r2)
    print("results:", r1, r2)  // 42 84
}

// Test 2: move with go — ownership transfer to coroutine
@test
fn test_move_go(): void {
    print("=== Test move go ===")

    shared let data = { count: 10 }

    // 'move data' transfers ownership to child coroutine (zero-copy)
    let task = go fn(d: Json): int {
        print("child got:", d.count)
        return d.count + 1
    }(move data)

    let result = await task
    print("child result:", result)  // 11
    // data is no longer usable here (compile error if referenced)
}

// Test 3: move with ch.send — ownership transfer via channel
@test
fn test_move_channel_send(): void {
    print("=== Test move channel send ===")

    shared const ch = Channel(1)
    shared let payload = [10, 20, 30]

    // send with move: transfers ownership through channel
    ch.send(move payload)
    // payload is no longer usable here (compile error if referenced)

    let received = ch.recv()
    print("received:", received)   // [10, 20, 30]
    ch.close()
}

// Test 4: normal variable — deep copy to coroutine (no move)
@test
fn test_normal_copy(): void {
    print("=== Test normal copy ===")

    let arr = [1, 2, 3]

    // Without move: coroutine gets a deep copy
    let task = go fn(data: Array<int>) {
        data.push(4)  // does not affect original
        return data.length
    }(arr)

    let result = await task
    print("original:", arr)        // [1, 2, 3] (unchanged)
    print("coro result:", result)  // 4
}

// Test 5: move in pipeline — sequential ownership transfer via channel
@test
fn test_move_pipeline(): void {
    print("=== Test move pipeline ===")

    shared const ch = Channel(1)
    shared let msg = { step: 0 }

    // Stage 1: modify and move-send
    let t1 = go fn(c: Channel<Json>, d: Json): void {
        d.step = d.step + 1
        print("stage1:", d.step)
        c.send(d)
    }(ch, move msg)

    await t1
    // msg is no longer usable here (moved in go call above)

    // Stage 2: receive and process
    let t2 = go fn(c: Channel<Json>): int {
        let d = c.recv()
        d.step = d.step + 1
        print("stage2:", d.step)
        return d.step
    }(ch)

    let final_step = await t2
    print("final step:", final_step)  // 2
    ch.close()
}

// Run all tests
test_shared_const()
test_move_go()
test_move_channel_send()
test_normal_copy()
test_move_pipeline()
print("=== All tests passed ===")
