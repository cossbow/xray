// 协程系统综合测试
// 作者：xingleixu@gmail.com
// 展示：go, await, task.cancel(), task.done, task.cancelled, task.result, defer, Channel, select

fn blocked(ch: Channel<int>): int {
    return ch.recv()
}

@test
fn test_main() {
    // === 1. 基本 go/await ===
    print("=== go/await ===")
    let task1 = go { return 42 }
    print("task1 result:", await task1)

    // === 2. 状态检查（await 后确定性） ===
    print("=== status ===")
    let task2 = go { return 100 }
    await task2
    print("done:", task2.done)
    print("result:", task2.result)

    // === 3. 取消协程（channel-blocked 保证未完成） ===
    print("=== cancel ===")
    const cancel_ch = new Channel<int>(0)
    let task3 = go blocked(cancel_ch)
    task3.cancel()
    let result3 = await task3
    print("cancelled:", task3.cancelled)
    print("cancelled result:", result3)
    cancel_ch.close()

    // === 4. Channel 通信 ===
    print("=== channel ===")
    shared const ch = new Channel(3)
    ch.trySend(1)
    ch.trySend(2)
    ch.trySend(3)
    print("recv:", ch.tryRecv(), ch.tryRecv(), ch.tryRecv())

    // === 5. defer 清理 ===
    print("=== defer ===")
    fn cleanup(): void { print("cleanup!") }
    fn with_defer(): int {
        defer cleanup()
        print("working...")
        return 42
    }
    with_defer()

    // === 6. await all ===
    print("=== await all ===")
    let t1 = go { return 1 }
    let t2 = go { return 2 }
    let t3 = go { return 3 }
    let results = await all [t1, t2, t3]
    print("all results:", results)

    // === 7. await any (single task = deterministic) ===
    print("=== await any ===")
    let t4 = go { return "winner" }
    let first = await any [t4]
    print("first result:", first)

    print("=== done ===")
}
