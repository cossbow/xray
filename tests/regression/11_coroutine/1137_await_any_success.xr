/*
** 测试 await anySuccess - 等待任一协程成功完成（跳过失败的）
** 作者：xingleixu@gmail.com
*/

fn success() -> int {
    return 42
}
fn failing() -> int {
    throw "error"
    return 0
}

@test
fn test_await_any_success() {
    // Test 1: single success
    print("test1: single success")
    let t1 = go success()
    let r1 = await anySuccess [t1]
    print("  result:", r1)

    // Test 2: pre-completed tasks, array-order scan (deterministic)
    print("test2: pre-completed tasks")
    let t2 = go success()
    let t3 = go success()
    await t2
    await t3
    let r2 = await anySuccess [t2, t3]
    print("  result:", r2)

    // Test 3: one failing + one success — anySuccess skips failure
    print("test3: skip failure")
    let t4 = go failing()
    let t5 = go success()
    await t4
    await t5
    let r3 = await anySuccess [t4, t5]
    print("  result:", r3)

    print("done")
}

// 期望输出：
// test1: single success
//   result: 42
// test2: pre-completed tasks
//   result: 42
// test3: skip failure
//   result: 42
// done
