// Test task.monitor() API — completion notification via Channel

fn compute(): int {
    return 42
}
fn failing(): int {
    throw "monitor test error"
    return 0
}
fn test_monitor_success() {
    let t = go compute()
    let ch = t.monitor()
    let r = await t
    let val, ok = ch.tryRecv()
    assert(ok, "monitor channel should have value after task completes")
    assert(val.done, "monitor should receive completed task")
    assert(val.result == 42, "monitor task should carry result")
    ch.close()
}
fn test_monitor_fail() {
    let t = go failing()
    let ch = t.monitor()
    await t
    let val, ok = ch.tryRecv()
    assert(ok, "monitor channel should have value after task fails")
    assert(val.done, "monitor should receive completed task on failure")
    assert(val.error == "monitor test error", "monitor task should carry error")
    ch.close()
}
fn test_monitor_already_done() {
    let t = go compute()
    let r = await t
    let ch = t.monitor()
    let val, ok = ch.tryRecv()
    assert(ok, "monitor on completed task should have immediate value")
    assert(val.done, "monitor should receive completed task (already done)")
    assert(val.result == 42, "monitor task should carry result (already done)")
    ch.close()
}

@test
fn test_task_monitor() {


    // Test 1: monitor a successful task

    // Test 2: monitor a failing task

    // Test 3: monitor an already-completed task

    test_monitor_success()
    test_monitor_fail()
    test_monitor_already_done()
}

