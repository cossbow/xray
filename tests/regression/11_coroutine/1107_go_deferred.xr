// 测试 go 延迟执行行为
// go 不立即执行，await 时才执行
//
// 注意：协程通过返回值获取结果，不共享可变状态

@test
fn test_deferred() {
    print("start")
    
    // 简单测试：每个协程返回独立的值
    fn get_one(): int { return 1 }
    fn get_two(): int { return 2 }
    fn get_three(): int { return 3 }
    
    // go 创建协程
    let t1 = go get_one()
    let t2 = go get_two()
    let t3 = go get_three()
    
    // await 获取结果
    let r1 = await t1
    print(r1)       // 1
    
    let r2 = await t2
    print(r2)       // 2
    
    let r3 = await t3
    print(r3)       // 3
    
    // 重复 await 返回相同结果
    let r1_again = await t1
    print(r1_again) // 1
    
    print("end")
}

test_deferred()

// 期望输出：
// start
// 1
// 2
// 3
// 1
// end
