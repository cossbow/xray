// 测试 task.result 属性
// 作者：xingleixu@gmail.com

fn blocked(ch: Channel<int>) -> int {
    return ch.recv()
}

fn compute(x: int) -> int {
    return x * 2
}

@test
fn test_main() {
    // Test 1: blocked task — result is null before completion
    const ch = new Channel<int>(0)
    let task = go blocked(ch)
    print("before:", task.result)

    ch.send(21)
    let result = await task
    print("after:", task.result)
    print("again:", task.result)
    ch.close()

    // Test 2: cancel blocked task — result is null
    const ch2 = new Channel<int>(0)
    let task2 = go blocked(ch2)
    task2.cancel()
    await task2
    print("cancelled:", task2.result)
    ch2.close()

    // Test 3: completed task — result accessible
    let task3 = go compute(21)
    await task3
    print("completed:", task3.result)
}

// 期望输出：
// before: null
// after: 21
// again: 21
// cancelled: null
// completed: 42
