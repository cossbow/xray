// Test coroutine error handling patterns
// Covers: task.error, task.result, try-catch behavior, await all errors,
//         await any, Coro.monitor error notification
//
// REGRESSION: Bug #9 - sysmon vs timer-wheel race
//             (commit c976d0d).
// FAIL_AT:    pre-c976d0d under --jit-force, ~1/10 runs
//             -> sysmon_assist() called xr_check_next_timeout_time()
//                from the sysmon thread, asserting the
//                owner-exclusive invariant
//                `next_timeout_time == next_timeout_pos`. Owner
//                workers update those two fields in two separate
//                non-atomic stores, and sysmon could observe the
//                intermediate state when a worker reached M_PARKING,
//                tripping the assertion.
// PASS_AT:    c976d0d+ with --jit-force or --no-jit
//             -> sysmon now reads tw->next_timeout_pos directly
//                (naturally-aligned 64-bit load is atomic on
//                x86-64 / AArch64); the owner-exclusive check
//                stays for paths that genuinely need it.
// REQUIRES_JIT_FORCE
// Triggering shape: timer-driven coroutine error patterns combined
// with sysmon-noticed M_PARKING transitions. Race is timing-
// sensitive — `scripts/repro_jit_force_burn.sh` with N=30 is the
// recommended way to reproduce the original ~1/10 failure rate.

import time
fn test_basic_error() {
    let t1 = go {
        let x = 1 / 0
        return x
    }
    await t1
    print("t1.done:", t1.done)
    print("t1.error:", t1.error)
    print("t1.result:", t1.result)

    let t2 = go { return 42 }
    let r = await t2
    print("t2.done:", t2.done)
    print("t2.error:", t2.error)
    print("t2.result:", t2.result)
    print("await result:", r)
}
fn test_try_catch_cannot_catch() {
    try {
        let t = go {
            throw "something went wrong"
        }
        let r = await t
        print("await returned:", r)
        print("t.error:", t.error)
        print("catch was NOT triggered")
    } catch (e) {
        print("UNEXPECTED: caught:", e)
    }
}
fn test_try_catch_in_coro() {
    let t = go {
        try {
            let x = 1 / 0
            return x
        } catch (e) {
            return "caught: " + string(e)
        }
    }
    let r = await t
    print("result:", r)
    print("t.error:", t.error)
}
fn test_manual_error_check() {
    fn risky_task(n: int) -> int {
        if (n == 0) {
            throw "cannot process zero"
        }
        return 100 / n
    }

    let t = go risky_task(0)
    await t

    if (t.error != null) {
        print("Task failed:", t.error)
    } else {
        print("Task succeeded:", t.result)
    }
}
fn test_await_all_with_errors() {
    let tasks = [
        go { return "ok-1" },
        go { throw "fail-2" },
        go { return "ok-3" }
    ]

    let results = await all(tasks)
    for (let i = 0; i < tasks.length; i++) {
        let t = tasks[i]
        if (t.error != null) {
            print("  task[" + string(i) + "] FAILED:", t.error)
        } else {
            print("  task[" + string(i) + "] OK:", results[i])
        }
    }
}
fn test_await_any() {
    let tasks = [
        go { time.sleep(100); return "slow" },
        go { return "fast" }
    ]
    let r = await any(tasks)
    print("First result:", r)
}
fn test_monitor_error() {
    let t = go(name: "err-worker") {
        time.sleep(10)
        throw "worker crashed"
    }

    let ch = Coro.monitor("err-worker")
    let reason = ch.recv()
    print("Monitor reason:", reason)
    print("task.error:", t.error)
}

@test
fn test_coro_error_patterns() {

    // ========== Pattern 1: Basic task.error / task.result ==========

    // ========== Pattern 2: try-catch CANNOT catch coroutine errors ==========

    // ========== Pattern 3: try-catch CAN catch inside coroutine ==========

    // ========== Pattern 4: Manual error check after await ==========

    // ========== Pattern 5: await all with errors ==========

    // ========== Pattern 6: await any - first success wins ==========

    // ========== Pattern 7: Coro.monitor error notification ==========

    // ========== Run all ==========
    print("--- Pattern 1 ---")
    test_basic_error()
    print("--- Pattern 2 ---")
    test_try_catch_cannot_catch()
    print("--- Pattern 3 ---")
    test_try_catch_in_coro()
    print("--- Pattern 4 ---")
    test_manual_error_check()
    print("--- Pattern 5 ---")
    test_await_all_with_errors()
    print("--- Pattern 6 ---")
    test_await_any()
    print("--- Pattern 7 ---")
    test_monitor_error()
}

