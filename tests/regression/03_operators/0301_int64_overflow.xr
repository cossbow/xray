// 0301_int64_overflow.xr
// Test: 64-bit integer wrap-on-overflow semantics
//
// Tagged Union uses full 64-bit signed integer range:
//   INT64_MAX =  9223372036854775807  ( 2^63 - 1)
//   INT64_MIN = -9223372036854775808  (-2^63)
//
// All integer overflow wraps (Go/Rust/Java semantics).
// No auto-promotion to BigInt. BigInt must be used explicitly.

// ===== Boundary constants =====

@test
fn test_int64_max_value() {
    let max: int = 9223372036854775807
    assert_eq(max, 9223372036854775807)
    assert_eq(typeof(max), "int")
}

@test
fn test_int64_min_value() {
    let min: int = -9223372036854775807 - 1
    assert_eq(min, -9223372036854775807 - 1)
}

@test
fn test_boundary_identity() {
    let max: int = 9223372036854775807
    let min: int = -9223372036854775807 - 1
    assert_eq(max - max, 0)
    assert_eq(min - min, 0)
    assert_eq(max * 1, max)
    assert_eq(min * 1, min)
    assert_eq(max * 0, 0)
    assert_eq(max + 0, max)
    assert_eq(min + 0, min)
}

// ===== Large values within int64 range =====

@test
fn test_large_values_still_int() {
    let a: int = 140737488355327
    let r = a + 1
    assert_eq(r, 140737488355328)
    assert_eq(typeof(r), "int")
}

@test
fn test_large_addition_still_int() {
    let a: int = 100000000000000
    let b: int = 100000000000000
    let r = a + b
    assert_eq(r, 200000000000000)
    assert_eq(typeof(r), "int")
}

// ===== Addition overflow wraps =====

@test
fn test_add_near_boundary_ok() {
    let a: int = 9223372036854775806
    assert_eq(a + 1, 9223372036854775807)
}

@test
fn test_add_overflow_wraps() {
    let max: int = 9223372036854775807
    let r = max + 1
    // INT64_MAX + 1 wraps to INT64_MIN
    assert_eq(r, -9223372036854775807 - 1)
    assert_eq(typeof(r), "int")
}

@test
fn test_add_negative_overflow_wraps() {
    let min: int = -9223372036854775807 - 1
    let r = min + (-1)
    // INT64_MIN + (-1) wraps to INT64_MAX
    assert_eq(r, 9223372036854775807)
    assert_eq(typeof(r), "int")
}

// ===== Subtraction overflow wraps =====

@test
fn test_sub_near_boundary_ok() {
    let a: int = -9223372036854775807
    assert_eq(a - 1, -9223372036854775807 - 1)
}

@test
fn test_sub_overflow_wraps() {
    let min: int = -9223372036854775807 - 1
    let r = min - 1
    // INT64_MIN - 1 wraps to INT64_MAX
    assert_eq(r, 9223372036854775807)
    assert_eq(typeof(r), "int")
}

@test
fn test_sub_positive_overflow_wraps() {
    let max: int = 9223372036854775807
    let r = max - (-1)
    // INT64_MAX - (-1) = INT64_MAX + 1 wraps to INT64_MIN
    assert_eq(r, -9223372036854775807 - 1)
    assert_eq(typeof(r), "int")
}

// ===== Multiplication overflow wraps =====

@test
fn test_mul_within_range() {
    let a: int = 1000000
    assert_eq(a * 1000000, 1000000000000)
}

@test
fn test_mul_overflow_wraps() {
    let max: int = 9223372036854775807
    let r = max * 2
    // INT64_MAX * 2 wraps: result is -2 (unsigned: 0xFFFFFFFFFFFFFFFE)
    assert_eq(r, -2)
    assert_eq(typeof(r), "int")
}

@test
fn test_mul_both_large_ok() {
    let a: int = 3000000000
    let b: int = 3000000001
    let r = a * b
    assert_eq(r, 9000000003000000000)
    assert_eq(typeof(r), "int")
}

// ===== Negation overflow wraps =====

@test
fn test_neg_normal() {
    assert_eq(-42, -42)
    assert_eq(-(-42), 42)
    assert_eq(-140737488355327, -140737488355327)
}

@test
fn test_neg_min_wraps() {
    let min: int = -9223372036854775807 - 1
    let r = -min
    // -INT64_MIN wraps to INT64_MIN (two's complement)
    assert_eq(r, -9223372036854775807 - 1)
    assert_eq(typeof(r), "int")
}

// ===== Left shift within range =====

@test
fn test_shift_within_range() {
    let one: int = 1
    assert_eq(one << 46, 70368744177664)
    assert_eq(one << 62, 4611686018427387904)
}

// ===== Compound assignment overflow wraps =====

@test
fn test_compound_add_wraps() {
    let x: int = 9223372036854775807
    x += 1
    assert_eq(x, -9223372036854775807 - 1)
    assert_eq(typeof(x), "int")
}

@test
fn test_compound_sub_wraps() {
    let x: int = -9223372036854775807 - 1
    x -= 1
    assert_eq(x, 9223372036854775807)
    assert_eq(typeof(x), "int")
}

@test
fn test_compound_mul_wraps() {
    let x: int = 9223372036854775807
    x *= 2
    assert_eq(x, -2)
    assert_eq(typeof(x), "int")
}

// ===== Compound assignment within range =====

@test
fn test_compound_near_boundary_ok() {
    let x: int = 9223372036854775806
    x += 1
    assert_eq(x, 9223372036854775807)

    let y: int = -9223372036854775807
    y -= 1
    assert_eq(y, -9223372036854775807 - 1)
}

// ===== Negative * negative boundary =====

@test
fn test_mul_neg_neg_ok() {
    let a: int = 140737488355327
    assert_eq(a * -1, -140737488355327)
}

// ===== INT64_MIN / -1 wrap (would overflow signed range) =====
//
// 2^63 cannot fit in int64, so VM/JIT/AOT all wrap:
//   INT64_MIN / -1 = INT64_MIN
//   INT64_MIN % -1 = 0
// On x64 this requires the JIT to detect the case before IDIV (which
// raises #DE / SIGFPE); on ARM64 SDIV produces the wrap naturally.

@test
fn test_div_min_neg_one_wraps() {
    let min: int = -9223372036854775807 - 1
    let r = min / -1
    assert_eq(r, -9223372036854775807 - 1)
    assert_eq(typeof(r), "int")
}

@test
fn test_mod_min_neg_one_is_zero() {
    let min: int = -9223372036854775807 - 1
    let r = min % -1
    assert_eq(r, 0)
    assert_eq(typeof(r), "int")
}

@test
fn test_div_min_neg_one_in_loop() {
    // Loop forces JIT compilation on hot paths so that the wrap path
    // is exercised on the JIT side, not just the interpreter.
    let min: int = -9223372036854775807 - 1
    let acc: int = 0
    for (i in 0..200) {
        acc += min / -1
    }
    // min / -1 = min, summed 200 times wraps repeatedly.
    // 200 * min mod 2^64: 200 * (-2^63) wraps; explicit value: 0
    // because (-2^63 * 200) mod 2^64 = (-2^63 * 200 + k * 2^64) for some k
    // 200 * 2^63 = 25 * 2^66 = (multiple of 2^64) so result wraps to 0.
    assert_eq(acc, 0)
}

@test
fn test_div_normal_with_neg_one_divisor() {
    // Non-INT64_MIN dividends with -1 divisor stay correct.
    assert_eq(42 / -1, -42)
    assert_eq(-42 / -1, 42)
    assert_eq(0 / -1, 0)
    let big: int = 9223372036854775807
    assert_eq(big / -1, -9223372036854775807)
}

// ===== int.abs() boundary =====
//
// (-INT64_MIN) is signed-overflow UB. abs() must wrap, returning
// INT64_MIN itself instead of letting the compiler emit a NEG that
// triggers SIGFPE in some build configurations.

@test
fn test_abs_min_wraps() {
    let min: int = -9223372036854775807 - 1
    assert_eq(min.abs(), -9223372036854775807 - 1)
}

@test
fn test_abs_normal() {
    assert_eq((-42).abs(), 42)
    assert_eq((42).abs(), 42)
    assert_eq((0).abs(), 0)
    let max: int = 9223372036854775807
    assert_eq(max.abs(), 9223372036854775807)
}
