// 作者：xingleixu@gmail.com
// 测试：运算符优先级

// ===== 算术优先级 =====

@test
fn test_mul_before_add() {
    assert_eq(2 + 3 * 4, 14)
    assert_eq(10 - 2 * 3, 4)
}

@test
fn test_div_before_sub() {
    assert_eq(10 - 6 / 2, 7)
    assert_eq(20 + 8 / 4, 22)
}

@test
fn test_parentheses_override() {
    assert_eq((2 + 3) * 4, 20)
    assert_eq(2 * (3 + 4), 14)
}

// ===== 比较与逻辑优先级 =====

@test
fn test_comparison_before_and() {
    assert_eq(1 < 2 && 3 < 4, true)
    assert_eq(1 > 2 && 3 < 4, false)
}

@test
fn test_and_before_or() {
    assert_eq(true || false && false, true)
    assert_eq(false || true && true, true)
    assert_eq(false || false && true, false)
}

// ===== 算术与比较混合 =====

@test
fn test_arithmetic_then_compare() {
    assert_eq(2 + 3 < 10, true)
    assert_eq(2 * 5 == 10, true)
    assert_eq(10 - 3 >= 7, true)
}

// ===== 位运算优先级 =====

@test
fn test_shift_before_comparison() {
    let x = 1
    let shift = 3
    let result = x << shift
    assert_eq(result < 16, true)
}

@test
fn test_bitwise_and_before_or() {
    // a | b & c == a | (b & c)
    assert_eq(0b1100 | 0b1010 & 0b0110, 0b1110)
}

// ===== 一元运算符 =====

@test
fn test_unary_minus() {
    assert_eq(-5 + 10, 5)
    assert_eq(10 + -5, 5)
    assert_eq(-(-5), 5)
}

@test
fn test_logical_not() {
    assert_eq(!true, false)
    assert_eq(!false, true)
    assert_eq(!!true, true)
}

// ===== 复杂表达式 =====

@test
fn test_complex_expression() {
    let a = 2
    let b = 3
    let c = 4
    // a + b * c - a = 2 + 12 - 2 = 12
    assert_eq(a + b * c - a, 12)
}

@test
fn test_nested_parentheses() {
    assert_eq(((1 + 2) * 3) + 4, 13)
    assert_eq((1 + (2 * (3 + 4))), 15)
}

// ===== 三元运算符优先级 =====

@test
fn test_ternary_with_arithmetic() {
    let x = 5
    let result = x > 3 ? x * 2 : x + 1
    assert_eq(result, 10)
}

@test
fn test_ternary_false_branch() {
    let x = 1
    let result = x > 3 ? x * 2 : x + 1
    assert_eq(result, 2)
}

@test
fn test_nested_ternary() {
    let x = 5
    let result = x < 0 ? "negative" : x == 0 ? "zero" : "positive"
    assert_eq(result, "positive")
}

@test
fn test_ternary_zero() {
    let x = 0
    let result = x < 0 ? "negative" : x == 0 ? "zero" : "positive"
    assert_eq(result, "zero")
}

// ===== 赋值优先级（最低）=====

@test
fn test_assignment_lowest() {
    let x = 0
    x = 2 + 3  // 赋值的是 5，不是 (x = 2) + 3
    assert_eq(x, 5)
}

