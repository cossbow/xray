// 0302_int64_native.xr
// Test: int64 native operations (no 48-bit limit) + division by zero
//
// All arithmetic uses native 64-bit instructions when typed as int.
// These tests deliberately exercise >48-bit values and edge cases
// to expose any hidden boxing/overflow issues in the compiler.

// ===== Basic int64 arithmetic =====

@test
fn test_int64_add(): void {
    let a: int = 100
    let b: int = 200
    assert_eq(a + b, 300)
}

@test
fn test_int64_sub(): void {
    let a: int = 100
    let b: int = 200
    assert_eq(a - b, -100)
}

@test
fn test_int64_mul(): void {
    let a: int = 1000000
    let b: int = 1000000
    assert_eq(a * b, 1000000000000)
}

@test
fn test_int64_div(): void {
    let a: int = 100
    let b: int = 3
    assert_eq(a / b, 33)
}

@test
fn test_int64_mod(): void {
    let a: int = 100
    let b: int = 3
    assert_eq(a % b, 1)
}

@test
fn test_int64_neg(): void {
    let a: int = 42
    assert_eq(-a, -42)
}

// ===== Beyond 48-bit: assert_eq with both I64 operands =====

@test
fn test_int64_beyond_48bit_add(): void {
    let a: int = 140737488355327
    let b: int = 1
    let result: int = a + b
    // Both sides are I64 — should use OP_EQ_I64, no boxing
    assert_eq(result - b, a)
}

@test
fn test_int64_large_multiply_verify(): void {
    let a: int = 1000000000
    let b: int = 1000000000
    let result: int = a * b
    // Both sides are I64 — should use OP_EQ_I64
    assert_eq(result / a, b)
}

@test
fn test_int64_negative_large(): void {
    let a: int = -140737488355328
    let b: int = -1
    let result: int = a + b
    assert_eq(result + 1, a)
}

// ===== Beyond 48-bit: assert_eq with >48-bit literal =====
// This tests whether assert_eq(I64_var, literal) correctly avoids boxing
// when the literal exceeds 48-bit range.

@test
fn test_int64_assert_eq_large_literal(): void {
    let a: int = 140737488355327
    let b: int = a + 1
    // b = 140737488355328 (>48-bit), assert_eq second arg is I64 expr
    let expected: int = 140737488355328
    assert_eq(b, expected)
}

// ===== Beyond 48-bit: comparison in expression context =====
// assert(result > a) where both are I64 — does it box?

@test
fn test_int64_comparison_expr(): void {
    let a: int = 140737488355327
    let b: int = 1
    let result: int = a + b
    // This tests if > comparison boxes I64 operands
    assert(result > a)
}

@test
fn test_int64_comparison_expr_lt(): void {
    let a: int = 140737488355327
    let result: int = a + 1000
    assert(a < result)
}

@test
fn test_int64_comparison_eq_expr(): void {
    let a: int = 140737488355327
    let b: int = a
    assert(a == b)
}

// ===== Division by zero =====

@test
fn test_int64_div_by_zero(): void {
    let a: int = 42
    let zero: int = 0
    assert_throws(fn() { let r = a / zero })
}

@test
fn test_int64_mod_by_zero(): void {
    let a: int = 42
    let zero: int = 0
    assert_throws(fn() { let r = a % zero })
}

// ===== Bitwise operations =====

@test
fn test_int64_bitwise(): void {
    let a: int = 0xFF00
    let b: int = 0x0FF0
    assert_eq(a & b, 0x0F00)
    assert_eq(a | b, 0xFFF0)
    assert_eq(a ^ b, 0xF0F0)
}

// ===== Shift operations beyond 48-bit =====

@test
fn test_int64_shift_large(): void {
    let a: int = 1
    let r47: int = a << 47
    // 2^47 = 140737488355328, verify via shift back
    assert_eq(r47 >> 47, 1)
}

@test
fn test_int64_shift_62(): void {
    let a: int = 1
    let r62: int = a << 62
    assert_eq(r62 >> 62, 1)
}

// ===== Compound assignment beyond 48-bit =====

@test
fn test_int64_compound_add_large(): void {
    let x: int = 140737488355327
    x += 1000
    assert_eq(x - 1000, 140737488355327)
}

@test
fn test_int64_compound_mul_large(): void {
    let x: int = 1000000000
    x *= 1000000000
    assert_eq(x / 1000000000, 1000000000)
}

// ===== typeof =====

@test
fn test_typeof_int64(): void {
    let a: int = 42
    assert_eq(typeof(a), Type.int)
}

@test
fn test_typeof_float64(): void {
    let a: float = 3.14
    assert_eq(typeof(a), Type.float)
}
