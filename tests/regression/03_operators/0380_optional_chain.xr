// 0380_optional_chain.xr
// 作者：xingleixu@gmail.com
// 测试：可选链运算符（?.）

// ===== 基本可选链 =====

@test
fn test_optional_property_access() {
    let person = { name: "Alice", age: 25 }
    let name = person?.name
    assert_eq(name, "Alice")
}

@test
fn test_optional_on_null() {
    let person = null
    let name = person?.name
    assert_eq(name, null)
}

// ===== 嵌套可选链 =====

@test
fn test_nested_optional_chain() {
    let data = {
        user: {
            profile: {
                name: "Bob"
            }
        }
    }
    let name = data?.user?.profile?.name
    assert_eq(name, "Bob")
}

@test
fn test_nested_null_in_chain() {
    let data = {
        user: null
    }
    let name = data?.user?.profile?.name
    assert_eq(name, null)
}

// ===== 可选链与索引访问 =====

@test
fn test_optional_index_access() {
    let data = {
        items: [1, 2, 3]
    }
    let items = data?.items
    assert_eq(items[0], 1)
}

@test
fn test_optional_array_chain() {
    let data = {
        values: [10, 20, 30]
    }
    let vals = data?.values
    assert_eq(vals != null, true)
    assert_eq(vals[1], 20)
}

// ===== 与空值合并组合 =====

@test
fn test_optional_with_nullish() {
    let config = {
        settings: null
    }
    let theme = config?.settings?.theme ?? "default"
    assert_eq(theme, "default")
}

@test
fn test_optional_value_with_nullish() {
    let config = {
        settings: {
            theme: "dark"
        }
    }
    let theme = config?.settings?.theme ?? "default"
    assert_eq(theme, "dark")
}

