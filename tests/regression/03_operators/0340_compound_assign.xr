// 0340_compound_assign.xr
// 作者：xingleixu@gmail.com
// 测试：复合赋值运算符

// ===== 算术复合赋值 =====

@test
fn test_add_assign(): void {
    let x = 10
    x += 5
    assert_eq(x, 15)
    
    x += -3
    assert_eq(x, 12)
}

@test
fn test_sub_assign(): void {
    let x = 10
    x -= 3
    assert_eq(x, 7)
    
    x -= -2
    assert_eq(x, 9)
}

@test
fn test_mul_assign(): void {
    let x = 5
    x *= 3
    assert_eq(x, 15)
    
    x *= 2
    assert_eq(x, 30)
}

@test
fn test_div_assign(): void {
    let x = 20
    x /= 4
    assert_eq(x, 5)
    
    x /= 2
    assert_eq(x, 2)
}

@test
fn test_mod_assign(): void {
    let x = 17
    x %= 5
    assert_eq(x, 2)
}

// ===== 位运算复合赋值 =====

@test
fn test_and_assign(): void {
    let x = 0b1111
    x &= 0b1010
    assert_eq(x, 0b1010)
}

@test
fn test_or_assign(): void {
    let x = 0b1010
    x |= 0b0101
    assert_eq(x, 0b1111)
}

@test
fn test_xor_assign(): void {
    let x = 0b1111
    x ^= 0b1010
    assert_eq(x, 0b0101)
}

@test
fn test_shl_assign(): void {
    let x = 1
    x <<= 3
    assert_eq(x, 8)
}

@test
fn test_shr_assign(): void {
    let x = 16
    x >>= 2
    assert_eq(x, 4)
}

// ===== 自增自减 =====

// xray 仅支持后置自增自减，且只能单独成行

@test
fn test_increment_postfix(): void {
    let x = 5
    x++
    assert_eq(x, 6)
}

@test
fn test_decrement_postfix(): void {
    let x = 5
    x--
    assert_eq(x, 4)
}

// ===== 链式操作 =====

@test
fn test_chain_increment(): void {
    let x = 0
    x++
    x++
    x++
    assert_eq(x, 3)
}

// ===== 浮点数 =====

@test
fn test_float_compound(): void {
    let x = 1.5
    x += 2.5
    assert_eq(x, 4.0)
    
    x *= 2.0
    assert_eq(x, 8.0)
}

// ===== 边界条件 =====

@test
fn test_assign_zero(): void {
    let x = 10
    x += 0
    assert_eq(x, 10)
    
    x *= 0
    assert_eq(x, 0)
}

@test
fn test_negative_increment(): void {
    let x = 0
    x--
    assert_eq(x, -1)
}

