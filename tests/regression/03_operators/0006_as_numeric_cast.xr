// as operator for numeric type conversion (truncation, widening)

@test
fn test_float_as_int_truncation() {
    assert_eq(3.14 as int, 3)
    assert_eq(3.99 as int, 3)
    assert_eq(-2.7 as int, -2)
    assert_eq(0.0 as int, 0)
}

@test
fn test_int_as_float() {
    assert_eq(42 as float, 42.0)
    assert_eq(0 as float, 0.0)
}

@test
fn test_as_string() {
    assert_eq(123 as string, "123")
    assert_eq(3.14 as string, "3.14")
}

@test
fn test_as_bool() {
    assert_eq(1 as bool, true)
    assert_eq(0 as bool, false)
}
