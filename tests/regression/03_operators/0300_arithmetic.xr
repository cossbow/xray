// 作者：xingleixu@gmail.com
// 测试：算术运算符

// ===== 加法 =====

@test
fn test_add_integers() {
    assert_eq(1 + 2, 3)
    assert_eq(0 + 0, 0)
    assert_eq(-1 + 1, 0)
    assert_eq(-5 + -3, -8)
}

@test
fn test_add_floats() {
    assert_eq(1.5 + 2.5, 4.0)
    assert_eq(0.0 + 0.0, 0.0)
    assert_eq(-1.5 + 1.5, 0.0)
}

@test
fn test_add_mixed() {
    assert_eq(1 + 1.5, 2.5)
    assert_eq(2.5 + 1, 3.5)
}

// ===== 减法 =====

@test
fn test_sub_integers() {
    assert_eq(5 - 3, 2)
    assert_eq(0 - 0, 0)
    assert_eq(3 - 5, -2)
    assert_eq(-5 - -3, -2)
}

@test
fn test_sub_floats() {
    assert_eq(5.5 - 2.5, 3.0)
    assert_eq(1.0 - 1.0, 0.0)
}

@test
fn test_sub_mixed() {
    assert_eq(5 - 2.5, 2.5)
    assert_eq(5.5 - 2, 3.5)
}

// ===== 乘法 =====

@test
fn test_mul_integers() {
    assert_eq(3 * 4, 12)
    assert_eq(0 * 100, 0)
    assert_eq(-3 * 4, -12)
    assert_eq(-3 * -4, 12)
}

@test
fn test_mul_floats() {
    assert_eq(2.5 * 4.0, 10.0)
    assert_eq(0.5 * 0.5, 0.25)
}

@test
fn test_mul_mixed() {
    assert_eq(2 * 2.5, 5.0)
    assert_eq(2.5 * 2, 5.0)
}

// ===== 除法 =====

@test
fn test_div_integers() {
    assert_eq(10 / 2, 5)
    assert_eq(7 / 2, 3)  // 整数除法
    assert_eq(-10 / 3, -3)
}

@test
fn test_div_floats() {
    assert_eq(10.0 / 4.0, 2.5)
    assert_eq(1.0 / 2.0, 0.5)
}

@test
fn test_div_mixed() {
    assert_eq(5 / 2.0, 2.5)
    assert_eq(5.0 / 2, 2.5)
}

// ===== 取模 =====

@test
fn test_mod_positive() {
    assert_eq(10 % 3, 1)
    assert_eq(15 % 5, 0)
    assert_eq(7 % 4, 3)
}

@test
fn test_mod_negative() {
    assert_eq(-10 % 3, -1)
    assert_eq(10 % -3, 1)
}

@test
fn test_mod_zero_dividend() {
    assert_eq(0 % 5, 0)
}

// ===== 一元运算 =====

@test
fn test_unary_minus() {
    assert_eq(-5, -5)
    assert_eq(-(-5), 5)
    assert_eq(-(3 + 2), -5)
}

// 注意：xray 不支持一元正运算符 +x

// ===== 边界条件 =====

@test
fn test_with_zero() {
    assert_eq(0 + 5, 5)
    assert_eq(5 - 0, 5)
    assert_eq(0 * 100, 0)
    assert_eq(0 / 100, 0)
}

@test
fn test_identity() {
    assert_eq(5 + 0, 5)
    assert_eq(5 - 0, 5)
    assert_eq(5 * 1, 5)
    assert_eq(5 / 1, 5)
}

@test
fn test_chained() {
    assert_eq(1 + 2 + 3, 6)
    assert_eq(10 - 3 - 2, 5)
    assert_eq(2 * 3 * 4, 24)
}

// ===== 优先级 =====

@test
fn test_precedence() {
    assert_eq(2 + 3 * 4, 14)      // 乘法优先
    assert_eq((2 + 3) * 4, 20)    // 括号优先
    assert_eq(10 - 4 / 2, 8)      // 除法优先
    assert_eq(10 / 2 + 3, 8)
}

