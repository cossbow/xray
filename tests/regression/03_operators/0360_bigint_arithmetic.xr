// 0360_bigint_arithmetic.xr
// 作者：xingleixu@gmail.com
// 测试：BigInt 算术运算符

// ===== 加法 =====

@test
fn test_add_small() {
    let a = 100n
    let b = 200n
    assert_eq((a + b).toString(), "300")
}

@test
fn test_add_large() {
    let a = 999999999999999999999999999999n
    let b = 1n
    assert_eq((a + b).toString(), "1000000000000000000000000000000")
}

// ===== 减法 =====

@test
fn test_sub_basic() {
    let a = 200n
    let b = 100n
    assert_eq((a - b).toString(), "100")
}

@test
fn test_sub_negative_result() {
    let a = 100n
    let b = 200n
    assert_eq((a - b).toString(), "-100")
}

// ===== 乘法 =====

@test
fn test_mul_basic() {
    let a = 100n
    let b = 200n
    assert_eq((a * b).toString(), "20000")
}

@test
fn test_mul_large() {
    let a = 12345678901234567890n
    let b = 2n
    assert_eq((a * b).toString(), "24691357802469135780")
}

// ===== 除法 =====

@test
fn test_div_basic() {
    let a = 100n
    let b = 3n
    assert_eq((a / b).toString(), "33")
}

@test
fn test_div_exact() {
    let a = 100n
    let b = 10n
    assert_eq((a / b).toString(), "10")
}

// ===== 取模 =====

@test
fn test_mod_basic() {
    let a = 100n
    let b = 3n
    assert_eq((a % b).toString(), "1")
}

@test
fn test_mod_no_remainder() {
    let a = 100n
    let b = 10n
    assert_eq((a % b).toString(), "0")
}

// ===== 取负 =====

@test
fn test_negate_positive() {
    let a = 999n
    assert_eq((-a).toString(), "-999")
}

@test
fn test_negate_negative() {
    let a = -999n
    assert_eq((-a).toString(), "999")
}
