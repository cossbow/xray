// Strict equality must distinguish int from float
// 1 === 1.0 should be false (different types, no coercion)

// Same type comparisons
@test
fn test_strict_eq_same_type() {
    assert_eq(1 === 1, true)
    assert_eq(1.0 === 1.0, true)
    assert_eq("a" === "a", true)
    assert_eq(true === true, true)
    assert_eq(null === null, true)
}

// Cross-type: int vs float must be false
@test
fn test_strict_eq_cross_type() {
    assert_eq(1 === 1.0, false)
    assert_eq(0 === 0.0, false)
}

// Strict inequality
@test
fn test_strict_ne() {
    assert_eq(1 !== 1.0, true)
    assert_eq(1 !== 1, false)
}
