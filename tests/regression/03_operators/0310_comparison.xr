// 0310_comparison.xr
// 作者：xingleixu@gmail.com
// 测试：比较运算符

// ===== 等于 =====

@test
fn test_eq_integers(): void {
    assert_eq(5 == 5, true)
    assert_eq(5 == 6, false)
    assert_eq(0 == 0, true)
    assert_eq(-1 == -1, true)
}

@test
fn test_eq_floats(): void {
    assert_eq(3.14 == 3.14, true)
    assert_eq(3.14 == 3.15, false)
}

@test
fn test_eq_strings(): void {
    assert_eq("hello" == "hello", true)
    assert_eq("hello" == "world", false)
    assert_eq("" == "", true)
}

@test
fn test_eq_bool(): void {
    assert_eq(true == true, true)
    assert_eq(false == false, true)
    assert_eq(true == false, false)
}

@test
fn test_eq_null(): void {
    assert_eq(null == null, true)
    let x = null
    assert_eq(x == null, true)
}

// ===== 不等于 =====

@test
fn test_ne_integers(): void {
    assert_eq(5 != 6, true)
    assert_eq(5 != 5, false)
}

@test
fn test_ne_strings(): void {
    assert_eq("a" != "b", true)
    assert_eq("a" != "a", false)
}

@test
fn test_ne_mixed(): void {
    assert_eq(1 != null, true)
    assert_eq("" != null, true)
}

// ===== 小于 =====

@test
fn test_lt_integers(): void {
    assert_eq(3 < 5, true)
    assert_eq(5 < 5, false)
    assert_eq(5 < 3, false)
    assert_eq(-5 < 0, true)
}

@test
fn test_lt_floats(): void {
    assert_eq(3.14 < 3.15, true)
    assert_eq(3.14 < 3.14, false)
}

@test
fn test_lt_strings(): void {
    assert_eq("a" < "b", true)
    assert_eq("abc" < "abd", true)
    assert_eq("b" < "a", false)
}

// ===== 小于等于 =====

@test
fn test_le_integers(): void {
    assert_eq(3 <= 5, true)
    assert_eq(5 <= 5, true)
    assert_eq(6 <= 5, false)
}

@test
fn test_le_floats(): void {
    assert_eq(3.14 <= 3.14, true)
    assert_eq(3.14 <= 3.15, true)
}

// ===== 大于 =====

@test
fn test_gt_integers(): void {
    assert_eq(5 > 3, true)
    assert_eq(5 > 5, false)
    assert_eq(3 > 5, false)
    assert_eq(0 > -5, true)
}

@test
fn test_gt_floats(): void {
    assert_eq(3.15 > 3.14, true)
    assert_eq(3.14 > 3.14, false)
}

@test
fn test_gt_strings(): void {
    assert_eq("b" > "a", true)
    assert_eq("a" > "b", false)
}

// ===== 大于等于 =====

@test
fn test_ge_integers(): void {
    assert_eq(5 >= 3, true)
    assert_eq(5 >= 5, true)
    assert_eq(3 >= 5, false)
}

@test
fn test_ge_floats(): void {
    assert_eq(3.14 >= 3.14, true)
    assert_eq(3.15 >= 3.14, true)
}

// ===== 边界条件 =====

@test
fn test_compare_with_zero(): void {
    assert_eq(0 == 0, true)
    assert_eq(0 < 1, true)
    assert_eq(0 > -1, true)
    assert_eq(-0.0 == 0.0, true)
}

@test
fn test_chain_comparison(): void {
    let x = 5
    assert_eq(3 < x && x < 10, true)
    assert_eq(0 <= x && x <= 10, true)
}

