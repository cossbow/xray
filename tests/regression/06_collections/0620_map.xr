// 0620_map.xr
// 作者：xingleixu@gmail.com
// 测试：Map 集合
// ===== 创建 =====
@test
fn test_map_literal(): void {
    let m = { "a" => 1, "b" => 2, "c" => 3 }
    assert_eq(m.length, 3)
}

@test
fn test_empty_map(): void {
    let m = #{}
    assert_eq(m.length, 0)
}

@test
fn test_single_entry(): void {
    let m = { "key" => "value" }
    assert_eq(m.length, 1)
}

// ===== 获取 =====
@test
fn test_get_basic(): void {
    let m = { "name" => "Alice", "age" => 30 }
    assert_eq(m.get("name"), "Alice")
    assert_eq(m.get("age"), 30)
}

@test
fn test_get_missing(): void {
    let m = { "a" => 1 }
    assert_eq(m.get("b"), null)
}

@test
fn test_bracket_access(): void {
    let m = { "x" => 10, "y" => 20 }
    assert_eq(m["x"], 10)
    assert_eq(m["y"], 20)
}

// ===== 设置 =====
@test
fn test_set_new(): void {
    let m = #{}
    m.set("key", "value")
    assert_eq(m.get("key"), "value")
    assert_eq(m.length, 1)
}

@test
fn test_set_overwrite(): void {
    let m = { "key" => "old" }
    m.set("key", "new")
    assert_eq(m.get("key"), "new")
    assert_eq(m.length, 1)
}

@test
fn test_bracket_assign(): void {
    let m = #{}
    m["x"] = 100
    assert_eq(m["x"], 100)
}

// ===== 检查 =====
@test
fn test_has_key(): void {
    let m = { "a" => 1, "b" => 2 }
    assert_eq(m.has("a"), true)
    assert_eq(m.has("c"), false)
}

// ===== 删除 =====
@test
fn test_delete(): void {
    let m = { "a" => 1, "b" => 2, "c" => 3 }
    m.delete("b")
    assert_eq(m.length, 2)
    assert_eq(m.has("b"), false)
    assert_eq(m.has("a"), true)
    assert_eq(m.has("c"), true)
}

@test
fn test_delete_missing(): void {
    let m = { "a" => 1 }
    m.delete("b")
    // 不存在的键
    assert_eq(m.length, 1)
}

// ===== 遍历 =====
@test
fn test_iterate_values(): void {
    let m = { "a" => 1, "b" => 2, "c" => 3 }
    let sum = 0
    for (k, v in m) {
        sum += v
    }
    assert_eq(sum, 6)
}

@test
fn test_collect_keys(): void {
    let m = { "x" => 10, "y" => 20, "z" => 30 }
    let keys: Array<string> = []
    for (k, v in m) {
        keys.push(k)
    }
    assert_eq(keys.length, 3)
}

// ===== keys/values =====
@test
fn test_keys(): void {
    let m = { "a" => 1, "b" => 2 }
    let keys = m.keys()
    assert_eq(keys.length, 2)
}

@test
fn test_values(): void {
    let m = { "a" => 1, "b" => 2 }
    let values = m.values()
    assert_eq(values.length, 2)
}

// ===== 清空 =====
@test
fn test_clear(): void {
    let m = { "a" => 1, "b" => 2, "c" => 3 }
    m.clear()
    assert_eq(m.length, 0)
}

// ===== 不同类型的键值 =====
@test
fn test_string_keys(): void {
    let m = { "hello" => 1, "world" => 2 }
    assert_eq(m.get("hello"), 1)
}

@test
fn test_mixed_value_types(): void {
    let m = { "int" => 42, "str" => "hello", "bool" => true, "null" => null }
    assert_eq(m.get("int"), 42)
    assert_eq(m.get("str"), "hello")
    assert_eq(m.get("bool"), true)
    assert_eq(m.get("null"), null)
}

// ===== 边界条件 =====
@test
fn test_many_entries(): void {
    let m = #{}
    for (let i = 0; i < 100; i++) {
        m.set("key" + i.toString(), i)
    }
    assert_eq(m.length, 100)
    assert_eq(m.get("key50"), 50)
}

@test
fn test_overwrite_many_times(): void {
    let m = { "x" => 0 }
    for (let i = 0; i < 10; i++) {
        m.set("x", i)
    }
    assert_eq(m.get("x"), 9)
    assert_eq(m.length, 1)
}
