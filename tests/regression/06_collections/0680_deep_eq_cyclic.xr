// 0680_deep_eq_cyclic.xr
// Test: deep equality across many shared sub-objects.
// Regression: previously the cycle-detection visited list was capped at
// 64 (a, b) pairs, which produced false negatives on structures with
// many shared sub-arrays. The visited set is now an unbounded hash set.
@test
fn deep_eq_many_shared_arrays() {
    // Build two parallel arrays where each element is itself a fresh
    // 3-element array. Use 200 elements -- well beyond the old 64-pair
    // cap -- so deep_compare must visit > 64 distinct (a, b) pairs.
    let a: Array<Array<int>> = []
    let b: Array<Array<int>> = []
    for (let i = 0; i < 200; i++) {
        a.push([i, i + 1, i + 2])
        b.push([i, i + 1, i + 2])
    }
    assert(a == b, "200-deep parallel arrays must compare equal")

    // Mutate one cell deep in the structure -- equality must flip.
    a[150][1] = -1
    assert(a != b, "single inner mutation must break equality")
}

@test
fn deep_eq_nested_maps() {
    // Same idea for maps: 100 keys, each holding a small array.
    let m1 = #{}
    let m2 = #{}
    for (let k = 0; k < 100; k++) {
        let key = "k" + k.toString()
        m1.set(key, [k, k * 2])
        m2.set(key, [k, k * 2])
    }
    assert(m1 == m2, "100-entry parallel maps must compare equal")

    let inner = m2.get("k50")
    inner[0] = 999
    assert(m1 != m2, "value mutation must break map equality")
}
