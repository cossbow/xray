// 测试：接口定义和实现

// ===== 基本接口 =====

interface Drawable {
    draw(): void
}

class Circle implements Drawable {
    radius: float

    constructor(radius: float) {
        this.radius = radius
    }

    draw(): void {        // 实现接口方法
    }

    getRadius(): float {        return this.radius
    }
}

@test
fn test_interface_implementation(): void {
    let circle = new Circle(5.0)
    assert_eq(circle.getRadius(), 5.0)
}

// ===== 多方法接口 =====

interface Shape {
    area(): float
    perimeter(): float
}

class Rectangle implements Shape {
    width: float
    height: float

    constructor(w: float, h: float) {
        this.width = w
        this.height = h
    }

    area(): float {        return this.width * this.height
    }

    perimeter(): float {        return 2 * (this.width + this.height)
    }
}

@test
fn test_multi_method_interface(): void {
    let rect = new Rectangle(3.0, 4.0)
    assert_eq(rect.area(), 12.0)
    assert_eq(rect.perimeter(), 14.0)
}

// ===== 多个类实现同一接口 =====

class Square implements Shape {
    side: float

    constructor(s: float) {
        this.side = s
    }

    area(): float {        return this.side * this.side
    }

    perimeter(): float {        return 4 * this.side
    }
}

@test
fn test_multiple_implementations(): void {
    let rect = new Rectangle(2.0, 3.0)
    let square = new Square(4.0)

    assert_eq(rect.area(), 6.0)
    assert_eq(square.area(), 16.0)
}

// ===== 接口与普通方法混合 =====

interface Printable {
    toString(): string
}

class Person implements Printable {
    name: string
    age: int

    constructor(name: string, age: int) {
        this.name = name
        this.age = age
    }

    toString(): string {        return this.name + " (" + this.age + ")"
    }

    greet(): string {        return "Hello, " + this.name
    }
}

@test
fn test_interface_with_extra_methods(): void {
    let p = new Person("Alice", 30)
    assert_eq(p.greet(), "Hello, Alice")
}

