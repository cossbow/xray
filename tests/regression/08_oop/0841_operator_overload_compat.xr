// 0841_operator_overload_compat.xr
// 作者：xingleixu@gmail.com
// 测试：运算符重载优化向后兼容性
//
// **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
// **Validates: Requirements 5.1, 5.3**
//
// **Feature: operator-overload-optimization, Property 6: 向后兼容性 - 无运算符重载**
// **Validates: Requirements 5.2**
//
// 验证：
// 1. 有运算符重载的类执行算术运算产生正确结果
// 2. 无运算符重载的类执行算术运算产生正确结果
// 3. 继承运算符重载的类正确工作
// 4. 通过 builder API 动态添加运算符方法后正确工作

// ===== Property 5: 有运算符重载的类 =====

// 测试类：Vector2D - 有加减乘除运算符重载
class Vector2D {
    x: float
    y: float
    
    constructor(x, y) {
        this.x = x
        this.y = y
    }
    
    operator+(other: Vector2D) -> Vector2D {
        return new Vector2D(this.x + other.x, this.y + other.y)
    }
    
    operator-(other: Vector2D) -> Vector2D {
        return new Vector2D(this.x - other.x, this.y - other.y)
    }
    
    operator*(scalar: float) -> Vector2D {
        return new Vector2D(this.x * scalar, this.y * scalar)
    }
    
    operator/(scalar: float) -> Vector2D {
        return new Vector2D(this.x / scalar, this.y / scalar)
    }
    
    operator==(other: Vector2D) -> bool {
        return this.x == other.x && this.y == other.y
    }
}

@test
fn test_property5_add_operator() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let a = new Vector2D(1.0, 2.0)
    let b = new Vector2D(3.0, 4.0)
    let c = a + b
    assert_eq(c.x, 4.0)
    assert_eq(c.y, 6.0)
}

@test
fn test_property5_sub_operator() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let a = new Vector2D(5.0, 7.0)
    let b = new Vector2D(2.0, 3.0)
    let c = a - b
    assert_eq(c.x, 3.0)
    assert_eq(c.y, 4.0)
}

@test
fn test_property5_mul_operator() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let v = new Vector2D(2.0, 3.0)
    let scaled = v * 2.0
    assert_eq(scaled.x, 4.0)
    assert_eq(scaled.y, 6.0)
}

@test
fn test_property5_div_operator() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let v = new Vector2D(10.0, 20.0)
    let halved = v / 2.0
    assert_eq(halved.x, 5.0)
    assert_eq(halved.y, 10.0)
}

@test
fn test_property5_eq_operator() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let a = new Vector2D(1.0, 2.0)
    let b = new Vector2D(1.0, 2.0)
    let c = new Vector2D(3.0, 4.0)
    assert_eq(a == b, true)
    assert_eq(a == c, false)
}

@test
fn test_property5_chained_operations() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let a = new Vector2D(1.0, 1.0)
    let b = new Vector2D(2.0, 2.0)
    let c = new Vector2D(3.0, 3.0)
    let result = a + b + c
    assert_eq(result.x, 6.0)
    assert_eq(result.y, 6.0)
}

// ===== 测试类：Money - 有比较运算符重载 =====

class Money {
    amount: int
    
    constructor(amount) {
        this.amount = amount
    }
    
    operator<(other: Money) -> bool {
        return this.amount < other.amount
    }
    
    operator<=(other: Money) -> bool {
        return this.amount <= other.amount
    }
    
    operator>(other: Money) -> bool {
        return this.amount > other.amount
    }
    
    operator>=(other: Money) -> bool {
        return this.amount >= other.amount
    }
}

@test
fn test_property5_comparison_operators() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let a = new Money(100)
    let b = new Money(200)
    let c = new Money(100)
    
    assert_eq(a < b, true)
    assert_eq(a <= b, true)
    assert_eq(b > a, true)
    assert_eq(b >= a, true)
    assert_eq(a <= c, true)
    assert_eq(a >= c, true)
}

// ===== 测试类：BitSet - 有位运算符重载 =====

class BitSet {
    value: int
    
    constructor(v) {
        this.value = v
    }
    
    operator &(other: BitSet) -> BitSet {
        return new BitSet(this.value & other.value)
    }
    
    operator |(other: BitSet) -> BitSet {
        return new BitSet(this.value | other.value)
    }
    
    operator ^(other: BitSet) -> BitSet {
        return new BitSet(this.value ^ other.value)
    }
}

@test
fn test_property5_bitwise_and() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let bs1 = new BitSet(12)  // 0b1100
    let bs2 = new BitSet(10)  // 0b1010
    let result = bs1 & bs2
    assert_eq(result.value, 8)  // 0b1000
}

@test
fn test_property5_bitwise_or() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let bs1 = new BitSet(12)  // 0b1100
    let bs2 = new BitSet(10)  // 0b1010
    let result = bs1 | bs2
    assert_eq(result.value, 14)  // 0b1110
}

@test
fn test_property5_bitwise_xor() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let bs1 = new BitSet(12)  // 0b1100
    let bs2 = new BitSet(10)  // 0b1010
    let result = bs1 ^ bs2
    assert_eq(result.value, 6)  // 0b0110
}

// ===== 测试类：Matrix - 有下标运算符重载 =====

class Matrix {
    data: Array<int>
    
    constructor() {
        this.data = [0, 0, 0, 0]
    }
    
    operator[](index: int) -> int {
        return this.data[index]
    }
    
    operator[]=(index: int, value: int) {
        this.data[index] = value
    }
}

@test
fn test_property5_subscript_get() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let m = new Matrix()
    m.data[0] = 10
    m.data[1] = 20
    assert_eq(m[0], 10)
    assert_eq(m[1], 20)
}

@test
fn test_property5_subscript_set() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let m = new Matrix()
    m[0] = 100
    m[1] = 200
    assert_eq(m.data[0], 100)
    assert_eq(m.data[1], 200)
}

// ===== 测试继承运算符重载 =====

class Vector3D extends Vector2D {
    z: float
    
    constructor(x, y, z) {
        super(x, y)
        this.z = z
    }
    
    // 重写加法运算符
    operator+(other: Vector3D) -> Vector3D {
        return new Vector3D(this.x + other.x, this.y + other.y, this.z + other.z)
    }
}

@test
fn test_property5_inherited_operator() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let a = new Vector3D(1.0, 2.0, 3.0)
    let b = new Vector3D(4.0, 5.0, 6.0)
    let c = a + b
    assert_eq(c.x, 5.0)
    assert_eq(c.y, 7.0)
    assert_eq(c.z, 9.0)
}

// ===== Property 6: 无运算符重载的类 =====

// 测试类：Point - 没有运算符重载
class Point {
    x: int
    y: int
    
    constructor(x, y) {
        this.x = x
        this.y = y
    }
    
    add(other: Point) -> Point {
        return new Point(this.x + other.x, this.y + other.y)
    }
}

@test
fn test_property6_no_operator_overload() {
    // **Feature: operator-overload-optimization, Property 6: 向后兼容性 - 无运算符重载**
    // **Validates: Requirements 5.2**
    let p1 = new Point(1, 2)
    let p2 = new Point(3, 4)
    
    // 使用普通方法而不是运算符
    let p3 = p1.add(p2)
    assert_eq(p3.x, 4)
    assert_eq(p3.y, 6)
}

@test
fn test_property6_primitive_arithmetic() {
    // **Feature: operator-overload-optimization, Property 6: 向后兼容性 - 无运算符重载**
    // **Validates: Requirements 5.2**
    // 验证原始类型的算术运算不受影响
    let a = 10
    let b = 3
    
    assert_eq(a + b, 13)
    assert_eq(a - b, 7)
    assert_eq(a * b, 30)
    assert_eq(a / b, 3)
    assert_eq(a % b, 1)
}

@test
fn test_property6_primitive_comparison() {
    // **Feature: operator-overload-optimization, Property 6: 向后兼容性 - 无运算符重载**
    // **Validates: Requirements 5.2**
    // 验证原始类型的比较运算不受影响
    let a = 10
    let b = 20
    
    assert_eq(a < b, true)
    assert_eq(a <= b, true)
    assert_eq(b > a, true)
    assert_eq(b >= a, true)
    assert_eq(a == a, true)
    assert_eq(a != b, true)
}

@test
fn test_property6_primitive_bitwise() {
    // **Feature: operator-overload-optimization, Property 6: 向后兼容性 - 无运算符重载**
    // **Validates: Requirements 5.2**
    // 验证原始类型的位运算不受影响
    let a = 12  // 0b1100
    let b = 10  // 0b1010
    
    assert_eq(a & b, 8)   // 0b1000
    assert_eq(a | b, 14)  // 0b1110
    assert_eq(a ^ b, 6)   // 0b0110
}

@test
fn test_property6_float_arithmetic() {
    // **Feature: operator-overload-optimization, Property 6: 向后兼容性 - 无运算符重载**
    // **Validates: Requirements 5.2**
    // 验证浮点数算术运算不受影响
    let a = 10.5
    let b = 2.5
    
    assert_eq(a + b, 13.0)
    assert_eq(a - b, 8.0)
    assert_eq(a * b, 26.25)
    assert_eq(a / b, 4.2)
}

@test
fn test_property6_string_concat() {
    // **Feature: operator-overload-optimization, Property 6: 向后兼容性 - 无运算符重载**
    // **Validates: Requirements 5.2**
    // 验证字符串拼接不受影响
    let s1 = "Hello"
    let s2 = " World"
    let s3 = s1 + s2
    assert_eq(s3, "Hello World")
}

// ===== 混合测试：有运算符重载和无运算符重载的类混合使用 =====

@test
fn test_mixed_classes() {
    // 同时使用有运算符重载和无运算符重载的类
    let v1 = new Vector2D(1.0, 2.0)
    let v2 = new Vector2D(3.0, 4.0)
    let p1 = new Point(1, 2)
    let p2 = new Point(3, 4)
    
    // Vector2D 使用运算符重载
    let v3 = v1 + v2
    assert_eq(v3.x, 4.0)
    assert_eq(v3.y, 6.0)
    
    // Point 使用普通方法
    let p3 = p1.add(p2)
    assert_eq(p3.x, 4)
    assert_eq(p3.y, 6)
    
    // 原始类型运算
    let sum = 10 + 20
    assert_eq(sum, 30)
}

// ===== 测试取模运算符重载 =====

class ModVector {
    x: int
    y: int
    
    constructor(x, y) {
        this.x = x
        this.y = y
    }
    
    operator%(other: ModVector) -> ModVector {
        return new ModVector(this.x % other.x, this.y % other.y)
    }
}

@test
fn test_property5_mod_operator() {
    // **Feature: operator-overload-optimization, Property 5: 向后兼容性 - 有运算符重载**
    // **Validates: Requirements 5.1, 5.3**
    let a = new ModVector(17, 23)
    let b = new ModVector(5, 7)
    let c = a % b
    assert_eq(c.x, 2)  // 17 % 5 = 2
    assert_eq(c.y, 2)  // 23 % 7 = 2
}

