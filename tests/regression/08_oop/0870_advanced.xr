// ===== super.method() 完整测试 =====

class Shape {
    name: string

    constructor(name) {
        this.name = name
    }

    describe() -> string {        return "Shape: " + this.name
    }

    area() -> int {        return 0
    }
}

class Rectangle extends Shape {
    width: int
    height: int

    constructor(w, h) {
        super("Rectangle")
        this.width = w
        this.height = h
    }

    describe() -> string {        // 调用父类方法并扩展
        return super.describe() + " (${this.width}x${this.height})"
    }

    area() -> int {        return this.width * this.height
    }
}

@test
fn test_super_method_with_extension() {
    let rect = new Rectangle(5, 3)
    assert_eq(rect.describe(), "Shape: Rectangle (5x3)")
    assert_eq(rect.area(), 15)
}

// ===== 三层继承 + super =====

class A {
    value: int

    constructor(v) {
        this.value = v
    }

    getValue() -> int {        return this.value
    }

    describe() -> string {        return "A:${this.value}"
    }
}

class B extends A {
    extra: int

    constructor(v, e) {
        super(v)
        this.extra = e
    }

    getValue() -> int {        return super.getValue() + this.extra
    }

    describe() -> string {        return super.describe() + ",B:${this.extra}"
    }
}

class C extends B {
    more: int

    constructor(v, e, m) {
        super(v, e)
        this.more = m
    }

    getValue() -> int {        return super.getValue() + this.more
    }

    describe() -> string {        return super.describe() + ",C:${this.more}"
    }
}

@test
fn test_three_level_inheritance() {
    let c = new C(1, 2, 3)
    assert_eq(c.value, 1)
    assert_eq(c.extra, 2)
    assert_eq(c.more, 3)
    assert_eq(c.getValue(), 6)  // 1 + 2 + 3
    assert_eq(c.describe(), "A:1,B:2,C:3")
}

// ===== super 在不同方法中调用 =====

class Logger {
    prefix: string

    constructor(prefix) {
        this.prefix = prefix
    }

    log(msg: string) -> string {        return this.prefix + ": " + msg    }

    warn(msg: string) -> string {        return "[WARN] " + this.log(msg)    }
}

class FileLogger extends Logger {
    file: string

    constructor(file) {
        super("FILE")
        this.file = file
    }

    log(msg: string) -> string {        return super.log(msg) + " -> " + this.file    }

    // warn 继承自父类，但会调用子类的 log
}

@test
fn test_super_in_chain() {
    let fl = new FileLogger("app.log")
    assert_eq(fl.log("test"), "FILE: test -> app.log")
    assert_eq(fl.warn("error"), "[WARN] FILE: error -> app.log")
}

// ===== 方法作为一等公民 =====

class Processor {
    factor: int

    constructor(f) {
        this.factor = f
    }

    process(x: int) -> int {        return x * this.factor    }
}

@test
fn test_method_reference() {
    let p = new Processor(3)
    assert_eq(p.process(5), 15)

    // 方法绑定到实例
    let fn_ref = p.process
    // 注意：这需要语言支持绑定方法
    // assert_eq(fn_ref(5), 15)
}

// ===== 类内部调用其他方法 =====

class Calculator {
    base: int

    constructor(base) {
        this.base = base
    }

    add(x: int) -> int {        return this.base + x    }

    addTwice(x: int) -> int {        return this.add(x) + this.add(x)    }

    addChain(a: int, b: int, c: int) -> int {        return this.add(a) + this.add(b) + this.add(c) - this.base * 2    }
}

@test
fn test_internal_method_calls() {
    let calc = new Calculator(10)
    assert_eq(calc.add(5), 15)
    assert_eq(calc.addTwice(3), 26)  // (10+3) + (10+3)
    assert_eq(calc.addChain(1, 2, 3), 16)  // (10+1) + (10+2) + (10+3) - 20
}

// ===== 构造函数中调用方法 =====

class Initializer {
    data: string
    processed: string

    constructor(input: string) {
        this.data = input
        this.processed = this.transform(input)
    }

    transform(s: string) -> string {        return "[" + s + "]"    }
}

@test
fn test_constructor_calls_method() {
    let init = new Initializer("hello")
    assert_eq(init.data, "hello")
    assert_eq(init.processed, "[hello]")
}

// ===== 字段初始化顺序 =====

class Ordered {
    a: int
    b: int
    c: int

    constructor() {
        this.a = 1
        this.b = this.a + 1
        this.c = this.b + 1
    }
}

@test
fn test_field_init_order() {
    let o = new Ordered()
    assert_eq(o.a, 1)
    assert_eq(o.b, 2)
    assert_eq(o.c, 3)
}

// ===== 对象作为参数 =====

class Box {
    value: int

    constructor(v) {
        this.value = v
    }

    add(other: Box) -> Box {
        return new Box(this.value + other.value)
    }

    equals(other: Box) -> bool {
        return this.value == other.value
    }
}

@test
fn test_object_as_param() {
    let b1 = new Box(10)
    let b2 = new Box(20)
    let b3 = b1.add(b2)

    assert_eq(b3.value, 30)
    assert_eq(b1.equals(b2), false)
    assert_eq(b1.equals(new Box(10)), true)
}

// ===== 对象数组 =====

class Item {
    name: string
    price: int

    constructor(n, p) {
        this.name = n
        this.price = p
    }
}

@test
fn test_object_array() {
    let items = [
        new Item("apple", 100),
        new Item("banana", 50),
        new Item("orange", 75)
    ]

    assert_eq(items.length, 3)
    assert_eq(items[0].name, "apple")
    assert_eq(items[1].price, 50)

    // 计算总价
    let total = 0
    for (item in items) {
        total = total + item.price
    }
    assert_eq(total, 225)
}

// ===== 对象存入 Map =====

class MapUser {
    name: string
    level: int

    constructor(n, l) {
        this.name = n
        this.level = l
    }
}

@test
fn test_object_in_map() {
    let users = #{}  // 使用 #{} 创建 Map，不是 {}
    users["alice"] = new MapUser("Alice", 10)
    users["bob"] = new MapUser("Bob", 5)

    assert_eq(users["alice"].name, "Alice")
    assert_eq(users["alice"].level, 10)
    assert_eq(users["bob"].name, "Bob")
    assert_eq(users["bob"].level, 5)
}

