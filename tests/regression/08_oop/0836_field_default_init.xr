/*
 * 0836_field_default_init.xr - test class field default initialization
 */

class Simple {
    a = 0
    b = 3.14
    c = "hello"
    d = true

    constructor() {
        // 字段已自动初始化
    }
}
class Complex {
    _map = #{}
    _arr: Array<int> = []
    _config: Map<string, int> = {"debug" => 0, "port" => 8080}

    constructor() {
        // 字段已自动初始化
    }

    addItem(key: string, value: int): void {
        this._map[key] = value
        this._arr.push(value)
    }

    getMapSize(): int {
        return this._map.keys().length
    }

    getArrSize(): int {
        return this._arr.length
    }

    getPort(): int {
        return this._config["port"]
    }
}
class Override {
    _name = "default"
    _count = 0

    constructor(name, count) {
        this._name = name
        this._count = count
    }

    getName(): string {
        return this._name
    }

    getCount(): int {
        return this._count
    }
}
class Counter {
    _items: Array<string> = []

    constructor() {}

    add(item: string): void {
        this._items.push(item)
    }

    count(): int {
        return this._items.length
    }
}

@test
fn test_field_default_init() {

    /* 测试1：简单字面量默认值 */

    let s = new Simple()

    print("Simple.a = ${s.a}")       // expect: 0
    print("Simple.b = ${s.b}")       // expect: 3.14
    print("Simple.c = ${s.c}")       // expect: hello
    print("Simple.d = ${s.d}")       // expect: true

    /* 测试2：复合类型默认值 */

    let c = new Complex()


    print("初始 map size: ${c.getMapSize()}")  // expect: 0
    print("初始 arr size: ${c.getArrSize()}")  // expect: 0
    print("config port: ${c.getPort()}")       // expect: 8080

    c.addItem("a", 1)
    c.addItem("b", 2)
    print("添加后 map size: ${c.getMapSize()}")  // expect: 2
    print("添加后 arr size: ${c.getArrSize()}")  // expect: 2

    /* 测试3：构造函数参数覆盖默认值 */

    let o2 = new Override("custom", 42)

    print("Override 覆盖 name: ${o2.getName()}")   // expect: custom
    print("Override 覆盖 count: ${o2.getCount()}") // expect: 42

    /* 测试4：多实例独立性 */

    let c1 = new Counter()
    let c2 = new Counter()

    c1.add("a")
    c1.add("b")
    c2.add("x")

    print("c1 count: ${c1.count()}")  // expect: 2
    print("c2 count: ${c2.count()}")  // expect: 1
}

