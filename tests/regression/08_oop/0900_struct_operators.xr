// Test: struct operator overloading
// Expected: operator +, ==, - work correctly with value semantics

struct Vec2 {
    x: float
    y: float

    operator +(other: Vec2): Vec2 {
        return Vec2{x: this.x + other.x, y: this.y + other.y}
    }

    operator -(other: Vec2): Vec2 {
        return Vec2{x: this.x - other.x, y: this.y - other.y}
    }

    operator ==(other: Vec2): bool {
        return this.x === other.x && this.y === other.y
    }
}

let a = Vec2{x: 1.0, y: 2.0}
let b = Vec2{x: 3.0, y: 4.0}

// === operator + ===
let c = a + b
assert(c.x == 4.0)
assert(c.y == 6.0)

// === operator - ===
let d = b - a
assert(d.x == 2.0)
assert(d.y == 2.0)

// === operator == ===
let e = Vec2{x: 1.0, y: 2.0}
assert(a == e)
assert(!(a == b))

// === Chained operators ===
let f = a + b + a
assert(f.x == 5.0)
assert(f.y == 8.0)

// === Value semantics preserved after operator ===
a.x = 99.0
assert(c.x == 4.0)
assert(d.x == 2.0)

// === Operator on copies ===
let g = a
let h = g + Vec2{x: 1.0, y: 0.0}
assert(h.x == 100.0)
assert(g.x == 99.0)

print("ok")
