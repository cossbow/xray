// 测试：类基础

// ===== 简单类 =====

class Point {
    x: int
    y: int
    
    constructor(x, y) {
        this.x = x
        this.y = y
    }
    
    toString(): string {
        return "(${this.x}, ${this.y})"
    }
}

@test
fn test_class_instantiation(): void {
    let p = new Point(3, 4)
    assert_eq(p.x, 3)
    assert_eq(p.y, 4)
}

@test
fn test_class_method(): void {
    let p = new Point(5, 10)
    assert_eq(p.toString(), "(5, 10)")
}

// ===== 方法调用 =====

class Counter {
    count: int
    
    constructor() {
        this.count = 0
    }
    
    increment(): void {
        this.count = this.count + 1
    }
    
    decrement(): void {
        this.count = this.count - 1
    }
    
    getValue(): int {
        return this.count
    }
}

@test
fn test_method_modifies_state(): void {
    let c = new Counter()
    assert_eq(c.getValue(), 0)
    
    c.increment()
    c.increment()
    assert_eq(c.getValue(), 2)
    
    c.decrement()
    assert_eq(c.getValue(), 1)
}

// ===== 多个实例 =====

@test
fn test_multiple_instances(): void {
    let c1 = new Counter()
    let c2 = new Counter()
    
    c1.increment()
    c1.increment()
    c2.increment()
    
    assert_eq(c1.getValue(), 2)
    assert_eq(c2.getValue(), 1)
}

// ===== 方法返回 this =====

class Builder {
    value: string
    
    constructor() {
        this.value = ""
    }
    
    append(s: string): string {
        this.value += s
        return this
    }
    
    build(): int {
        return this.value
    }
}

@test
fn test_method_chaining(): void {
    let b = new Builder()
    let result = b.append("hello").append(" ").append("world").build()
    assert_eq(result, "hello world")
}

// ===== 默认值 =====

class Config {
    name: string
    enabled: bool
    
    constructor() {
        this.name = "default"
        this.enabled = true
    }
}

@test
fn test_default_values(): void {
    let cfg = new Config()
    assert_eq(cfg.name, "default")
    assert_eq(cfg.enabled, true)
}

// ===== 字段访问 =====

class Person {
    name: string
    age: int
    
    constructor(name, age) {
        this.name = name
        this.age = age
    }
}

@test
fn test_field_read(): void {
    let p = new Person("Alice", 30)
    assert_eq(p.name, "Alice")
    assert_eq(p.age, 30)
}

@test
fn test_field_write(): void {
    let p = new Person("Alice", 30)
    p.name = "Bob"
    p.age = 25
    assert_eq(p.name, "Bob")
    assert_eq(p.age, 25)
}

// ===== 多参数方法 =====

class Calculator {
    add(a: int, b: int): int {
        return a + b
    }
    
    multiply(a: int, b: int, c: int): int {
        return a * b * c
    }
}

@test
fn test_multi_param_methods(): void {
    let calc = new Calculator()
    assert_eq(calc.add(3, 5), 8)
    assert_eq(calc.multiply(2, 3, 4), 24)
}

