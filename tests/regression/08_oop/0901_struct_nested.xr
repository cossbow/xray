// Test: nested struct (struct field is another struct instance)
// Expected: nested struct fields work, copy is deep

struct Point {
    x: float
    y: float
}
struct Rect {
    origin: Point
    size: Point

    area(): float {
        return this.size.x * this.size.y
    }
}

@test
fn test_struct_nested() {


    // === Basic nested construction ===
    let r = Rect{
        origin: Point{x: 0.0, y: 0.0},
        size: Point{x: 100.0, y: 50.0}
    }
    assert(r.origin.x == 0.0)
    assert(r.origin.y == 0.0)
    assert(r.size.x == 100.0)
    assert(r.size.y == 50.0)
    assert(r.area() == 5000.0)

    // === Copy of nested struct is deep ===
    let r2 = r
    r2.origin.x = 10.0
    r2.size.x = 200.0
    assert(r.origin.x == 0.0)
    assert(r.size.x == 100.0)
    assert(r2.origin.x == 10.0)
    assert(r2.size.x == 200.0)

    // === Method on copied nested struct ===
    assert(r.area() == 5000.0)
    assert(r2.area() == 10000.0)
}

