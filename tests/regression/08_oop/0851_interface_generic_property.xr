// 0851_interface_generic_property.xr
// 作者：xingleixu@gmail.com
// 测试：接口的泛型类型参数、属性签名、以及 implements/extends
//      子句对参数化接口的承载（语法层面）。
//
// 说明：当前阶段约束匹配仍按裸名进行，所以 `Iterable<int>` 与
// `Iterable<string>` 在类型层面是等价的；type-arg-aware 校验是后续
// commit 的工作。

// ===== 单类型参数泛型接口 =====

interface Container<T> {
    get(index: int): T
    size(): int
}

class IntBox implements Container<int> {
    value: int

    constructor(v: int) {
        this.value = v
    }

    get(index: int): int {
        return this.value
    }

    size(): int {
        return 1
    }
}

@test
fn test_implements_with_type_args(): void {
    let b = new IntBox(42)
    assert_eq(b.get(0), 42)
    assert_eq(b.size(), 1)
}

// ===== 多类型参数泛型接口 + 带类型实参的 extends =====

interface Pair<K, V> {
    key(): K
    value(): V
}

interface KVDescriptor<K, V> extends Pair<K, V> {
    describe(): string
}

class StringIntEntry implements KVDescriptor<string, int> {
    k: string
    v: int

    constructor(k: string, v: int) {
        this.k = k
        this.v = v
    }

    key(): string {
        return this.k
    }

    value(): int {
        return this.v
    }

    describe(): string {
        return this.k
    }
}

@test
fn test_extends_with_type_args(): void {
    let e = new StringIntEntry("age", 30)
    assert_eq(e.key(), "age")
    assert_eq(e.value(), 30)
    assert_eq(e.describe(), "age")
}

// ===== 接口属性签名 =====

interface HasLength {
    length: int
}

class Buffer implements HasLength {
    size: int

    constructor(s: int) {
        this.size = s
    }

    length: int {
        fn() { return this.size }
    }
}

@test
fn test_interface_property(): void {
    let b = new Buffer(10)
    assert_eq(b.length, 10)
}

// ===== 接口属性 + const 修饰 =====

interface Identifiable {
    const id: int
    name: string
}

class Item implements Identifiable {
    item_id: int
    item_name: string

    constructor(id: int, name: string) {
        this.item_id = id
        this.item_name = name
    }

    id: int {
        fn() { return this.item_id }
    }

    name: string {
        fn() { return this.item_name }
    }
}

@test
fn test_interface_const_property(): void {
    let it = new Item(7, "widget")
    assert_eq(it.id, 7)
    assert_eq(it.name, "widget")
}

// ===== 泛型接口 + 属性混合 =====

interface SizedCollection<T> {
    length: int
    first(): T
}

@test
fn test_generic_interface_with_property_declares(): void {
    assert_eq(1, 1)
}

// ===== 受约束的泛型类型参数 =====

interface Numeric {
    toFloat(): float
}

interface Stats<T: Numeric> {
    mean(): float
    sum(): T
}

@test
fn test_constrained_generic_interface(): void {
    assert_eq(1, 1)
}
