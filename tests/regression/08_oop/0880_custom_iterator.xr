// 测试：自定义迭代器协议（Iterable/Iterator 接口）

// ===== 基本范围迭代器 =====

class CustomRangeIter {
    current: int
    end: int
    
    constructor(start: int, end: int) {
        this.current = start
        this.end = end
    }
    
    hasNext() -> bool {
        return this.current < this.end
    }
    
    next() -> int {
        let val = this.current
        this.current = this.current + 1
        return val
    }
}

class CustomRange {
    start: int
    end: int
    
    constructor(start: int, end: int) {
        this.start = start
        this.end = end
    }
    
    iterator() -> CustomRangeIter {
        return CustomRangeIter(this.start, this.end)
    }
}

@test
fn test_basic_range_iterator() {
    let sum = 0
    for (i in CustomRange(1, 6)) {
        sum = sum + i
    }
    assert_eq(sum, 15)  // 1+2+3+4+5
}

@test
fn test_empty_range() {
    let count = 0
    for (i in CustomRange(5, 5)) {
        count = count + 1
    }
    assert_eq(count, 0)
}

@test
fn test_single_element_range() {
    let result = 0
    for (i in CustomRange(42, 43)) {
        result = i
    }
    assert_eq(result, 42)
}

// ===== 步长迭代器 =====

class StepIterator {
    current: int
    end: int
    step: int
    
    constructor(start: int, end: int, step: int) {
        this.current = start
        this.end = end
        this.step = step
    }
    
    hasNext() -> bool {
        if (this.step > 0) {
            return this.current < this.end
        } else {
            return this.current > this.end
        }
    }
    
    next() -> int {
        let val = this.current
        this.current = this.current + this.step
        return val
    }
}

class StepRange {
    start: int
    end: int
    step: int
    
    constructor(start: int, end: int, step: int) {
        this.start = start
        this.end = end
        this.step = step
    }
    
    iterator() -> StepIterator {
        return StepIterator(this.start, this.end, this.step)
    }
}

@test
fn test_step_range_forward() {
    let values: Array<int> = []
    for (i in StepRange(0, 10, 2)) {
        values.push(i)
    }
    assert_eq(values.length, 5)
    assert_eq(values[0], 0)
    assert_eq(values[1], 2)
    assert_eq(values[2], 4)
    assert_eq(values[3], 6)
    assert_eq(values[4], 8)
}

@test
fn test_step_range_backward() {
    let values: Array<int> = []
    for (i in StepRange(10, 0, -2)) {
        values.push(i)
    }
    assert_eq(values.length, 5)
    assert_eq(values[0], 10)
    assert_eq(values[1], 8)
    assert_eq(values[2], 6)
    assert_eq(values[3], 4)
    assert_eq(values[4], 2)
}

// ===== 斐波那契迭代器 =====

class FibIterator {
    a: int
    b: int
    count: int
    max: int
    
    constructor(max: int) {
        this.a = 0
        this.b = 1
        this.count = 0
        this.max = max
    }
    
    hasNext() -> bool {
        return this.count < this.max
    }
    
    next() -> int {
        let val = this.a
        let tmp = this.a + this.b
        this.a = this.b
        this.b = tmp
        this.count = this.count + 1
        return val
    }
}

class Fibonacci {
    max: int
    
    constructor(n: int) {
        this.max = n
    }
    
    iterator() -> FibIterator {
        return FibIterator(this.max)
    }
}

@test
fn test_fibonacci_iterator() {
    let values: Array<int> = []
    for (n in Fibonacci(8)) {
        values.push(n)
    }
    assert_eq(values.length, 8)
    assert_eq(values[0], 0)
    assert_eq(values[1], 1)
    assert_eq(values[2], 1)
    assert_eq(values[3], 2)
    assert_eq(values[4], 3)
    assert_eq(values[5], 5)
    assert_eq(values[6], 8)
    assert_eq(values[7], 13)
}

// ===== 字符串字符迭代器 =====

class CharIterator {
    str: string
    index: int
    
    constructor(s: string) {
        this.str = s
        this.index = 0
    }
    
    hasNext() -> bool {
        return this.index < this.str.length
    }
    
    next() -> string {
        let ch = this.str[this.index]
        this.index = this.index + 1
        return ch
    }
}

class Chars {
    str: string
    
    constructor(s: string) {
        this.str = s
    }
    
    iterator() -> CharIterator {
        return CharIterator(this.str)
    }
}

@test
fn test_char_iterator() {
    let chars: Array<string> = []
    for (ch in Chars("hello")) {
        chars.push(ch)
    }
    assert_eq(chars.length, 5)
    assert_eq(chars[0], "h")
    assert_eq(chars[1], "e")
    assert_eq(chars[2], "l")
    assert_eq(chars[3], "l")
    assert_eq(chars[4], "o")
}

// ===== 嵌套迭代 =====

@test
fn test_nested_iteration() {
    let pairs: Array<string> = []
    for (i in CustomRange(1, 4)) {
        for (j in CustomRange(1, 4)) {
            pairs.push("${i},${j}")
        }
    }
    assert_eq(pairs.length, 9)
    assert_eq(pairs[0], "1,1")
    assert_eq(pairs[4], "2,2")
    assert_eq(pairs[8], "3,3")
}

// ===== 迭代器与 break/continue =====

@test
fn test_iterator_with_break() {
    let sum = 0
    for (i in CustomRange(1, 100)) {
        if (i > 5) {
            break
        }
        sum = sum + i
    }
    assert_eq(sum, 15)  // 1+2+3+4+5
}

@test
fn test_iterator_with_continue() {
    let sum = 0
    for (i in CustomRange(1, 11)) {
        if (i % 2 == 0) {
            continue
        }
        sum = sum + i
    }
    assert_eq(sum, 25)  // 1+3+5+7+9
}

// ===== 迭代器变量作为表达式 =====

@test
fn test_iterator_inline() {
    let sum = 0
    for (i in CustomRange(1, 6)) {
        sum = sum + i * i
    }
    assert_eq(sum, 55)  // 1+4+9+16+25
}

// ===== 迭代器与变量存储 =====

@test
fn test_iterator_stored_in_variable() {
    let r = CustomRange(1, 4)
    let sum = 0
    for (i in r) {
        sum = sum + i
    }
    assert_eq(sum, 6)  // 1+2+3
}
