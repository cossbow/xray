// ===== 私有字段 =====

class Account {
    private balance: int
    
    constructor(initial: int) {
        this.balance = initial
    }
    
    deposit(amount: int): void {        this.balance = this.balance + amount
    }
    
    withdraw(amount: int): bool {        if (amount <= this.balance) {
            this.balance = this.balance - amount
            return true
        }
        return false
    }
    
    getBalance(): void {        return this.balance
    }
}

@test
fn test_private_field_access(): void {
    let acc = new Account(100)
    assert_eq(acc.getBalance(), 100)
}

@test
fn test_private_field_modify(): void {
    let acc = new Account(100)
    acc.deposit(50)
    assert_eq(acc.getBalance(), 150)
}

@test
fn test_private_field_withdraw(): void {
    let acc = new Account(100)
    let success = acc.withdraw(30)
    assert_eq(success, true)
    assert_eq(acc.getBalance(), 70)
}

// ===== 多私有字段 =====

class User {
    private password: string
    private email: string
    name: string
    
    constructor(name: string, email: string, password: string) {
        this.name = name
        this.email = email
        this.password = password
    }
    
    checkPassword(pwd: string): bool {        return this.password == pwd
    }
    
    getEmail(): string {        return this.email
    }
}

@test
fn test_multiple_private_fields(): void {
    let user = new User("Alice", "alice@test.com", "secret123")
    assert_eq(user.name, "Alice")
    assert_eq(user.checkPassword("secret123"), true)
    assert_eq(user.checkPassword("wrong"), false)
}

// ===== 私有字段与继承 =====

class BankAccount {
    private balance: int
    
    constructor(initial: int) {
        this.balance = initial
    }
    
    getBalance(): void {        return this.balance
    }
    
    addAmount(amount: int): void {        this.balance = this.balance + amount
    }
}

class SavingsAccount extends BankAccount {
    interestRate: float
    
    constructor(initial: int, rate: float) {
        super(initial)
        this.interestRate = rate
    }
    
    applyInterest(): void {        let interest = (this.getBalance() * this.interestRate).floor()
        this.addAmount(interest)
    }
}

@test
fn test_private_with_inheritance(): void {
    let savings = new SavingsAccount(1000, 0.1)
    assert_eq(savings.getBalance(), 1000)
    savings.applyInterest()
    assert_eq(savings.getBalance(), 1100)
}

