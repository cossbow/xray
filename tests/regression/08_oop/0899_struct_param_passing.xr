// Test: struct pass-by-value in function parameters
// Expected: modifying struct parameter inside function does not affect caller

struct Point {
    x: float
    y: float
}

// Function that modifies its struct parameter
fn move_point(p: Point, dx: float, dy: float): Point {
    p.x = p.x + dx
    p.y = p.y + dy
    return p
}

// === Caller's struct is not modified ===
let p1 = Point{x: 1.0, y: 2.0}
let p2 = move_point(p1, 10.0, 20.0)
assert(p1.x == 1.0)
assert(p1.y == 2.0)
assert(p2.x == 11.0)
assert(p2.y == 22.0)

// === Multiple calls, original unchanged ===
let p3 = move_point(p1, 100.0, 200.0)
assert(p1.x == 1.0)
assert(p1.y == 2.0)
assert(p3.x == 101.0)
assert(p3.y == 202.0)

// === Struct parameter with method ===
struct Vec2 {
    x: float
    y: float

    scale(factor: float): Vec2 {
        return Vec2{x: this.x * factor, y: this.y * factor}
    }
}

fn double_and_offset(v: Vec2): Vec2 {
    v.x = v.x * 2.0
    v.y = v.y * 2.0
    return v
}

let v1 = Vec2{x: 3.0, y: 4.0}
let v2 = double_and_offset(v1)
assert(v1.x == 3.0)
assert(v1.y == 4.0)
assert(v2.x == 6.0)
assert(v2.y == 8.0)

// === Struct return from function (fresh object) ===
fn make_point(x: float, y: float): Point {
    return Point{x: x, y: y}
}

let p4 = make_point(42.0, 99.0)
let p5 = make_point(42.0, 99.0)
p4.x = 0.0
assert(p5.x == 42.0)

print("ok")
