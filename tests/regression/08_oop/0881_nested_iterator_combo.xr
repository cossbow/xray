// 0881_nested_iterator_combo.xr
// Author: xingleixu@gmail.com
// Test: Nested custom iterators with method calls, break/continue, and mixed types
// Regression: IC cache_index stale frame->pc bug (fixed)

// ===== Reusable iterator classes =====

class CustomRangeIter {
    val: int
    max: int
    constructor(start: int, end: int) {
        this.val = start
        this.max = end
    }
    hasNext() -> bool { return this.val < this.max }
    next() -> int {
        let v = this.val
        this.val = this.val + 1
        return v
    }
}

class CustomRange {
    start: int
    end: int
    constructor(s: int, e: int) { this.start = s; this.end = e }
    iterator() -> CustomRangeIter { return CustomRangeIter(this.start, this.end) }
}

// ===== Triple nested for-in =====

@test
fn test_triple_nested_for_in() {
    let count = 0
    let sum = 0
    for (i in CustomRange(1, 4)) {
        for (j in CustomRange(1, 4)) {
            for (k in CustomRange(1, 4)) {
                count = count + 1
                sum = sum + i * 100 + j * 10 + k
            }
        }
    }
    assert_eq(count, 27)
    // 111+112+113+121+...+333
    assert_eq(sum, 5994)
}

// ===== Nested for-in with method calls in body =====

class Accumulator {
    total: int
    constructor() { this.total = 0 }
    add(n: int) { this.total = this.total + n }    get() -> int { return this.total }
}

@test
fn test_nested_for_in_with_method_calls() {
    let acc = Accumulator()
    for (i in CustomRange(1, 5)) {
        for (j in CustomRange(1, 5)) {
            acc.add(i * j)
        }
    }
    // sum of i*j for i=1..4, j=1..4 = (1+2+3+4)^2 = 100
    assert_eq(acc.get(), 100)
}

// ===== Nested for-in with break in inner loop =====

@test
fn test_nested_for_in_inner_break() {
    let pairs: Array<string> = []
    for (i in CustomRange(1, 6)) {
        for (j in CustomRange(1, 6)) {
            if (j > i) { break }
            pairs.push("${i},${j}")
        }
    }
    // Lower triangle: (1,1), (2,1),(2,2), (3,1),(3,2),(3,3), ...
    assert_eq(pairs.length, 15)
    assert_eq(pairs[0], "1,1")
    assert_eq(pairs[1], "2,1")
    assert_eq(pairs[2], "2,2")
}

// ===== Nested for-in with continue in outer loop =====

@test
fn test_nested_for_in_outer_continue() {
    let results: Array<int> = []
    for (i in CustomRange(1, 6)) {
        if (i % 2 == 0) { continue }
        let sum = 0
        for (j in CustomRange(1, 4)) {
            sum = sum + j
        }
        results.push(i * sum)
    }
    // i=1,3,5; sum=1+2+3=6; results=[6, 18, 30]
    assert_eq(results.length, 3)
    assert_eq(results[0], 6)
    assert_eq(results[1], 18)
    assert_eq(results[2], 30)
}

// ===== Different iterator types nested =====

class StepIter {
    val: int
    max: int
    step: int
    constructor(s: int, e: int, st: int) { this.val = s; this.max = e; this.step = st }
    hasNext() -> bool {
        if (this.step > 0) { return this.val < this.max }
        return this.val > this.max
    }
    next() -> int {
        let v = this.val
        this.val = this.val + this.step
        return v
    }
}

class StepRange {
    s: int
    e: int
    st: int
    constructor(s: int, e: int, st: int) { this.s = s; this.e = e; this.st = st }
    iterator() -> StepIter { return StepIter(this.s, this.e, this.st) }
}

@test
fn test_mixed_iterator_types_nested() {
    let results: Array<string> = []
    for (i in CustomRange(0, 3)) {
        for (j in StepRange(10, 40, 10)) {
            results.push("${i}:${j}")
        }
    }
    assert_eq(results.length, 9)
    assert_eq(results[0], "0:10")
    assert_eq(results[3], "1:10")
    assert_eq(results[8], "2:30")
}

// ===== For-in with array operations inside =====

@test
fn test_for_in_with_array_map() {
    let results: Array<int> = []
    for (i in CustomRange(1, 4)) {
        let arr = [1, 2, 3]
        let mapped = arr.map(fn(x) { return x * i })
        results.push(mapped.reduce(fn(a, b) { return a + b }, 0))
    }
    // i=1: sum([1,2,3])=6, i=2: sum([2,4,6])=12, i=3: sum([3,6,9])=18
    assert_eq(results.length, 3)
    assert_eq(results[0], 6)
    assert_eq(results[1], 12)
    assert_eq(results[2], 18)
}

// ===== Nested for-in collecting into shared structure =====

@test
fn test_nested_for_in_matrix_build() {
    let matrix: Array<Array<int>> = []
    for (i in CustomRange(0, 3)) {
        let row: Array<int> = []
        for (j in CustomRange(0, 4)) {
            row.push(i * 4 + j)
        }
        matrix.push(row)
    }
    assert_eq(matrix.length, 3)
    assert_eq(matrix[0].length, 4)
    assert_eq(matrix[0][0], 0)
    assert_eq(matrix[1][2], 6)
    assert_eq(matrix[2][3], 11)
}

// ===== Iterator reuse across multiple loops =====

@test
fn test_iterable_reuse() {
    let r = CustomRange(1, 4)
    let sum1 = 0
    for (i in r) { sum1 = sum1 + i }
    let sum2 = 0
    for (i in r) { sum2 = sum2 + i }
    // Each for-in creates a fresh iterator via iterator()
    assert_eq(sum1, 6)
    assert_eq(sum2, 6)
}

// ===== Nested for-in with early return from function =====

fn find_pair(target: int) -> string {
    for (i in CustomRange(1, 10)) {
        for (j in CustomRange(1, 10)) {
            if (i * j == target) {
                return "${i},${j}"
            }
        }
    }
    return "not found"
}

@test
fn test_nested_for_in_early_return() {
    assert_eq(find_pair(12), "2,6")
    assert_eq(find_pair(35), "5,7")
}

// ===== Stress: many iterations =====

@test
fn test_nested_stress_100x100() {
    let count = 0
    for (i in CustomRange(0, 100)) {
        for (j in CustomRange(0, 100)) {
            count = count + 1
        }
    }
    assert_eq(count, 10000)
}

// ===== Iterator creating iterator inside next() =====

class FlattenIter {
    outer: Array<Array<int>>
    outerIdx: int
    innerIdx: int
    constructor(data: Array<Array<int>>) {
        this.outer = data
        this.outerIdx = 0
        this.innerIdx = 0
    }
    hasNext() -> bool {
        while (this.outerIdx < this.outer.length) {
            if (this.innerIdx < this.outer[this.outerIdx].length) {
                return true
            }
            this.outerIdx = this.outerIdx + 1
            this.innerIdx = 0
        }
        return false
    }
    next() -> int {
        let val = this.outer[this.outerIdx][this.innerIdx]
        this.innerIdx = this.innerIdx + 1
        return val
    }
}

class FlattenIterable {
    data: Array<Array<int>>
    constructor(d: Array<Array<int>>) { this.data = d }
    iterator() -> FlattenIter { return FlattenIter(this.data) }
}

@test
fn test_flatten_iterator() {
    let data = [[1, 2], [3], [4, 5, 6]]
    let result: Array<int> = []
    for (v in FlattenIterable(data)) {
        result.push(v)
    }
    assert_eq(result.length, 6)
    assert_eq(result[0], 1)
    assert_eq(result[2], 3)
    assert_eq(result[5], 6)
}

@test
fn test_nested_flatten_iterators() {
    let data1 = [[1, 2], [3, 4]]
    let data2 = [[10, 20], [30]]
    let products: Array<int> = []
    for (a in FlattenIterable(data1)) {
        for (b in FlattenIterable(data2)) {
            products.push(a * b)
        }
    }
    // 1*10,1*20,1*30,2*10,2*20,2*30,3*10,3*20,3*30,4*10,4*20,4*30
    assert_eq(products.length, 12)
    assert_eq(products[0], 10)
    assert_eq(products[2], 30)
    assert_eq(products[11], 120)
}

// ===== Iterator with complex state mutation =====

class FilteredRangeIter {
    val: int
    max: int
    divisor: int
    constructor(s: int, e: int, d: int) {
        this.val = s
        this.max = e
        this.divisor = d
        // Advance to first valid value
        while (this.val < this.max && this.val % this.divisor != 0) {
            this.val = this.val + 1
        }
    }
    hasNext() -> bool { return this.val < this.max }
    next() -> int {
        let v = this.val
        this.val = this.val + 1
        while (this.val < this.max && this.val % this.divisor != 0) {
            this.val = this.val + 1
        }
        return v
    }
}

class FilteredRange {
    s: int
    e: int
    d: int
    constructor(s: int, e: int, d: int) { this.s = s; this.e = e; this.d = d }
    iterator() -> FilteredRangeIter { return FilteredRangeIter(this.s, this.e, this.d) }
}

@test
fn test_nested_filtered_ranges() {
    // Multiples of 3 in [1,20) crossed with multiples of 5 in [1,30)
    let pairs: Array<string> = []
    for (a in FilteredRange(1, 20, 3)) {
        for (b in FilteredRange(1, 30, 5)) {
            pairs.push("${a}x${b}")
        }
    }
    // a: 3,6,9,12,15,18 (6 values); b: 5,10,15,20,25 (5 values)
    assert_eq(pairs.length, 30)
    assert_eq(pairs[0], "3x5")
    assert_eq(pairs[5], "6x5")
    assert_eq(pairs[29], "18x25")
}

// ===== for-in with higher-order + method calls on iterator result =====

@test
fn test_for_in_with_chained_operations() {
    let results: Array<string> = []
    for (i in CustomRange(1, 5)) {
        let arr = [10, 20, 30]
        let mapped = arr.map(fn(x) { return x * i })
        let filtered = mapped.filter(fn(x) { return x > 25 })
        let total = filtered.reduce(fn(a, b) { return a + b }, 0)
        results.push("i=${i}:sum=${total}")
    }
    // i=1: [10,20,30]->filter>25->[30]->sum=30
    // i=2: [20,40,60]->filter>25->[40,60]->sum=100
    // i=3: [30,60,90]->filter>25->[30,60,90]->sum=180
    // i=4: [40,80,120]->filter>25->[40,80,120]->sum=240
    assert_eq(results[0], "i=1:sum=30")
    assert_eq(results[1], "i=2:sum=100")
    assert_eq(results[2], "i=3:sum=180")
    assert_eq(results[3], "i=4:sum=240")
}

// ===== Interleaved iterator and findIndex (tests the call_status bug fix) =====

@test
fn test_iterator_then_findIndex() {
    let sums: Array<int> = []
    for (i in CustomRange(1, 4)) {
        let arr = [1, 2, 3, 4, 5]
        let mapped = arr.map(fn(x) { return x * i })
        let idx = mapped.findIndex(fn(x) { return x > 6 })
        sums.push(idx)
    }
    // i=1: [1,2,3,4,5]->findIndex(>6)=-1
    // i=2: [2,4,6,8,10]->findIndex(>6)=3
    // i=3: [3,6,9,12,15]->findIndex(>6)=2
    assert_eq(sums[0], -1)
    assert_eq(sums[1], 3)
    assert_eq(sums[2], 2)
}

// ===== Recursive function with iterator =====

fn collect_custom_range_recursive(depth: int, max_depth: int) -> Array<string> {
    let results: Array<string> = []
    if (depth >= max_depth) {
        results.push("leaf:${depth}")
        return results
    }
    for (i in CustomRange(0, 3)) {
        let sub = collect_custom_range_recursive(depth + 1, max_depth)
        for (let j = 0; j < sub.length; j++) {
            results.push("d${depth}i${i}:${sub[j]}")
        }
    }
    return results
}

@test
fn test_recursive_with_iterator() {
    let result = collect_custom_range_recursive(0, 2)
    // depth 0: 3 branches, each depth 1: 3 branches, each depth 2: leaf
    // Total: 3 * 3 = 9
    assert_eq(result.length, 9)
    assert_eq(result[0], "d0i0:d1i0:leaf:2")
    assert_eq(result[8], "d0i2:d1i2:leaf:2")
}

// ===== 4-deep nested for-in with mixed break/continue =====

@test
fn test_4deep_nested_break_continue() {
    let count = 0
    for (a in CustomRange(0, 5)) {
        if (a == 3) { continue }
        for (b in CustomRange(0, 5)) {
            if (b > a) { break }
            for (c in CustomRange(0, 3)) {
                for (d in CustomRange(0, 2)) {
                    count = count + 1
                }
            }
        }
    }
    // a=0: b=0, c*d=3*2=6 -> 6
    // a=1: b=0,1, each c*d=6 -> 12
    // a=2: b=0,1,2, each 6 -> 18
    // a=3: skipped
    // a=4: b=0,1,2,3,4, each 6 -> 30
    assert_eq(count, 66)
}
