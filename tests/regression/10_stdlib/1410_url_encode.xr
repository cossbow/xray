// 1410_url_encode.xr
// Test: url module encode/decode (RFC 3986)

import url

// ============================================================
// 第一部分：URL 编码测试
// ============================================================

@test
fn test_encode_no_change() {
    // 字母数字不需要编码
    let encoded = url.encode("hello")
    assert_eq(encoded, "hello")
}

@test
fn test_encode_space() {
    // 空格编码为 %20
    let encoded = url.encode("hello world")
    assert_eq(encoded, "hello%20world")
}

@test
fn test_encode_special_chars() {
    // 特殊字符编码
    let encoded = url.encode("a=1&b=2")
    assert_eq(encoded, "a%3D1%26b%3D2")
}

@test
fn test_encode_chinese() {
    // 中文字符编码
    let encoded = url.encode("你好")
    assert_eq(encoded, "%E4%BD%A0%E5%A5%BD")
}

@test
fn test_encode_mixed() {
    // 混合字符编码
    let encoded = url.encode("hello 世界!")
    assert_eq(encoded, "hello%20%E4%B8%96%E7%95%8C%21")
}

@test
fn test_encode_reserved_chars() {
    // 保留字符不编码：- _ . ~
    let encoded = url.encode("a-b_c.d~e")
    assert_eq(encoded, "a-b_c.d~e")
}

@test
fn test_encode_percent() {
    // 百分号编码
    let encoded = url.encode("100%")
    assert_eq(encoded, "100%25")
}

// ============================================================
// 第二部分：URL 解码测试
// ============================================================

@test
fn test_decode_no_change() {
    // 普通字符串不变
    let decoded = url.decode("hello")
    assert_eq(decoded, "hello")
}

@test
fn test_decode_percent_20() {
    // %20 解码为空格
    let decoded = url.decode("hello%20world")
    assert_eq(decoded, "hello world")
}

@test
fn test_decode_plus_sign() {
    // RFC 3986 decode: '+' stays as '+' (use decodeForm for form data)
    let decoded = url.decode("hello+world")
    assert_eq(decoded, "hello+world")
}

@test
fn test_decode_special_chars() {
    // 特殊字符解码
    let decoded = url.decode("a%3D1%26b%3D2")
    assert_eq(decoded, "a=1&b=2")
}

@test
fn test_decode_chinese() {
    // 中文字符解码
    let decoded = url.decode("%E4%BD%A0%E5%A5%BD")
    assert_eq(decoded, "你好")
}

@test
fn test_decode_mixed_case() {
    // 大小写十六进制都能解码
    let decoded1 = url.decode("%2f")
    let decoded2 = url.decode("%2F")
    assert_eq(decoded1, "/")
    assert_eq(decoded2, "/")
}

// ============================================================
// 第三部分：往返测试
// ============================================================

@test
fn test_roundtrip_simple() {
    // 简单字符串往返
    let original = "hello world"
    let encoded = url.encode(original)
    let decoded = url.decode(encoded)
    assert_eq(decoded, original)
}

@test
fn test_roundtrip_special() {
    // 特殊字符往返
    let original = "a=1&b=2"
    let encoded = url.encode(original)
    let decoded = url.decode(encoded)
    assert_eq(decoded, original)
}

@test
fn test_roundtrip_unicode() {
    // Unicode 字符往返
    let original = "你好世界"
    let encoded = url.encode(original)
    let decoded = url.decode(encoded)
    assert_eq(decoded, original)
}
