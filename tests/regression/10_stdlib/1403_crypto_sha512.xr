// 1403_crypto_sha512.xr
// Test: crypto SHA-512 hash and HMAC-SHA512
//
// Coverage:
//   - SHA-512 hash
//   - HMAC-SHA512

import crypto

// ============================================================
// SHA-512 hash tests
// ============================================================

@test
fn test_sha512_empty_string() {
    let hash = crypto.sha512("")
    assert_eq(hash, "cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e")
}

@test
fn test_sha512_hello() {
    let hash = crypto.sha512("hello")
    assert_eq(hash, "9b71d224bd62f3785d96d46ad3ea3d73319bfbc2890caadae2dff72519673ca72323c3d99ba5c11d7c7acc6e14b8c5da0c4663475c2e5c3adef46f73bcdec043")
}

@test
fn test_sha512_hello_world() {
    let hash = crypto.sha512("Hello World")
    assert_eq(hash, "2c74fd17edafd80e8447b0d46741ee243b7eb74dd2149a0ab1b9246fb30382f27e853d8585719e0e67cbda0daa8f51671064615d645ae27acb15bfb1447f459b")
}

@test
fn test_sha512_length() {
    // SHA-512 always returns 128 hex characters
    assert_eq(crypto.sha512("test").length, 128)
}

@test
fn test_sha512_long_string() {
    let hash = crypto.sha512("The quick brown fox jumps over the lazy dog")
    assert_eq(hash, "07e547d9586f6a73f73fbac0435ed76951218fb7d0c8d788a309d785436bbb642e93a252a954f23912547d1e8a3b5ed6e1bfd7097821233fa0538f3db854fee6")
}

// ============================================================
// HMAC-SHA512 tests
// ============================================================

@test
fn test_hmac_sha512_basic() {
    let hmac = crypto.hmac("sha512", "key", "message")
    // HMAC-SHA512 length is 128 hex chars
    assert_eq(hmac.length, 128)
}

@test
fn test_hmac_sha512_empty_message() {
    let hmac = crypto.hmac("sha512", "key", "")
    assert_eq(hmac.length, 128)
}

@test
fn test_hmac_sha512_known_vector() {
    // RFC 4231 test case 2
    let hmac = crypto.hmac("sha512", "Jefe", "what do ya want for nothing?")
    assert_eq(hmac, "164b7a7bfcf819e2e395fbe73b56e0a387bd64222e831fd610270cd7ea2505549758bf75c05a994a6d034f65f8f0e6fdcaeab1a34d4a6b4b636e070a38bce737")
}
