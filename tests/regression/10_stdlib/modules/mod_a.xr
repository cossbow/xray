/*
** mod_a.xr
** 模块冲突测试 - 模块 A
**
** 作者：xingleixu@gmail.com
** 
** 测试：模块内部函数和变量不会与其他模块冲突
*/

/* 私有变量 */
let _internal = "A"
const _VERSION = "1.0"

/* 私有函数 */
fn _helper() -> string {
    return _internal + "-helper"
}

/* 导出函数 */
fn publicFn() -> string {
    return _helper() + "-" + _VERSION
}

export publicFn
