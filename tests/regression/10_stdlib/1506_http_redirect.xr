// Test HTTP redirect status code handling

import http

fn isRedirect(s: int): bool { return s == 301 || s == 302 || s == 303 || s == 307 || s == 308 }
fn isPermanent(s: int): bool { return s == 301 || s == 308 }
fn isTemporary(s: int): bool { return s == 302 || s == 303 || s == 307 }

@test
fn test_redirect_codes(): void {
    assert(isRedirect(301))
    assert(isRedirect(302))
    assert(isRedirect(307))
    assert(isRedirect(308))
    assert(!isRedirect(200))
    assert(!isRedirect(404))
}

@test
fn test_permanent_vs_temporary(): void {
    assert(isPermanent(301))
    assert(isPermanent(308))
    assert(!isPermanent(302))
    assert(isTemporary(302))
    assert(isTemporary(307))
    assert(!isTemporary(301))
}

@test
fn test_location_header(): void {
    let resp = { status: 302, headers: { "Location" => "https://example.com/new" } }
    assert_eq(resp.headers.get("Location"), "https://example.com/new")
}

@test
fn test_resolve_redirect(): void {
    fn resolve(base: string, loc: string): string {
        if (loc.indexOf("http://") == 0 || loc.indexOf("https://") == 0) { return loc }
        return base + loc
    }
    assert_eq(resolve("http://example.com", "/new"), "http://example.com/new")
    assert_eq(resolve("http://example.com", "https://other.com"), "https://other.com")
}

print("All http redirect tests passed")