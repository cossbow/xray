// 测试：JSON 特殊值和边界情况测试
// 借鉴：simdjson 的特殊值测试

// ===== null 值测试 =====

@test
fn test_null_standalone() {
    assert_eq(Json.parse("null"), null)
}

@test
fn test_null_in_array() {
    let arr = Json.parse("[null, null, null]")
    assert_eq(arr.length, 3)
    assert_eq(arr[0], null)
    assert_eq(arr[1], null)
    assert_eq(arr[2], null)
}

@test
fn test_null_in_object() {
    let obj = Json.parse("{\"value\": null}")
    assert_eq(obj.value, null)
}

@test
fn test_null_mixed() {
    let data = Json.parse("{\"a\": null, \"b\": 1, \"c\": null, \"d\": \"text\"}")
    assert_eq(data.a, null)
    assert_eq(data.b, 1)
    assert_eq(data.c, null)
    assert_eq(data.d, "text")
}

// ===== boolean 值测试 =====

@test
fn test_true_standalone() {
    assert_eq(Json.parse("true"), true)
}

@test
fn test_false_standalone() {
    assert_eq(Json.parse("false"), false)
}

@test
fn test_booleans_in_array() {
    let arr = Json.parse("[true, false, true, false]")
    assert_eq(arr[0], true)
    assert_eq(arr[1], false)
    assert_eq(arr[2], true)
    assert_eq(arr[3], false)
}

@test
fn test_booleans_in_object() {
    let obj = Json.parse("{\"enabled\": true, \"disabled\": false}")
    assert_eq(obj.enabled, true)
    assert_eq(obj.disabled, false)
}

// ===== 空白处理测试 =====

@test
fn test_whitespace_before() {
    assert_eq(Json.parse("  42"), 42)
    assert_eq(Json.parse("\n42"), 42)
    assert_eq(Json.parse("\t42"), 42)
    assert_eq(Json.parse("\r\n42"), 42)
}

@test
fn test_whitespace_after() {
    assert_eq(Json.parse("42  "), 42)
    assert_eq(Json.parse("42\n"), 42)
    assert_eq(Json.parse("42\t"), 42)
}

@test
fn test_whitespace_both() {
    assert_eq(Json.parse("  42  "), 42)
    assert_eq(Json.parse("\n\t42\t\n"), 42)
}

@test
fn test_whitespace_in_array() {
    let arr = Json.parse("[  1  ,  2  ,  3  ]")
    assert_eq(arr.length, 3)
    assert_eq(arr[0], 1)
    assert_eq(arr[1], 2)
    assert_eq(arr[2], 3)
}

@test
fn test_whitespace_in_object() {
    let obj = Json.parse("{  \"key\"  :  \"value\"  }")
    assert_eq(obj.key, "value")
}

@test
fn test_multiline_json() {
    let jsonStr = "{\n  \"name\": \"Alice\",\n  \"age\": 30\n}"
    let obj = Json.parse(jsonStr)
    assert_eq(obj.name, "Alice")
    assert_eq(obj.age, 30)
}

// ===== 空集合测试 =====

@test
fn test_empty_array() {
    let arr = Json.parse("[]")
    assert_eq(arr.length, 0)
}

@test
fn test_empty_object() {
    let obj = Json.parse("{}")
    assert_eq(obj != null, true)
}

@test
fn test_empty_string() {
    let s = Json.parse("\"\"")
    assert_eq(s, "")
    assert_eq(s.length, 0)
}

@test
fn test_nested_empty() {
    let data = Json.parse("{\"arr\": [], \"obj\": {}, \"str\": \"\"}")
    assert_eq(data.arr.length, 0)
    assert_eq(data.str, "")
}

// ===== 数字零测试 =====

@test
fn test_zero_integer() {
    assert_eq(Json.parse("0"), 0)
}

@test
fn test_zero_float() {
    assert_eq(Json.parse("0.0"), 0.0)
}

@test
fn test_negative_zero() {
    let nz = Json.parse("-0")
    assert_eq(nz, 0)  // -0 == 0
}

@test
fn test_zero_exponent() {
    assert_eq(Json.parse("0e0"), 0.0)
    assert_eq(Json.parse("0e10"), 0.0)
    assert_eq(Json.parse("0e-10"), 0.0)
}

// ===== 特殊数字格式 =====

@test
fn test_integer_as_float() {
    // 整数形式的浮点数
    assert_eq(Json.parse("1.0"), 1.0)
    assert_eq(Json.parse("100.0"), 100.0)
}

@test
fn test_float_no_integer_part() {
    // 小数部分开头
    assert_eq(Json.parse("0.5"), 0.5)
    assert_eq(Json.parse("0.123"), 0.123)
}

@test
fn test_exponent_only() {
    // 只有指数
    assert_eq(Json.parse("1e0"), 1.0)
    assert_eq(Json.parse("5E0"), 5.0)
}

// ===== stringify 特殊值 =====

@test
fn test_stringify_null() {
    assert_eq(Json.stringify(null), "null")
}

@test
fn test_stringify_true() {
    assert_eq(Json.stringify(true), "true")
}

@test
fn test_stringify_false() {
    assert_eq(Json.stringify(false), "false")
}

@test
fn test_stringify_zero() {
    assert_eq(Json.stringify(0), "0")
}

@test
fn test_stringify_empty_array() {
    assert_eq(Json.stringify([]), "[]")
}

@test
fn test_stringify_empty_string() {
    assert_eq(Json.stringify(""), "\"\"")
}

// ===== keys 和 values 测试 =====

@test
fn test_keys_empty_object() {
    let keys = Json.keys("{}")
    assert_eq(keys.length, 0)
}

@test
fn test_keys_simple_object() {
    let keys = Json.keys(Json.parse("{\"a\": 1, \"b\": 2, \"c\": 3}")!)
    assert_eq(keys.length, 3)
    // 键顺序可能不确定，检查是否包含
    let hasA = false
    let hasB = false
    let hasC = false
    let i = 0
    while (i < keys.length) {
        if (keys[i] == "a") { hasA = true }
        if (keys[i] == "b") { hasB = true }
        if (keys[i] == "c") { hasC = true }
        i++
    }
    assert_eq(hasA, true)
    assert_eq(hasB, true)
    assert_eq(hasC, true)
}

@test
fn test_values_empty_object() {
    let values = Json.values("{}")
    assert_eq(values.length, 0)
}

@test
fn test_values_simple_object() {
    let values = Json.values(Json.parse("{\"a\": 1, \"b\": 2, \"c\": 3}")!)
    assert_eq(values.length, 3)
    // 检查是否包含所有值
    let has1 = false
    let has2 = false
    let has3 = false
    let i = 0
    while (i < values.length) {
        if (values[i] == 1) { has1 = true }
        if (values[i] == 2) { has2 = true }
        if (values[i] == 3) { has3 = true }
        i++
    }
    assert_eq(has1, true)
    assert_eq(has2, true)
    assert_eq(has3, true)
}

// ===== BOM 处理测试 =====

// 注意：BOM 是 UTF-8 编码的字节序标记 \xEF\xBB\xBF
// xray 可能需要特殊处理或忽略

// ===== 大数字精度测试 =====

@test
fn test_precision_integer() {
    // Test integer precision within 48-bit range
    let n = Json.parse("123456789012345")
    assert_eq(n, 123456789012345)
}

@test
fn test_precision_float() {
    // 测试浮点精度
    let f = Json.parse("1.2345678901234567")
    // 浮点数精度有限，检查近似值
    assert_eq(f > 1.23456, true)
    assert_eq(f < 1.23457, true)
}

// ===== 格式化输出测试 =====

@test
fn test_stringify_indent() {
    let obj = { name: "Alice", age: 30 }
    let jsonStr = Json.stringify(obj, 2)  // 2 空格缩进
    assert_eq(jsonStr.contains("\n"), true)
}

@test
fn test_stringify_no_indent() {
    let obj = { name: "Alice", age: 30 }
    let jsonStr = Json.stringify(obj)  // 无缩进
    // 紧凑格式不应包含多余空白
    assert_eq(jsonStr.contains("Alice"), true)
}

// ===== 特殊字符串值 =====

@test
fn test_string_with_colon() {
    let s = Json.parse("\"key:value\"")
    assert_eq(s, "key:value")
}

@test
fn test_string_with_comma() {
    let s = Json.parse("\"a,b,c\"")
    assert_eq(s, "a,b,c")
}

@test
fn test_string_with_brackets() {
    let s = Json.parse("\"[1,2,3]\"")
    assert_eq(s, "[1,2,3]")
}

@test
fn test_string_with_braces() {
    let s = Json.parse("\"{key: value}\"")
    assert_eq(s, "{key: value}")
}

