// 1010_json_serialize_types.xr
// Test: Json.stringify for Enum, DateTime, and non-serializable type error

import datetime

enum Color { Red, Green, Blue }

@test
fn test_stringify_enum() {
    let obj = { color: Color.Red }
    let s = Json.stringify(obj)
    assert_eq(s, '{"color":"Red"}')
}

@test
fn test_stringify_enum_value_direct() {
    let s = Json.stringify(Color.Blue)
    assert_eq(s, '"Blue"')
}

@test
fn test_stringify_datetime() {
    let dt = datetime.createUTC(2026, 4, 30, 9, 0, 0)
    let s = Json.stringify(dt)
    // ISO 8601 format
    assert(s.includes("2026"))
    assert(s.includes("04"))
    assert(s.includes("30"))
}

@test
fn test_stringify_datetime_in_object() {
    let dt = datetime.createUTC(2026, 1, 15, 12, 30, 0)
    let obj = { created: dt, name: "test" }
    let s = Json.stringify(obj)
    assert(s.includes('"created"'))
    assert(s.includes("2026"))
    assert(s.includes('"name":"test"'))
}

@test
fn test_stringify_non_serializable_throws() {
    let f = fn() {}
    let obj = { handler: f }
    let caught = false
    try {
        Json.stringify(obj)
    } catch (e) {
        caught = true
        let msg = string(e)
        assert(msg.includes("cannot serialize"))
    }
    assert(caught)
}
