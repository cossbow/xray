// 1022_math_type_preserve.xr - Math module type preservation and edge cases

import math

// ===== Type preservation: floor/ceil/round return int =====

@test
fn test_floor_returns_int() {
    let r = math.floor(3.7)
    assert_eq(r, 3)
    assert_eq(typeof(r) == Type.int, true)
}

@test
fn test_floor_int_passthrough() {
    let r = math.floor(5)
    assert_eq(r, 5)
    assert_eq(typeof(r) == Type.int, true)
}

@test
fn test_ceil_returns_int() {
    let r = math.ceil(3.2)
    assert_eq(r, 4)
    assert_eq(typeof(r) == Type.int, true)
}

@test
fn test_ceil_int_passthrough() {
    let r = math.ceil(7)
    assert_eq(r, 7)
    assert_eq(typeof(r) == Type.int, true)
}

@test
fn test_round_returns_int() {
    let r = math.round(3.5)
    assert_eq(r, 4)
    assert_eq(typeof(r) == Type.int, true)
}

@test
fn test_round_int_passthrough() {
    let r = math.round(10)
    assert_eq(r, 10)
    assert_eq(typeof(r) == Type.int, true)
}

// ===== Type preservation: min/max preserve int =====

@test
fn test_min_int_preserves_type() {
    let r = math.min(3, 7)
    assert_eq(r, 3)
    assert_eq(typeof(r) == Type.int, true)
}

@test
fn test_min_float_returns_float() {
    let r = math.min(3.5, 7.2)
    assert(r > 3.4 && r < 3.6)
    assert_eq(typeof(r) == Type.float, true)
}

@test
fn test_max_int_preserves_type() {
    let r = math.max(3, 7)
    assert_eq(r, 7)
    assert_eq(typeof(r) == Type.int, true)
}

@test
fn test_max_float_returns_float() {
    let r = math.max(3.5, 7.2)
    assert(r > 7.1 && r < 7.3)
    assert_eq(typeof(r) == Type.float, true)
}

// ===== min/max variadic =====

@test
fn test_min_variadic() {
    assert_eq(math.min(5, 3, 8, 1, 9), 1)
    assert_eq(math.min(10, 20, 30), 10)
}

@test
fn test_max_variadic() {
    assert_eq(math.max(5, 3, 8, 1, 9), 9)
    assert_eq(math.max(10, 20, 30), 30)
}

// ===== clamp type preservation =====

@test
fn test_clamp_int_preserves_type() {
    let r = math.clamp(5, 0, 10)
    assert_eq(r, 5)
    assert_eq(typeof(r) == Type.int, true)
}

@test
fn test_clamp_below_int() {
    let r = math.clamp(-5, 0, 10)
    assert_eq(r, 0)
    assert_eq(typeof(r) == Type.int, true)
}

// ===== abs edge cases =====

@test
fn test_abs_int_preserves_type() {
    let r = math.abs(-42)
    assert_eq(r, 42)
    assert_eq(typeof(r) == Type.int, true)
}

@test
fn test_abs_float_returns_float() {
    let r = math.abs(-3.14)
    assert(r > 3.13 && r < 3.15)
    assert_eq(typeof(r) == Type.float, true)
}

// ===== trunc type preservation =====

@test
fn test_trunc_positive() {
    assert_eq(math.trunc(3.7), 3)
    assert_eq(typeof(math.trunc(3.7)) == Type.int, true)
}

@test
fn test_trunc_negative() {
    assert_eq(math.trunc(-3.7), -3)
}

@test
fn test_trunc_int_passthrough() {
    let r = math.trunc(5)
    assert_eq(r, 5)
    assert_eq(typeof(r) == Type.int, true)
}

// ===== Negative floor/ceil =====

@test
fn test_floor_negative() {
    assert_eq(math.floor(-3.2), -4)
    assert_eq(math.floor(-3.7), -4)
}

@test
fn test_ceil_negative() {
    assert_eq(math.ceil(-3.2), -3)
    assert_eq(math.ceil(-3.7), -3)
}

@test
fn test_round_negative() {
    assert_eq(math.round(-3.4), -3)
    assert_eq(math.round(-3.5), -4)
}
