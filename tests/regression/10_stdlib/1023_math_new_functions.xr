// 1023_math_new_functions.xr - Tests for newly added math functions

import math

// ===== Hyperbolic functions =====

@test
fn test_sinh_zero(): void {
    let r = math.sinh(0)
    assert(r > -0.01 && r < 0.01)
}

@test
fn test_sinh_one(): void {
    let r = math.sinh(1)
    assert(r > 1.17 && r < 1.18)  // sinh(1) ≈ 1.1752
}

@test
fn test_cosh_zero(): void {
    let r = math.cosh(0)
    assert(r > 0.99 && r < 1.01)  // cosh(0) = 1
}

@test
fn test_cosh_one(): void {
    let r = math.cosh(1)
    assert(r > 1.54 && r < 1.55)  // cosh(1) ≈ 1.5431
}

@test
fn test_tanh_zero(): void {
    let r = math.tanh(0)
    assert(r > -0.01 && r < 0.01)
}

@test
fn test_tanh_large(): void {
    let r = math.tanh(10)
    assert(r > 0.99 && r < 1.01)  // tanh(large) → 1
}

// ===== hypot =====

@test
fn test_hypot_345(): void {
    let r = math.hypot(3, 4)
    assert(r > 4.99 && r < 5.01)  // 3-4-5 triangle
}

@test
fn test_hypot_zero(): void {
    let r = math.hypot(0, 5)
    assert(r > 4.99 && r < 5.01)
}

// ===== cbrt =====

@test
fn test_cbrt_8(): void {
    let r = math.cbrt(8)
    assert(r > 1.99 && r < 2.01)
}

@test
fn test_cbrt_27(): void {
    let r = math.cbrt(27)
    assert(r > 2.99 && r < 3.01)
}

@test
fn test_cbrt_negative(): void {
    let r = math.cbrt(-8)
    assert(r > -2.01 && r < -1.99)
}

// ===== trunc =====

@test
fn test_trunc_positive_float(): void {
    assert_eq(math.trunc(3.9), 3)
}

@test
fn test_trunc_negative_float(): void {
    assert_eq(math.trunc(-3.9), -3)
}

// ===== fmod =====

@test
fn test_fmod_basic(): void {
    let r = math.fmod(5.3, 2.0)
    assert(r > 1.29 && r < 1.31)  // 5.3 mod 2.0 = 1.3
}

@test
fn test_fmod_negative(): void {
    let r = math.fmod(-5.3, 2.0)
    assert(r > -1.31 && r < -1.29)
}

// ===== log1p / expm1 =====

@test
fn test_log1p_zero(): void {
    let r = math.log1p(0)
    assert(r > -0.01 && r < 0.01)  // log(1+0) = 0
}

@test
fn test_log1p_small(): void {
    // log1p(1e-15) should be more accurate than log(1 + 1e-15)
    let r = math.log1p(1)
    assert(r > 0.69 && r < 0.70)  // ln(2) ≈ 0.6931
}

@test
fn test_expm1_zero(): void {
    let r = math.expm1(0)
    assert(r > -0.01 && r < 0.01)  // exp(0)-1 = 0
}

@test
fn test_expm1_one(): void {
    let r = math.expm1(1)
    assert(r > 1.71 && r < 1.72)  // e-1 ≈ 1.7183
}

// ===== lerp =====

@test
fn test_lerp_start(): void {
    let r = math.lerp(0, 10, 0)
    assert(r > -0.01 && r < 0.01)
}

@test
fn test_lerp_end(): void {
    let r = math.lerp(0, 10, 1)
    assert(r > 9.99 && r < 10.01)
}

@test
fn test_lerp_mid(): void {
    let r = math.lerp(0, 10, 0.5)
    assert(r > 4.99 && r < 5.01)
}

@test
fn test_lerp_quarter(): void {
    let r = math.lerp(100, 200, 0.25)
    assert(r > 124.9 && r < 125.1)
}

// ===== degToRad / radToDeg =====

@test
fn test_degToRad_180(): void {
    let r = math.degToRad(180)
    assert(r > 3.14 && r < 3.15)  // PI
}

@test
fn test_degToRad_90(): void {
    let r = math.degToRad(90)
    assert(r > 1.57 && r < 1.58)  // PI/2
}

@test
fn test_radToDeg_pi(): void {
    let r = math.radToDeg(math.PI)
    assert(r > 179.9 && r < 180.1)
}

@test
fn test_radToDeg_half_pi(): void {
    let r = math.radToDeg(math.PI / 2)
    assert(r > 89.9 && r < 90.1)
}

// ===== New constants =====

@test
fn test_tau(): void {
    let tau = math.TAU
    assert(tau > 6.28 && tau < 6.29)
}

@test
fn test_sqrt2(): void {
    let s = math.SQRT2
    assert(s > 1.41 && s < 1.42)
}

@test
fn test_ln2(): void {
    let l = math.LN2
    assert(l > 0.69 && l < 0.70)
}

@test
fn test_epsilon(): void {
    assert(math.EPSILON > 0)
    assert(math.EPSILON < 1e-10)
}

@test
fn test_max_int(): void {
    assert(math.MAX_INT > 0)
    assert_eq(typeof(math.MAX_INT) == Type.int, true)
}

@test
fn test_min_int(): void {
    assert(math.MIN_INT < 0)
    assert_eq(typeof(math.MIN_INT) == Type.int, true)
}

@test
fn test_max_float(): void {
    assert(math.MAX_FLOAT > 1e300)
}
