// 1402_crypto_random.xr
// 作者：xingleixu@gmail.com
// 测试：crypto 库随机数和 UUID 测试
//
// 覆盖功能：
//   - randomBytes 随机字节生成
//   - uuid UUID v4 生成

import crypto

// ============================================================
// 第一部分：randomBytes 测试
// ============================================================

@test
fn test_random_bytes_length_8() {
    // 生成 8 字节随机数（hex 编码后 16 字符）
    let r = crypto.randomBytes(8)
    assert_eq(r.length, 16)
}

@test
fn test_random_bytes_length_16() {
    // 生成 16 字节随机数（hex 编码后 32 字符）
    let r = crypto.randomBytes(16)
    assert_eq(r.length, 32)
}

@test
fn test_random_bytes_length_32() {
    // 生成 32 字节随机数（hex 编码后 64 字符）
    let r = crypto.randomBytes(32)
    assert_eq(r.length, 64)
}

@test
fn test_random_bytes_uniqueness() {
    // 验证每次生成的随机数不同
    let r1 = crypto.randomBytes(16)
    let r2 = crypto.randomBytes(16)
    assert_true(r1 != r2)
}

@test
fn test_random_bytes_hex_format() {
    // 验证输出是有效的十六进制字符串
    let r = crypto.randomBytes(4)
    assert_eq(r.length, 8)
    // 十六进制字符检查可以通过长度间接验证
}

// ============================================================
// 第二部分：UUID v4 测试
// ============================================================

@test
fn test_uuid_length() {
    // UUID v4 格式：xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
    let uuid = crypto.uuid()
    assert_eq(uuid.length, 36)
}

@test
fn test_uuid_format() {
    // 验证 UUID 包含 4 个破折号
    let uuid = crypto.uuid()
    let parts = uuid.split("-")
    assert_eq(parts.length, 5)
}

@test
fn test_uuid_parts_length() {
    // 验证各段长度：8-4-4-4-12
    let uuid = crypto.uuid()
    let parts = uuid.split("-")
    assert_eq(parts[0].length, 8)
    assert_eq(parts[1].length, 4)
    assert_eq(parts[2].length, 4)
    assert_eq(parts[3].length, 4)
    assert_eq(parts[4].length, 12)
}

@test
fn test_uuid_uniqueness() {
    // 验证每次生成的 UUID 不同
    let uuid1 = crypto.uuid()
    let uuid2 = crypto.uuid()
    assert_true(uuid1 != uuid2)
}

@test
fn test_uuid_multiple_uniqueness() {
    // 生成多个 UUID 验证唯一性
    let uuids: Array<string> = []
    for (i in 0..10) {
        uuids.push(crypto.uuid())
    }
    // 检查前两个不同（概率验证）
    assert_true(uuids[0] != uuids[1])
    assert_true(uuids[1] != uuids[2])
}
