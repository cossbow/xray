// Test gc module - runtime GC introspection and control

import gc

// @test gc.isrunning returns bool
@test
fn test_gc_isrunning() {
    let running = gc.isrunning()
    assert_eq(typeof(running), "bool")
}

// @test gc.count returns non-negative
@test
fn test_gc_count() {
    let kb = gc.count()
    assert(kb >= 0)
}

// @test gc.countb returns non-negative bytes
@test
fn test_gc_countb() {
    let bytes = gc.countb()
    assert(bytes >= 0)
}

// @test gc.objects returns non-negative
@test
fn test_gc_objects() {
    let objs = gc.objects()
    assert(objs >= 0)
}

// @test gc.state returns valid state string
@test
fn test_gc_state() {
    let state = gc.state()
    assert_eq(typeof(state), "string")
    assert(state.length > 0)
}

// @test gc.collect does not crash
@test
fn test_gc_collect() {
    gc.collect()
    assert(true)
}

// @test gc.step does not crash
@test
fn test_gc_step() {
    gc.step()
    assert(true)
}

// @test allocation increases memory
@test
fn test_alloc_increases_memory() {
    gc.collect()
    let before = gc.countb()
    let arr: Array<string> = []
    for (let i = 0; i < 100; i++) {
        arr.push("item_" + string(i))
    }
    let after = gc.countb()
    assert(after >= before)
}

print("All gc tests passed")
