// 1008_json_yaml_fuzz.xr
// Author: xingleixu@gmail.com
// Test: Programmatic fuzz testing for JSON/YAML parsers
// Generates random-ish structures and verifies roundtrip / no-crash behavior


import yaml

// ===== JSON fuzz: generated nested structures =====

@test
fn test_json_fuzz_nested_arrays(): void {
    // Build increasingly nested arrays: [1], [[1]], [[[1]]], ...
    for (let depth = 1; depth <= 8; depth++) {
        let s = ""
        for (let i = 0; i < depth; i++) { s = s + "[" }
        s = s + "1"
        for (let i = 0; i < depth; i++) { s = s + "]" }
        let result = Json.parse(s)
        // Navigate to innermost value
        let val = result
        for (let i = 1; i < depth; i++) { val = val[0] }
        assert_eq(val[0], 1)
    }
}

@test
fn test_json_fuzz_nested_objects(): void {
    // Build nested objects: {"k0":{"k1":{"k2":42}}}
    for (let depth = 1; depth <= 6; depth++) {
        let s = ""
        for (let i = 0; i < depth; i++) {
            s = s + "{\"k" + i.toString() + "\":"
        }
        s = s + "42"
        for (let i = 0; i < depth; i++) { s = s + "}" }
        let result = Json.parse(s)
        let val = result
        for (let i = 0; i < depth; i++) {
            val = val["k" + i.toString()]
        }
        assert_eq(val, 42)
    }
}

@test
fn test_json_fuzz_wide_arrays(): void {
    // Arrays with increasing width: [1], [1,2], [1,2,3], ..., [1..50]
    for (let width = 1; width <= 50; width += 10) {
        let parts: Array<string> = []
        for (let i = 0; i < width; i++) {
            parts.push(i.toString())
        }
        let s = "[" + parts.join(",") + "]"
        let arr = Json.parse(s)
        assert_eq(arr.length, width)
        assert_eq(arr[0], 0)
        assert_eq(arr[width - 1], width - 1)
    }
}

@test
fn test_json_fuzz_wide_objects(): void {
    // Objects with increasing key count
    for (let width = 1; width <= 50; width += 10) {
        let parts: Array<string> = []
        for (let i = 0; i < width; i++) {
            parts.push("\"f" + i.toString() + "\":" + i.toString())
        }
        let s = "{" + parts.join(",") + "}"
        let obj = Json.parse(s)
        assert_eq(obj["f0"], 0)
        assert_eq(obj["f" + (width - 1).toString()], width - 1)
    }
}

// ===== JSON fuzz: roundtrip stability =====

@test
fn test_json_roundtrip_stress(): void {
    // Build a complex object, stringify, parse, verify
    let data = {
        users: [],
        meta: { count: 0 }
    }
    for (let i = 0; i < 20; i++) {
        data.users.push({
            id: i,
            name: "user" + i.toString(),
            active: i % 2 == 0,
            scores: [i * 10, i * 20, i * 30]
        })
    }
    data.meta.count = 20

    let s = Json.stringify(data)
    let parsed = Json.parse(s)

    assert_eq(parsed.users.length, 20)
    assert_eq(parsed.meta.count, 20)
    assert_eq(parsed.users[0].id, 0)
    assert_eq(parsed.users[0].name, "user0")
    assert_eq(parsed.users[0].active, true)
    assert_eq(parsed.users[0].scores[2], 0)
    assert_eq(parsed.users[19].id, 19)
    assert_eq(parsed.users[19].name, "user19")
    assert_eq(parsed.users[19].active, false)
    assert_eq(parsed.users[19].scores[1], 380)
}

// ===== JSON fuzz: mixed type arrays =====

@test
fn test_json_fuzz_mixed_types(): void {
    // Alternate types in array
    let parts: Array<string> = []
    for (let i = 0; i < 30; i++) {
        let mod = i % 5
        if (mod == 0) { parts.push(i.toString()) }
        else if (mod == 1) { parts.push("\"s" + i.toString() + "\"") }
        else if (mod == 2) { parts.push("true") }
        else if (mod == 3) { parts.push("null") }
        else { parts.push("[" + i.toString() + "]") }
    }
    let s = "[" + parts.join(",") + "]"
    let arr = Json.parse(s)
    assert_eq(arr.length, 30)
    assert_eq(arr[0], 0)
    assert_eq(arr[1], "s1")
    assert_eq(arr[2], true)
    assert_eq(arr[3], null)
    assert_eq(arr[4][0], 4)
}

// ===== YAML fuzz: generated flow structures =====

@test
fn test_yaml_fuzz_flow_mappings(): void {
    // Generate flow mappings with increasing keys
    for (let n = 1; n <= 10; n += 3) {
        let parts: Array<string> = []
        for (let i = 0; i < n; i++) {
            parts.push("k" + i.toString() + ": " + i.toString())
        }
        let s = "data: {" + parts.join(", ") + "}"
        let obj = yaml.parse(s)
        let data = obj["data"]
        assert_eq(data["k0"], 0)
        assert_eq(data["k" + (n - 1).toString()], n - 1)
    }
}

@test
fn test_yaml_fuzz_flow_sequences(): void {
    // Generate flow sequences with increasing elements
    for (let n = 1; n <= 20; n += 5) {
        let parts: Array<string> = []
        for (let i = 0; i < n; i++) {
            parts.push(i.toString())
        }
        let s = "list: [" + parts.join(", ") + "]"
        let obj = yaml.parse(s)
        let list = obj["list"]
        assert_eq(list[0], 0)
        assert_eq(list[n - 1], n - 1)
    }
}

@test
fn test_yaml_fuzz_nested_flow(): void {
    // Nested flow mappings at various depths
    let s1 = "d: {a: {b: 1}}"
    let o1 = yaml.parse(s1)
    assert_eq(o1["d"]["a"]["b"], 1)

    let s2 = "d: {a: {b: {c: 2}}}"
    let o2 = yaml.parse(s2)
    assert_eq(o2["d"]["a"]["b"]["c"], 2)

    let s3 = "d: {a: {b: {c: {d: 3}}}}"
    let o3 = yaml.parse(s3)
    assert_eq(o3["d"]["a"]["b"]["c"]["d"], 3)
}

// ===== YAML fuzz: roundtrip =====

@test
fn test_yaml_roundtrip_basic(): void {
    let original = {"name" => "test", "version" => 1, "debug" => false}
    let s = yaml.stringify(original)
    let parsed = yaml.parse(s)
    assert_eq(parsed["name"], "test")
    assert_eq(parsed["version"], 1)
    assert_eq(parsed["debug"], false)
}

// ===== YAML fuzz: mixed block and flow =====

@test
fn test_yaml_fuzz_block_with_flow_values(): void {
    // Multiple block keys with flow values
    let lines: Array<string> = []
    for (let i = 0; i < 5; i++) {
        lines.push("group" + i.toString() + ": {val: " + (i * 10).toString() + "}")
    }
    let s = lines.join("\n")
    let obj = yaml.parse(s)
    assert_eq(obj["group0"]["val"], 0)
    assert_eq(obj["group2"]["val"], 20)
    assert_eq(obj["group4"]["val"], 40)
}

@test
fn test_yaml_fuzz_block_keys_with_flow_arrays(): void {
    let lines: Array<string> = []
    for (let i = 0; i < 4; i++) {
        let a = i * 3
        let b = i * 3 + 1
        let c = i * 3 + 2
        lines.push("row" + i.toString() + ": [" + a.toString() + ", " + b.toString() + ", " + c.toString() + "]")
    }
    let s = lines.join("\n")
    let obj = yaml.parse(s)
    assert_eq(obj["row0"][0], 0)
    assert_eq(obj["row0"][2], 2)
    assert_eq(obj["row3"][0], 9)
    assert_eq(obj["row3"][2], 11)
}

// ===== YAML fuzz: block sequence with nested mappings (regression) =====

@test
fn test_yaml_fuzz_block_sequence_nested(): void {
    // Programmatically generate block sequence items with nested mappings
    let lines: Array<string> = []
    lines.push("items:")
    for (let i = 0; i < 5; i++) {
        lines.push("  - id: " + i.toString())
        lines.push("    value: " + (i * 100).toString())
    }
    let s = lines.join("\n")
    let obj = yaml.parse(s)
    let items = obj["items"]
    assert_eq(items.length, 5)
    assert_eq(items[0]["id"], 0)
    assert_eq(items[0]["value"], 0)
    assert_eq(items[4]["id"], 4)
    assert_eq(items[4]["value"], 400)
}

// ===== YAML fuzz: mixed block + flow sequence items =====

@test
fn test_yaml_fuzz_mixed_block_flow_items(): void {
    let lines: Array<string> = []
    lines.push("data:")
    for (let i = 0; i < 4; i++) {
        if (i % 2 == 0) {
            lines.push("  - {k: " + i.toString() + "}")
        } else {
            lines.push("  - " + i.toString())
        }
    }
    let s = lines.join("\n")
    let obj = yaml.parse(s)
    let data = obj["data"]
    assert_eq(data[0]["k"], 0)
    assert_eq(data[1], 1)
    assert_eq(data[2]["k"], 2)
    assert_eq(data[3], 3)
}

// ===== JSON fuzz: deeply nested mixed structures =====

@test
fn test_json_fuzz_deep_mixed(): void {
    // Build: {"a": [{"b": [{"c": 42}]}]}
    let s = "{\"a\":[{\"b\":[{\"c\":42}]}]}"
    let obj = Json.parse(s)
    assert_eq(obj.a[0].b[0].c, 42)

    // Build: [{"k": [1, [2, [3]]]}]
    let s2 = "[{\"k\":[1,[2,[3]]]}]"
    let obj2 = Json.parse(s2)
    assert_eq(obj2[0].k[0], 1)
    assert_eq(obj2[0].k[1][0], 2)
    assert_eq(obj2[0].k[1][1][0], 3)
}

// ===== JSON fuzz: stress roundtrip with complex nesting =====

@test
fn test_json_fuzz_complex_roundtrip(): void {
    let data = {
        matrix: [[1, 2], [3, 4]],
        config: {
            nested: {
                deep: true,
                values: [10, 20, 30]
            }
        },
        tags: ["a", "b", "c"],
        empty_obj: {},
        empty_arr: [],
        flag: false,
        nothing: null
    }
    let s = Json.stringify(data)
    let p = Json.parse(s)
    assert_eq(p.matrix[0][0], 1)
    assert_eq(p.matrix[1][1], 4)
    assert_eq(p.config.nested.deep, true)
    assert_eq(p.config.nested.values[2], 30)
    assert_eq(p.tags[1], "b")
    assert_eq(p.flag, false)
    assert_eq(p.nothing, null)
}

// ===== JSON fuzz: stringify special values =====

@test
fn test_json_fuzz_stringify_special(): void {
    assert_eq(Json.stringify(null), "null")
    assert_eq(Json.stringify(true), "true")
    assert_eq(Json.stringify(false), "false")
    assert_eq(Json.stringify(42), "42")
    assert_eq(Json.stringify("hello"), "\"hello\"")
    assert_eq(Json.stringify([]), "[]")
    assert_eq(Json.stringify({}), "{}")
}

// ===== JSON fuzz: many nested arrays =====

@test
fn test_json_fuzz_many_nested_arrays(): void {
    // Build array of arrays: [[0,1],[2,3],[4,5],...,[98,99]]
    let parts: Array<string> = []
    for (let i = 0; i < 50; i++) {
        let a = i * 2
        let b = i * 2 + 1
        parts.push("[" + a.toString() + "," + b.toString() + "]")
    }
    let s = "[" + parts.join(",") + "]"
    let arr = Json.parse(s)
    assert_eq(arr.length, 50)
    assert_eq(arr[0][0], 0)
    assert_eq(arr[0][1], 1)
    assert_eq(arr[49][0], 98)
    assert_eq(arr[49][1], 99)
}

// ===== YAML fuzz: deep nested block mappings =====

@test
fn test_yaml_fuzz_deep_block(): void {
    let lines: Array<string> = []
    // Build 5-level deep block mapping
    lines.push("l0:")
    lines.push("  l1:")
    lines.push("    l2:")
    lines.push("      l3:")
    lines.push("        l4: deep_value")
    let s = lines.join("\n")
    let obj = yaml.parse(s)
    assert_eq(obj["l0"]["l1"]["l2"]["l3"]["l4"], "deep_value")
}

// ===== YAML fuzz: multiple block sequences at same level =====

@test
fn test_yaml_fuzz_sibling_sequences(): void {
    let s = "a: [1, 2, 3]\nb: [4, 5, 6]\nc: [7, 8, 9]"
    let obj = yaml.parse(s)
    assert_eq(obj["a"][0], 1)
    assert_eq(obj["b"][1], 5)
    assert_eq(obj["c"][2], 9)
}
