// 1421_datetime_format.xr
// Test: datetime formatting (dot-syntax API)

import datetime

// ============================================================
// Part 1: Basic formatting
// ============================================================

@test
fn test_format_full(): void {
    let dt = datetime.create(2024, 6, 15, 14, 30, 45)
    let formatted = dt.format("YYYY-MM-DD HH:mm:ss")
    assert_eq(formatted, "2024-06-15 14:30:45")
}

@test
fn test_format_date_only(): void {
    let dt = datetime.create(2024, 6, 15, 14, 30, 45)
    let formatted = dt.format("YYYY-MM-DD")
    assert_eq(formatted, "2024-06-15")
}

@test
fn test_format_time_only(): void {
    let dt = datetime.create(2024, 6, 15, 14, 30, 45)
    let formatted = dt.format("HH:mm:ss")
    assert_eq(formatted, "14:30:45")
}

@test
fn test_format_compact(): void {
    let dt = datetime.create(2024, 6, 15)
    let formatted = dt.format("YYYYMMDD")
    assert_eq(formatted, "20240615")
}

@test
fn test_format_short_time(): void {
    let dt = datetime.create(2024, 6, 15, 14, 30, 45)
    let formatted = dt.format("HH:mm")
    assert_eq(formatted, "14:30")
}

// ============================================================
// Part 2: Edge cases
// ============================================================

@test
fn test_format_new_year(): void {
    let dt = datetime.create(2024, 1, 1, 0, 0, 0)
    let formatted = dt.format("YYYY-MM-DD HH:mm:ss")
    assert_eq(formatted, "2024-01-01 00:00:00")
}

@test
fn test_format_year_end(): void {
    let dt = datetime.create(2024, 12, 31, 23, 59, 59)
    let formatted = dt.format("YYYY-MM-DD HH:mm:ss")
    assert_eq(formatted, "2024-12-31 23:59:59")
}

@test
fn test_format_single_digit_month(): void {
    let dt = datetime.create(2024, 3, 5)
    let formatted = dt.format("YYYY-MM-DD")
    assert_eq(formatted, "2024-03-05")
}

@test
fn test_format_midnight(): void {
    let dt = datetime.create(2024, 6, 15, 0, 0, 0)
    let formatted = dt.format("HH:mm:ss")
    assert_eq(formatted, "00:00:00")
}

@test
fn test_format_noon(): void {
    let dt = datetime.create(2024, 6, 15, 12, 0, 0)
    let formatted = dt.format("HH:mm:ss")
    assert_eq(formatted, "12:00:00")
}

// ============================================================
// Part 3: Current time formatting
// ============================================================

@test
fn test_format_now(): void {
    let dt = datetime.now()
    let formatted = dt.format("YYYY-MM-DD")
    assert_eq(formatted.length, 10)
}

@test
fn test_format_now_full(): void {
    let dt = datetime.now()
    let formatted = dt.format("YYYY-MM-DD HH:mm:ss")
    assert_eq(formatted.length, 19)
}

// ============================================================
// Part 4: toISOString
// ============================================================

@test
fn test_to_iso_string_utc(): void {
    let dt = datetime.fromTimestamp(1718438400)
    let iso = dt.toISOString()
    assert_true(iso.length > 20)
}
