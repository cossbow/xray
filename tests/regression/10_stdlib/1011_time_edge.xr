// 1011_time_edge.xr - Time module edge case tests

import time

// ===== Monotonic clock ordering =====

@test
fn test_monotonic_ordering() {
    let t1 = time.monotonic()
    let t2 = time.monotonic()
    let t3 = time.monotonic()
    assert(t3 >= t2)
    assert(t2 >= t1)
}

// ===== time.now precision =====

@test
fn test_now_returns_milliseconds() {
    let t = time.now()
    // Should be in milliseconds (13+ digits since 2001)
    assert(t > 1000000000000)
}

@test
fn test_now_advances() {
    let t1 = time.now()
    time.sleep(10)
    let t2 = time.now()
    assert(t2 > t1)
}

// ===== time.clock accumulates =====

@test
fn test_clock_non_negative() {
    let c = time.clock()
    assert(c >= 0)
}

// ===== time.sleep boundary =====

@test
fn test_sleep_zero() {
    let start = time.monotonic()
    time.sleep(0)
    let end = time.monotonic()
    assert(end >= start)
}

@test
fn test_sleep_small() {
    let start = time.monotonic()
    time.sleep(1)
    let end = time.monotonic()
    assert(end >= start)
}
