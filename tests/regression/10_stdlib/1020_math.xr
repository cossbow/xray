// 测试：数学运算

import math

// ===== 基本数学 =====

@test
fn test_abs_positive(): void {
    assert_eq(math.abs(5), 5)
    assert_eq(math.abs(100), 100)
}

@test
fn test_abs_negative(): void {
    assert_eq(math.abs(-5), 5)
    assert_eq(math.abs(-100), 100)
}

@test
fn test_abs_zero(): void {
    assert_eq(math.abs(0), 0)
}

// ===== 最大最小值 =====

@test
fn test_max(): void {
    assert_eq(math.max(3, 7), 7)
    assert_eq(math.max(-5, -2), -2)
    assert_eq(math.max(10, 10), 10)
}

@test
fn test_min(): void {
    assert_eq(math.min(3, 7), 3)
    assert_eq(math.min(-5, -2), -5)
    assert_eq(math.min(10, 10), 10)
}

// ===== 取整函数 =====

@test
fn test_floor(): void {
    assert_eq(math.floor(3.7), 3)
    assert_eq(math.floor(3.2), 3)
    assert_eq(math.floor(-3.2), -4)
}

@test
fn test_ceil(): void {
    assert_eq(math.ceil(3.2), 4)
    assert_eq(math.ceil(3.7), 4)
    assert_eq(math.ceil(-3.7), -3)
}

@test
fn test_round(): void {
    assert_eq(math.round(3.4), 3)
    assert_eq(math.round(3.5), 4)
    assert_eq(math.round(3.6), 4)
}

// ===== 幂运算 =====

@test
fn test_pow(): void {
    assert_eq(math.pow(2, 3), 8)
    assert_eq(math.pow(3, 2), 9)
    assert_eq(math.pow(10, 0), 1)
}

@test
fn test_sqrt(): void {
    assert_eq(math.sqrt(4), 2)
    assert_eq(math.sqrt(9), 3)
    assert_eq(math.sqrt(1), 1)
}

// ===== 常量 =====

@test
fn test_pi(): void {
    let pi = math.PI
    assert_eq(pi > 3.14, true)
    assert_eq(pi < 3.15, true)
}

@test
fn test_e(): void {
    let e = math.E
    assert_eq(e > 2.71, true)
    assert_eq(e < 2.72, true)
}

// ===== 三角函数 =====

@test
fn test_sin_zero(): void {
    let s = math.sin(0)
    assert_eq(s > -0.01, true)
    assert_eq(s < 0.01, true)
}

@test
fn test_cos_zero(): void {
    let c = math.cos(0)
    assert_eq(c > 0.99, true)
    assert_eq(c < 1.01, true)
}

// ===== 随机数 =====

@test
fn test_random_range(): void {
    let r = math.random()
    assert_eq(r >= 0, true)
    assert_eq(r < 1, true)
}

