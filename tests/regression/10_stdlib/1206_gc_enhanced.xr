// Test enhanced gc module - covers new APIs and edge cases
// Added after gc module optimization (P0-P3)
//
// REGRESSION: Bugs #8 / #10 / #11 - GC chain corruption under
//             --jit-force (commits 5f7a535 + 2e1dacc).
// FAIL_AT:    pre-5f7a535 / pre-2e1dacc on x64 with --jit-force,
//             >50% rate on the 1205+1206+1207 GC-stress combo
//             -> Bug #8 (5f7a535): sweep_block rebuilt
//                block->alloc_marks without first flushing the
//                deferred JIT-inline-allocator marks; lines actually
//                holding live objects were treated as free, the hole
//                scanner allocated new objects on top of still-live
//                ones, and the next sweep walked a corrupted
//                local_allgc list and crashed on a garbage curr ptr
//                (e.g. 0x0000_0004_0000_0005).
//             -> Bug #10 (2e1dacc): mark_coro_roots scanned the JIT
//                GC stack map using ARM64 frame layout constants on
//                x64; the "pointers" so obtained were garbage that
//                reallymarkobject dereferenced and stamped 0x04 over
//                neighbouring live chain links.
//             -> Bug #11 (2e1dacc): conservative stack scan of
//                coro->vm_ctx.stack tagged JIT-frame XrValue slots as
//                live PTRs, but the JIT never writes vm_ctx.stack, so
//                those triplets were stale leftovers from earlier
//                interpreter activations and the ptr no longer aimed
//                at a valid object start.
// PASS_AT:    5f7a535+ (xr_immix_flush_marks at sweep_block entry,
//             idempotent so steady-state cost is negligible) AND
//             2e1dacc+ (ARM64-only guard around the stack-map scan,
//             plus four-shape GCHeader validate at markobject entry).
//             1206 under --jit-force: 30/30 burn-in green on
//             Windows x64.
// REQUIRES_JIT_FORCE  (for Bugs #10 / #11; Bug #8 also surfaces
//                     under --no-jit when JIT inline allocator runs
//                     in the same process, but the 1206 case is the
//                     historical reproducer under JIT-force).
//
// Triggering combination: 1206 alone gives partial coverage;
// `scripts/run_gc_stress.sh 10` exercises 1205/1206/1207 in
// rotation, which is the exact sequence that surfaced all three
// bugs during the May 2026 burn-in.

import gc

// @test gc.disable/enable pairing works
@test
fn test_gc_disable_enable() {
    assert_eq(gc.isrunning(), true)
    gc.disable()
    assert_eq(gc.isrunning(), false)
    gc.enable()
    assert_eq(gc.isrunning(), true)
}

// @test gc.disable prevents GC from running
@test
fn test_gc_disable_prevents_gc() {
    gc.disable()
    let before_count = gc.gccount()
    // Allocate a bunch of objects
    let arr: Array<Json> = []
    for (let i = 0; i < 500; i++) {
        arr.push({"idx" => i, "data" => "item_" + string(i)})
    }
    // GC should not have run while disabled
    let after_count = gc.gccount()
    assert_eq(before_count, after_count)
    gc.enable()
}

// @test gc.setpause returns old value
@test
fn test_gc_setpause_returns_old() {
    let old1 = gc.setpause(150)
    let old2 = gc.setpause(200)
    assert_eq(old2, 150)
    // Restore
    gc.setpause(old1)
}

// @test gc.setstepmul returns old value
@test
fn test_gc_setstepmul_returns_old() {
    let old1 = gc.setstepmul(300)
    let old2 = gc.setstepmul(100)
    assert_eq(old2, 300)
    // Restore
    gc.setstepmul(old1)
}

// @test gc.info contains expected keys
@test
fn test_gc_info_keys() {
    let info = gc.info()
    // Memory stats
    assert(info["totalBytes"] >= 0)
    assert(info["totalKB"] >= 0.0)
    assert(info["marked"] >= 0)
    // GC state
    assert(info["state"].length > 0)
    assert(info["gcCount"] >= 0)
    // Tuning
    assert(info["pause"] > 0)
    assert(info["stepMul"] > 0)
    // Timing (new)
    assert(info["gcTimeMs"] >= 0.0)
    assert(info["lastGcTimeUs"] >= 0.0)
    // Immix stats (new)
    assert(info["blocks"] >= 0)
    assert(info["freeBlocks"] >= 0)
    assert(info["recycleBlocks"] >= 0)
    assert(info["fullBlocks"] >= 0)
    assert(info["liveLines"] >= 0)
    assert(info["freeLines"] >= 0)
    // Monitoring
    assert(info["finalizerCount"] >= 0)
}

// @test gc.collect updates timing stats
@test
fn test_gc_collect_updates_timing() {
    gc.collect()
    let info = gc.info()
    // After at least one collect, lastGcTimeUs should be > 0
    assert(info["lastGcTimeUs"] > 0.0)
    assert(info["gcTimeMs"] >= 0.0)
}

// @test gc.collect returns cycle count
@test
fn test_gc_collect_returns_count() {
    let count1 = gc.collect()
    let count2 = gc.collect()
    assert(count2 > count1)
}

// @test gc.countb decreases after collect with dead objects
@test
fn test_gc_countb_decreases_after_collect() {
    gc.collect()
    let baseline = gc.countb()
    // Create objects in a scope that makes them collectable
    fn make_garbage() {
        let temp: Array<Json> = []
        for (let i = 0; i < 200; i++) {
            temp.push({"garbage" => i})
        }
    }
    make_garbage()
    let after_alloc = gc.countb()
    assert(after_alloc >= baseline)
    gc.collect()
    let after_gc = gc.countb()
    // Memory should decrease (garbage was collected)
    assert(after_gc <= after_alloc)
}

// @test gc.objects tracks allocations
@test
fn test_gc_objects_tracks_alloc() {
    let before = gc.objects()
    let arr: Array<Json> = []
    for (let i = 0; i < 10; i++) {
        arr.push({"k" => i})
    }
    let after = gc.objects()
    assert(after > before)
}

// @test gc.fragmentation returns valid ratio
@test
fn test_gc_fragmentation() {
    let frag = gc.fragmentation()
    assert(frag >= 0.0)
    assert(frag <= 1.0)
}

// @test gc.fragmentation changes after churn
@test
fn test_gc_fragmentation_after_churn() {
    gc.collect()
    let frag_before = gc.fragmentation()
    // Create and discard lots of objects to cause fragmentation
    for (let round = 0; round < 10; round++) {
        let temp: Array<Array<int>> = []
        for (let j = 0; j < 100; j++) {
            temp.push([j, j + 1])
        }
    }
    gc.collect()
    let frag_after = gc.fragmentation()
    // Both should be valid ratios
    assert(frag_after >= 0.0)
    assert(frag_after <= 1.0)
}

// @test gc.debt basic behavior
@test
fn test_gc_debt() {
    gc.collect()
    let debt_after_gc = gc.debt()
    // After full GC, debt should be non-positive (budget remaining)
    assert(debt_after_gc <= 0)
}

// @test gc.state returns valid state names
@test
fn test_gc_state_valid() {
    let state = gc.state()
    // State should be one of the valid GC states
    let valid_states = ["PAUSE", "PROPAGATE", "ATOMIC", "SWEEP", "FINALIZE"]
    let found = false
    for (let i = 0; i < valid_states.length; i++) {
        if (state == valid_states[i]) {
            found = true
        }
    }
    assert(found)
}

print("All enhanced gc tests passed")
