// Test HTTP/2 client API existence

import http

@test
fn test_h2_apis_exist() {
    assert(http.h2Get != null)
    assert(http.h2Post != null)
    assert(http.h2Request != null)
}

@test
fn test_h2_options_object() {
    let opts = {
        url: "https://example.com/api",
        method: "POST",
        headers: { "Content-Type" => "application/json" },
        body: '{"key": "value"}'
    }
    assert_eq(opts.method, "POST")
    assert(opts.headers != null)
}

print("All http2 client tests passed")