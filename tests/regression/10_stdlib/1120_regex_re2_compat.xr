/**
 * @file 1120_regex_re2_compat.xr
 * @brief RE2 正则引擎兼容性回归测试
 * @author xingleixu@gmail.com
 * 
 * 基于 re2/testing 测试用例，确保 xray 正则库与 RE2 兼容
 */

import regex

// ============================================================================
// 辅助函数
// ============================================================================

fn match_ok(pattern: string, text: string): bool {
    let re = regex.compile(pattern)
    if (re == null) {
        return false
    }
    return regex.find(re, text) != null
}

fn match_eq(pattern: string, text: string, expected: string): bool {
    let re = regex.compile(pattern)
    if (re == null) {
        return false
    }
    let result = regex.find(re, text)
    if (result == null) {
        return false
    }
    return result["text"] == expected
}

// ============================================================================
// 1. 基本字面量匹配
// ============================================================================

@test
fn test_literal_single_char(): void {
    assert_eq(match_ok("a", "a"), true)
    assert_eq(match_ok("a", "b"), false)
    assert_eq(match_ok("a", ""), false)
}

@test
fn test_literal_in_string(): void {
    assert_eq(match_ok("a", "zyzzyva"), true)
    assert_eq(match_ok("a", "cab"), true)
    assert_eq(match_ok("hello", "hello world"), true)
}

@test
fn test_literal_multi_char(): void {
    assert_eq(match_ok("abc", "abc"), true)
    assert_eq(match_ok("abc", "xabcy"), true)
    assert_eq(match_ok("abc", "ab"), false)
}

// ============================================================================
// 2. 量词测试
// ============================================================================

@test
fn test_star_quantifier(): void {
    assert_eq(match_ok("a*", ""), true)
    assert_eq(match_ok("a*", "a"), true)
    assert_eq(match_ok("a*", "aaa"), true)
    assert_eq(match_ok("a*", "b"), true)  // 空匹配
}

@test
fn test_plus_quantifier(): void {
    assert_eq(match_ok("a+", ""), false)
    assert_eq(match_ok("a+", "a"), true)
    assert_eq(match_ok("a+", "aaa"), true)
    assert_eq(match_ok("a+", "b"), false)
}

@test
fn test_question_quantifier(): void {
    assert_eq(match_ok("a?", ""), true)
    assert_eq(match_ok("a?", "a"), true)
    assert_eq(match_ok("a?", "aa"), true)
    assert_eq(match_ok("a?", "b"), true)  // 空匹配
}

@test
fn test_repeat_exact(): void {
    assert_eq(match_ok("a{2}", "a"), false)
    assert_eq(match_ok("a{2}", "aa"), true)
    assert_eq(match_ok("a{2}", "aaa"), true)
}

@test
fn test_repeat_range(): void {
    assert_eq(match_ok("a{2,3}", "a"), false)
    assert_eq(match_ok("a{2,3}", "aa"), true)
    assert_eq(match_ok("a{2,3}", "aaa"), true)
    assert_eq(match_ok("a{2,3}", "aaaa"), true)
}

@test
fn test_repeat_min(): void {
    assert_eq(match_ok("a{2,}", "a"), false)
    assert_eq(match_ok("a{2,}", "aa"), true)
    assert_eq(match_ok("a{2,}", "aaaa"), true)
}

// ============================================================================
// 3. 锚点测试
// ============================================================================

@test
fn test_anchor_begin(): void {
    assert_eq(match_ok("^a", "a"), true)
    assert_eq(match_ok("^a", "ba"), false)
    assert_eq(match_ok("^", "x"), true)
    assert_eq(match_ok("^", ""), true)
}

@test
fn test_anchor_end(): void {
    assert_eq(match_ok("a$", "a"), true)
    assert_eq(match_ok("a$", "ab"), false)
    assert_eq(match_ok("$", "x"), true)
    assert_eq(match_ok("$", ""), true)
}

@test
fn test_anchor_both(): void {
    assert_eq(match_ok("^a$", "a"), true)
    assert_eq(match_ok("^a$", "ab"), false)
    assert_eq(match_ok("^a$", "ba"), false)
    assert_eq(match_ok("^$", ""), true)
    assert_eq(match_ok("^$", "a"), false)
}

@test
fn test_anchor_with_alt(): void {
    assert_eq(match_ok("^(foo|bar)$", "foo"), true)
    assert_eq(match_ok("^(foo|bar)$", "bar"), true)
    assert_eq(match_ok("^(foo|bar)$", "baz"), false)
}

// ============================================================================
// 4. 字符类测试
// ============================================================================

@test
fn test_char_class_simple(): void {
    assert_eq(match_ok("[abc]", "a"), true)
    assert_eq(match_ok("[abc]", "b"), true)
    assert_eq(match_ok("[abc]", "c"), true)
    assert_eq(match_ok("[abc]", "d"), false)
}

@test
fn test_char_class_range(): void {
    assert_eq(match_ok("[a-z]", "a"), true)
    assert_eq(match_ok("[a-z]", "m"), true)
    assert_eq(match_ok("[a-z]", "z"), true)
    assert_eq(match_ok("[a-z]", "A"), false)
    assert_eq(match_ok("[a-z]", "0"), false)
}

@test
fn test_char_class_negated(): void {
    assert_eq(match_ok("[^a]", "b"), true)
    assert_eq(match_ok("[^a]", "a"), false)
    assert_eq(match_ok("[^a-z]", "A"), true)
    assert_eq(match_ok("[^a-z]", "0"), true)
    assert_eq(match_ok("[^a-z]", "a"), false)
    assert_eq(match_ok("[^0-9]", "a"), true)
    assert_eq(match_ok("[^0-9]", "5"), false)
}

@test
fn test_char_class_combined(): void {
    assert_eq(match_ok("[a-zA-Z]", "a"), true)
    assert_eq(match_ok("[a-zA-Z]", "Z"), true)
    assert_eq(match_ok("[a-zA-Z0-9]", "5"), true)
}

// ============================================================================
// 5. 预定义字符类测试
// ============================================================================

@test
fn test_digit_class(): void {
    assert_eq(match_ok("\\d", "0"), true)
    assert_eq(match_ok("\\d", "9"), true)
    assert_eq(match_ok("\\d", "a"), false)
    assert_eq(match_ok("\\d+", "123"), true)
}

@test
fn test_word_class(): void {
    assert_eq(match_ok("\\w", "a"), true)
    assert_eq(match_ok("\\w", "Z"), true)
    assert_eq(match_ok("\\w", "0"), true)
    assert_eq(match_ok("\\w", "_"), true)
    assert_eq(match_ok("\\w", "-"), false)
}

@test
fn test_space_class(): void {
    assert_eq(match_ok("\\s", " "), true)
    assert_eq(match_ok("\\s", "\t"), true)
    assert_eq(match_ok("\\s", "\n"), true)
    assert_eq(match_ok("\\s", "a"), false)
}

@test
fn test_negated_classes(): void {
    assert_eq(match_ok("\\D", "a"), true)
    assert_eq(match_ok("\\D", "0"), false)
    assert_eq(match_ok("\\W", "-"), true)
    assert_eq(match_ok("\\W", "a"), false)
    assert_eq(match_ok("\\S", "a"), true)
    assert_eq(match_ok("\\S", " "), false)
}

// ============================================================================
// 6. 交替测试
// ============================================================================

@test
fn test_alternation_simple(): void {
    assert_eq(match_ok("a|b", "a"), true)
    assert_eq(match_ok("a|b", "b"), true)
    assert_eq(match_ok("a|b", "c"), false)
}

@test
fn test_alternation_words(): void {
    assert_eq(match_ok("foo|bar", "foo"), true)
    assert_eq(match_ok("foo|bar", "bar"), true)
    assert_eq(match_ok("foo|bar", "baz"), false)
}

@test
fn test_alternation_in_group(): void {
    assert_eq(match_ok("(a|b)c", "ac"), true)
    assert_eq(match_ok("(a|b)c", "bc"), true)
    assert_eq(match_ok("(a|b)c", "cc"), false)
}

// ============================================================================
// 7. 分组测试
// ============================================================================

@test
fn test_capture_group(): void {
    assert_eq(match_ok("(a)", "a"), true)
    assert_eq(match_ok("(ab)", "ab"), true)
    assert_eq(match_ok("(a)(b)", "ab"), true)
}

@test
fn test_noncapture_group(): void {
    assert_eq(match_ok("(?:a)", "a"), true)
    assert_eq(match_ok("(?:ab)+", "abab"), true)
}

@test
fn test_nested_groups(): void {
    assert_eq(match_ok("((a))", "a"), true)
    assert_eq(match_ok("(a(b)c)", "abc"), true)
    assert_eq(match_ok("((a)(b))", "ab"), true)
}

@test
fn test_deeply_nested(): void {
    assert_eq(match_ok("((((((((((x))))))))))", "x"), true)
}

// ============================================================================
// 8. 词边界测试
// ============================================================================

@test
fn test_word_boundary(): void {
    assert_eq(match_ok("\\bfoo\\b", "foo"), true)
    assert_eq(match_ok("\\bfoo\\b", "foo bar"), true)
    assert_eq(match_ok("\\bfoo\\b", "foobar"), false)
    assert_eq(match_ok("\\bfoo\\b", "barfoo"), false)
}

@test
fn test_word_boundary_single(): void {
    assert_eq(match_ok("\\bx\\b", "x"), true)
    assert_eq(match_ok("\\bx\\b", "<x>"), true)
    assert_eq(match_ok("\\bx\\b", "ax"), false)
}

@test
fn test_not_word_boundary(): void {
    assert_eq(match_ok("\\Bfoo", "xfoo"), true)
    assert_eq(match_ok("foo\\B", "foobar"), true)
}

// ============================================================================
// 9. 点号测试
// ============================================================================

@test
fn test_dot(): void {
    assert_eq(match_ok(".", "a"), true)
    assert_eq(match_ok(".", "1"), true)
    assert_eq(match_ok(".", " "), true)
    assert_eq(match_ok(".", "\n"), false)  // 默认不匹配换行
}

@test
fn test_dot_star(): void {
    assert_eq(match_ok("a.*b", "ab"), true)
    assert_eq(match_ok("a.*b", "axxb"), true)
    assert_eq(match_ok("a.*b", "a\nb"), false)  // 不跨行
}

// ============================================================================
// 10. 转义字符测试
// ============================================================================

@test
fn test_escape_metachar(): void {
    assert_eq(match_ok("\\.", "a.b"), true)
    assert_eq(match_ok("\\.", "ab"), false)
    assert_eq(match_ok("\\^", "^"), true)
    assert_eq(match_ok("\\$", "$"), true)
    assert_eq(match_ok("\\\\", "\\"), true)
}

@test
fn test_escape_special(): void {
    assert_eq(match_ok("\\|", "|"), true)
    assert_eq(match_ok("\\(", "("), true)
    assert_eq(match_ok("\\)", ")"), true)
    assert_eq(match_ok("\\[", "["), true)
    assert_eq(match_ok("\\]", "]"), true)
    assert_eq(match_ok("\\*", "*"), true)
    assert_eq(match_ok("\\+", "+"), true)
    assert_eq(match_ok("\\?", "?"), true)
}

@test
fn test_escape_sequences(): void {
    assert_eq(match_ok("\\t", "\t"), true)
    assert_eq(match_ok("\\n", "\n"), true)
    assert_eq(match_ok("\\r", "\r"), true)
}

// ============================================================================
// 11. Unicode 属性测试
// ============================================================================

@test
fn test_unicode_han(): void {
    assert_eq(match_ok("\\p{Han}", "你"), true)
    assert_eq(match_ok("\\p{Han}", "a"), false)
    assert_eq(match_ok("\\p{Han}+", "你好世界"), true)
}

@test
fn test_unicode_latin(): void {
    assert_eq(match_ok("\\p{Latin}", "a"), true)
    assert_eq(match_ok("\\p{Latin}", "Z"), true)
    assert_eq(match_ok("\\p{Latin}", "你"), false)
}

@test
fn test_unicode_number(): void {
    assert_eq(match_ok("\\p{N}", "0"), true)
    assert_eq(match_ok("\\p{N}", "9"), true)
    assert_eq(match_ok("\\p{N}+", "123"), true)
}

@test
fn test_unicode_negated(): void {
    assert_eq(match_ok("\\P{Han}", "a"), true)
    assert_eq(match_ok("\\P{Han}", "你"), false)
    assert_eq(match_eq("\\P{Han}+", "你好World", "World"), true)
}

@test
fn test_unicode_mixed(): void {
    assert_eq(match_eq("\\p{Han}+", "Hello你好World", "你好"), true)
    assert_eq(match_eq("\\p{Latin}+", "你好Hello世界", "Hello"), true)
}

// ============================================================================
// 12. UTF-8 测试
// ============================================================================

@test
fn test_utf8_literal(): void {
    assert_eq(match_ok("本", "本"), true)
    assert_eq(match_ok("日本語", "日本語"), true)
}

@test
fn test_utf8_dot(): void {
    assert_eq(match_ok("...", "日本語"), true)
    assert_eq(match_ok("..", "你好"), true)
}

@test
fn test_utf8_greek(): void {
    assert_eq(match_ok("α", "α"), true)
    assert_eq(match_ok("α+", "αβγ"), true)
}

// ============================================================================
// 13. 非贪婪量词测试
// ============================================================================

@test
fn test_lazy_star(): void {
    assert_eq(match_eq("a*?", "aaa", ""), true)
}

@test
fn test_lazy_plus(): void {
    assert_eq(match_eq("a+?", "aaa", "a"), true)
}

@test
fn test_lazy_question(): void {
    assert_eq(match_eq("a??", "a", ""), true)
}

@test
fn test_lazy_repeat(): void {
    assert_eq(match_eq("a{2,}?", "aaaa", "aa"), true)
}

// ============================================================================
// 14. 忽略大小写测试
// ============================================================================

@test
fn test_ignorecase_inline(): void {
    let re = regex.compile("(?i)hello")
    let result = regex.find(re, "HELLO")
    assert_eq(result != null, true)
    assert_eq(result["text"], "HELLO")
}

@test
fn test_ignorecase_flag(): void {
    let re = regex.compile("hello", "i")
    let result = regex.find(re, "HeLLo")
    assert_eq(result != null, true)
    assert_eq(result["text"], "HeLLo")
}

@test
fn test_case_sensitive(): void {
    assert_eq(match_ok("hello", "HELLO"), false)
}

// ============================================================================
// 15. 多行模式测试
// ============================================================================

@test
fn test_multiline_begin(): void {
    let re = regex.compile("(?m)^world")
    let result = regex.find(re, "hello\nworld")
    assert_eq(result != null, true)
}

@test
fn test_multiline_end(): void {
    let re = regex.compile("(?m)hello$")
    let result = regex.find(re, "hello\nworld")
    assert_eq(result != null, true)
}

// ============================================================================
// 16. DOTALL 模式测试
// ============================================================================

@test
fn test_dotall(): void {
    let re = regex.compile("(?s)a.b")
    let result = regex.find(re, "a\nb")
    assert_eq(result != null, true)
}

@test
fn test_dot_no_newline(): void {
    assert_eq(match_ok("a.b", "a\nb"), false)
}

// ============================================================================
// 17. 替换和分割测试
// ============================================================================

@test
fn test_replace(): void {
    let re = regex.compile("\\d+")
    let result = regex.replace(re, "abc123def", "XXX")
    assert_eq(result, "abcXXXdef")
}

@test
fn test_replace_all(): void {
    let re = regex.compile("\\d+")
    let result = regex.replaceAll(re, "a1b2c3", "X")
    assert_eq(result, "aXbXcX")
}

@test
fn test_split(): void {
    let re = regex.compile(",\\s*")
    let parts = regex.split(re, "a, b, c")
    assert_eq(parts.length, 3)
    assert_eq(parts[0], "a")
    assert_eq(parts[1], "b")
    assert_eq(parts[2], "c")
}

// ============================================================================
// 18. 边界情况测试
// ============================================================================

@test
fn test_empty_pattern(): void {
    assert_eq(match_ok("", "abc"), true)  // 空模式匹配空字符串
}

@test
fn test_empty_text(): void {
    assert_eq(match_ok("a", ""), false)
    assert_eq(match_ok("a*", ""), true)
    assert_eq(match_ok("a?", ""), true)
}

@test
fn test_complex_pattern(): void {
    assert_eq(match_ok("(a+|b)+", "ab"), true)
    assert_eq(match_ok("((a|b)+)", "abab"), true)
    assert_eq(match_ok("a(b|c)*d", "abbbcd"), true)
}

print("=== RE2 兼容性回归测试完成 ===")
