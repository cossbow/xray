import json

// 1004_json_nested.xr
// 作者：xingleixu@gmail.com
// 测试：JSON 深嵌套和复杂结构测试
// 借鉴：simdjson 的嵌套和大型文档测试

// ===== 数组嵌套测试 =====

@test
fn test_nested_array_2_levels(): void {
    let arr = json.parse("[[1, 2], [3, 4]]")
    assert_eq(arr.length, 2)
    assert_eq(arr[0][0], 1)
    assert_eq(arr[0][1], 2)
    assert_eq(arr[1][0], 3)
    assert_eq(arr[1][1], 4)
}

@test
fn test_nested_array_3_levels(): void {
    let arr = json.parse("[[[1, 2], [3, 4]], [[5, 6], [7, 8]]]")
    assert_eq(arr[0][0][0], 1)
    assert_eq(arr[0][1][1], 4)
    assert_eq(arr[1][0][0], 5)
    assert_eq(arr[1][1][1], 8)
}

@test
fn test_nested_array_deep(): void {
    // 6 层嵌套
    let arr = json.parse("[[[[[[42]]]]]]")
    assert_eq(arr[0][0][0][0][0][0], 42)
}

@test
fn test_nested_empty_arrays(): void {
    let arr = json.parse("[[], [[]], [[], []]]")
    assert_eq(arr.length, 3)
    assert_eq(arr[0].length, 0)
    assert_eq(arr[1].length, 1)
    assert_eq(arr[1][0].length, 0)
    assert_eq(arr[2].length, 2)
}

// ===== 对象嵌套测试 =====

@test
fn test_nested_object_2_levels(): void {
    let obj = json.parse("{\"user\": {\"name\": \"Alice\", \"age\": 30}}")
    assert_eq(obj.user.name, "Alice")
    assert_eq(obj.user.age, 30)
}

@test
fn test_nested_object_3_levels(): void {
    let obj = json.parse("{\"a\": {\"b\": {\"c\": 42}}}")
    assert_eq(obj.a.b.c, 42)
}

@test
fn test_nested_object_deep(): void {
    // 深层嵌套对象
    let obj = json.parse("{\"l1\": {\"l2\": {\"l3\": {\"l4\": {\"value\": 100}}}}}")
    assert_eq(obj.l1.l2.l3.l4.value, 100)
}

@test
fn test_nested_empty_objects(): void {
    let obj = json.parse("{\"a\": {}, \"b\": {\"c\": {}}}")
    assert_eq(obj.a != null, true)
    assert_eq(obj.b.c != null, true)
}

// ===== 混合嵌套测试 =====

@test
fn test_object_with_arrays(): void {
    let obj = json.parse("{\"numbers\": [1, 2, 3], \"letters\": [\"a\", \"b\", \"c\"]}")
    assert_eq(obj.numbers.length, 3)
    assert_eq(obj.numbers[0], 1)
    assert_eq(obj.letters[0], "a")
}

@test
fn test_array_with_objects(): void {
    let arr = json.parse("[{\"id\": 1}, {\"id\": 2}, {\"id\": 3}]")
    assert_eq(arr.length, 3)
    assert_eq(arr[0].id, 1)
    assert_eq(arr[1].id, 2)
    assert_eq(arr[2].id, 3)
}

@test
fn test_complex_mixed(): void {
    let data = json.parse("{\"users\": [{\"name\": \"Alice\", \"scores\": [90, 85]}, {\"name\": \"Bob\", \"scores\": [78, 92]}]}")
    assert_eq(data.users.length, 2)
    assert_eq(data.users[0].name, "Alice")
    assert_eq(data.users[0].scores[0], 90)
    assert_eq(data.users[1].name, "Bob")
    assert_eq(data.users[1].scores[1], 92)
}

// ===== 多键对象测试 =====

@test
fn test_object_many_keys(): void {
    let obj = json.parse("{\"a\":1,\"b\":2,\"c\":3,\"d\":4,\"e\":5,\"f\":6,\"g\":7,\"h\":8,\"i\":9,\"j\":10}")
    assert_eq(obj.a, 1)
    assert_eq(obj.e, 5)
    assert_eq(obj.j, 10)
}

@test
fn test_object_long_keys(): void {
    let obj = json.parse("{\"very_long_key_name_here\": 42, \"another_very_long_key\": 100}")
    assert_eq(obj.very_long_key_name_here, 42)
    assert_eq(obj.another_very_long_key, 100)
}

// ===== 大型数组测试 =====

@test
fn test_large_array(): void {
    // 构建大数组
    let jsonStr = "["
    let i = 0
    while (i < 100) {
        if (i > 0) {
            jsonStr = jsonStr + ","
        }
        jsonStr = jsonStr + i.toString()
        i++
    }
    jsonStr = jsonStr + "]"
    
    let arr = json.parse(jsonStr)
    assert_eq(arr.length, 100)
    assert_eq(arr[0], 0)
    assert_eq(arr[50], 50)
    assert_eq(arr[99], 99)
}

// ===== 真实数据结构模拟 =====

@test
fn test_user_profile(): void {
    let jsonStr = "{\"id\": 12345, \"username\": \"johndoe\", \"email\": \"john@example.com\", \"profile\": {\"firstName\": \"John\", \"lastName\": \"Doe\", \"age\": 28}, \"settings\": {\"theme\": \"dark\", \"notifications\": true}}"
    let user = json.parse(jsonStr)
    assert_eq(user.id, 12345)
    assert_eq(user.username, "johndoe")
    assert_eq(user.profile.firstName, "John")
    assert_eq(user.profile.age, 28)
    assert_eq(user.settings.theme, "dark")
    assert_eq(user.settings.notifications, true)
}

@test
fn test_api_response(): void {
    let jsonStr = "{\"status\": \"success\", \"code\": 200, \"data\": {\"items\": [{\"id\": 1, \"name\": \"Item 1\"}, {\"id\": 2, \"name\": \"Item 2\"}], \"total\": 2}, \"meta\": {\"page\": 1, \"limit\": 10}}"
    let response = json.parse(jsonStr)
    assert_eq(response.status, "success")
    assert_eq(response.code, 200)
    assert_eq(response.data.items.length, 2)
    assert_eq(response.data.items[0].name, "Item 1")
    assert_eq(response.data.total, 2)
    assert_eq(response.meta.page, 1)
}

@test
fn test_geojson_like(): void {
    let jsonStr = "{\"geoType\": \"Point\", \"coordinates\": [125.6, 10.1]}"
    let geo = json.parse(jsonStr)
    assert_eq(geo.geoType, "Point")
    assert_eq(geo.coordinates.length, 2)
    assert_eq(geo.coordinates[0], 125.6)
    assert_eq(geo.coordinates[1], 10.1)
}

@test
fn test_config_file(): void {
    let jsonStr = "{\"version\": \"1.0.0\", \"debug\": false, \"database\": {\"host\": \"localhost\", \"port\": 5432, \"name\": \"mydb\"}, \"features\": [\"feature1\", \"feature2\", \"feature3\"]}"
    let config = json.parse(jsonStr)
    assert_eq(config.version, "1.0.0")
    assert_eq(config.debug, false)
    assert_eq(config.database.host, "localhost")
    assert_eq(config.database.port, 5432)
    assert_eq(config.features.length, 3)
}

// ===== 边界情况 =====

@test
fn test_single_element_array(): void {
    let arr = json.parse("[42]")
    assert_eq(arr.length, 1)
    assert_eq(arr[0], 42)
}

@test
fn test_single_key_object(): void {
    let obj = json.parse("{\"key\": \"value\"}")
    assert_eq(obj.key, "value")
}

@test
fn test_mixed_types_array(): void {
    let arr = json.parse("[1, \"two\", true, null, 3.14, {\"key\": \"value\"}, [1, 2]]")
    assert_eq(arr.length, 7)
    assert_eq(arr[0], 1)
    assert_eq(arr[1], "two")
    assert_eq(arr[2], true)
    assert_eq(arr[3], null)
    assert_eq(arr[4], 3.14)
    assert_eq(arr[5].key, "value")
    assert_eq(arr[6][0], 1)
}

@test
fn test_null_values_in_object(): void {
    let obj = json.parse("{\"a\": null, \"b\": null, \"c\": 1}")
    assert_eq(obj.a, null)
    assert_eq(obj.b, null)
    assert_eq(obj.c, 1)
}

@test
fn test_boolean_values_in_object(): void {
    let obj = json.parse("{\"yes\": true, \"no\": false}")
    assert_eq(obj.yes, true)
    assert_eq(obj.no, false)
}

// ===== stringify 嵌套测试 =====

@test
fn test_stringify_nested_array(): void {
    let arr = [[1, 2], [3, 4]]
    let jsonStr = json.stringify(arr)
    let parsed = json.parse(jsonStr)
    assert_eq(parsed[0][0], 1)
    assert_eq(parsed[1][1], 4)
}

@test
fn test_stringify_nested_object(): void {
    let obj = { user: { name: "Alice" } }
    let jsonStr = json.stringify(obj)
    let parsed = json.parse(jsonStr)
    assert_eq(parsed.user.name, "Alice")
}

@test
fn test_stringify_complex(): void {
    let data = {
        users: [
            { name: "Alice", age: 30 },
            { name: "Bob", age: 25 }
        ]
    }
    let jsonStr = json.stringify(data)
    let parsed = json.parse(jsonStr)
    assert_eq(parsed.users.length, 2)
    assert_eq(parsed.users[0].name, "Alice")
}

