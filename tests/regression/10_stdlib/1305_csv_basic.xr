// 1300_csv_basic.xr - CSV module tests

import csv

// ===== Basic parsing =====

@test
fn test_parse_basic() {
    let data = "name,age,city\nAlice,30,Beijing\nBob,25,Shanghai"
    let rows = csv.parse(data)
    assert_eq(rows.length, 3)
    assert_eq(rows[0][0], "name")
    assert_eq(rows[1][0], "Alice")
    assert_eq(rows[1][1], "30")
}

@test
fn test_parse_with_header() {
    let data = "name,age,city\nAlice,30,Beijing\nBob,25,Shanghai"
    let rows = csv.parse(data, { header: true })
    assert_eq(rows.length, 2)
    assert_eq(rows[0]["name"], "Alice")
    assert_eq(rows[0]["age"], "30")
}

// ===== Quoted fields =====

@test
fn test_parse_quoted() {
    let data = "name,desc\n\"John\",\"Hello, World\""
    let rows = csv.parse(data)
    assert_eq(rows[1][1], "Hello, World")
}

@test
fn test_parse_escaped_quotes() {
    let data = "name,quote\n\"Test\",\"He said \"\"Hello\"\"\""
    let rows = csv.parse(data)
    assert_eq(rows[1][1], "He said \"Hello\"")
}

// ===== Stringify =====

@test
fn test_stringify() {
    let arr = [["a", "b", "c"], ["1", "2", "3"]]
    let result = csv.stringify(arr)
    assert(result != null)
    assert(result.length > 0)
}

// ===== TSV =====

@test
fn test_parse_tsv() {
    let tsv = "a\tb\tc\n1\t2\t3"
    let rows = csv.parseTsv(tsv)
    assert_eq(rows[0][1], "b")
}

// ===== Empty data =====

@test
fn test_parse_empty() {
    let empty = csv.parse("")
    assert_eq(empty.length, 0)
}

// ===== Dynamic typing =====

@test
fn test_parse_dynamic_typing() {
    let data = "name,age,active\nAlice,30,true\nBob,25,false"
    let rows = csv.parse(data, { header: true, dynamicTyping: true })
    assert_eq(rows[0]["age"], 30)
    assert_eq(rows[0]["active"], true)
}

// ===== parseDetailed =====

@test
fn test_parse_detailed() {
    let detailed = csv.parseDetailed("a,b\n1,2\n3,4")
    assert_eq(detailed["meta"]["rows"], 3)
    assert_eq(detailed["meta"]["columns"], 2)
}

// ===== parseAuto =====

@test
fn test_parse_auto() {
    let auto = csv.parseAuto("a;b;c\n1;2;3")
    assert_eq(auto[0][1], "b")
}

// ===== Empty fields =====

@test
fn test_parse_empty_fields() {
    let data = "a,,c\n1,,3"
    let rows = csv.parse(data)
    assert_eq(rows[0][1], "")
    assert_eq(rows[1][1], "")
    assert_eq(rows[0].length, 3)
}

@test
fn test_parse_consecutive_delimiters() {
    let data = ",,,\n,,,"
    let rows = csv.parse(data)
    assert_eq(rows[0].length, 4)
    assert_eq(rows[0][0], "")
}

// ===== CRLF handling =====

@test
fn test_parse_crlf() {
    let data = "a,b\r\n1,2\r\n3,4"
    let rows = csv.parse(data)
    assert_eq(rows.length, 3)
    assert_eq(rows[2][0], "3")
}

@test
fn test_parse_mixed_linebreaks() {
    let data = "a,b\n1,2\r\n3,4\r5,6"
    let rows = csv.parse(data)
    assert_eq(rows.length, 4)
}

// ===== Config: skipRows =====

@test
fn test_parse_skip_rows() {
    let data = "skip1\nskip2\na,b\n1,2"
    let rows = csv.parse(data, { skipRows: 2 })
    assert_eq(rows.length, 2)
    assert_eq(rows[0][0], "a")
}

// ===== Config: maxRows =====

@test
fn test_parse_max_rows() {
    let data = "a,b\n1,2\n3,4\n5,6\n7,8"
    let rows = csv.parse(data, { maxRows: 2 })
    assert_eq(rows.length, 2)
}

// ===== Config: trimFields =====

@test
fn test_parse_trim_fields() {
    let data = " a , b \n 1 , 2 "
    let rows = csv.parse(data, { trimFields: true })
    assert_eq(rows[0][0], "a")
    assert_eq(rows[0][1], "b")
    assert_eq(rows[1][0], "1")
}

// ===== Config: comments =====

@test
fn test_parse_comments() {
    let data = "a,b\n# comment\n1,2"
    let rows = csv.parse(data, { comments: "#" })
    assert_eq(rows.length, 2)
    assert_eq(rows[1][0], "1")
}

// ===== Config: relaxColumns =====

@test
fn test_parse_relax_columns() {
    let data = "a,b,c\n1,2\n3,4,5,6"
    let result = csv.parseDetailed(data, { relaxColumns: true })
    assert_eq(result["data"].length, 3)
}

// ===== Stringify with typed values =====

@test
fn test_stringify_typed() {
    let arr = [["name", "age", "active"], ["Alice", "30", "true"], ["Bob", "25", "false"]]
    let result = csv.stringify(arr)
    assert(result.indexOf("30") >= 0)
    assert(result.indexOf("true") >= 0)
    assert(result.indexOf("false") >= 0)
}

// ===== Stringify roundtrip =====

@test
fn test_roundtrip() {
    let original = "name,age\nAlice,30\nBob,25\n"
    let parsed = csv.parse(original)
    let output = csv.stringify(parsed)
    let reparsed = csv.parse(output)
    assert_eq(reparsed.length, parsed.length)
    assert_eq(reparsed[0][0], parsed[0][0])
}

// ===== Quoted field with newline =====

@test
fn test_quoted_newline() {
    let data = "a,b\n"  + "\"line1\nline2\",value"
    let rows = csv.parse(data)
    assert_eq(rows.length, 2)
    assert_eq(rows[1][0], "line1\nline2")
}

// ===== Dynamic typing edge cases =====

@test
fn test_dynamic_typing_edge() {
    let data = "val\n0\n-123\n3.14\nTRUE\nFALSE\nNULL\nhello"
    let rows = csv.parse(data, { dynamicTyping: true })
    assert_eq(rows[1][0], 0)
    assert_eq(rows[2][0], -123)
    // 3.14 should be float
    assert(rows[3][0] > 3.0)
    assert(rows[3][0] < 4.0)
    assert_eq(rows[4][0], true)
    assert_eq(rows[5][0], false)
    assert_eq(rows[6][0], null)
    assert_eq(rows[7][0], "hello")
}

// ===== Semicolon delimiter =====

@test
fn test_parse_semicolon() {
    let data = "a;b;c\n1;2;3"
    let rows = csv.parse(data, { delimiter: ";" })
    assert_eq(rows[0][1], "b")
    assert_eq(rows[1][1], "2")
}

// ===== Pipe delimiter auto-detect =====

@test
fn test_parse_auto_pipe() {
    let data = "a|b|c\n1|2|3"
    let auto = csv.parseAuto(data)
    assert_eq(auto[0][1], "b")
}
