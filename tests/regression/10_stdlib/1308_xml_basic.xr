// 1303_xml_basic.xr - XML module tests

import xml

// ===== Basic parsing =====

@test
fn test_parse_basic(): void {
    let data = "<root><item>Hello</item></root>"
    let doc = xml.parse(data) ?? {}
    assert_eq(doc["tag"], "root")
}

@test
fn test_parse_children(): void {
    let data = "<root><item>Hello</item></root>"
    let doc = xml.parse(data) ?? {}
    let children = doc["children"]
    assert_eq(children.length, 1)
    assert_eq(children[0]["tag"], "item")
}

@test
fn test_parse_text(): void {
    let data = "<root><item>Hello</item></root>"
    let doc = xml.parse(data) ?? {}
    let textNode = doc["children"][0]["children"][0]
    assert_eq(textNode["text"], "Hello")
}

// ===== Attributes =====

@test
fn test_parse_attrs(): void {
    let data = "<user id=\"123\" name=\"Alice\"/>"
    let doc = xml.parse(data) ?? {}
    let attrs = doc["attrs"]
    assert_eq(attrs["id"], "123")
    assert_eq(attrs["name"], "Alice")
}

// ===== Nested elements =====

@test
fn test_parse_deep_nesting(): void {
    let data = "<root><a><b><c>deep</c></b></a></root>"
    let doc = xml.parse(data) ?? {}
    let cNode = doc["children"][0]["children"][0]["children"][0]
    assert_eq(cNode["tag"], "c")
}

// ===== Multiple children =====

@test
fn test_parse_multiple_children(): void {
    let data = "<list><item>1</item><item>2</item><item>3</item></list>"
    let doc = xml.parse(data) ?? {}
    assert_eq(doc["children"].length, 3)
}

// ===== Create element =====

@test
fn test_create_element(): void {
    let elem = xml.element("div")
    assert_eq(elem["tag"], "div")
}

// ===== Empty element =====

@test
fn test_parse_empty_element(): void {
    let data = "<empty/>"
    let doc = xml.parse(data) ?? {}
    assert_eq(doc["tag"], "empty")
    assert_eq(doc["children"].length, 0)
}

// ===== Comments =====

@test
fn test_parse_preserve_comments(): void {
    let data = "<root><!-- comment --><item/></root>"
    let doc = xml.parse(data, { preserveComments: true }) ?? {}
    assert_eq(doc["children"].length, 2)
}

// ===== Stringify =====

@test
fn test_stringify_compact(): void {
    let data = "<msg>Hi</msg>"
    let doc = xml.parse(data) ?? {}
    let str = xml.stringify(doc, { indent: 0, declaration: false })
    assert_eq(str, "<msg>Hi</msg>")
}
