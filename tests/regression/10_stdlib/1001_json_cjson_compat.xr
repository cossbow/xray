// 第六部分：数字输出测试 (print_number.c)
// ============================================================

@test
fn test_stringify_number_zero(): void {
    // print_number_should_print_zero
    assert_eq(json.stringify(0), "0")
}

@test
fn test_stringify_negative_integers(): void {
    // print_number_should_print_negative_integers
    assert_eq(json.stringify(-1), "-1")
    assert_eq(json.stringify(-32768), "-32768")
    assert_eq(json.stringify(-2147483648), "-2147483648")
}

@test
fn test_stringify_positive_integers(): void {
    // print_number_should_print_positive_integers
    assert_eq(json.stringify(1), "1")
    assert_eq(json.stringify(32767), "32767")
    assert_eq(json.stringify(2147483647), "2147483647")
}

@test
fn test_stringify_positive_reals(): void {
    // print_number_should_print_positive_reals
    let s1 = json.stringify(0.123)
    assert_true(s1.contains("0.123"))
    
    let s2 = json.stringify(3.1415926535897931)
    assert_true(s2.contains("3.14159"))
}

@test
fn test_stringify_negative_reals(): void {
    // print_number_should_print_negative_reals
    let s1 = json.stringify(-0.0123)
    assert_true(s1.contains("-0.0123"))
}

// ============================================================
// 第七部分：字符串输出测试 (print_string.c)
// ============================================================

@test
fn test_stringify_empty_string(): void {
    // print_string_should_print_empty_strings
    assert_eq(json.stringify(""), "\"\"")
}

@test
fn test_stringify_simple_string(): void {
    assert_eq(json.stringify("hello"), "\"hello\"")
}

@test
fn test_stringify_escape_characters(): void {
    // 双引号需要转义
    let s1 = json.stringify("\"")
    assert_true(s1.contains("\\\""))
    
    // 反斜杠需要转义
    let s2 = json.stringify("\\")
    assert_true(s2.contains("\\\\"))
    
    // 换行符需要转义
    let s3 = json.stringify("\n")
    assert_true(s3.contains("\\n"))
    
    // Tab 需要转义
    let s4 = json.stringify("\t")
    assert_true(s4.contains("\\t"))
}

@test
fn test_stringify_utf8(): void {
    // print_string_should_print_utf8
    let s = json.stringify("ü猫慕")
    assert_true(s.contains("ü猫慕"))
}

// ============================================================
// 第八部分：杂项测试 (misc_tests.c)
// ============================================================

@test
fn test_deeply_nested_json(): void {
    // cjson_should_not_parse_to_deeply_nested_jsons
    // 测试深度嵌套的 JSON（应该能处理合理深度）
    let jsonStr = "[[[[[[[[[[1]]]]]]]]]]"  // 10 层嵌套
    let arr = json.parse(jsonStr)
    assert_true(arr != null)
}

@test
fn test_parse_big_numbers_no_error(): void {
    // cjson_parse_big_numbers_should_not_report_error
    let json1 = "{\"a\": true, \"b\": [ null,9999999999999999999999999999999999999999999999912345678901234567]}"
    assert_eq(json.isValid(json1), true)
    
    let json2 = "{\"a\": true, \"b\": [ null,999999999999999999999999999999999999999999999991234567890.1234567E3]}"
    assert_eq(json.isValid(json2), true)
    
    // 无效的大数字（多个小数点）
    let json3 = "{\"a\": true, \"b\": [ null,99999999999999999999999999999999999999999999999.1234567890.1234567]}"
    assert_eq(json.isValid(json3), false)
    
    // 无效的大数字（多个指数）
    let json4 = "{\"a\": true, \"b\": [ null,99999999999999999999999999999999999999999999999E1234567890e1234567]}"
    assert_eq(json.isValid(json4), false)
}

@test
fn test_utf8_bom(): void {
    // skip_utf8_bom_should_skip_bom
    // UTF-8 BOM: \xEF\xBB\xBF
    // 注意：xray 的 JSON 库是否支持 BOM 取决于实现
    let jsonStr = "\u{FEFF}{}"  // BOM + {}
    let result = json.isValid(jsonStr)
    // BOM 处理是可选的，这里只验证不崩溃
    assert_true(result == true || result == false)
}

@test
fn test_type_check(): void {
    // typecheck_functions_should_check_type
    assert_eq(json.typeof("null"), "null")
    assert_eq(json.typeof("true"), "boolean")
    assert_eq(json.typeof("false"), "boolean")
    assert_eq(json.typeof("42"), "number")
    assert_eq(json.typeof("3.14"), "number")
    assert_eq(json.typeof("\"hello\""), "string")
    assert_eq(json.typeof("[]"), "array")
    assert_eq(json.typeof("{}"), "object")
}

// ============================================================
// 第九部分：cJSON 输入文件测试 (tests/inputs/)
// ============================================================

@test
fn test_cjson_input_test1(): void {
    // 测试 test1: 嵌套对象（glossary）
    let jsonStr = "{\"glossary\": {\"title\": \"example glossary\", \"GlossDiv\": {\"title\": \"S\", \"GlossList\": {\"GlossEntry\": {\"ID\": \"SGML\", \"SortAs\": \"SGML\", \"GlossTerm\": \"Standard Generalized Markup Language\", \"Acronym\": \"SGML\", \"Abbrev\": \"ISO 8879:1986\", \"GlossDef\": {\"para\": \"A meta-markup language, used to create markup languages such as DocBook.\", \"GlossSeeAlso\": [\"GML\", \"XML\"]}, \"GlossSee\": \"markup\"}}}}}"
    let obj = json.parse(jsonStr)
    assert_eq(obj.glossary.title, "example glossary")
    assert_eq(obj.glossary.GlossDiv.GlossList.GlossEntry.ID, "SGML")
    assert_eq(obj.glossary.GlossDiv.GlossList.GlossEntry.GlossDef.GlossSeeAlso[0], "GML")
}

@test
fn test_cjson_input_test2(): void {
    // 测试 test2: 菜单对象
    let jsonStr = "{\"menu\": {\"id\": \"file\", \"value\": \"File\", \"popup\": {\"menuitem\": [{\"value\": \"New\", \"onclick\": \"CreateNewDoc()\"}, {\"value\": \"Open\", \"onclick\": \"OpenDoc()\"}, {\"value\": \"Close\", \"onclick\": \"CloseDoc()\"}]}}}"
    let obj = json.parse(jsonStr)
    assert_eq(obj.menu.id, "file")
    assert_eq(obj.menu.popup.menuitem.length, 3)
    assert_eq(obj.menu.popup.menuitem[0].value, "New")
}

@test
fn test_cjson_input_test3(): void {
    // 测试 test3: widget 对象
    let jsonStr = "{\"widget\": {\"debug\": \"on\", \"window\": {\"title\": \"Sample Konfabulator Widget\", \"name\": \"main_window\", \"width\": 500, \"height\": 500}, \"image\": {\"src\": \"Images/Sun.png\", \"name\": \"sun1\", \"hOffset\": 250, \"vOffset\": 250, \"alignment\": \"center\"}, \"text\": {\"data\": \"Click Here\", \"size\": 36, \"style\": \"bold\", \"name\": \"text1\", \"hOffset\": 250, \"vOffset\": 100, \"alignment\": \"center\", \"onMouseUp\": \"sun1.opacity = (sun1.opacity / 100) * 90;\"}}}"
    let obj = json.parse(jsonStr)
    assert_eq(obj.widget.debug, "on")
    assert_eq(obj.widget.window.width, 500)
    assert_eq(obj.widget.image.alignment, "center")
}

@test
fn test_cjson_input_test5(): void {
    // 测试 test5: 带 null 元素的数组
    let jsonStr = "{\"menu\": {\"header\": \"SVG Viewer\", \"items\": [{\"id\": \"Open\"}, {\"id\": \"OpenNew\", \"label\": \"Open New\"}, null, {\"id\": \"ZoomIn\", \"label\": \"Zoom In\"}, {\"id\": \"ZoomOut\", \"label\": \"Zoom Out\"}]}}"
    let obj = json.parse(jsonStr)
    assert_eq(obj.menu.header, "SVG Viewer")
    assert_eq(obj.menu.items.length, 5)
    assert_eq(obj.menu.items[0].id, "Open")
    assert_eq(obj.menu.items[2], null)  // 数组中的 null
    assert_eq(obj.menu.items[3].label, "Zoom In")
}

// ============================================================
// 第十部分：往返测试 (roundtrip)
// ============================================================

@test
fn test_roundtrip_primitives(): void {
    // 原始类型往返
    assert_eq(json.parse(json.stringify(42)), 42)
    assert_eq(json.parse(json.stringify(3.14)), 3.14)
    assert_eq(json.parse(json.stringify(true)), true)
    assert_eq(json.parse(json.stringify(false)), false)
    assert_eq(json.parse(json.stringify(null)), null)
    assert_eq(json.parse(json.stringify("hello")), "hello")
}

@test
fn test_roundtrip_array(): void {
    let original = [1, 2, 3, "four", true, null]
    let jsonStr = json.stringify(original)
    let parsed = json.parse(jsonStr)
    assert_eq(parsed.length, 6)
    assert_eq(parsed[0], 1)
    assert_eq(parsed[3], "four")
    assert_eq(parsed[4], true)
    assert_eq(parsed[5], null)
}

@test
fn test_roundtrip_object(): void {
    let original = { name: "Alice", age: 30, active: true }
    let jsonStr = json.stringify(original)
    let parsed = json.parse(jsonStr)
    assert_eq(parsed.name, "Alice")
    assert_eq(parsed.age, 30)
    assert_eq(parsed.active, true)
}

@test
fn test_roundtrip_nested(): void {
    let original = {
        users: [
            { name: "Alice", scores: [100, 95, 88] },
            { name: "Bob", scores: [85, 90, 92] }
        ],
        metadata: { version: 1, valid: true }
    }
    let jsonStr = json.stringify(original)
    let parsed = json.parse(jsonStr)
    assert_eq(parsed.users.length, 2)
    assert_eq(parsed.users[0].name, "Alice")
    assert_eq(parsed.users[0].scores[0], 100)
    assert_eq(parsed.metadata.version, 1)
}

// ============================================================
// 第十一部分：边界情况和错误处理
// ============================================================

@test
fn test_whitespace_handling(): void {
    // JSON 应该正确处理各种空白字符
    let json1 = "  {  \"key\"  :  \"value\"  }  "
    let obj1 = json.parse(json1)
    assert_eq(obj1.key, "value")
    
    let json2 = "[\n\t1,\n\t2,\n\t3\n]"
    let arr2 = json.parse(json2)
    assert_eq(arr2.length, 3)
}

@test
fn test_special_number_formats(): void {
    // 各种数字格式
    assert_eq(json.parse("1e1"), 10.0)
    assert_eq(json.parse("1E1"), 10.0)
    assert_eq(json.parse("1e+1"), 10.0)
    assert_eq(json.parse("1e-1"), 0.1)
    
    let v = json.parse("1.23456789012345678901234567890")
    assert_true(v > 1.234 && v < 1.235)
}

@test
fn test_empty_structures(): void {
    assert_eq(json.stringify([]), "[]")
    assert_eq(json.stringify({}), "{}")
    
    let emptyArr = json.parse("[]")
    assert_eq(emptyArr.length, 0)
}

@test
fn test_unicode_strings(): void {
    // 各种 Unicode 字符
    let s1 = json.parse("\"Hello, 世界\"")
    assert_eq(s1, "Hello, 世界")
    
    let s2 = json.parse("\"🎉🎊🎁\"")
    assert_eq(s2, "🎉🎊🎁")
    
    let s3 = json.parse("\"日本語テスト\"")
    assert_eq(s3, "日本語テスト")
}

@test
fn test_keys_with_special_characters(): void {
    // 键名中的特殊字符
    let jsonStr = "{\"key-with-dash\": 1, \"key.with.dot\": 2, \"key with space\": 3}"
    let obj = json.parse(jsonStr)
    // 注意：xray 可能需要使用索引访问这些特殊键名
    assert_true(obj != null)
}

@test
fn test_invalid_json_detection(): void {
    // 各种无效 JSON
    assert_eq(json.isValid(""), false)
    assert_eq(json.isValid("{"), false)
    assert_eq(json.isValid("}"), false)
    assert_eq(json.isValid("["), false)
    assert_eq(json.isValid("]"), false)
    assert_eq(json.isValid("{\"key\"}"), false)
    assert_eq(json.isValid("{\"key\":}"), false)
    assert_eq(json.isValid("[1,]"), false)
    assert_eq(json.isValid("undefined"), false)
    assert_eq(json.isValid("NaN"), false)
}

