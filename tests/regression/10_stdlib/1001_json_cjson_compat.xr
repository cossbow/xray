@test
fn test_parse_value_null(): void {
    // parse_value_should_parse_null
    assert_eq(json.parse("null"), null)
}

@test
fn test_parse_value_true(): void {
    // parse_value_should_parse_true
    assert_eq(json.parse("true"), true)
}

@test
fn test_parse_value_false(): void {
    // parse_value_should_parse_false
    assert_eq(json.parse("false"), false)
}

@test
fn test_parse_value_number(): void {
    // parse_value_should_parse_number
    let v = json.parse("1.5")
    assert_eq(v, 1.5)
}

@test
fn test_parse_value_string(): void {
    // parse_value_should_parse_string
    assert_eq(json.parse("\"\""), "")
    assert_eq(json.parse("\"hello\""), "hello")
}

@test
fn test_parse_value_array(): void {
    // parse_value_should_parse_array
    let arr = json.parse("[]")
    assert_eq(arr.length, 0)
}

@test
fn test_parse_value_object(): void {
    // parse_value_should_parse_object
    let obj = json.parse("{}")
    assert_true(obj != null)
}

