import json

// 1001_json_cjson_compat.xr
// 作者：xingleixu@gmail.com
// 测试：JSON 库与 cJSON 测试用例兼容性验证
// 
// 本文件基于 cJSON 测试用例设计，覆盖以下测试文件：
//   - parse_number.c: 数字解析
//   - parse_string.c: 字符串解析
//   - parse_array.c: 数组解析
//   - parse_object.c: 对象解析
//   - parse_value.c: 基础值解析
//   - print_number.c: 数字输出
//   - print_string.c: 字符串输出
//   - misc_tests.c: 杂项测试

// ============================================================
// 第一部分：数字解析测试 (parse_number.c)
// ============================================================

@test
fn test_parse_number_zero(): void {
    // parse_number_should_parse_zero
    assert_eq(json.parse("0"), 0)
    assert_eq(json.parse("0.0"), 0.0)
    assert_eq(json.parse("-0"), 0)
}

@test
fn test_parse_negative_integers(): void {
    // parse_number_should_parse_negative_integers
    assert_eq(json.parse("-1"), -1)
    assert_eq(json.parse("-32768"), -32768)
    assert_eq(json.parse("-2147483648"), -2147483648)
}

@test
fn test_parse_positive_integers(): void {
    // parse_number_should_parse_positive_integers
    assert_eq(json.parse("1"), 1)
    assert_eq(json.parse("32767"), 32767)
    assert_eq(json.parse("2147483647"), 2147483647)
}

@test
fn test_parse_positive_reals(): void {
    // parse_number_should_parse_positive_reals
    let v1 = json.parse("0.001")
    assert_true(v1 > 0.0009 && v1 < 0.0011)
    
    let v2 = json.parse("10e-10")
    assert_true(v2 > 0 && v2 < 0.000001)
    
    let v3 = json.parse("10E-10")
    assert_true(v3 > 0 && v3 < 0.000001)
    
    let v4 = json.parse("10e10")
    assert_true(v4 > 9e10)
    
    let v5 = json.parse("123e+127")
    assert_true(v5 > 1e128)
    
    let v6 = json.parse("123e-128")
    assert_true(v6 > 0 && v6 < 1e-125)
}

@test
fn test_parse_negative_reals(): void {
    // parse_number_should_parse_negative_reals
    let v1 = json.parse("-0.001")
    assert_true(v1 < -0.0009 && v1 > -0.0011)
    
    let v2 = json.parse("-10e-10")
    assert_true(v2 < 0 && v2 > -0.000001)
    
    let v3 = json.parse("-10E-10")
    assert_true(v3 < 0 && v3 > -0.000001)
    
    let v4 = json.parse("-10e20")
    assert_true(v4 < -9e20)
    
    let v5 = json.parse("-123e+127")
    assert_true(v5 < -1e128)
    
    let v6 = json.parse("-123e-128")
    assert_true(v6 < 0 && v6 > -1e-125)
}

@test
fn test_parse_big_numbers(): void {
    // parse_number_should_parse_big_numbers
    // Very large numbers overflow to Infinity (float) — just verify they parse without crash
    let v1 = json.parse("9999999999999999999999999999999999999999999999912345678901234567")
    assert_eq(typeof(v1), Type.float)
    
    let v2 = json.parse("9999999999999999999999999999999999999999999999912345678901234567E10")
    assert_eq(typeof(v2), Type.float)
    
    let v3 = json.parse("999999999999999999999999999999999999999999999991234567890.1234567")
    assert_eq(typeof(v3), Type.float)
    assert_true(v3 > 0.0)
}

// ============================================================
// 第二部分：字符串解析测试 (parse_string.c)
// ============================================================

@test
fn test_parse_empty_string(): void {
    // parse_string_should_parse_strings - empty
    let s = json.parse("\"\"")
    assert_eq(s, "")
}

@test
fn test_parse_simple_string(): void {
    let s = json.parse("\"hello world\"")
    assert_eq(s, "hello world")
}

@test
fn test_parse_escape_sequences(): void {
    // parse_string_should_parse_strings - escapes
    // 测试基本转义序列
    let s1 = json.parse("\"\\\"\"")  // \"
    assert_eq(s1, "\"")
    
    let s2 = json.parse("\"\\\\\"")  // \\
    assert_eq(s2, "\\")
    
    let s3 = json.parse("\"\\/\"")   // \/
    assert_eq(s3, "/")
    
    let s4 = json.parse("\"\\b\"")   // \b
    assert_eq(s4.length, 1)
    
    let s5 = json.parse("\"\\f\"")   // \f
    assert_eq(s5.length, 1)
    
    let s6 = json.parse("\"\\n\"")   // \n
    assert_eq(s6, "\n")
    
    let s7 = json.parse("\"\\r\"")   // \r
    assert_eq(s7, "\r")
    
    let s8 = json.parse("\"\\t\"")   // \t
    assert_eq(s8, "\t")
}

@test
fn test_parse_unicode_escape(): void {
    // parse_string_should_parse_strings - \uXXXX
    // €（欧元符号）= U+20AC
    let s1 = json.parse("\"\\u20AC\"")
    assert_eq(s1, "€")
    
    // 猫 = U+732B
    let s2 = json.parse("\"\\u732b\"")
    assert_eq(s2, "猫")
}

@test
fn test_parse_utf16_surrogate_pairs(): void {
    // parse_string_should_parse_utf16_surrogate_pairs
    // 🐱 = U+1F431 = \uD83D\uDC31 (UTF-16 代理对)
    let s = json.parse("\"\\uD83D\\udc31\"")
    assert_eq(s, "🐱")
}

@test
fn test_parse_raw_control_characters(): void {
    // cJSON 允许解析原始控制字符
    let s = json.parse("\"\\b\\f\\n\\r\\t\"")
    assert_eq(s.length, 5)
}

@test
fn test_parse_complex_escape(): void {
    // parse_string_should_parse_bug_94
    let jsonStr = "\"~!@\\\\#$%^&*()\\\\\\\\-\\\\+{}[]:\\\\;\\\\\\\"\\\\<\\\\>?/.,DC=ad,DC=com\""
    let s = json.parse(jsonStr)
    assert_eq(s, "~!@\\#$%^&*()\\\\-\\+{}[]:\\;\\\"\\<\\>?/.,DC=ad,DC=com")
}

@test
fn test_parse_invalid_string(): void {
    // parse_string_should_not_parse_non_strings
    assert_eq(json.isValid("this\" is not a string\""), false)
    assert_eq(json.isValid(""), false)
}

// ============================================================
// 第三部分：数组解析测试 (parse_array.c)
// ============================================================

@test
fn test_parse_empty_arrays(): void {
    // parse_array_should_parse_empty_arrays
    let arr1 = json.parse("[]")
    assert_eq(arr1.length, 0)
    
    let arr2 = json.parse("[\n\t]")
    assert_eq(arr2.length, 0)
}

@test
fn test_parse_array_with_one_element(): void {
    // parse_array_should_parse_arrays_with_one_element
    let arr1 = json.parse("[1]")
    assert_eq(arr1.length, 1)
    assert_eq(arr1[0], 1)
    
    let arr2 = json.parse("[\"hello!\"]")
    assert_eq(arr2.length, 1)
    assert_eq(arr2[0], "hello!")
    
    let arr3 = json.parse("[[]]")
    assert_eq(arr3.length, 1)
    assert_eq(arr3[0].length, 0)
    
    let arr4 = json.parse("[null]")
    assert_eq(arr4.length, 1)
    assert_eq(arr4[0], null)
}

@test
fn test_parse_array_with_multiple_elements(): void {
    // parse_array_should_parse_arrays_with_multiple_elements
    let arr1 = json.parse("[1\t,\n2, 3]")
    assert_eq(arr1.length, 3)
    assert_eq(arr1[0], 1)
    assert_eq(arr1[1], 2)
    assert_eq(arr1[2], 3)
    
    // 混合类型数组
    let arr2 = json.parse("[1, null, true, false, [], \"hello\", {}]")
    assert_eq(arr2.length, 7)
    assert_eq(arr2[0], 1)
    assert_eq(arr2[1], null)
    assert_eq(arr2[2], true)
    assert_eq(arr2[3], false)
    assert_eq(arr2[4].length, 0)  // []
    assert_eq(arr2[5], "hello")
    // arr2[6] 是空对象
}

@test
fn test_parse_invalid_arrays(): void {
    // parse_array_should_not_parse_non_arrays
    assert_eq(json.isValid("["), false)
    assert_eq(json.isValid("]"), false)
    assert_eq(json.isValid("42"), true)  // 这是有效的 JSON，只是不是数组
}

// ============================================================
// 第四部分：对象解析测试 (parse_object.c)
// ============================================================

@test
fn test_parse_empty_objects(): void {
    // parse_object_should_parse_empty_objects
    let obj1 = json.parse("{}")
    assert_true(obj1 != null)
    
    let obj2 = json.parse("{\n\t}")
    assert_true(obj2 != null)
}

@test
fn test_parse_object_with_one_element(): void {
    // parse_object_should_parse_objects_with_one_element
    let obj1 = json.parse("{\"one\":1}")
    assert_eq(obj1.one, 1)
    
    let obj2 = json.parse("{\"hello\":\"world!\"}")
    assert_eq(obj2.hello, "world!")
    
    let obj3 = json.parse("{\"array\":[]}")
    assert_eq(obj3.array.length, 0)
    
    let obj4 = json.parse("{\"nullable\":null}")
    assert_eq(obj4.nullable, null)
}

@test
fn test_parse_object_with_multiple_elements(): void {
    // parse_object_should_parse_objects_with_multiple_elements
    let obj1 = json.parse("{\"one\":1\t,\t\"two\"\n:2, \"three\":3}")
    assert_eq(obj1.one, 1)
    assert_eq(obj1.two, 2)
    assert_eq(obj1.three, 3)
    
    // 混合类型对象
    let obj2 = json.parse("{\"one\":1, \"nullval\":null, \"trueval\":true, \"falseval\":false, \"array\":[], \"world\":\"hello\", \"object\":{}}")
    assert_eq(obj2.one, 1)
    assert_eq(obj2.nullval, null)
    assert_eq(obj2.trueval, true)
    assert_eq(obj2.falseval, false)
    assert_eq(obj2.array.length, 0)
    assert_eq(obj2.world, "hello")
}

@test
fn test_parse_invalid_objects(): void {
    // parse_object_should_not_parse_non_objects
    assert_eq(json.isValid("{"), false)
    assert_eq(json.isValid("}"), false)
}

