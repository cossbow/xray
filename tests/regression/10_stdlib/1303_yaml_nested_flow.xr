// 1303_yaml_nested_flow.xr
// Author: xingleixu@gmail.com
// Test: YAML nested flow structures (flow mapping + flow sequence combinations)
// Regression: scan-ahead not stopping at flow indicators (fixed)

import yaml

// ===== Flow mapping nested in flow mapping =====

@test
fn test_nested_flow_mapping(): void {
    let data = "outer: {inner: {a: 1, b: 2}, c: 3}"
    let obj = yaml.parse(data)
    let outer = obj["outer"]
    assert_eq(outer["inner"]["a"], 1)
    assert_eq(outer["inner"]["b"], 2)
    assert_eq(outer["c"], 3)
}

// ===== Flow sequence nested in flow mapping =====

@test
fn test_flow_sequence_in_flow_mapping(): void {
    let data = "config: {ports: [80, 443, 8080], host: localhost}"
    let obj = yaml.parse(data)
    let cfg = obj["config"]
    assert_eq(cfg["ports"][0], 80)
    assert_eq(cfg["ports"][1], 443)
    assert_eq(cfg["ports"][2], 8080)
    assert_eq(cfg["host"], "localhost")
}

// ===== Flow mapping nested in flow sequence =====

@test
fn test_flow_mapping_in_flow_sequence(): void {
    let data = "items: [{name: alice, age: 30}, {name: bob, age: 25}]"
    let obj = yaml.parse(data)
    let items = obj["items"]
    assert_eq(items[0]["name"], "alice")
    assert_eq(items[0]["age"], 30)
    assert_eq(items[1]["name"], "bob")
    assert_eq(items[1]["age"], 25)
}

// ===== Flow sequence nested in flow sequence =====

@test
fn test_nested_flow_sequence(): void {
    let data = "matrix: [[1, 2, 3], [4, 5, 6], [7, 8, 9]]"
    let obj = yaml.parse(data)
    let m = obj["matrix"]
    assert_eq(m[0][0], 1)
    assert_eq(m[0][2], 3)
    assert_eq(m[1][1], 5)
    assert_eq(m[2][2], 9)
}

// ===== Multiple flow mappings at same level =====

@test
fn test_multiple_flow_mappings(): void {
    let data = "a: {x: 1}\nb: {y: 2}\nc: {z: 3}"
    let obj = yaml.parse(data)
    assert_eq(obj["a"]["x"], 1)
    assert_eq(obj["b"]["y"], 2)
    assert_eq(obj["c"]["z"], 3)
}

// ===== Flow mapping with various value types =====

@test
fn test_flow_mapping_mixed_values(): void {
    let data = "mix: {num: 42, str: hello, flag: true, nothing: null}"
    let obj = yaml.parse(data)
    let mix = obj["mix"]
    assert_eq(mix["num"], 42)
    assert_eq(mix["str"], "hello")
    assert_eq(mix["flag"], true)
    assert_eq(mix["nothing"], null)
}

// ===== Empty flow structures =====

@test
fn test_empty_flow_structures(): void {
    let data = "empty_map: {}\nempty_list: []"
    let obj = yaml.parse(data)
    assert(obj["empty_map"] != null)
    assert(obj["empty_list"] != null)
}

// ===== Deeply nested flow =====

@test
fn test_deep_nested_flow(): void {
    let data = "deep: {l1: {l2: {l3: 42}}}"
    let obj = yaml.parse(data)
    assert_eq(obj["deep"]["l1"]["l2"]["l3"], 42)
}

// ===== Flow mapping with quoted keys =====

@test
fn test_flow_mapping_quoted_keys(): void {
    let data = "data: {\"key one\": 1, 'key two': 2}"
    let obj = yaml.parse(data)
    let d = obj["data"]
    assert_eq(d["key one"], 1)
    assert_eq(d["key two"], 2)
}

// ===== Complex real-world-like YAML =====

@test
fn test_complex_yaml_config(): void {
    let data = "app:\n  name: myapp\n  version: 1\n  database:\n    host: localhost\n    port: 5432\n  features: [auth, logging, cache]\n  limits: {max_conn: 100, timeout: 30}"
    let obj = yaml.parse(data)
    let app = obj["app"]
    assert_eq(app["name"], "myapp")
    assert_eq(app["version"], 1)
    assert_eq(app["database"]["host"], "localhost")
    assert_eq(app["database"]["port"], 5432)
    assert_eq(app["features"][0], "auth")
    assert_eq(app["features"][2], "cache")
    assert_eq(app["limits"]["max_conn"], 100)
    assert_eq(app["limits"]["timeout"], 30)
}

// ===== Block sequence with flow mapping items =====

@test
fn test_flow_in_block_sequence(): void {
    let data = "servers:\n  - {host: a.com, port: 80}\n  - {host: b.com, port: 443}"
    let obj = yaml.parse(data)
    let servers = obj["servers"]
    assert_eq(servers[0]["host"], "a.com")
    assert_eq(servers[0]["port"], 80)
    assert_eq(servers[1]["host"], "b.com")
    assert_eq(servers[1]["port"], 443)
}

// ===== Block sequence with nested block mappings =====

@test
fn test_block_sequence_nested_mappings(): void {
    let data = "users:\n  - name: Alice\n    age: 30\n  - name: Bob\n    age: 25"
    let obj = yaml.parse(data)
    let users = obj["users"]
    assert_eq(users[0]["name"], "Alice")
    assert_eq(users[0]["age"], 30)
    assert_eq(users[1]["name"], "Bob")
    assert_eq(users[1]["age"], 25)
}

// ===== Block sequence with 3+ multi-line items =====

@test
fn test_block_sequence_three_items(): void {
    let data = "tasks:\n  - id: 1\n    status: done\n  - id: 2\n    status: pending\n  - id: 3\n    status: active"
    let obj = yaml.parse(data)
    let tasks = obj["tasks"]
    assert_eq(tasks.length, 3)
    assert_eq(tasks[0]["id"], 1)
    assert_eq(tasks[0]["status"], "done")
    assert_eq(tasks[1]["id"], 2)
    assert_eq(tasks[2]["status"], "active")
}

// ===== Block sequence with mixed inline and block items =====

@test
fn test_block_sequence_mixed_items(): void {
    let data = "items:\n  - simple\n  - {complex: true}\n  - name: nested\n    value: 42"
    let obj = yaml.parse(data)
    let items = obj["items"]
    assert_eq(items[0], "simple")
    assert_eq(items[1]["complex"], true)
    assert_eq(items[2]["name"], "nested")
    assert_eq(items[2]["value"], 42)
}

// ===== Deeply nested block structure =====

@test
fn test_deep_block_nesting(): void {
    let data = "l1:\n  l2:\n    l3:\n      value: deep"
    let obj = yaml.parse(data)
    assert_eq(obj["l1"]["l2"]["l3"]["value"], "deep")
}

// ===== Block sequence inside block sequence (via multiline) =====

@test
fn test_block_mapping_with_multiple_sequences(): void {
    let data = "fruits: [apple, banana]\nvegs: [carrot, pea]"
    let obj = yaml.parse(data)
    assert_eq(obj["fruits"][0], "apple")
    assert_eq(obj["fruits"][1], "banana")
    assert_eq(obj["vegs"][0], "carrot")
    assert_eq(obj["vegs"][1], "pea")
}

// ===== Real-world: docker-compose-like YAML =====

@test
fn test_docker_compose_like(): void {
    let data = "services:\n  web:\n    image: nginx\n    ports: [80, 443]\n  db:\n    image: postgres\n    ports: [5432]"
    let obj = yaml.parse(data)
    let svc = obj["services"]
    assert_eq(svc["web"]["image"], "nginx")
    assert_eq(svc["web"]["ports"][0], 80)
    assert_eq(svc["web"]["ports"][1], 443)
    assert_eq(svc["db"]["image"], "postgres")
    assert_eq(svc["db"]["ports"][0], 5432)
}

// ===== YAML multiline and special values =====

@test
fn test_yaml_special_values(): void {
    let data = "t1: true\nt2: false\nn1: null\nn2: ~\ni1: 42\nf1: 3.14"
    let obj = yaml.parse(data)
    assert_eq(obj["t1"], true)
    assert_eq(obj["t2"], false)
    assert_eq(obj["n1"], null)
    assert_eq(obj["n2"], null)
    assert_eq(obj["i1"], 42)
    assert_eq(obj["f1"], 3.14)
}
