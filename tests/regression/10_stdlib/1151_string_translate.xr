// 1151_string_translate.xr - String translate/translateBytes tests

// ===== translateBytes =====

@test
fn test_translate_bytes_basic(): void {
    let COMP = {"A" => "T", "T" => "A", "C" => "G", "G" => "C"}
    assert_eq("ACGT".translateBytes(COMP), "TGCA")
    assert_eq("AAAA".translateBytes(COMP), "TTTT")
    assert_eq("CCCC".translateBytes(COMP), "GGGG")
    assert_eq("".translateBytes(COMP), "")
}

@test
fn test_translate_bytes_partial(): void {
    let partial = {"A" => "X"}
    assert_eq("ABCD".translateBytes(partial), "XBCD")
    assert_eq("AAAA".translateBytes(partial), "XXXX")
}

@test
fn test_translate_bytes_reverse_complement(): void {
    let COMP = {"A" => "T", "T" => "A", "C" => "G", "G" => "C"}
    assert_eq("ACGTACGT".reverseBytes().translateBytes(COMP), "ACGTACGT")
    assert_eq("AACC".reverseBytes().translateBytes(COMP), "GGTT")
}

// ===== translate (Unicode) =====

@test
fn test_translate_unicode(): void {
    let cnTable = {"你" => "我", "好" => "坏"}
    assert_eq("你好".translate(cnTable), "我坏")
    assert_eq("你好你".translate(cnTable), "我坏我")
}

@test
fn test_translate_ascii_consistency(): void {
    let asciiTable = {"H" => "h", "W" => "w"}
    assert_eq("HW".translate(asciiTable), "hw")
    assert_eq("HW".translateBytes(asciiTable), "hw")
}

@test
fn test_translate_empty_table(): void {
    let empty = #{}
    assert_eq("ABC".translateBytes(empty), "ABC")
    assert_eq("ABC".translate(empty), "ABC")
}
