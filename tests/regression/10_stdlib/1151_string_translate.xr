// 1151_string_translate.xr - String.translate (Unicode-aware codepoint mapping)

@test
fn test_translate_basic_ascii() {
    let COMP = #{"A": "T", "T": "A", "C": "G", "G": "C"}
    assert_eq("ACGT".translate(COMP), "TGCA")
    assert_eq("AAAA".translate(COMP), "TTTT")
    assert_eq("CCCC".translate(COMP), "GGGG")
    assert_eq("".translate(COMP), "")
}

@test
fn test_translate_partial() {
    let partial = #{"A": "X"}
    assert_eq("ABCD".translate(partial), "XBCD")
    assert_eq("AAAA".translate(partial), "XXXX")
}

@test
fn test_translate_unicode() {
    let cnTable = #{"你": "我", "好": "坏"}
    assert_eq("你好".translate(cnTable), "我坏")
    assert_eq("你好你".translate(cnTable), "我坏我")
}

@test
fn test_translate_empty_table() {
    let empty = #{}
    assert_eq("ABC".translate(empty), "ABC")
}

@test
fn test_translate_with_reverse() {
    // Byte-level reverse used to live on String; now reverse() is
    // Unicode-aware and round-trips through translate for ASCII data.
    let COMP = #{"A": "T", "T": "A", "C": "G", "G": "C"}
    assert_eq("ACGTACGT".reverse().translate(COMP), "ACGTACGT")
    assert_eq("AACC".reverse().translate(COMP), "GGTT")
}
