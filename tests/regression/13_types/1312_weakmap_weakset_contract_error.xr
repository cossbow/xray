// Test: WeakMap.set / WeakSet.add reject value-type keys via a
// catchable runtime exception.
//
// Before, the dispatcher silently printed a [WeakMap] / [WeakSet]
// banner to stderr and returned null, leaving the caller no way
// to detect or recover. The builtin layer now throws a contract
// exception (XR_ERR_INVALID_ARG_TYPE) so user code can guard the
// call with try/catch like any other invariant violation.
//
// xray classifies any heap-tagged value (XR_VALUE_NEEDS_GC) as a
// valid weak key/element, so the rejection only fires for the
// raw value tags: null / bool / int / float.

// ----- WeakMap with value-type key must throw -----

@test
fn test_weakmap_weakset_contract_error() {
    let wm = new WeakMap()

    let caught_int = false
    try { wm.set(42, "value") } catch (e) { caught_int = true }
    assert(caught_int, "WeakMap.set(int, ...) must throw")

    let caught_float = false
    try { wm.set(3.14, "value") } catch (e) { caught_float = true }
    assert(caught_float, "WeakMap.set(float, ...) must throw")

    let caught_bool = false
    try { wm.set(true, "value") } catch (e) { caught_bool = true }
    assert(caught_bool, "WeakMap.set(bool, ...) must throw")

    let caught_null = false
    try { wm.set(null, "value") } catch (e) { caught_null = true }
    assert(caught_null, "WeakMap.set(null, ...) must throw")

    // Object key still succeeds.
    let key = { name: "valid" }
    wm.set(key, "ok")
    assert_eq(wm.get(key), "ok")

    // ----- WeakSet with value-type element must throw -----
    let ws = new WeakSet()

    let caught_set_int = false
    try { ws.add(7) } catch (e) { caught_set_int = true }
    assert(caught_set_int, "WeakSet.add(int) must throw")

    let caught_set_bool = false
    try { ws.add(true) } catch (e) { caught_set_bool = true }
    assert(caught_set_bool, "WeakSet.add(true) must throw")

    let caught_set_null = false
    try { ws.add(null) } catch (e) { caught_set_null = true }
    assert(caught_set_null, "WeakSet.add(null) must throw")

    // Object element still succeeds.
    let obj = { id: 1 }
    ws.add(obj)
    assert_eq(ws.has(obj), true)
}

