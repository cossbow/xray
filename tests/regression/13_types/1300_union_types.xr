/*
** 1300_union_types.xr
** Union type annotation and type narrowing tests
*/

// Test 1: basic union type variable

fn to_string_value(v: int | string): string {
    if (typeof(v) == Type.int) {
        return "int"
    } else {
        return "str"
    }
}
fn parse_value(s: string): int | string {
    if (s == "42") {
        return 42
    }
    return s
}
fn classify(v: int | string | bool): string {
    if (typeof(v) == Type.int) {
        return "number"
    } else if (typeof(v) == Type.string) {
        return "text"
    } else {
        return "flag"
    }
}
class Dog {
    name: string
    constructor(name) { this.name = name }
    speak(): string { return "woof" }
}
class Cat {
    name: string
    constructor(name) { this.name = name }
    speak(): string { return "meow" }
}

@test
fn test_union_types() {
    let x: int | string = 42
    assert_eq(typeof(x), Type.int)
    x = "hello"
    assert_eq(typeof(x), Type.string)

    // Test 2: union in function parameter
    assert_eq(to_string_value(42), "int")
    assert_eq(to_string_value("hello"), "str")

    // Test 3: union return type
    let a = parse_value("42")
    assert_eq(typeof(a), Type.int)
    let b = parse_value("hello")
    assert_eq(typeof(b), Type.string)

    // Test 4: union with null normalizes to nullable (int | null -> int?)
    let n: int | null = 42
    assert_eq(typeof(n), Type.int)

    // Test 5: numeric promotion preserved (int | float -> float)
    let f: int | float = 3.14
    assert_eq(typeof(f), Type.float)

    // Test 6: three-member union
    assert_eq(classify(42), "number")
    assert_eq(classify("hi"), "text")
    assert_eq(classify(true), "flag")

    // Test 7: union assignability - int is assignable to int | string
    let u: int | string = 100
    assert_eq(typeof(u), Type.int)
    u = "world"
    assert_eq(typeof(u), Type.string)

    // Test 8: type alias with union
    type Result = int | string
    let r: Result = 42
    assert_eq(typeof(r), Type.int)
    r = "ok"
    assert_eq(typeof(r), Type.string)

    // Test 9: JSON type alias as union member (non-union alias allowed)
    type User = {id: int, name: string}
    type Response = User | bool
    let resp: Response = true
    assert_eq(typeof(resp), Type.bool)

    // Test 10: nullable union member (int? | string)
    let m: int? | string = null
    assert_eq(typeof(m), Type.null)
    m = 42
    assert_eq(typeof(m), Type.int)
    m = "hi"
    assert_eq(typeof(m), Type.string)

    // Test 11: class instance union

    let pet: Dog | Cat = new Dog("Buddy")
    assert_eq(pet.speak(), "woof")
    pet = new Cat("Whiskers")
    assert_eq(pet.speak(), "meow")

    // Test 12: class instance with is check
    let pet2: Dog | Cat = new Dog("Rex")
    assert_eq(pet2 is Dog, true)
    assert_eq(pet2 is Cat, false)

    // Test 13: container with union element type
    let arr: Array<int | string> = [1, "hello", 2, "world"]
    assert_eq(arr.length, 4)
    assert_eq(typeof(arr[0]), Type.int)
    assert_eq(typeof(arr[1]), Type.string)
}

