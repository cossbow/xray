/*
** 0525_typeof.xr
** typeof() 内置函数测试
**
** 作者：xingleixu@gmail.com
**
** 测试 typeof() 函数返回变量类型名称字符串
*/
// 测试基本类型
assert_eq(typeof(123), "int")
assert_eq(typeof(3.14), "float")
assert_eq(typeof("hello"), "string")
assert_eq(typeof(true), "bool")
assert_eq(typeof(false), "bool")
assert_eq(typeof(null), "null")
// 测试容器类型
let arr = [1, 2, 3]
assert_eq(typeof(arr), "Array")
let map = #{"a": 1}
assert_eq(typeof(map), "Map")
let s = #[1, 2, 3]
assert_eq(typeof(s), "Set")

// 测试函数类型
@test
fn test_fn() -> int {
    return 42
}

assert_eq(typeof(test_fn), "function")
// 测试闭包
let closure = fn() {
    return 1
}
assert_eq(typeof(closure), "function")
// 测试变量类型
let x = 10
assert_eq(typeof(x), "int")
let y = 3.14
assert_eq(typeof(y), "float")
// 测试表达式结果类型
assert_eq(typeof(1 + 2), "int")
assert_eq(typeof("a" + "b"), "string")
print("typeof() 测试通过!")
