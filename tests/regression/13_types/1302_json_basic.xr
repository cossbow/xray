// 0510_json_basic.xr
// 作者：xingleixu@gmail.com
// 测试：Json 对象基础功能
//
// REGRESSION: Bug #7 - x64 XM_CALL_DIRECT missing null / poison closure
//             guard (commit 2feae1e).
// FAIL_AT:    pre-2feae1e on x64 with --jit-force
//             -> closure ptr loaded from call_args[0] was sometimes
//                NULL (or poisoned with non-zero high 16 bits), but
//                fast path went straight into
//                `movzx rcx, byte [r11+8]; cmp rcx, 5` to check
//                XR_TFUNCTION. The byte-load at NULL+0x8 faulted with
//                ACCESS_VIOLATION before the type check ever ran.
//             -> ARM64 backend already had the cbz + lsr/cbnz guards;
//                x64 just skipped them.
// PASS_AT:    2feae1e+ on x64 (mirrored test + Jcc-to-slow guards
//             before the type byte-load) and on ARM64.
// REQUIRES_JIT_FORCE
// Triggering shape: nested `fn create(): Json { return {} }; create()`
// in test_json_return_type below — the closure flows through a
// non-call_args route on this site, leaving call_args[0] uninitialised.
//
// ===== 匿名对象（自动允许扩展）=====
@test
fn test_anonymous_object() {
    let user = { "name": "Alice", "age": 30 }
    assert_eq(user.name, "Alice")
    assert_eq(user.age, 30)
}

@test
fn test_anonymous_object_dynamic_add() {
    let obj = { "x": 1 }
    obj.y = 2
    // 动态添加字段
    obj.z = 3
    assert_eq(obj.x, 1)
    assert_eq(obj.y, 2)
    assert_eq(obj.z, 3)
}

@test
fn test_empty_object() {
    let obj = {}
    obj.name = "test"
    assert_eq(obj.name, "test")
}

@test
fn test_nested_object() {
    let person = { "name": "Bob", "address": { "city": "Shanghai", "zip": "200000" } }
    assert_eq(person.name, "Bob")
    assert_eq(person.address.city, "Shanghai")
    assert_eq(person.address.zip, "200000")
}

// ===== Json 类型注解 =====
@test
fn test_json_type_annotation() {
    let cfg: Json = { "port": 8080 }
    cfg.host = "localhost"
    // Json 允许动态添加
    assert_eq(cfg.port, 8080)
    assert_eq(cfg.host, "localhost")
}

@test
fn test_json_return_type() {
    fn createConfig(): Json {
        return { "debug": true }
    }
    let c = createConfig()
    c.level = "info"
    assert_eq(c.debug, true)
    assert_eq(c.level, "info")
}

// ===== 字段类型多样性 =====
@test
fn test_various_field_types() {
    let obj = { "int_val": 42, "float_val": 3.14, "str_val": "hello", "bool_val": true, "null_val": null, "arr_val": [1, 2, 3] }
    assert_eq(obj.int_val, 42)
    assert_eq(obj.float_val, 3.14)
    assert_eq(obj.str_val, "hello")
    assert_eq(obj.bool_val, true)
    assert_eq(obj.null_val, null)
    assert_eq(obj.arr_val[0], 1)
}

print("json_basic: all tests passed")
