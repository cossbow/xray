// 1305_json_computed_property.xr
// Test: computed property syntax { [expr]: value }

// ===== Basic computed property =====
@test
fn test_basic_computed_property() {
    let key = "name"
    let obj = { [key]: "Alice" }
    assert_eq(obj["name"], "Alice")
}

@test
fn test_computed_with_value_expr() {
    let key = "sum"
    let obj = { [key]: 1 + 2 + 3 }
    assert_eq(obj["sum"], 6)
}

// ===== Mixed static and computed =====
@test
fn test_mixed_static_computed() {
    let k = "dynamic"
    let obj = { "static_field": 1, [k]: 2 }
    assert_eq(obj.static_field, 1)
    assert_eq(obj["dynamic"], 2)
}

@test
fn test_multiple_computed() {
    let k1 = "first"
    let k2 = "second"
    let obj = { [k1]: 1, [k2]: 2, "third": 3 }
    assert_eq(obj["first"], 1)
    assert_eq(obj["second"], 2)
    assert_eq(obj.third, 3)
}

@test
fn test_computed_at_different_positions() {
    let k = "middle"
    let obj = { "start": 0, [k]: 1, "end": 2 }
    assert_eq(obj.start, 0)
    assert_eq(obj["middle"], 1)
    assert_eq(obj.end, 2)
}

// ===== Expression as key =====
@test
fn test_concat_expression_key() {
    let prefix = "user_"
    let obj = { [prefix + "id"]: 123 }
    assert_eq(obj["user_id"], 123)
}

@test
fn test_complex_expression_key() {
    let base = "field"
    let idx = 1
    let obj = { [base + "_" + string(idx)]: "value1" }
    assert_eq(obj["field_1"], "value1")
}

// ===== Computed property in function =====
@test
fn test_computed_in_function() {
    fn makeObj(key: string, value: int): Json {
        return { [key]: value }
    }
    let obj1 = makeObj("a", 1)
    let obj2 = makeObj("b", 2)
    assert_eq(obj1["a"], 1)
    assert_eq(obj2["b"], 2)
}

@test
fn test_computed_with_index_keys() {
    let keys = ["x", "y", "z"]
    let values = [10, 20, 30]
    let obj0 = { [keys[0]]: values[0] }
    let obj1 = { [keys[1]]: values[1] }
    let obj2 = { [keys[2]]: values[2] }
    assert_eq(obj0["x"], 10)
    assert_eq(obj1["y"], 20)
    assert_eq(obj2["z"], 30)
}

// ===== Computed + dynamic add =====
@test
fn test_computed_then_dynamic_add() {
    let k = "initial"
    let obj = { [k]: 1 }
    obj.added = 2
    obj["another"] = 3
    assert_eq(obj["initial"], 1)
    assert_eq(obj.added, 2)
    assert_eq(obj["another"], 3)
}
