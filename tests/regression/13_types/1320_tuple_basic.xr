// 作者：xingleixu@gmail.com
// 测试：tuple 字面量、字段访问、解构、函数返回，跨多个调用边界

@test
fn test_tuple_literal_and_field() {
    let t = (1, 2, 3)
    assert_eq(t.0, 1)
    assert_eq(t.1, 2)
    assert_eq(t.2, 3)
}

@test
fn test_tuple_heterogeneous() {
    let t = (10, "hi", true)
    assert_eq(t.0, 10)
    assert_eq(t.1, "hi")
    assert_eq(t.2, true)
}

@test
fn test_tuple_destructure() {
    let pair = (42, "hello")
    let (a, b) = pair
    assert_eq(a, 42)
    assert_eq(b, "hello")
}

fn make_pair() -> (int, string) {
    return (7, "ok")
}

@test
fn test_tuple_function_return_field_access() {
    let r = make_pair()
    assert_eq(r.0, 7)
    assert_eq(r.1, "ok")
}

@test
fn test_tuple_function_return_destructure() {
    let (n, s) = make_pair()
    assert_eq(n, 7)
    assert_eq(s, "ok")
}

@test
fn test_tuple_nested_field_access() {
    // Tuples can contain tuples; .N is still constant-time per level.
    let t = ((1, 2), (3, 4))
    assert_eq(t.0.0, 1)
    assert_eq(t.0.1, 2)
    assert_eq(t.1.0, 3)
    assert_eq(t.1.1, 4)
}

@test
fn test_tuple_unary() {
    // Single-element tuple is structurally distinct from a scalar.
    let t = (99,)
    assert_eq(t.0, 99)
}
