// 1300_json_overflow.xr
// Test: Json object overflow - dynamically add fields beyond in_object_capacity

// Test 1: Basic overflow - add many fields dynamically
@test
fn test_overflow_basic() {
    let obj = {}
    obj.a = 1
    obj.b = 2
    obj.c = 3
    obj.d = 4
    obj.e = 5
    obj.f = 6
    obj.g = 7
    obj.h = 8
    obj.i = 9
    obj.j = 10
    obj.k = 11
    obj.l = 12

    assert_eq(obj.a, 1)
    assert_eq(obj.b, 2)
    assert_eq(obj.c, 3)
    assert_eq(obj.d, 4)
    assert_eq(obj.e, 5)
    assert_eq(obj.f, 6)
    assert_eq(obj.g, 7)
    assert_eq(obj.h, 8)
    assert_eq(obj.i, 9)
    assert_eq(obj.j, 10)
    assert_eq(obj.k, 11)
    assert_eq(obj.l, 12)
}

// Test 2: Overflow field update
@test
fn test_overflow_update() {
    let obj = {}
    obj.f0 = 0
    obj.f1 = 1
    obj.f2 = 2
    obj.f3 = 3
    obj.f4 = 4
    obj.f5 = 5
    obj.f6 = 6
    obj.f7 = 7
    obj.f8 = 8
    obj.f9 = 9
    obj.f10 = 10
    obj.f11 = 11
    obj.f12 = 12

    obj.f10 = 999
    obj.f12 = 777

    assert_eq(obj.f0, 0)
    assert_eq(obj.f5, 5)
    assert_eq(obj.f10, 999)
    assert_eq(obj.f11, 11)
    assert_eq(obj.f12, 777)
}

// Test 3: for-in iteration over overflow fields
@test
fn test_overflow_forin() {
    let obj = {}
    obj.p1 = 1
    obj.p2 = 2
    obj.p3 = 3
    obj.p4 = 4
    obj.p5 = 5
    obj.p6 = 6
    obj.p7 = 7
    obj.p8 = 8
    obj.p9 = 9
    obj.p10 = 10
    obj.p11 = 11

    let sum = 0
    let count = 0
    for (k, v in obj) {
        sum = sum + v
        count = count + 1
    }
    assert_eq(count, 11)
    assert_eq(sum, 66)
}

// Test 4: Dynamic string-keyed access with overflow
@test
fn test_overflow_dynamic_key() {
    let obj = {}
    for (i in 0..15) {
        obj["field_" + string(i)] = i * 2
    }
    assert_eq(obj["field_0"], 0)
    assert_eq(obj["field_7"], 14)
    assert_eq(obj["field_14"], 28)
}

// Test 5: for-in key order with overflow
@test
fn test_overflow_forin_keys() {
    let obj = {}
    obj.alpha   = 1
    obj.beta    = 2
    obj.gamma   = 3
    obj.delta   = 4
    obj.epsilon = 5
    obj.zeta    = 6
    obj.eta     = 7
    obj.theta   = 8
    obj.iota    = 9
    obj.kappa   = 10
    obj.lambda  = 11

    let first_key = ""
    let last_val = 0
    let count = 0
    for (k, v in obj) {
        if (count == 0) { first_key = k }
        last_val = v
        count = count + 1
    }
    assert_eq(count, 11)
    assert_eq(first_key, "alpha")
    assert_eq(last_val, 11)
}
