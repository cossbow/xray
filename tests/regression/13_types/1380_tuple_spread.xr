// 1380_tuple_spread.xr
// 测试：spread 操作符 `...t`（tuple 拼接 / 函数调用展开）

// ===== 函数调用展开：所有参数 =====
@test
fn test_call_spread_all_args() {
    fn dist(x1: int, y1: int, x2: int, y2: int) -> int {
        let dx = x2 - x1
        let dy = y2 - y1
        return dx * dx + dy * dy
    }
    let p1 = (0, 0)
    let p2 = (3, 4)
    assert_eq(dist(...p1, ...p2), 25)
}

// ===== 函数调用展开：混合 spread 与显式参数 =====
@test
fn test_call_spread_mixed() {
    fn add4(a: int, b: int, c: int, d: int) -> int {
        return a + b + c + d
    }
    let p1 = (1, 2)
    let p2 = (3, 4)
    assert_eq(add4(...p1, ...p2), 10)
    assert_eq(add4(0, ...p1, 99), 102)
    assert_eq(add4(...p1, 100, 200), 303)
}

// ===== Tuple 拼接：纯 spread =====
@test
fn test_tuple_concat_pure_spread() {
    let head = (1, 2)
    let tail = (3, 4, 5)
    let all = (...head, ...tail)
    assert_eq(all.0, 1)
    assert_eq(all.1, 2)
    assert_eq(all.2, 3)
    assert_eq(all.3, 4)
    assert_eq(all.4, 5)
}

// ===== Tuple 拼接：spread + 显式元素混合 =====
@test
fn test_tuple_concat_mixed() {
    let head = (1, 2)
    let tail = (4, 5)
    let mixed = (0, ...head, 3, ...tail, 6)
    assert_eq(mixed.0, 0)
    assert_eq(mixed.1, 1)
    assert_eq(mixed.2, 2)
    assert_eq(mixed.3, 3)
    assert_eq(mixed.4, 4)
    assert_eq(mixed.5, 5)
    assert_eq(mixed.6, 6)
}

// ===== 异构类型：spread 保留每个槽位的精确类型 =====
@test
fn test_spread_heterogeneous() {
    fn describe(n: int, s: string, b: bool) -> string {
        return string(n) + "/" + s + "/" + string(b)
    }
    let t = (42, "answer", true)
    assert_eq(describe(...t), "42/answer/true")
}

// ===== 嵌套 spread 在 tuple 中 =====
@test
fn test_nested_spread() {
    let inner = (2, 3)
    let outer: (int, int, int, int) = (1, ...inner, 4)
    assert_eq(outer.0, 1)
    assert_eq(outer.1, 2)
    assert_eq(outer.2, 3)
    assert_eq(outer.3, 4)
}
