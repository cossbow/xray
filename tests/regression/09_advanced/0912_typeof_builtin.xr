// 0912_typeof_builtin.xr
// 作者：xingleixu@gmail.com
// 测试：typeof() builtin —— 返回运行时类型的字符串名

// ===== 基本类型 =====

@test
fn test_typeof_int() {
    assert_eq(typeof(42), "int")
    assert_eq(typeof(0), "int")
    assert_eq(typeof(-100), "int")
}

@test
fn test_typeof_float() {
    assert_eq(typeof(3.14), "float")
    assert_eq(typeof(0.0), "float")
}

@test
fn test_typeof_string() {
    assert_eq(typeof("hello"), "string")
    assert_eq(typeof(""), "string")
}

@test
fn test_typeof_bool() {
    assert_eq(typeof(true), "bool")
    assert_eq(typeof(false), "bool")
}

@test
fn test_typeof_null() {
    let n: int? = null
    assert_eq(typeof(n), "null")
}

// ===== 容器类型 =====

@test
fn test_typeof_array() {
    let a = [1, 2, 3]
    assert_eq(typeof(a), "Array")
}

@test
fn test_typeof_map() {
    let m = #{"a": 1}
    assert_eq(typeof(m), "Map")
}

@test
fn test_typeof_set() {
    let s = #[1, 2, 3]
    assert_eq(typeof(s), "Set")
}

// ===== 实例 =====

class Point {
    x: int
    y: int
    constructor(x: int, y: int) {
        this.x = x
        this.y = y
    }
}

@test
fn test_typeof_instance() {
    let p = Point(3, 4)
    // For class instances typeof() returns the class name.
    assert_eq(typeof(p), "Point")
}

// ===== 寄存器使用 =====

@test
fn test_typeof_does_not_corrupt_argument() {
    // typeof() reads R[B]; verify the source register is intact afterwards.
    let v = 42
    let n = typeof(v)
    assert_eq(n, "int")
    assert_eq(v, 42)
}

@test
fn test_typeof_in_expression() {
    let s = "hello"
    let result = typeof(s) + ":" + s
    assert_eq(result, "string:hello")
}
