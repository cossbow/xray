// 测试：边界条件和特殊情况

// ===== 空值处理 =====

@test
fn test_null_equality() {
    let x = null
    assert_eq(x == null, true)
    assert_eq(null == null, true)
    assert_eq(x != null, false)
}

@test
fn test_null_in_condition() {
    let x = null
    if (x == null) {
        assert_eq(true, true)
    } else {
        assert_eq(true, false)  // 不应该执行
    }
}

// ===== 空集合 =====

@test
fn test_empty_array_operations() {
    let arr: Array<int> = []
    assert_eq(arr.length, 0)

    // 对空数组的 map/filter
    let mapped = arr.map((x) -> x * 2)
    assert_eq(mapped.length, 0)
}

@test
fn test_empty_string() {
    let s = ""
    assert_eq(s.length, 0)
    assert_eq(s == "", true)
    assert_eq(s.includes(""), true)
}

// ===== 单元素集合 =====

@test
fn test_single_element_array() {
    let arr = [42]
    assert_eq(arr.length, 1)
    assert_eq(arr[0], 42)
    let doubled = arr.map((x) -> x * 2)
    assert_eq(doubled[0], 84)
}

// ===== 递归边界 =====

@test
fn test_recursion_base_case() {
    fn factorial(n: int) -> int {
        if (n <= 1) { return 1 }
        return n * factorial(n - 1)
    }

    assert_eq(factorial(0), 1)
    assert_eq(factorial(1), 1)
    assert_eq(factorial(5), 120)
}

// ===== 循环边界 =====

@test
fn test_zero_iteration_loop() {
    let count = 0
    for (i in 0..0) {
        count = count + 1
    }
    assert_eq(count, 0)
}

@test
fn test_single_iteration_loop() {
    let count = 0
    for (i in 0..1) {
        count = count + 1
    }
    assert_eq(count, 1)
}

// ===== 数值边界 =====

@test
fn test_negative_numbers() {
    assert_eq(-1 + 1, 0)
    assert_eq(-5 * -2, 10)
    assert_eq(-10 / 2, -5)
}

@test
fn test_zero_division_float() {
    let caught = false
    try {
        let x = 1.0 / 0.0
    } catch (e) {
        caught = true
    }
    assert_eq(caught, true)
}

// ===== 字符串边界 =====

@test
fn test_string_edge_cases() {
    let s = "a"
    assert_eq(s.length, 1)
    assert_eq(s.charAt(0), "a")
    assert_eq(s.toUpperCase(), "A")
}

@test
fn test_unicode_string() {
    let s = "你好"
    assert_eq(s.length > 0, true)
}

// ===== 嵌套结构边界 =====

@test
fn test_deep_nesting() {
    let data = {
        a: {
            b: {
                c: {
                    value: 42
                }
            }
        }
    }
    assert_eq(data.a.b.c.value, 42)
}

// ===== 闭包边界 =====

@test
fn test_closure_capture() {
    let x = 10
    let f = () -> x
    assert_eq(f(), 10)

    // 修改外部变量后闭包应该看到新值
    x = 20
    assert_eq(f(), 20)
}

