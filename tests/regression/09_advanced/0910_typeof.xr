// 测试：typeof 运算符

// ===== 基本类型 =====

@test
fn test_typeof_int() {
    let x = 42
    assert_eq(typeof(x), "int")
    // Bare literals without type context are NaN-boxed
    assert_eq(typeof(0), "int")
    assert_eq(typeof(-100), "int")
}

@test
fn test_typeof_float() {
    let x = 3.14
    assert_eq(typeof(x), "float")
    assert_eq(typeof(0.0), "float")
}

@test
fn test_typeof_string() {
    let s = "hello"
    assert_eq(typeof(s), "string")
    assert_eq(typeof(""), "string")
}

@test
fn test_typeof_bool() {
    assert_eq(typeof(true), "bool")
    assert_eq(typeof(false), "bool")
}

@test
fn test_typeof_null() {
    assert_eq(typeof(null), "null")
}

// ===== 集合类型 =====

@test
fn test_typeof_array() {
    let arr = [1, 2, 3]
    assert_eq(typeof(arr), "Array")
}

@test
fn test_typeof_map() {
    let m = #{"key": "value"}
    assert_eq(typeof(m), "Map")
}

@test
fn test_typeof_set() {
    let s = #[1, 2, 3]
    assert_eq(typeof(s), "Set")
}

// ===== 函数类型 =====

@test
fn test_typeof_function() {
    fn add(a: int, b: int) -> int { return a + b }
    assert_eq(typeof(add), "function")
    
    let lambda = (x: int) -> x * 2
    assert_eq(typeof(lambda), "function")
}

// ===== 类实例 =====

class MyClass {
    value: int
    constructor(v) { this.value = v }
}

@test
fn test_typeof_instance() {
    let obj = new MyClass(10)
    assert_eq(typeof(obj), "MyClass")
}

