/*
** 异常处理测试用例
** 作者：xingleixu@gmail.com
*/

// 1. 基本 try-catch
print("1. try-catch")
try { throw "e1" } catch (e) { assert_eq(e, "e1") }
print("   PASS")

// 2. try-finally
print("2. try-finally")
let f2 = false
try { } finally { f2 = true }
assert_eq(f2, true)
print("   PASS")

// 3. try-catch-finally
print("3. try-catch-finally")
let c3 = false
let f3 = false
try { throw "e3" } catch (e) { c3 = true } finally { f3 = true }
assert_eq(c3, true)
assert_eq(f3, true)
print("   PASS")

// 4. finally 执行顺序
print("4. finally order")
let a4: Array<string> = []
try { a4.push("try") } finally { a4.push("finally") }
a4.push("after")
assert_eq(a4.length, 3)
assert_eq(a4[0], "try")
assert_eq(a4[1], "finally")
assert_eq(a4[2], "after")
print("   PASS")

// 5. 嵌套 finally 传播
print("5. nested finally propagation")
let a5: Array<string> = []
try {
    try { a5.push("try"); throw "x" } finally { a5.push("finally") }
} catch (e) { a5.push("catch") }
assert_eq(a5.length, 3)
assert_eq(a5[0], "try")
assert_eq(a5[1], "finally")
assert_eq(a5[2], "catch")
print("   PASS")

// 6. 嵌套 catch + re-throw
print("6. nested catch re-throw")
let i6 = false
let o6 = false
try {
    try { throw "inner" } catch (e) { i6 = true; throw "outer" }
} catch (e) { o6 = true; assert_eq(e, "outer") }
assert_eq(i6, true)
assert_eq(o6, true)
print("   PASS")

// 7. 跨函数传播
print("7. cross function")
fn thr7(): void { throw "from_fn" }
let c7 = null
try { thr7() } catch (e) { c7 = e }
assert_eq(c7, "from_fn")
print("   PASS")

// 8. 函数内 finally
print("8. finally in function")
let f8 = false
fn fn8(): void { try { throw "x" } finally { f8 = true } }
try { fn8() } catch (e) { }
assert_eq(f8, true)
print("   PASS")

// 9. throw 不同类型
print("9. throw types")
try { throw "str" } catch (e) { assert_eq(e, "str") }
try { throw 42 } catch (e) { assert_eq(e, 42) }
try { throw [1, 2] } catch (e) { assert_eq(e.length, 2) }
try { throw {a: 1} } catch (e) { assert_eq(e.a, 1) }
print("   PASS")

// 10. 深层调用栈
print("10. deep call stack")
fn d4(): void { throw "deep" }
fn d3(): void { d4() }
fn d2(): void { d3() }
fn d1(): void { d2() }
let c10 = null
try { d1() } catch (e) { c10 = e }
assert_eq(c10, "deep")
print("   PASS")

// 11. re-throw 累加
print("11. re-throw chain")
let n11 = 0
try {
    try {
        try { throw "a" } catch (e) { n11 = n11 + 1; throw string(e) + "b" }
    } catch (e) { n11 = n11 + 1; throw string(e) + "c" }
} catch (e) { n11 = n11 + 1; assert_eq(e, "abc") }
assert_eq(n11, 3)
print("   PASS")

// 12. try 中 return
print("12. return in try")
fn r12(): string {
    try { return "ret" } finally { }
    return "no"
}
assert_eq(r12(), "ret")
print("   PASS")

// 13. catch 中 return
print("13. return in catch")
fn r13(): string {
    try { throw "x" } catch (e) { return "caught" }
    return "no"
}
assert_eq(r13(), "caught")
print("   PASS")

// 14. 顺序 try-catch
print("14. sequential try-catch")
let s14: Array<string> = []
try { s14.push("a"); throw "x" } catch (e) { s14.push("b") }
try { s14.push("c"); throw "y" } catch (e) { s14.push("d") }
assert_eq(s14.length, 4)
assert_eq(s14[0], "a")
assert_eq(s14[1], "b")
assert_eq(s14[2], "c")
assert_eq(s14[3], "d")
print("   PASS")

// 15. 只有 finally（无 catch）
print("15. only finally")
let f15 = false
try {
    try { throw "e" } finally { f15 = true }
} catch (e) { }
assert_eq(f15, true)
print("   PASS")

// 16. try-catch-finally 组合后嵌套 throw（bug 回归测试）
print("16. tcf + nested throw (regression)")
let c16 = false
let f16 = false
try { throw "e" } catch (e) { c16 = true } finally { f16 = true }
assert_eq(c16, true)
assert_eq(f16, true)
let i16 = false
let o16 = false
try {
    try { throw "i" } catch (e) { i16 = true; throw "o" }
} catch (e) { o16 = true }
assert_eq(i16, true)
assert_eq(o16, true)
print("   PASS")

// 17. finally 中修改变量
print("17. modify in finally")
fn f17(): int {
    let x = 1
    try { x = 2; return x } finally { x = 3 }
}
assert_eq(f17(), 2)
print("   PASS")

// 18. 多层嵌套 try
print("18. multi-level nesting")
let a18: Array<string> = []
try {
    a18.push("t1")
    try {
        a18.push("t2")
        try {
            a18.push("t3")
            throw "e"
        } catch (e) { a18.push("c3") }
    } finally { a18.push("f2") }
} finally { a18.push("f1") }
assert_eq(a18.length, 6)
print("   PASS")

// 19. catch-block rethrow must execute finally (regression: P1 fix)
print("19. catch rethrow + finally")
let a19: Array<string> = []
try {
    try {
        throw "orig"
    } catch (e) {
        a19.push("catch")
        throw "rethrown"
    } finally {
        a19.push("finally")
    }
} catch (e) {
    a19.push("outer")
    assert_eq(e, "rethrown")
}
assert_eq(a19.length, 3)
assert_eq(a19[0], "catch")
assert_eq(a19[1], "finally")
assert_eq(a19[2], "outer")
print("   PASS")

// 20. catch-block rethrow WITHOUT finally (should propagate normally)
print("20. catch rethrow no finally")
let a20: Array<string> = []
try {
    try {
        throw "a"
    } catch (e) {
        a20.push("inner-catch")
        throw "b"
    }
} catch (e) {
    a20.push("outer-catch")
    assert_eq(e, "b")
}
assert_eq(a20.length, 2)
assert_eq(a20[0], "inner-catch")
assert_eq(a20[1], "outer-catch")
print("   PASS")

// 21. throw in finally block propagates to outer
print("21. throw in finally")
let a21: Array<string> = []
try {
    try {
        throw "orig"
    } finally {
        a21.push("finally")
        throw "from-finally"
    }
} catch (e) {
    a21.push("outer")
    assert_eq(e, "from-finally")
}
assert_eq(a21.length, 2)
assert_eq(a21[0], "finally")
assert_eq(a21[1], "outer")
print("   PASS")

// 22. nested catch-rethrow-finally chain
print("22. nested catch-rethrow-finally chain")
let a22: Array<string> = []
try {
    try {
        try {
            throw "deep"
        } catch (e) {
            a22.push("c1")
            throw "mid"
        } finally {
            a22.push("f1")
        }
    } catch (e) {
        a22.push("c2")
        assert_eq(e, "mid")
    } finally {
        a22.push("f2")
    }
} finally {
    a22.push("f3")
}
assert_eq(a22[0], "c1")
assert_eq(a22[1], "f1")
assert_eq(a22[2], "c2")
assert_eq(a22[3], "f2")
assert_eq(a22[4], "f3")
assert_eq(a22.length, 5)
print("   PASS")

print("\n=== All 22 exception tests passed! ===")
