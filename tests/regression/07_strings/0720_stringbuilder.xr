// 测试：StringBuilder 内置类

// ===== 基本操作 =====

@test
fn test_basic_append() {
    let sb = new StringBuilder()
    sb.append("Hello")
    sb.append(" ")
    sb.append("World")
    assert_eq(sb.toString(), "Hello World")
}

@test
fn test_chain_append() {
    let sb = new StringBuilder()
    sb.append("a").append("b").append("c")
    assert_eq(sb.toString(), "abc")
}

// ===== 不同类型 =====

@test
fn test_append_int() {
    let sb = new StringBuilder()
    sb.append("num: ")
    sb.append(42)
    assert_eq(sb.toString(), "num: 42")
}

@test
fn test_append_float() {
    let sb = new StringBuilder()
    sb.append("pi: ")
    sb.append(3.14)
    let result = sb.toString()
    assert_eq(result.startsWith("pi: 3.14"), true)
}

@test
fn test_mixed_types() {
    let sb = new StringBuilder()
    sb.append("count=")
    sb.append(100)
    sb.append(", ok=")
    sb.append(true)
    let result = sb.toString()
    assert_eq(result.contains("100"), true)
}

// ===== 循环中使用 =====

@test
fn test_loop_append() {
    let sb = new StringBuilder()
    for (i in 0..5) {
        sb.append("x")
    }
    assert_eq(sb.toString(), "xxxxx")
}

@test
fn test_loop_numbers() {
    let sb = new StringBuilder()
    for (i in 1..4) {
        if (i > 1) {
            sb.append(",")
        }
        sb.append(i)
    }
    assert_eq(sb.toString(), "1,2,3")
}

// ===== clear 方法 =====

@test
fn test_clear() {
    let sb = new StringBuilder()
    sb.append("test")
    sb.clear()
    sb.append("new")
    assert_eq(sb.toString(), "new")
}

@test
fn test_clear_then_reuse() {
    let sb = new StringBuilder()
    sb.append("first")
    assert_eq(sb.toString(), "first")
    sb.clear()
    sb.append("second")
    assert_eq(sb.toString(), "second")
}

// ===== 空 StringBuilder =====

@test
fn test_empty() {
    let sb = new StringBuilder()
    assert_eq(sb.toString(), "")
}

// ===== 大量数据 =====

@test
fn test_large_append() {
    let sb = new StringBuilder()
    for (i in 0..100) {
        sb.append("a")
    }
    assert_eq(sb.toString().length, 100)
}

