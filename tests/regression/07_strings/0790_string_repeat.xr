/*
** 字符串重复语法测试
** 作者：xingleixu@gmail.com
** 
** 测试 "str" * n 和 n * "str" 语法
*/

// 基本测试：字符串 * 整数

@test
fn test_string_repeat() {
    let line = "=" * 50
    assert_eq(line.length, 50)

    let stars = "*" * 10
    assert_eq(stars, "**********")

    // 整数 * 字符串（交换顺序）
    let dashes = 5 * "-"
    assert_eq(dashes, "-----")

    // 边界情况
    let empty = "x" * 0
    assert_eq(empty, "")

    let single = "abc" * 1
    assert_eq(single, "abc")

    // 多字符重复
    let pattern = "ab" * 3
    assert_eq(pattern, "ababab")

    // 中文字符重复
    let chinese = "好" * 3
    assert_eq(chinese, "好好好")

    // 变量方式
    let s: string = "-"
    let n: int = 5
    let result = s * n
    assert_eq(result, "-----")

    // 表达式中使用
    let header = "+" + "-" * 20 + "+"
    assert_eq(header.length, 22)

    // 打印分隔线
}

