// 测试：递归函数

// ===== 阶乘 =====

@test
fn test_factorial() {
    fn factorial(n: int) -> int {
        if (n <= 1) { return 1 }
        return n * factorial(n - 1)
    }
    
    assert_eq(factorial(0), 1)
    assert_eq(factorial(1), 1)
    assert_eq(factorial(5), 120)
    assert_eq(factorial(6), 720)
}

// ===== 斐波那契 =====

@test
fn test_fibonacci() {
    fn fib(n: int) -> int {
        if (n <= 1) { return n }
        return fib(n - 1) + fib(n - 2)
    }
    
    assert_eq(fib(0), 0)
    assert_eq(fib(1), 1)
    assert_eq(fib(2), 1)
    assert_eq(fib(5), 5)
    assert_eq(fib(10), 55)
}

// ===== 累加 =====

@test
fn test_sum_to() {
    fn sumTo(n: int) -> int {
        if (n <= 0) { return 0 }
        return n + sumTo(n - 1)
    }
    
    assert_eq(sumTo(0), 0)
    assert_eq(sumTo(1), 1)
    assert_eq(sumTo(5), 15)
    assert_eq(sumTo(10), 55)
}

// ===== 最大公约数 =====

@test
fn test_gcd() {
    fn gcd(a: int, b: int) -> int {
        if (b == 0) { return a }
        return gcd(b, a % b)
    }
    
    assert_eq(gcd(48, 18), 6)
    assert_eq(gcd(100, 25), 25)
    assert_eq(gcd(17, 13), 1)
    assert_eq(gcd(12, 12), 12)
}

// ===== 幂运算 =====

@test
fn test_power() {
    fn power(base: int, exp: int) -> int {
        if (exp == 0) { return 1 }
        return base * power(base, exp - 1)
    }
    
    assert_eq(power(2, 0), 1)
    assert_eq(power(2, 1), 2)
    assert_eq(power(2, 10), 1024)
    assert_eq(power(3, 4), 81)
}

// ===== 数组递归 =====

@test
fn test_array_sum() {
    fn arraySum(arr: Array<int>, i: int) -> int {
        if (i >= arr.length) { return 0 }
        return arr[i] + arraySum(arr, i + 1)
    }
    
    assert_eq(arraySum([1, 2, 3, 4, 5], 0), 15)
    assert_eq(arraySum([], 0), 0)
    assert_eq(arraySum([42], 0), 42)
}

@test
fn test_count_down() {
    let result: Array<int> = []
    fn countdown(n: int) {
        if (n <= 0) { return }
        result.push(n)
        countdown(n - 1)
    }
    
    countdown(5)
    assert_eq(result.length, 5)
    assert_eq(result[0], 5)
    assert_eq(result[4], 1)
}

// ===== 二分查找 =====

@test
fn test_binary_search() {
    fn binarySearch(arr: Array<int>, target: int, low: int, high: int) -> int {
        if (low > high) { return -1 }
        let mid = (low + high) / 2
        if (arr[mid] == target) { return mid }
        if (arr[mid] > target) {
            return binarySearch(arr, target, low, mid - 1)
        }
        return binarySearch(arr, target, mid + 1, high)
    }
    
    let arr = [1, 3, 5, 7, 9, 11, 13]
    assert_eq(binarySearch(arr, 7, 0, arr.length - 1), 3)
    assert_eq(binarySearch(arr, 1, 0, arr.length - 1), 0)
    assert_eq(binarySearch(arr, 13, 0, arr.length - 1), 6)
    assert_eq(binarySearch(arr, 4, 0, arr.length - 1), -1)
}

// ===== 相互递归 =====

@test
fn test_mutual_recursion() {
    fn isEven(n: int) -> bool {
        if (n == 0) { return true }
        return isOdd(n - 1)
    }
    
    fn isOdd(n: int) -> bool {
        if (n == 0) { return false }
        return isEven(n - 1)
    }
    
    assert_eq(isEven(0), true)
    assert_eq(isEven(4), true)
    assert_eq(isEven(7), false)
    assert_eq(isOdd(5), true)
    assert_eq(isOdd(6), false)
}

// ===== 边界条件 =====

@test
fn test_deep_recursion() {
    fn recurse(n: int) -> int {
        if (n <= 0) { return 0 }
        return 1 + recurse(n - 1)
    }
    
    assert_eq(recurse(100), 100)
    assert_eq(recurse(500), 500)
}

