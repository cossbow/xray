// 测试：箭头函数

// ===== 基础箭头函数 =====

@test
fn test_arrow_basic(): void {
    let add = (a: int, b: int) => a + b
    assert_eq(add(3, 5), 8)
}

@test
fn test_arrow_single_param(): void {
    let double = (x: int) => x * 2
    assert_eq(double(5), 10)
}

@test
fn test_arrow_no_params(): void {
    let getHello = () => "hello"
    assert_eq(getHello(), "hello")
}

// ===== 带块的箭头函数 =====

@test
fn test_arrow_block(): void {
    let factorial = (n: int): int => {
        if (n <= 1) { return 1 }
        return n * factorial(n - 1)
    }
    assert_eq(factorial(5), 120)
}

@test
fn test_arrow_block_multiple_statements(): void {
    let process = (x: int) => {
        let a = x * 2
        let b = a + 10
        return b
    }
    assert_eq(process(5), 20)
}

// ===== 作为回调 =====

@test
fn test_arrow_map(): void {
    let arr = [1, 2, 3, 4, 5]
    let doubled = arr.map((x) => x * 2)
    
    assert_eq(doubled[0], 2)
    assert_eq(doubled[4], 10)
}

@test
fn test_arrow_filter(): void {
    let arr = [1, 2, 3, 4, 5, 6]
    let evens = arr.filter((x) => x % 2 == 0)
    
    assert_eq(evens.length, 3)
    assert_eq(evens[0], 2)
    assert_eq(evens[2], 6)
}

@test
fn test_arrow_reduce(): void {
    let arr = [1, 2, 3, 4, 5]
    let sum = arr.reduce((acc, x) => acc + x, 0)
    assert_eq(sum, 15)
}

// ===== 链式调用 =====

@test
fn test_arrow_chained(): void {
    let arr = [1, 2, 3, 4, 5]
    let result = arr
        .filter((x) => x % 2 == 1)   // [1, 3, 5]
        .map((x) => x * 2)            // [2, 6, 10]
        .reduce((a, b) => a + b, 0)   // 18
    
    assert_eq(result, 18)
}

// ===== 闭包捕获 =====

@test
fn test_arrow_closure(): void {
    let multiplier = 3
    let times = (x: int) => x * multiplier
    
    assert_eq(times(5), 15)
    assert_eq(times(10), 30)
}

@test
fn test_arrow_capture_param(): void {
    fn makeMultiplier(n: int): fn(int): int {
        return (x: int) => x * n
    }
    
    let double = makeMultiplier(2)
    let triple = makeMultiplier(3)
    
    assert_eq(double(5), 10)
    assert_eq(triple(5), 15)
}

// ===== 返回箭头函数 =====

@test
fn test_arrow_return_arrow(): void {
    let makeAdder = (x: int) => (y: int) => x + y
    
    let add5 = makeAdder(5)
    let add10 = makeAdder(10)
    
    assert_eq(add5(3), 8)
    assert_eq(add10(3), 13)
}

@test
fn test_arrow_curried(): void {
    let add = (a: int) => (b: int) => (c: int) => a + b + c
    
    assert_eq(add(1)(2)(3), 6)
}

// ===== forEach =====

@test
fn test_arrow_foreach(): void {
    let arr = [1, 2, 3]
    let sum = 0
    arr.forEach((x) => {
        sum += x
    })
    assert_eq(sum, 6)
}

// ===== 边界条件 =====

@test
fn test_arrow_immediate_call(): void {
    let result = ((x: int) => x * 2)(5)
    assert_eq(result, 10)
}

@test
fn test_arrow_as_method_arg(): void {
    fn apply(f: fn(int): int, x: int): int {
        return f(x)
    }
    
    let result = apply((x) => x * 3, 5)
    assert_eq(result, 15)
}

