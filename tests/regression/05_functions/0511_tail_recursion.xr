// 0511_tail_recursion.xr
// Test: Tail recursion optimization (contification)
// Tail-recursive calls should be converted to loops at bytecode level.

// ===== Accumulator-style fibonacci =====
@test
fn test_fib_tail() {
    fn fib_acc(n: int, a: int, b: int): int {
        if (n <= 0) { return a }
        if (n == 1) { return b }
        return fib_acc(n - 1, b, a + b)
    }

    fn fib(n: int): int {
        return fib_acc(n, 0, 1)
    }

    assert_eq(fib(0), 0)
    assert_eq(fib(1), 1)
    assert_eq(fib(2), 1)
    assert_eq(fib(5), 5)
    assert_eq(fib(10), 55)
    assert_eq(fib(20), 6765)
    assert_eq(fib(46), 1836311903)
}

// ===== Parameter swap correctness =====
@test
fn test_swap_params() {
    fn swap_count(a: int, b: int, n: int): int {
        if (n <= 0) { return a }
        return swap_count(b, a, n - 1)
    }

    assert_eq(swap_count(1, 2, 0), 1)
    assert_eq(swap_count(1, 2, 1), 2)
    assert_eq(swap_count(1, 2, 2), 1)
    assert_eq(swap_count(1, 2, 100), 1)
    assert_eq(swap_count(1, 2, 101), 2)
}

// ===== Tail-recursive GCD =====
@test
fn test_gcd_tail() {
    fn gcd(a: int, b: int): int {
        if (b == 0) { return a }
        return gcd(b, a % b)
    }

    assert_eq(gcd(48, 18), 6)
    assert_eq(gcd(100, 25), 25)
    assert_eq(gcd(17, 13), 1)
    assert_eq(gcd(0, 5), 5)
    assert_eq(gcd(12, 12), 12)
}

// ===== Tail-recursive factorial =====
@test
fn test_factorial_tail() {
    fn fact(n: int, acc: int): int {
        if (n <= 1) { return acc }
        return fact(n - 1, n * acc)
    }

    assert_eq(fact(0, 1), 1)
    assert_eq(fact(1, 1), 1)
    assert_eq(fact(5, 1), 120)
    assert_eq(fact(10, 1), 3628800)
}

// ===== Deep tail recursion (no stack overflow) =====
@test
fn test_deep_tail_recursion() {
    fn count_down(n: int): int {
        if (n <= 0) { return 0 }
        return count_down(n - 1)
    }

    // With tail recursion optimization, this should NOT stack overflow.
    // Without optimization, 100000 levels would overflow.
    assert_eq(count_down(100000), 0)
}

// ===== Tail-recursive sum =====
@test
fn test_sum_tail() {
    fn sum_acc(n: int, acc: int): int {
        if (n <= 0) { return acc }
        return sum_acc(n - 1, acc + n)
    }

    assert_eq(sum_acc(0, 0), 0)
    assert_eq(sum_acc(10, 0), 55)
    assert_eq(sum_acc(100, 0), 5050)
    assert_eq(sum_acc(1000, 0), 500500)
}

// ===== Non-tail recursion still works =====
@test
fn test_non_tail_recursion() {
    fn fib_naive(n: int): int {
        if (n <= 1) { return n }
        return fib_naive(n - 1) + fib_naive(n - 2)
    }

    assert_eq(fib_naive(0), 0)
    assert_eq(fib_naive(1), 1)
    assert_eq(fib_naive(10), 55)
    assert_eq(fib_naive(20), 6765)
}

// ===== Single param tail recursion =====
@test
fn test_single_param() {
    fn collatz_steps(n: int): int {
        if (n <= 1) { return 0 }
        if (n % 2 == 0) {
            return 1 + collatz_steps(n / 2)
        }
        return 1 + collatz_steps(3 * n + 1)
    }

    // Note: this is NOT tail-recursive (1 + recursive_call),
    // so it tests that non-tail recursive calls are unaffected.
    assert_eq(collatz_steps(1), 0)
    assert_eq(collatz_steps(2), 1)
    assert_eq(collatz_steps(6), 8)
}

// ===== Tail-recursive with boolean result =====
@test
fn test_is_even_tail() {
    fn is_even(n: int): bool {
        if (n == 0) { return true }
        if (n == 1) { return false }
        return is_even(n - 2)
    }

    assert_eq(is_even(0), true)
    assert_eq(is_even(1), false)
    assert_eq(is_even(100), true)
    assert_eq(is_even(99), false)
    assert_eq(is_even(10000), true)
}

// ===== Non-recursive tail call (OP_TAILCALL for variable calls) =====
@test
fn test_non_recursive_tailcall() {
    fn add(a: int, b: int): int { return a + b }
    fn mul(a: int, b: int): int { return a * b }

    fn compute(op: string, x: int, y: int): int {
        if (op == "add") { return add(x, y) }
        if (op == "mul") { return mul(x, y) }
        return 0
    }

    assert_eq(compute("add", 3, 4), 7)
    assert_eq(compute("mul", 3, 4), 12)
    assert_eq(compute("sub", 3, 4), 0)
}

// ===== Mutual recursion with tail calls =====
@test
fn test_mutual_tail_recursion() {
    fn is_even(n: int): bool {
        if (n == 0) { return true }
        return is_odd(n - 1)
    }
    fn is_odd(n: int): bool {
        if (n == 0) { return false }
        return is_even(n - 1)
    }

    assert_eq(is_even(0), true)
    assert_eq(is_even(1), false)
    assert_eq(is_even(10), true)
    assert_eq(is_odd(11), true)
    assert_eq(is_odd(12), false)
}

// ===== Non-tail position: ensure regular calls still work =====
@test
fn test_non_tail_regular_call() {
    fn double(x: int): int { return x * 2 }
    fn add_then_double(a: int, b: int): int {
        let sum = a + b
        return double(sum)
    }

    assert_eq(add_then_double(3, 4), 14)
    assert_eq(add_then_double(0, 0), 0)
}

// ===== Instance method tail recursion (OP_INVOKE_TAIL) =====
@test
fn test_method_tail_recursion() {
    class Accumulator {
        total: int
        constructor() { this.total = 0 }

        add(n: int): int {
            if (n <= 0) { return this.total }
            this.total = this.total + n
            return this.add(n - 1)
        }
    }

    let acc = Accumulator()
    assert_eq(acc.add(10), 55)
    assert_eq(acc.add(0), 55)
}

// ===== Cross-method tail call on same instance =====
@test
fn test_method_cross_tail() {
    class Toggler {
        state: bool
        steps: int
        constructor() {
            this.state = false
            this.steps = 0
        }

        toggleOn(n: int): bool {
            if (n <= 0) { return this.state }
            this.state = true
            this.steps = this.steps + 1
            return this.toggleOff(n - 1)
        }

        toggleOff(n: int): bool {
            if (n <= 0) { return this.state }
            this.state = false
            this.steps = this.steps + 1
            return this.toggleOn(n - 1)
        }
    }

    let t = Toggler()
    assert_eq(t.toggleOn(0), false)
    assert_eq(t.toggleOn(1), true)
    assert_eq(t.toggleOn(2), false)
    assert_eq(t.toggleOn(3), true)
    assert_eq(t.steps, 6)
}

// ===== Static method tail recursion (top-level class) =====
class MathUtil {
    static factorial(n: int, acc: int): float {
        if (n <= 1) { return acc }
        return MathUtil.factorial(n - 1, n * acc)
    }
    static countdown(n: int): string {
        if (n <= 0) { return "done" }
        return MathUtil.countdown(n - 1)
    }
}

@test
fn test_static_tail_recursion() {
    assert_eq(MathUtil.factorial(10, 1), 3628800)
    assert_eq(MathUtil.factorial(1, 1), 1)
    assert_eq(MathUtil.countdown(100), "done")
}

// ===== Deep method tail recursion (stack overflow without TCO) =====
@test
fn test_deep_method_tail_recursion() {
    class DeepCounter {
        val: int
        constructor() { this.val = 0 }
        count(n: int): int {
            if (n <= 0) { return this.val }
            this.val = this.val + 1
            return this.count(n - 1)
        }
    }

    let c = DeepCounter()
    assert_eq(c.count(100000), 100000)
}

print("tail_recursion: all tests passed")
