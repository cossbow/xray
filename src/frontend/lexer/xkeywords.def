 *
 * xkeywords.def - Single source of truth for all reserved keywords.
 *
 * USAGE:
 *   This file is intentionally NOT a normal header. Consumers must define
 *   XR_KW(spelling, length, token) before #include "xkeywords.def" and
 *   #undef XR_KW afterwards.
 *
 *   Example (build sorted lookup table):
 *     static const XrKeyword keywords[] = {
 *     #define XR_KW(name, len, type) { name, len, type },
 *     #include "xkeywords.def"
 *     #undef XR_KW
 *     };
 *
 * INVARIANTS (CHECKED):
 *   1. Entries MUST be sorted by ASCII memcmp order, then by length
 *      (i.e. by the same total order the lookup uses). Verified at
 *      lexer init time and by the unit test test_lexer_keyword_table.
 *   2. The `length` literal MUST equal sizeof(spelling) - 1. Verified at
 *      compile time via _Static_assert in xlex.c.
 *
 * RAW STRING NOTE:
 *   The single character `r` is NOT listed here because it is recognised
 *   contextually by xr_scanner_scan() as a raw-string prefix when followed
 *   by a quote. As a bare identifier it remains TK_NAME.
 */

/*           spelling       length  token             */
XR_KW(       "abstract",    8,      TK_ABSTRACT      )
XR_KW(       "as",          2,      TK_AS            )
XR_KW(       "await",       5,      TK_AWAIT         )
