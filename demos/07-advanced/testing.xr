// Demo: Testing
// @test functions, assertions, test lifecycle
//
// Run: xray test demos/07-advanced/testing.xr

// === Basic tests ===
@test
fn test_arithmetic() {
    assert_eq(1 + 1, 2)
    assert_eq(10 * 5, 50)
    assert_eq(7 % 3, 1)
}

@test
fn test_strings() {
    let s = "Hello, World!"
    assert_eq(s.length, 13)
    assert_true(s.startsWith("Hello"))
    assert_true(s.endsWith("!"))
    assert_eq(s.toLowerCase(), "hello, world!")
}

@test
fn test_arrays() {
    let arr = [1, 2, 3, 4, 5]
    assert_eq(arr.length, 5)
    assert_eq(arr[0], 1)
    assert_true(arr.includes(3))
    assert_false(arr.includes(99))
}

@test
fn test_nullable() {
    let x: int? = null
    assert_eq(x, null)
    assert_eq(x ?? 42, 42)

    x = 10
    assert_ne(x, null)
    assert_eq(x ?? 42, 10)
}

@test
fn test_exceptions() {
    assert_throws(() => {
        throw "expected error"
    })
}

// === Skip a test ===
@test(skip)
fn test_todo() {
    // Not implemented yet
    assert(false)
}

// === Test with custom timeout ===
@test(timeout: 5000)
fn test_with_timeout() {
    // This test has a 5-second timeout
    let sum = 0
    for (i in 0..1000) { sum = sum + i }
    assert_eq(sum, 499500)
}
