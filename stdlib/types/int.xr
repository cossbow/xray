// Built-in int type — implementation in src/runtime/value/xint_methods.c

@native
class int {
    abs() -> int
    toString() -> string
    toBigInt() -> BigInt
    toFloat() -> float
    toHex() -> string
    max(other: int) -> int
    min(other: int) -> int
    floor() -> int
    ceil() -> int
    round() -> int
    sqrt() -> float
    pow(exp: float) -> float
}
