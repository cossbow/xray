# Author: xingleixu@gmail.com
# Xray Project .gitignore

# ============================================================================
# Build directories
# ============================================================================
build/
build-*/
build_*/
cmake-build-*/

# Generated codegen artifacts (from xisa generator).
# Source of truth lives in src/jit/codegen/*.isa; generated files are
# rebuilt every clean configure. They must never be committed to git.
# See docs/tasks/076-codegen-master-spec.md §7 reverse-invariants #11.
build/generated/

# ============================================================================
# Build artifacts
# ============================================================================
*.o
*.a
*.so
*.dylib
*.dll
*.exe
/xray
a.out
*.xrc≤
luac.out

# ============================================================================
# IDE / Editor
# ============================================================================
.vscode/
.idea/
.crossnote/
.cursor/
.windsurf/
.github/copilot-instructions.md
*.swp
*.swo
*~
.DS_Store
.instructions.md

# ============================================================================
# Debug files
# ============================================================================
*.dSYM/
/core
vgcore.*
server_err.txt
tcp_err.txt
osr_debug.log
bin/

# ============================================================================
# Internal design
# ============================================================================
# Note: docs/ is intentionally NOT ignored at the repo level so IDE / Cascade
# tooling can read and edit it. If a user wants docs/ untracked in their local
# checkout, add `docs/` to .git/info/exclude (already set up in this repo).

# ============================================================================
# Temporary test files
# ============================================================================
tests/tmp/*
!tests/tmp/.gitkeep

# ============================================================================
# Benchmarks (multi-language comparisons & compiled binaries)
# ============================================================================
tests/benchmarks/

# ============================================================================
# Fuzz corpus
# ============================================================================
tests/fuzz/corpus/

# ============================================================================
# Go compiled binaries
# ============================================================================
*_go
tests/network/ws_tests/autobahn/reports/
osr_debug.log

# ============================================================================
# Editor / IDE checkpoints
# ============================================================================
.windsurf-backup/

# ============================================================================
# AOT scratch output
# ============================================================================
# `xray build --native` writes the generated C alongside the .xr source by
# default; ignore the common scratch name so it doesn't pollute git status.
/app.c

# ============================================================================
# Compiled bytecode bundles
# ============================================================================
# `.xrc` files are produced by the bytecode compiler / AOT runner as a
# scratch cache next to the source `.xr`. They are build artifacts and
# must never be committed.
*.xrc
