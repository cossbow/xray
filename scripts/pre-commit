#!/usr/bin/env bash
# Git pre-commit hook: auto-format staged C/H files with clang-format.
# Works on macOS, Linux, and Windows (Git Bash / MSYS2).
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#   or:   scripts/install-hooks.sh

set -e

# Find clang-format
CF=""
for candidate in clang-format clang-format-18 clang-format-17 clang-format-16 clang-format-15 clang-format-14; do
    if command -v "$candidate" >/dev/null 2>&1; then
        CF="$candidate"
        break
    fi
done

if [ -z "$CF" ]; then
    echo "pre-commit: clang-format not found, skipping format check"
    exit 0
fi

# Collect staged .c and .h files (excluding deleted)
STAGED=$(git diff --cached --name-only --diff-filter=d -- '*.c' '*.h')

if [ -z "$STAGED" ]; then
    exit 0
fi

# Format each staged file and re-add
FORMATTED=0
for f in $STAGED; do
    if [ -f "$f" ]; then
        "$CF" -i "$f"
        git add "$f"
        FORMATTED=$((FORMATTED + 1))
    fi
done

if [ "$FORMATTED" -gt 0 ]; then
    echo "pre-commit: formatted $FORMATTED file(s) with $CF"
fi
